# Dev cruft — keep it out of the packaged .vsix.
.vscode/**
.gitignore
src/**
scripts/**
out/**
**/*.ts
**/*.map
tsconfig.json
.vscodeignore

# All dev node_modules: the client is bundled into dist/extension.js by esbuild
# (vscode-languageclient is inlined), so no client node_modules are needed at
# runtime. The SERVER's runtime node_modules live under server-dist/ and are
# explicitly included below.
node_modules/**

# Esbuild can emit a meta/analysis file; never ship it.
dist/**/*.txt

# --- Included payload (these must ship) ---
# The bundled extension entrypoint.
!dist/extension.js
# The packaged resident server + its runtime node_modules (copied at package
# time by scripts/copy-server.js). server-dist/node_modules is matched by the
# blanket node_modules ignore above, so re-include it explicitly.
!server-dist/**
