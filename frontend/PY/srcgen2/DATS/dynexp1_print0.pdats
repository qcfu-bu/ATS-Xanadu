@impl
def d1pat_fprint(d1p, out):
    @impl[]
    def g_print/out():
        out
    match d1p.node():
        case D1Pid0(id0):
            prints("D1Pid0(", id0, ")")
        case D1Pint(int):
            prints("D1Pint(", int, ")")
        case D1Pchr(chr):
            prints("D1Pchr(", chr, ")")
        case D1Pflt(flt):
            prints("D1Pflt(", flt, ")")
        case D1Pstr(str):
            prints("D1Pstr(", str, ")")
        case D1Pb0sh():
            prints("D1Pb0sh(", ")")
        case D1Pb1sh(d1p):
            prints("D1Pb1sh(", d1p, ")")
        case D1Paspt(tok, d1p):
            prints("D1Paspt(", tok, ";", d1p, ")")
        case D1Pa0pp():
            prints("D1Pa0pp(", ")")
        case D1Pa1pp(d1f0, d1p1):
            prints("D1Pa1pp(", d1f0, ";", d1p1, ")")
        case D1Pa2pp(d1f0, d1p1, d1p2):
            print("D1Pa2pp(")
            prints(d1f0, ";", d1p1, ";", d1p2, ")")
        case D1Psarg(s1as):
            prints("D1Psarg(", s1as, ")")
        case D1Pl1st(d1ps):
            prints("D1Pl1st(", d1ps, ")")
        case D1Pl2st(dps1, dps2):
            prints("D1Pl2st(", dps1, ";", dps2, ")")
        case D1Pt1up(tok0, d1ps):
            prints("D1Pt1up(", tok0, ";", d1ps, ")")
        case D1Pt2up(tok0, dps1, dps2):
            print("D1Pt2up(")
            prints(tok0, ";", dps1, ";", dps2, ")")
        case D1Pannot(d1p1, s1e2):
            prints("D1Pannot(", d1p1, ";", s1e2, ")")
        case D1Pqual0(tok1, d1p2):
            prints("D1Pqual0(", tok1, ";", d1p2, ")")
        case D1Pnone0():
            prints("D1Pnone0(", ")")
        case D1Pnone1(dpat):
            prints("D1Pnone1(", dpat, ")")
        case D1Perrck(lvl1, d1p2):
            prints("D1Perrck(", lvl1, ";", d1p2, ")")

