@impl
def d1ecl_fprint(dcl, out):
    @impl[]
    def g_print/out():
        out
    match dcl.node():
        case D1Cd0ecl(d0cl):
            prints("D1Cd0ecl(", d0cl, ")")
        case D1Cextern(tknd, dcl1):
            prints("D1Cextern(", tknd, ";", dcl1, ")")
        case D1Cstatic(tknd, dcl1):
            prints("D1Cstatic(", tknd, ";", dcl1, ")")
        case D1Cdefine(tknd, geid, gmas, gopt):
            print("D1Cdefine(")
            prints(tknd, ";", geid, ";", gmas, ";", gopt, ")")
        case D1Cmacdef(tknd, geid, gmas, dopt):
            print("D1Cmacdef(")
            prints(tknd, ";", geid, ";", gmas, ";", dopt, ")")
        case D1Clocal0(head, body):
            prints("D1Clocal0(", head, ";", body, ")")
        case D1Cabssort(tknd, tid0):
            prints("D1Cabssort(", tknd, ";", tid0, ")")
        case D1Cstacst0(tknd, sid0, tmas, s1t1):
            print("D1Cstacst0(")
            prints(tknd, ";", sid0, ";", tmas, ";", s1t1, ")")
        case D1Csortdef(tknd, tid0, stdf):
            prints("D1Csortdef(", tknd, ";", tid0, ";", stdf, ")")
        case D1Csexpdef(tknd, seid, smas, tres, s1e1):
            prints("D1Csexpdef(", tknd, ";")
            prints(seid, ";", smas, ";", tres, ";", s1e1, ")")
        case D1Cabstype(tknd, seid, tmas, tres, atdf):
            prints("D1Cabstype(", tknd, ";")
            prints(seid, ";", tmas, ";", tres, ";", atdf, ")")
        case D1Cabsopen(tknd, sqid):
            prints("D1Cabsopen(", tknd, ";", sqid, ")")
        case D1Cabsimpl(tknd, sid1, smas, tres, sdef):
            prints("D1Cabsimpl(", tknd, ";")
            prints(sid1, ";", smas, ";", tres, ";", sdef, ")")
        case D1Csymload(tknd, deid, dqid, gopt):
            print("D1Csymload(")
            prints(tknd, ";", deid, ";", dqid, ";", gopt, ")")
        case D1Cinclude(knd0, tknd, g1e1, fopt, dopt):
            print("D1Cinclude(")
            prints(knd0, ";", tknd, ";", g1e1, ";", fopt, ";", "...", ")")
            ()
        case D1Cstaload(knd0, tknd, g1e1, fopt, dopt):
            print("D1Cstaload(")
            prints(knd0, ";", tknd, ";", g1e1, ";", fopt, ";", "...", ")")
            ()
        case D1Cdyninit(tknd, g1e1):
            prints("D1Cdyninit(", tknd, ";", g1e1, ")")
        case D1Cextcode(tknd, g1e1):
            prints("D1Cextcode(", tknd, ";", g1e1, ")")
        case D1Cdatasort(tknd, dtcs):
            prints("D1Cdatasort(", tknd, ";", dtcs, ")")
        case D1Cvaldclst(tknd, d1vs):
            prints("D1Cvaldclst(", tknd, ";", d1vs, ")")
        case D1Cvardclst(tknd, d1vs):
            prints("D1Cvardclst(", tknd, ";", d1vs, ")")
        case D1Cfundclst(tknd, tqas, d1fs):
            prints("D1Cfundclst(", tknd, ";", tqas, ";", d1fs, ")")
        case D1Cimplmnt0(tknd, s0qs, t0qs, dqid, t0is, farg, sres, d0e2):
            print("D1Cimplmnt0(")
            prints(tknd, ";", s0qs, ";", t0qs, ";")
            prints(dqid, ";", t0is, ";", farg, ";", sres, ";", d0e2, ")")
        case D1Cexcptcon(tknd, dtcs):
            prints("D1Cexcptcon(", tknd, ";", dtcs, ")")
        case D1Cdatatype(tknd, d1ts, wdcs):
            prints("D1Cdatatype(", tknd, ";", d1ts, ";", wdcs, ")")
        case D1Cdynconst(tknd, tqas, d1cs):
            prints("D1Cdynconst(", tknd, ";", tqas, ";", d1cs, ")")
        case D1Cnone0():
            prints("D1Cnone0(", ")")
        case D1Cnone1(d0cl):
            prints("D1Cnone1(", d0cl, ")")
        case D1Cendif(tend):
            prints("D1Cendif(", tend, ")")
        case D1Cthen0(dcls):
            prints("D1Cthen0(", dcls, ")")
        case D1Celse1(dcls):
            prints("D1Celse1(", dcls, ")")
        case D1Cifexp(gexp, dthn, dels, dend):
            prints("D1Cifexp(", gexp, ";", dthn, ";", dels, ";", dend, ")")
        case D1Celsif(gexp, dthn, dels, dend):
            prints("D1Celsif(", gexp, ";", dthn, ";", dels, ";", dend, ")")
        case D1Cerrck(lvl1, d1cl):
            prints("D1Cerrck(", lvl1, ";", d1cl, ")")

