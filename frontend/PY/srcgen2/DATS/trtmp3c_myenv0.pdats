def tmqstk_impltmprecq(stk0: !Tmqstk, d3cl: stamp, t2js: t2jaglst) -> stamp:
    match stk0:
        case Tmqstk_nil():
            the_stamp_nil
        case Tmqstk_timp(stmp, dcl1, stk1):
            if d3imp_stampeq(dcl1, d3cl):
                let test = tmpequal_d3cl_t2js(dcl1, t2js)
                if test:
                    stmp
                else:
                    tmqstk_impltmprecq(stk1, d3cl, t2js)
            else:
                tmqstk_impltmprecq(stk1, d3cl, t2js)
        case Tmqstk_svts(_, _, stk1):
            tmqstk_impltmprecq(stk1, d3cl, t2js)
        case Tmqstk_decl(stmp, dcl1, stk1):
            tmqstk_impltmprecq(stk1, d3cl, t2js)
        case Tmqstk_let0(stk1):
            tmqstk_impltmprecq(stk1, d3cl, t2js)
        case Tmqstk_loc1(stk1):
            tmqstk_impltmprecq(stk1, d3cl, t2js)
        case Tmqstk_loc2(stk1):
            tmqstk_impltmprecq(stk1, d3cl, t2js)

@impl
def tr3cenv_impltmprecq(env0, d3cl, t2js):
    let tmp0 = d3imp_get_stmp(d3cl)
    let @(TR3CENV)(topmap, !tmqstk) = env0
    let test = tmqstk_impltmprecq(tmqstk, tmp0, t2js)
    fold(env0)
    test

