private:
    @overload lctn = token_get_lctn
    @overload node = token_get_node

@impl
def t0int_get_lctn(int):
    match int:
        case T0INTnone(tok):
            tok.lctn()
        case T0INTsome(tok):
            tok.lctn()

@impl
def t0chr_get_lctn(chr):
    match chr:
        case T0CHRnone(tok):
            tok.lctn()
        case T0CHRsome(tok):
            tok.lctn()

@impl
def t0flt_get_lctn(flt):
