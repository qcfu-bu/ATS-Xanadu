private:
    @overload[1000000] lctn = token_get_lctn
    @overload[1000000] lctn = i0dnt_get_lctn
    @overload + = add_loctn_loctn

@impl
def s0qid_get_lctn(qid):
    match qid:
        case S0QIDnone(id0):
            id0.lctn()
        case S0QIDsome(tok, id0):
            tok.lctn() + id0.lctn()

@impl
def d0qid_get_lctn(qid):
    match qid:
        case D0QIDnone(id0):
            id0.lctn()
        case D0QIDsome(tok, id0):
            tok.lctn() + id0.lctn()


