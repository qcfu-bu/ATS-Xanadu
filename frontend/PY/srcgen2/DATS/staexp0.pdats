@impl
def t0str_get_lctn(str):
    match str:
        case T0STRnone(tok):
            tok.lctn()
        case T0STRsome(tok):
            tok.lctn()


private:
    enum I0dnt_:
        case I0DNT(loctn, i0dnt_node)
    @impl
    type I0dnt_tbox = I0dnt_

@impl
def i0dnt_none(tok):
    let loc = token_get_lctn(tok)
    I0DNT(loc, I0DNTnone(tok))

@impl
def i0dnt_some(tok):
    let loc = token_get_lctn(tok)
    I0DNT(loc, I0DNTsome(tok))

@impl
def i0dnt_get_lctn(lab):
    let I0DNT(loc, nod) = lab
    loc

@impl
def i0dnt_get_node(lab):
    let I0DNT(loc, nod) = lab
    nod


private:
    enum L0abl_:
        case L0ABL(loctn, l0abl_node)
    @impl
    type L0abl_tbox = L0abl_

@impl
def l0abl_make_node(loc, nod):
    L0ABL(loc, nod)

@impl
def l0abl_get_lctn(lab):
    let L0ABL(loc, nod) = lab
    loc

@impl
def l0abl_get_node(lab):
    let L0ABL(loc, nod) = lab
    nod


@impl
def l0abl_make_none(tok):
    l0abl_make_node(loc, L0ABLnone(tok))
where:
    let loc = token_get_lctn(tok)

@impl
def l0abl_make_int1(tok):
    let loc = token_get_lctn(tok)
    let T_INT01(rep) = token_get_node(tok)
    let int = @inst[SInt] g_parse(rep)
    l0abl_make_node(loc, L0ABLsome(LABint(int)))

@impl
def l0abl_make_name(tok):
    let loc = token_get_lctn(tok)
    let T_IDALP(rep) = token_get_node(tok)
    let sym = symbl_make_name(rep)
    l0abl_make_node(loc, L0ABLsome(LABsym(sym)))

