@impl
def s0exp_annotopt(s0e1, opt2):
    match opt2:
        case optn_nil():
            s0e1
        case optn_cons(s0t2):
            let loc0 = s0e1.lctn() + s0t2.lctn()
            s0exp(loc0, S0Eannot(s0e1, s0t2))

