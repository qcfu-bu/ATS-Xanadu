private:
    def auxs2vs(env0: !tr12env, toks: tokenlst, tvar: sort2, s2vs: s2varlst_vt) -> s2varlst_vt:
        match toks:
            case list_nil():
                s2vs
            case list_cons(tok1, toks):
                let sym1 = sargid_sym(tok1)
                let s2v1 = s2var_make_idst(sym1, tvar)
                tr12env_add0_s2var(env0, s2v1)
                auxs2vs(env0, toks, tvar, list_vt_cons(s2v1, s2vs))
    def auxloop(env0: !tr12env, s1qs: s1qualst, s2vs: s2varlst_vt, s2ps: s2explst_vt) -> (s2varlst, s2explst):
        match s1qs:
            case list_nil():
                let s2vs = list_vt2t(list_vt_reverse0(s2vs))
                let s2ps = list_vt2t(list_vt_reverse0(s2ps))
                (s2vs, s2ps)
            case list_cons(s1q1, s1qs):
                match s1q1.node():
                    case S1QUAprop(s1p1):
                        let tbtf = the_sort2_bool
                        let s2p1 = trans12_s1exp_stck(env0, s1p1, tbtf)
                        let s2ps = list_vt_cons(s2p1, s2ps)
                        auxloop(env0, s1qs, s2vs, s2ps)
                    case S1QUAvars(toks, topt):
                        let topt = trans12_sort1opt(env0, topt)
                        let tvar = match topt:
                            case optn_nil():
                                the_sort2_int0
                            case optn_cons(s2t0):
                                s2t0
                        let s2vs = auxs2vs(env0, toks, tvar, s2vs)
                        auxloop(env0, s1qs, s2vs, s2ps)

