def IDFSTq(ch: Char) -> Bool

@extern
def IDRSTq(ch: Char) -> Bool

@extern
def IDSYMq(ch: Char) -> Bool

@extern
def SYDLRq(ch: Char) -> Bool

@extern
def SYSRPq(ch: Char) -> Bool

@extern
def SLASHq(ch: Char) -> Bool

@extern
def STRSKq(ch: Char) -> Bool

@extern
def SLASH4q(cs: String) -> Bool

@extern
def LPARENq(ck: Char) -> Bool

@extern
def RPARENq(ch: Char) -> Bool

@extern
def SQUOTEq(ch: Char) -> Bool

@extern
def DQUOTEq(ch: Char) -> Bool

@impl
def EOLq(ch):
    ch == '\n'

@impl
def EMPq(ch):
    if (ch == ' '):
        true
    else:
        if (ch == '\t'):
            true
        else:
            false

@impl
def DOTq(ch):
    ch == '.'

@impl
def CLNq(ch):
    ch == ':'

@impl
def ALNUMq(ch):
    isalnum(ch)

@impl
def DIGITq(ch):
    isdigit(ch)

@impl
def ALNUM_q(ch):
    if isalnum(ch):
        true
    else:
        ch == '_'

@impl
def XDIGITq(ch):
    isxdigit(ch)

@impl
def IDFSTq(ch):
    match 0:
        case _ if isalpha(ch):
            true
        case _ if (ch == '_'):
            true
        case _:
            false

@impl
def IDRSTq(ch):
    match 0:
        case _ if isalnum(ch):
            true
        case _ if (ch == '_'):
            true
        case _ if (ch == '$'):
            true
        case _ if (ch == '\''):
            true
        case _:
            false

@impl
def IDSYMq(ch):
    @inst[String] @inst[cgtz] gseq_memberq(symseq, ch)
where:
    let symseq = "%&+-*/.:=@~`^|!?<>#"

@impl
def SYDLRq(ch):
    ch == '$'

@impl
def SYSRPq(ch):
    ch == '#'

@impl
def SLASHq(ch):
    ch == '/'

@impl
def STRSKq(ch):
    ch == '*'

@impl
def SLASH4q(cs):
    let s4 = "////"
    @inst[String] @inst[Char] gseq_prefixq(s4, cs)

@impl
def LPARENq(ch):
    ch == '\('

@impl
def RPARENq(ch):
    ch == '\)'

@impl
def SQUOTEq(ch):
    ch == '\''

@impl
def DQUOTEq(ch):
    ch == '\"'

@extern
def lexing_CMNT1_line[Obj: Vt](buf: !Obj, sym: String) -> tnode

@extern
def lexing_CMNT2_rest[Obj: Vt](buf: !Obj, sym: String) -> tnode

