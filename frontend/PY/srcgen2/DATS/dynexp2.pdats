@impl
def d2con_make_idtp(tok0, tqas, sexp):
    let ctag = -(1)
    let loc0 = tok0.lctn()
    let sym0 = dconid_sym(tok0)
    let t2p0 = s2exp_stpize(sexp)
    let stmp = the_d2con_stamp_new()
    let svts = s2vts_make_lctn_tqas(loc0, tqas)
    let xt2p = s2typ_subst0(t2p0, svts)
    D2CON(loc0, sym0, ctag, tqas, sexp, stmp, t2p0, xt2p)


