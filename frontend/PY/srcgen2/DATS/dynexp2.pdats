@impl
def d2con_get_narg(d2c0):
    let D2CON(loc0, sym0, ctag, tqas, s2e0, stmp, t2p0, xt2p) = d2c0
    auxmain(s2e0)
where:
    def auxmain(s2e0: s2exp) -> SInt:
        match s2e0.node():
            case S2Euni0(s2vs, s2ps, s2e1):
                auxmain(s2e1)
            case S2Efun1(f2cl, nprg, s2es, s2e1):
                list_length(s2es)

@impl
def d2con_get_nprg(d2c0):
    let D2CON(loc0, sym0, ctag, tqas, s2e0, stmp, t2p0, xt2p) = d2c0
    auxmain(s2e0)
where:
    def auxmain(s2e0: s2exp) -> SInt:
        match s2e0.node():
            case S2Euni0(s2vs, s2ps, s2e1):
                auxmain(s2e1)
            case S2Efun1(f2cl, nprg, s2es, s2e1):
                nprg

@impl
def d2con_set_ctag(d2c0, tag0):
    let d2c0 = @sapp[D2con_vt] UN.castlin10(d2c0)
    let @(D2CON_vt)(loc0, sym0, !ctag, tqas, s2e0, stmp, t2p0, xt2p) = d2c0
    ctag := tag0

@impl
