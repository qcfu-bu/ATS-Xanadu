def s2typ_subst0(t2p0: s2typ, svts: s2vts) -> s2typ:
    match svts:
        case list_nil():
            t2p0
        case list_cons(_):
            s2typ_subst0(t2p0, svts)

@impl
def d2pat_none0(loc0):
    d2pat_make_node(loc0, D2Pnone0())

@impl
def d2pat_none1(dpat):
    d2pat_make_node(dpat.lctn(), D2Pnone1(dpat))

@impl
def d2pat_none2(dpat):
    d2pat_make_node(dpat.lctn(), D2Pnone2(dpat))

@impl
def d2pat_any(loc0, sym1):
