@impl
def d2cst_make_dvar(tok0, d2v0, tqas):
    let loc0 = d2v0.lctn()
    let tknd = tok0.node()
    let sym0 = d2v0.name()
    let t2p0 = d2v0.styp()
    let sexp = d2v0.sexp()
    let stmp = the_d2cst_stamp_new()
    let xt2p = s2typ_none0()
    D2CST(loc0, sym0, tknd, tqas, sexp, stmp, t2p0, xt2p)

