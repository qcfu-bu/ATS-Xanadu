private:
    type Xatslocal0_tag_t = SInt
    type Xatslocal1_t2qas = t2qaglst
    def dconid_sym(tok0: token) -> sym_t:
        match tok0.node():
            case T_IDALP(nam1):
                symbl_make_name(nam1)
            case T_IDSYM(nam1):
                symbl_make_name(nam1)
    enum D2con:
        case D2CON(loc_t, sym_t, Xatslocal0_tag_t, Xatslocal1_t2qas, s2exp, stamp, s2typ, s2typ)
    @linear
    enum D2con_vt:
        case D2CON_vt(loc_t, sym_t, Xatslocal0_tag_t, Xatslocal1_t2qas, s2exp, stamp, s2typ, s2typ)
    @impl
    type D2con_tbox = D2con

@impl
