@impl
def d2pat_cons(loc0, d2cs):
    match d2cs:
        case list_nil():
            let drpt = d2rpt_new1(loc0)
            d2pat_make_node(loc0, D2Pcons(drpt, d2cs))
        case list_cons(d2c1, dcs2):
            match dcs2:
                case list_nil():
                    d2pat(loc0, D2Pcon(d2c1))
                case list_cons(_):
                    let drpt = d2rpt_new1(loc0)
                    d2pat_make_node(loc0, D2Pcons(drpt, d2cs))

