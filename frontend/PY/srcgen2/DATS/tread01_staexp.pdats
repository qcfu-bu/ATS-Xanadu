@impl
def tread01_sort1(s1t0, err):
    match s1t0.node():
        case S1Tid0(_):
            s1t0
        case S1Tint(_):
            s1t0
        case S1Ta0pp():
            err := err + 1
            sort1_a0pp_errck(loc0)
        case S1Ta1pp(s1f0, s1t1):
            let e00 = err
            let s1f0 = tread01_sort1(s1f0, err)
            let s1t1 = tread01_sort1(s1t1, err)
            if (err == e00):
                s1t0
            else:
                sort1_a1pp_errck(loc0, s1f0, s1t1)
        case S1Ta2pp(s1f0, s1t1, s1t2):
            let e00 = err
            let s1f0 = tread01_sort1(s1f0, err)
            let s1t1 = tread01_sort1(s1t1, err)
            let s1t2 = tread01_sort1(s1t2, err)
            if (err == e00):
                s1t0
            else:
                sort1_a2pp_errck(loc0, s1f0, s1t1, s1t2)
        case S1Tlist(s1ts):
            let e00 = err
            let s1ts = tread01_sort1lst(s1ts, err)
            if (err == e00):
                s1t0
            else:
                sort1_list_errck(loc0, s1ts)
        case S1Tqual0(tok1, s1t2):
            let e00 = err
            let s1t2 = tread01_sort1(s1t2, err)
            if (err == e00):
                s1t0
            else:
                sort1_qual0_errck(loc0, tok1, s1t2)
        case _:
            let lvl = 1
            err := err + 1
            sort1_errck(lvl, s1t0)
where:
    let loc0 = s1t0.lctn()

