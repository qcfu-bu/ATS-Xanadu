def g1exp_errck(lvl: SInt, g1e: g1exp) -> g1exp:
    g1exp(g1e.lctn(), G1Eerrck(lvl, g1e))

def g1exp_errvl_a1(g1e: g1exp) -> SInt:
    match g1e.node():
        case G1Eerrck(lvl, _):
            lvl
        case _:
            0

@overload g1exp_errvl = g1exp_errvl_a1

@overload errvl = g1exp_errvl_a1

def g1exp_errvl_a2(ge1: g1exp, ge2: g1exp) -> SInt:
    maxs(errvl(ge1), errvl(ge2))

@overload g1exp_errvl = g1exp_errvl_a2

@overload errvl = g1exp_errvl_a2

@extern
def g1exp_errvl_lst(ges: g1explst) -> SInt

@impl
def g1exp_errvl_lst(ges):
    match ges:
        case list_nil():
            0
        case list_cons(ge1, ges):
            maxs(errvl(ge1), g1exp_errvl_lst(ges))

@overload errvl = g1exp_errvl_lst

def g1exp_b0sh_errck(loc: loc_t) -> g1exp:
    g1exp_errck(1, g1exp(loc, G1Eb0sh()))

def g1exp_b1sh_errck(loc: loc_t, g1e: g1exp) -> g1exp:
    g1exp_errck(1, g1exp(loc, G1Eb1sh(g1e)))

def g1exp_a0pp_errck(loc: loc_t) -> g1exp:
    g1exp_errck(1, g1exp(loc, G1Ea0pp()))

def g1exp_a1pp_errck(loc: loc_t, ge1: g1exp, ge2: g1exp) -> g1exp:
    let lvl = maxs(errvl(ge1), errvl(ge2))
    g1exp_errck(lvl + 1, g1exp(loc, G1Ea1pp(ge1, ge2)))

def g1exp_a2pp_errck(loc: loc_t, ge1: g1exp, ge2: g1exp, ge3: g1exp) -> g1exp:
    let lvl = maxs(errvl(ge1), errvl(ge2), errvl(ge3))
    g1exp_errck(lvl + 1, g1exp(loc, G1Ea2pp(ge1, ge2, ge3)))

def g1exp_list_errck(loc: loc_t, ges: g1explst) -> g1exp:
    let lvl = errvl(ges)
    g1exp_errck(lvl + 1, g1exp(loc, G1Elist(ges)))

def g1exp_cond_errck(loc: loc_t, ge1: g1exp, ge2: g1exp, ge3: g1exp) -> g1exp:
    let lvl = maxs(errvl(ge1), errvl(ge2), errvl(ge3))
    g1exp_errck(lvl + 1, g1exp(loc, G1Eift0(ge1, ge2, ge3)))

@impl
def tread01_g1exp(g1e0, err):
    match g1e0.node():
        case G1Eid0(_):
            g1e0
        case G1Eint(_):
            g1e0
        case G1Echr(_):
            g1e0
        case G1Eflt(_):
            g1e0
        case G1Estr(_):
            g1e0
        case G1Eb0sh():
            err := err + 1
            g1exp_b0sh_errck(loc0)
        case G1Eb1sh(g1e1):
            let g1e1 = tread01_g1exp(g1e1, err)
            err := err + 1
            g1exp_b1sh_errck(loc0, g1e1)
        case G1Ea0pp():
            err := err + 1
            g1exp_a0pp_errck(loc0)
        case G1Ea1pp(_):
            f0_a1pp(g1e0, err)
        case G1Ea2pp(_):
            f0_a2pp(g1e0, err)
        case G1Elist(_):
            f0_list(g1e0, err)
        case G1Eift0(_, _, _):
            f0_cond(g1e0, err)
        case _:
            let lvl = 1
            err := err + 1
            g1exp_errck(lvl, g1e0)
where:
    let loc0 = g1e0.lctn()
    def f0_a1pp(g1e: g1exp, err: &SInt >> _) -> g1exp:
        let e00 = err
        let G1Ea1pp(g1f0, g1e1) = g1e.node()
        let g1f0 = tread01_g1exp(g1f0, err)
        let g1e1 = tread01_g1exp(g1e1, err)
        if (err == e00):
            g1e0
        else:
            g1exp_a1pp_errck(loc0, g1f0, g1e1)
    def f0_a2pp(g1e: g1exp, err: &SInt >> _) -> g1exp:
        let e00 = err
        let G1Ea2pp(g1f0, g1e1, g1e2) = g1e.node()
        let g1f0 = tread01_g1exp(g1f0, err)
        let g1e1 = tread01_g1exp(g1e1, err)
        let g1e2 = tread01_g1exp(g1e2, err)
        if (err == e00):
            g1e0
        else:
            g1exp_a2pp_errck(loc0, g1f0, g1e1, g1e2)
    def f0_list(g1e: g1exp, err: &SInt >> _) -> g1exp:
        let e00 = err
        let G1Elist(g1es) = g1e.node()
        let g1es = tread01_g1explst(g1es, err)
        if (err == e00):
            g1e0
        else:
            g1exp_list_errck(loc0, g1es)
    def f0_cond(g1e: g1exp, err: &SInt >> _) -> g1exp:
        let e00 = err
        let loc = g1e.lctn()
        let G1Eift0(g1e1, g1e2, g1e3) = g1e.node()
        let g1e1 = tread01_g1exp(g1e1, err)
        let g1e2 = tread01_g1exp(g1e2, err)
        let g1e3 = tread01_g1exp(g1e3, err)
        if (err == e00):
            g1e
        else:
            g1exp_cond_errck(loc, g1e1, g1e2, g1e3)

