@impl
def tread01_s1exp(s1e0, err):
    match s1e0.node():
        case S1Eid0(_):
            s1e0
        case S1Eint(_):
            s1e0
        case S1Echr(_):
            s1e0
        case S1Eflt(_):
            s1e0
        case S1Estr(_):
            s1e0
        case S1Eb0sh():
            err := err + 1
            s1exp_b0sh_errck(loc0)
        case S1Eb1sh(s1e1):
            let s1e1 = tread01_s1exp(s1e1, err)
            err := err + 1
            s1exp_b1sh_errck(loc0, s1e1)
        case S1Ea0pp():
            err := err + 1
            s1exp_a0pp_errck(loc0)
        case S1Earrw(_):
            f0_arrw(s1e0, err)
        case S1Ea1pp(_):
            f0_a1pp(s1e0, err)
        case S1Ea2pp(_):
            f0_a2pp(s1e0, err)
        case S1El1st(_):
            f0_l1st(s1e0, err)
        case S1El2st(_):
            f0_l2st(s1e0, err)
        case S1Et1up(_):
            f0_t1up(s1e0, err)
        case S1Et2up(_):
            f0_t2up(s1e0, err)
        case S1Er1cd(_):
            f0_r1cd(s1e0, err)
        case S1Er2cd(_):
            f0_r2cd(s1e0, err)
        case S1Euni0(s1qs):
            let e00 = err
            let s1qs = tread01_s1qualst(s1qs, err)
            if (err == e00):
                s1e0
            else:
                s1exp_uni0_errck(loc0, s1qs)
        case S1Eexi0(tknd, s1qs):
            let e00 = err
            let s1qs = tread01_s1qualst(s1qs, err)
            if (err == e00):
                s1e0
            else:
                s1exp_exi0_errck(loc0, tknd, s1qs)
        case S1Elams(_):
            f0_lams(s1e0, err)
        case S1Eannot(s1e1, s1t2):
            let e00 = err
            let s1e1 = tread01_s1exp(s1e1, err)
            let s1t2 = tread01_sort1(s1t2, err)
            if (err == e00):
                s1e0
            else:
                s1exp_annot_errck(loc0, s1e1, s1t2)
        case S1Equal0(tok1, s1e2):
            let e00 = err
            let s1e2 = tread01_s1exp(s1e2, err)
            if (err == e00):
                s1e0
            else:
                s1exp_qual0_errck(loc0, tok1, s1e2)
        case _:
            let lvl = 1
            err := err + 1
            s1exp_errck(lvl, s1e0)
where:
    let loc0 = s1e0.lctn()
    def f0_arrw(s1e: s1exp, err: &SInt >> _) -> s1exp:
        let e00 = err
        let loc = s1e.lctn()
        let S1Earrw(s1es) = s1e.node()
        if (err == e00):
            s1e
        else:
            s1exp_arrw_errck(loc0, s1es)
    def f0_a1pp(s1e: s1exp, err: &SInt >> _) -> s1exp:
        let e00 = err
        let loc = s1e.lctn()
        let S1Ea1pp(s1f0, s1e1) = s1e.node()
        let s1f0 = tread01_s1exp(s1f0, err)
        let s1e1 = tread01_s1exp(s1e1, err)
        if (err == e00):
            s1e
        else:
            s1exp_a1pp_errck(loc0, s1f0, s1e1)
    def f0_a2pp(s1e: s1exp, err: &SInt >> _) -> s1exp:
        let e00 = err
        let loc = s1e.lctn()
        let S1Ea2pp(s1f0, s1e1, s1e2) = s1e.node()
        let s1f0 = tread01_s1exp(s1f0, err)
        let s1e1 = tread01_s1exp(s1e1, err)
        let s1e2 = tread01_s1exp(s1e2, err)
        if (err == e00):
            s1e
        else:
            s1exp_a2pp_errck(loc0, s1f0, s1e1, s1e2)
    def f0_l1st(s1e: s1exp, err: &SInt >> _) -> s1exp:
        let e00 = err
        let loc = s1e.lctn()
        let S1El1st(s1es) = s1e.node()
        let s1es = tread01_s1explst(s1es, err)
        if (err == e00):
            s1e
        else:
            s1exp_l1st_errck(loc0, s1es)
    def f0_l2st(s1e: s1exp, err: &SInt >> _) -> s1exp:
        let e00 = err
        let loc = s1e.lctn()
        let S1El2st(ses1, ses2) = s1e.node()
        let ses1 = tread01_s1explst(ses1, err)
        let ses2 = tread01_s1explst(ses2, err)
        if (err == e00):
            s1e
        else:
            s1exp_l2st_errck(loc0, ses1, ses2)
    def f0_t1up(s1e: s1exp, err: &SInt >> _) -> s1exp:
        let e00 = err
        let loc = s1e.lctn()
        let S1Et1up(tknd, s1es) = s1e.node()
        let s1es = tread01_s1explst(s1es, err)
        if (err == e00):
            s1e
        else:
            s1exp_t1up_errck(loc0, tknd, s1es)
    def f0_t2up(s1e: s1exp, err: &SInt >> _) -> s1exp:
        let e00 = err
        let loc = s1e.lctn()
        let S1Et2up(tknd, ses1, ses2) = s1e.node()
        let ses1 = tread01_s1explst(ses1, err)
        let ses2 = tread01_s1explst(ses2, err)
        if (err == e00):
            s1e
        else:
            s1exp_t2up_errck(loc0, tknd, ses1, ses2)
    def f0_r1cd(s1e: s1exp, err: &SInt >> _) -> s1exp:
        let e00 = err
        let loc = s1e.lctn()
        let S1Er1cd(tknd, lses) = s1e.node()
        let lses = tread01_l1s1elst(lses, err)
        if (err == e00):
            s1e
        else:
            s1exp_r1cd_errck(loc0, tknd, lses)
