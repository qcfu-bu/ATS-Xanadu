@overload name = t2abs_get_name

@overload stmp = t2abs_get_stmp

@overload name = t2dat_get_name

@overload stmp = t2dat_get_stmp

@impl
def sort2_intq(s2t0):
    match s2t0:
        case S2Tbas(tbas):
            match tbas:
                case T2Bpred(name):
                    name == INT0_symbl
                case _:
                    false
        case _:
            false

@impl
def sort2_funq(s2t0):
    match s2t0:
        case S2Tfun0(_):
            true
        case S2Tfun1(_):
            true
        case _:
            false

