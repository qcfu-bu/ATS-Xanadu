@impl
def sort2_imprq(s2t0):
    match s2t0:
        case S2Tbas(tbas):
            match tbas:
                case T2Bimpr(_):
                    true
                case _:
                    false
        case S2Tfun1(targ, tres):
            sort2_imprq(tres)
        case _:
            false

