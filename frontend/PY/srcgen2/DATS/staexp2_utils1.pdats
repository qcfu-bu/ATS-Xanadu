@impl
def s2exp_stck(loc0, s2e1, s2t2):
    let s2t1 = s2e1.sort()
    if (s2t1 <= s2t2):
        s2e1
    else:
        s2exp_cast(loc0, s2e1, s2t2)

@impl
def l2s2e_stck(loc0, ls2e, s2t2):
    let S2LAB(l1, s2e1) = ls2e
    let s2t1 = s2e1.sort()
    if (s2t1 <= s2t2):
        ls2e
    else:
        S2LAB(l1, s2exp_cast(loc0, s2e1, s2t2))

@impl
def s2explst_stck(loc0, s2es, s2t2):
    type X0 = s2exp
    @impl[X0]
    def forall/test(x0):
        x0.sort() <= s2t2
    let test = @inst[X0] list_forall(s2es)
    if test:
        s2es
    else:
        type X0 = s2exp
        type Y0 = s2exp
        @impl[X0, Y0]
        def map/fopr(x0):
            s2exp_stck(loc0, x0, s2t2)
        @inst[X0] @inst[Y0] list_map(s2es)

@impl
def l2s2elst_stck(loc0, lses, s2t2):
    type X0 = l2s2e
    @impl[X0]
    def forall/test(x0):
        x0.sort() <= s2t2
    let test = @inst[X0] list_forall(lses)
    if test:
        lses
    else:
        type X0 = l2s2e
        type Y0 = l2s2e
        @impl[X0, Y0]
        def map/fopr(x0):
            l2s2e_stck(loc0, x0, s2t2)
        @inst[X0] @inst[Y0] list_map(lses)

private:
    def f0_l1st(s2es: s2explst, i0: SInt, lses: l2s2elst_vt) -> l2s2elst_vt:
        match s2es:
            case list_nil():
                lses
            case list_cons(s2e1, s2es):
                let l0 = LABint(i0)
                let lse1 = S2LAB(l0, s2e1)
                let lses = list_vt_cons(lse1, lses)
                f0_l1st(s2es, i0 + 1, lses)
    def f0_l2st(ses1: s2explst, ses2: s2explst, i0: Int, lses: l2s2elst_vt) -> l2s2elst_vt:
        match ses1:
            case list_nil():
                f0_l1st(ses2, i0, lses)
            case list_cons(s2e1, ses1):
                let l0 = LABint(i0)
                let lse1 = S2LAB(l0, s2e1)
                let lses = list_vt_cons(lse1, lses)
                f0_l2st(ses1, ses2, i0 + 1, lses)

@impl
def l2s2elst_make_l1st(s2es):
    let i0 = 0
    let lses = list_vt_nil()
    let lses = f0_l1st(s2es, i0, lses)
    list_vt2t(list_vt_reverse0(lses))

@impl
def l2s2elst_make_l2st(ses1, ses2):
    let i0 = 0
    let lses = list_vt_nil()
    let lses = f0_l2st(ses1, ses2, i0, lses)
    list_vt2t(list_vt_reverse0(lses))


