@impl
def sort2_polpos(s2t0):
    match s2t0:
        case S2Tbas(s2tb):
            match s2tb:
                case T2Bimpr(knd0, sym0):
                    let knd1 = sortpolpos(knd0)
                    S2Tbas(T2Bimpr(knd1, sym0))
                case _:
                    s2t0
        case _:
            s2t0

