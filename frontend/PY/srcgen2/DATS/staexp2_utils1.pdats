@impl
def t2abs_equal(x1, x2):
    x1.stmp() == x2.stmp()

@impl
def t2dat_equal(x1, x2):
    x1.stmp() == x2.stmp()

@impl[t2bas]
def g_lte:
    lte_t2bas_t2bas

@impl
def lte_t2bas_t2bas(x1, x2):
    match (x1, x2):
        case (T2Bpred(nm1), T2Bpred(nm2)):
            nm1 == nm2
        case (T2Btabs(ta1), T2Btabs(ta2)):
            t2abs_equal(ta1, ta2)
        case (T2Btdat(td1), T2Btdat(td2)):
            t2dat_equal(td1, td2)
        case (T2Bimpr(kx1, _), T2Bimpr(kx2, _)):
            subsort_test(kx1, kx2)
        case (_, _):
            false


@impl[sort2]
def g_lte:
    lte_sort2_sort2

@impl[sort2lst]
def g_lte:
    lte_sort2lst_sort2lst

@impl
def lte_sort2_sort2(x1, x2):
    match x1:
        case S2Tid0(tid1):
            match x2:
                case S2Tid0(tid2):
                    tid1 == tid2
                case _:
                    false
        case S2Tint(int1):
            match x2:
                case S2Tint(int2):
                    int1 == int2
                case _:
                    false
        case S2Tbas(stb1):
            match x2:
                case S2Tbas(stb2):
                    stb1 <= stb2
                case _:
                    false
        case S2Ttup(sts1):
            match x2:
                case S2Ttup(sts2):
                    sts1 <= sts2
                case _:
                    false
        case S2Tfun1(arg1, res1):
            match x2:
                case S2Tfun1(arg2, res2):
                    if (arg2 <= arg1):
                        res1 <= res2
                    else:
                        false
                case _:
                    false
        case S2Tapps(s2f1, arg1):
            match x2:
                case S2Tapps(s2f2, arg2):
                    if (s2f1 <= s2f2):
                        arg1 <= arg2
                    else:
                        false
                case _:
                    false
        case _:
            false

@impl
def lte_sort2lst_sort2lst(xs1, xs2):
    match xs1:
        case list_nil():
            match xs2:
                case list_nil():
                    true
                case list_cons(_):
                    false
        case list_cons(x1, xs1):
            match xs2:
                case list_nil():
                    false
                case list_cons(x2, xs2):
                    if x1 <= x2:
                        xs1 <= xs2
                    else:
                        false

