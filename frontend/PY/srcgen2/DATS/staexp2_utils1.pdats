@impl
def s2exp_cbrfq(s2e0):
    match s2e0.node():
        case S2Earg1(knd0, _):
            knd0 < 0
        case S2Eatx2(s2e1, _):
            s2exp_cbrfq(s2e1)
        case _:
            false

@impl
def s2explst_linq(s2es):
    list_exists(s2es)
where:
    @impl[s2exp]
    def exists/test:
        s2exp_linq

