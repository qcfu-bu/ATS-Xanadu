private:
    @overload t2penv = d2parsed_get_t2penv
    let the_ntime = a0ref_make_1val(0)
    def f0_pvsinit() -> Void:
        let xatsv_INT0 = INT0_symbl
        let xatsv_BOOL = BOOL_symbl
        let xatsv_ADDR = ADDR_symbl
        let xatsv_CHAR = CHAR_symbl
        let xatsv_STRN = STRN_symbl
        let xatsv_PROP = PROP_symbl
        let xatsv_VIEW = VIEW_symbl
        let xatsv_TYPE = TYPE_symbl
        let xatsv_TBOX = TBOX_symbl
        let xatsv_VTBX = VTBX_symbl
        let xatsv_VWTP = VWTP_symbl
        private:
            let env0 = the_sortenv_pvstmap()

        topmap_insert/any(env0, xatsv_INT0, S2TEXsrt(the_sort2_int0))
        topmap_insert/any(env0, xatsv_BOOL, S2TEXsrt(the_sort2_bool))
        topmap_insert/any(env0, xatsv_ADDR, S2TEXsrt(the_sort2_addr))
        topmap_insert/any(env0, xatsv_CHAR, S2TEXsrt(the_sort2_char))
        topmap_insert/any(env0, xatsv_STRN, S2TEXsrt(the_sort2_strn))
        topmap_insert/any(env0, xatsv_PROP, S2TEXsrt(the_sort2_prop))
        topmap_insert/any(env0, xatsv_TYPE, S2TEXsrt(the_sort2_type))
        topmap_insert/any(env0, xatsv_TBOX, S2TEXsrt(the_sort2_tbox))
        topmap_insert/any(env0, xatsv_VIEW, S2TEXsrt(the_sort2_view))
        topmap_insert/any(env0, xatsv_VWTP, S2TEXsrt(the_sort2_vwtp))
        topmap_insert/any(env0, xatsv_VTBX, S2TEXsrt(the_sort2_vtbx))
    def f0_pvsload(knd0: SInt, fnam: String) -> Void:
        let xatsv_XATSHOME = the_XATSHOME()
        let fpth = strn_append(xatsv_XATSHOME, fnam)
        let dpar = d0parsed_from_fpath(knd0, fpth)
        let dpar = d1parsed_of_trans01(dpar)
        let dpar = d2parsed_of_trans12(dpar)
        let D2TOPENV(tr11, tenv, senv, denv) = dpar.t2penv()
        the_sortenv_pvsmrgw(tenv)
        the_sexpenv_pvsmrgw(senv)
        the_dexpenv_pvsmrgw(denv)
    def f0_pvsfini() -> Bool:
        let ans = f1_dexpenv()
        ans

    def f1_dexpenv() -> Bool:
        type Kx0 = (SInt, list[d2itm])
        type Kxs = strm_vt[(SInt, list[d2itm])]
        def auxmain(kxs: Kxs, ans: Bool) -> Bool:
            match !(kxs):
                case ~strmcon_vt_nil():
                    ans
                case ~strmcon_vt_cons(kx1, kxs):
                    def fopr(kx1: Kx0):
                        let dis = kx1.1
                        if list_length(dis) <= 1:
                            ans
                        else:
                            match dis.head():
                                case D2ITMvar(d2v):
                                    true
                                case _:
                                    ans
                    auxmain(kxs, fopr(kx1))
        let kxs = topmap_strmize(the_dexpenv_pvstmap())
        auxmain(kxs, false)

@impl
def filpath_pvsload(knd0, fpth):
    f0_pvsload(knd0, fpth)

