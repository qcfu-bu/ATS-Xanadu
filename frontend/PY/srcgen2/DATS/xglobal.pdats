@impl
def the_gmacenv_pvsmrgw(map):
    type Kxs_t = (SInt, list[g1mac])
    let kxss = topmap_strmize(map)
    let env0 = the_gmacenv_pvstmap()
    def auxkxs1(env0: Gmacenv, kxs1: Kxs_t) -> Void:
        let (k1, xs1) = kxs1
        let list_cons(x1, xs1) = xs1
        prerrsln("the_gmacenv_pvsmrgw: auxkxs1: k1 = ", k1)
        prerrsln("the_gmacenv_pvsmrgw: auxkxs1: x1 = ", x1)
        let opt = the_xsymbls_search(k1)
        match opt:
            case ~optn_vt_cons(k1):
                topmap_insert/any(env0, k1, x1)
    def auxloop(env0: Gmacenv, kxss: strm_vt[Kxs_t]) -> Void:
        match !(kxss):
            case ~strmcon_vt_nil():
                ()
            case ~strmcon_vt_cons(kxs1, kxss):
                auxkxs1(env0, kxs1)
                auxloop(env0, kxss)
    auxloop(env0, kxss)

