def s2var_copy(s2v0: s2var) -> s2var:
    s2var(name, s2t0)
where:
    let name = s2v0.name()
    let s2t0 = s2v0.sort()

@overload[1000] copy = s2var_copy

def s2typ_new0_x2tp(loc0: loc_t) -> s2typ:
    s2typ_xtv(x2t2p_make_lctn(loc0))

def s2typ_subst0(t2p0: s2typ, svts: s2vts) -> s2typ:
    match svts:
        case list_nil():
            t2p0
        case list_cons(_):
            s2typ_subst0(t2p0, svts)

@extern
def list_ziprev[A: Type, B: Type](xs: list[A], ys: list[B]) -> list[(A, B)]

@impl[]
def list_ziprev[A: Type, B: Type](xs, ys):
    ziprev(xs, ys)
where:
    def ziprev(xs, ys):
        match xs:
            case list_nil():
                list_nil()
            case list_cons(x1, xs):
                match ys:
                    case list_nil():
                        list_nil
                    case list_cons(y1, ys):
                        list_cons((x1, y1), ziprev(xs, ys))

@impl
def trans23_d2pat(env0, d2p0):
    let loc0 = d2p0.lctn()
    let t2p0 = d2p0.styp()
    match d2p0.node():
        case D2Pany():
            f0_any(env0, d2p0)
        case D2Pvar(d2v):
            f0_var(env0, d2p0)
        case D2Pint(tok):
            d3pat_make_tpnd(loc0, t2p0, D3Pint(tok))
        case D2Pbtf(sym):
            d3pat_make_tpnd(loc0, t2p0, D3Pbtf(sym))
        case D2Pchr(tok):
            d3pat_make_tpnd(loc0, t2p0, D3Pchr(tok))
        case D2Pflt(tok):
            d3pat_make_tpnd(loc0, t2p0, D3Pflt(tok))
        case D2Pstr(tok):
            d3pat_make_tpnd(loc0, t2p0, D3Pstr(tok))
        case D2Pcon(_):
            f0_con(env0, d2p0)
        case D2Pbang(_):
            f0_bang(env0, d2p0)
        case D2Pflat(_):
            f0_flat(env0, d2p0)
        case D2Pfree(_):
            f0_free(env0, d2p0)
        case D2Pcons(_):
            f0_cons(env0, d2p0)
        case D2Psapp(_):
            f0_sapp(env0, d2p0)
        case D2Pdap0(_):
            f0_dap0(env0, d2p0)
        case D2Pdap1(_):
            f0_dap1(env0, d2p0)
        case D2Pdapp(_):
            f0_dapp(env0, d2p0)
        case D2Prfpt(_):
            f0_rfpt(env0, d2p0)
        case D2Ptup0(_):
            f0_tup0(env0, d2p0)
        case D2Ptup1(_):
            f0_tup1(env0, d2p0)
        case D2Pargtp(_):
            f0_argtp(env0, d2p0)
        case D2Pannot(_):
            f0_annot(env0, d2p0)
        case _:
            d3pat_none1(d2p0)
where:
    def f0_any(env0: !tr23env, d2p0: d2pat) -> d3pat:
        let loc0 = d2p0.lctn()
        let t2p0 = d2p0.styp()
        let D2Pany() = d2p0.node()
        d3pat(loc0, t2p0, D3Pany)
    def f0_var(env0: !tr23env, d2p0: d2pat) -> d3pat:
        let loc0 = d2p0.lctn()
        let D2Pvar(d2v0) = d2p0.node()
        let t2p0 = d2v0.styp()
        let t2p0 = s2typ_hnfiz0(t2p0)
        d2v0.styp(t2p0)
        d3pat(loc0, t2p0, D3Pvar(d2v0))
    def f0_con(env0: !tr23env, d2p0: d2pat) -> d3pat:
        let loc0 = d2p0.lctn()
        let D2Pcon(d2c1) = d2p0.node()
        let (t2js, t2p0) = d2con23_tjagize(loc0, d2c1)
        let d3p0 = d3pat_make_tpnd(loc0, t2p0, D3Pcon(d2c1))
        match t2js:
            case list_nil(_):
                d3p0
            case list_cons(_):
                d3pat_make_tpnd(loc0, t2p0, D3Ptapq(d3p0, t2js))
    def f0_bang(env0: !tr23env, d2p0: d2pat) -> d3pat:
        let loc0 = d2p0.lctn()
        let D2Pbang(d2p1) = d2p0.node()
        let d3p1 = trans23_d2pat(env0, d2p1)
        let t2p1 = d3p1.styp()
        let t2p0 = match t2p1.node():
            case T2Plft(t2p0):
                t2p0
            case _:
                s2typ_none1(t2p1)
        d3pat(loc0, t2p0, D3Pbang(d3p1))
    def f0_flat(env0: !tr23env, d2p0: d2pat) -> d3pat:
        let loc0 = d2p0.lctn()
        let D2Pflat(d2p1) = d2p0.node()
        let d3p1 = trans23_d2pat(env0, d2p1)
        let t2p1 = d3p1.styp()
        d3pat(loc0, t2p1, D3Pflat(d3p1))
    def f0_free(env0: !tr23env, d2p0: d2pat) -> d3pat:
        let loc0 = d2p0.lctn()
        let D2Pfree(d2p1) = d2p0.node()
        let d3p1 = trans23_d2pat(env0, d2p1)
        let t2p1 = d3p1.styp()
        d3pat(loc0, t2p1, D3Pfree(d3p1))
    def f0_cons(env0: !tr23env, d2p0: d2pat) -> d3pat:
        let loc0 = d2p0.lctn()
        let D2Pcons(drpt, d2cs) = d2p0.node()
        trans23_d2pat(env0, drpt.dpat())
    def f0_sapp(env0: !tr23env, d2p0: d2pat) -> d3pat:
        let D2Psapp(d2f0, s2as) = d2p0.node()
        let d3f0 = trans23_d2pat(env0, d2f0)
        let tfun = d3f0.styp()
        let d3f1 = match tfun.node():
            case T2Puni0(s2vs, t2p1):
                let t2ps = f1_t2ps(s2vs, s2as)
                let svts = list_ziprev(s2vs, t2ps)
                let t2p1 = s2typ_subst0(t2p1, svts)
                let s2as = f1_s2as(t2ps)
                d3pat_make_tpnd(loc0, t2p1, D3Psapq(d3f0, s2as))
            case _:
                d3f0
        let t2p1 = d3f1.styp()
        d3pat_make_tpnd(loc0, t2p1, D3Psapp(d3f1, s2as))
    where:
        let loc0 = d2p0.lctn()
        def f1_s2as(t2ps: s2typlst) -> s2arglst:
            match t2ps:
                case list_nil():
                    list_nil
                case list_cons(t2p1, t2ps):
                    let s2a1 = match t2p1.node():
                        case T2Pvar(s2a1):
                            s2arg_make_node(t2p1.sort(), S2Avar(s2a1))
                    list_cons(s2a1, f1_s2as(t2ps))
        def f1_t2ps(s2vs: s2varlst, s2as: s2varlst) -> s2typlst:
            match s2vs:
                case list_nil():
                    list_nil()
                case list_cons(s2v1, s2vs):
                    f1_t2ps_cons(s2v1, s2vs, s2as)

        def f1_t2ps_cons(s2v1: s2var, s2vs: s2varlst, s2as: s2varlst) -> s2typlst:
            match s2as:
                case list_nil():
                    let s2a1 = s2v1.copy()
                    let t2p1 = s2typ_var(s2a1)
                    list_cons(t2p1, f1_t2ps(s2vs, s2as))
                case list_cons(s2a1, s2as):
                    if (sort2_imprq(s2a1.sort())):
                        let t2p1 = s2typ_var(s2a1)
                        list_cons(t2p1, f1_t2ps(s2vs, s2as))
                    else:
                        f1_t2ps_cons(s2v1, s2vs, s2as)
    def f0_dap0(env0: !tr23env, d2p0: d2pat) -> d3pat:
        let loc0 = d2p0.lctn()
        let tres = s2typ_none0()
        d3pat(loc0, tres, D3Pnone1(d2p0))
    def f0_dap1(env0: !tr23env, d2p0: d2pat) -> d3pat:
        let loc0 = d2p0.lctn()
        let D2Pdap1(d2f0) = d2p0.node()
        let d3f0 = trans23_d2pat(env0, d2f0)
        let d3f0 = d3pat_sapqize(d3f0)
        let tfun = d3f0.styp()
        let tres = match tfun.node():
            case T2Pfun1(_, _, _, tres):
                tres
            case _:
                s2typ_none0()
        d3pat(loc0, tres, D3Pdap1(d3f0))
    def f0_dapp(env0: !tr23env, d2p0: d2pat) -> d3pat:
        let loc0 = d2p0.lctn()
        let D2Pdapp(d2f0, npf1, d2ps) = d2p0.node()
        let d3f0 = trans23_d2pat(env0, d2f0)
        let d3f0 = d3pat_sapqize(d3f0)
        let d3ps = trans23_d2patlst(env0, d2ps)
        let tfun = d3f0.styp()
        let targ = match tfun.node():
            case T2Pfun1(f2cl, npf1, t2ps, tres):
                t2ps
            case _:
                list_nil()
        let tres = match tfun.node():
            case T2Pfun1(f2cl, npf1, t2ps, tres):
                tres
            case _:
                tfun
        let d3ps = trans23_d3patlst_tpcks(env0, loc0, d3ps, targ)
        d3pat_make_tpnd(loc0, tres, D3Pdapp(d3f0, npf1, d3ps))
    def f0_rfpt(env0: !tr23env, d2p0: d2pat) -> d3pat:
        d3pat_make_tpnd(loc0, t2p2, D3Prfpt(d3p1, tkas, d3p2))
    where:
        let loc0 = d2p0.lctn()
        let D2Prfpt(d2p1, tkas, d2p2) = d2p0.node()
        let d3p2 = trans23_d2pat(env0, d2p2)
        let t2p2 = d3p2.styp()
        let d3p1 = trans23_d2pat_tpck(env0, d2p1, t2p2)
    def f0_tup0(env0: !tr23env, d2p0: d2pat) -> d3pat:
        d3pat_make_tpnd(loc0, t2p0, D3Ptup0(npf1, d3ps))
    where:
        let loc0 = d2p0.lctn()
        let D2Ptup0(npf1, d2ps) = d2p0.node()
        let d3ps = trans23_d2patlst(env0, d2ps)
        let t2p0 = match d3ps:
            case list_nil():
                the_s2typ_void()
            case list_cons(_):
                s2typ_tup0(npf1, s2typlst(d3ps))
    def f0_tup1(env0: !tr23env, d2p0: d2pat) -> d3pat:
        d3pat_make_tpnd(loc0, t2p0, D3Ptup1(tknd, npf1, d3ps))
    where:
        let loc0 = d2p0.lctn()
        let D2Ptup1(tknd, npf1, d2ps) = d2p0.node()
        let d3ps = trans23_d2patlst(env0, d2ps)
        let trcd = match tknd.node():
            case T_TRCD10(0):
                TRCDflt0
            case T_TRCD10(_):
                TRCDbox0
        let t2p0 = s2typ_tup1(trcd, npf1, s2typlst(d3ps))
    def f0_argtp(env0: !tr23env, d2p0: d2pat) -> d3pat:
        let loc0 = d2p0.lctn()
        let D2Pargtp(d2p1, t2p2) = d2p0.node()
        let d3p1 = match d2p1.node():
            case D2Pvar(_):
                trans23_d2pat(env0, d2p1)
            case _:
                trans23_d2pat_tpck(env0, d2p1, t2p2)
        d3pat(loc0, t2p2, D3Pargtp(d3p1, t2p2))
    def f0_annot(env0: !tr23env, d2p0: d2pat) -> d3pat:
        let loc0 = d2p0.lctn()
        let D2Pannot(d2p1, s1e2, s2e2) = d2p0.node()
        let t2p0 = d2p0.styp()
        let d3p1 = match d2p1.node():
            case D2Pvar(_):
                trans23_d2pat(env0, d2p1)
            case _:
                trans23_d2pat_tpck(env0, d2p1, t2p0)
        d3pat_make_tpnd(loc0, t2p0, D3Pannot(d3p1, s1e2, s2e2))

@impl
def trans23_l2d2p(env0, ld2p):
    let D2LAB(lab0, d2p1) = ld2p
    D3LAB(lab0, trans23_d2pat(env0, d2p1))

@impl
def trans23_d2exp(env0, d2e0):
    let loc0 = d2e0.lctn()
    let t2p0 = d2e0.styp()
    match d2e0.node():
        case D2Evar(_):
            f0_var(env0, d2e0)
        case D2Eint(tok):
            d3exp_make_tpnd(loc0, t2p0, D3Eint(tok))
        case D2Ebtf(sym):
            d3exp_make_tpnd(loc0, t2p0, D3Ebtf(sym))
        case D2Echr(tok):
            d3exp_make_tpnd(loc0, t2p0, D3Echr(tok))
        case D2Eflt(tok):
            d3exp_make_tpnd(loc0, t2p0, D3Eflt(tok))
        case D2Estr(tok):
            d3exp_make_tpnd(loc0, t2p0, D3Estr(tok))
        case D2Ei00(int):
            d3exp_make_tpnd(loc0, t2p0, D3Ei00(int))
        case D2Eb00(btf):
            d3exp_make_tpnd(loc0, t2p0, D3Eb00(btf))
        case D2Ec00(chr):
            d3exp_make_tpnd(loc0, t2p0, D3Ec00(chr))
        case D2Ef00(flt):
            d3exp_make_tpnd(loc0, t2p0, D3Ef00(flt))
        case D2Es00(str):
            d3exp_make_tpnd(loc0, t2p0, D3Es00(str))
        case D2Etop(_):
            f0_top(env0, d2e0)
        case D2Econ(_):
            f0_con(env0, d2e0)
        case D2Ecst(_):
            f0_cst(env0, d2e0)
        case D2Econs(_):
            f0_cons(env0, d2e0)
        case D2Ecsts(_):
            f0_csts(env0, d2e0)
        case D2Esym0(_):
            f0_sym0(env0, d2e0)
        case D2Esapp(_):
            f0_sapp(env0, d2e0)
        case D2Etapp(_):
            f0_tapp(env0, d2e0)
        case D2Edap0(_):
            f0_dap0(env0, d2e0)
        case D2Edapp(_):
            f0_dapp(env0, d2e0)
        case D2Eproj(_):
            f0_proj(env0, d2e0)
        case D2Elet0(_):
            f0_let0(env0, d2e0)
        case D2Eift0(_):
            f0_ift0(env0, d2e0)
        case D2Ecas0(_):
            f0_cas0(env0, d2e0)
        case D2Eseqn(_):
            f0_seqn(env0, d2e0)
        case D2Etup0(_):
            f0_tup0(env0, d2e0)
        case D2Etup1(_):
            f0_tup1(env0, d2e0)
        case D2Ercd2(_):
            f0_rcd2(env0, d2e0)
        case D2Elam0(_):
            f0_lam0(env0, d2e0)
        case D2Efix0(_):
            f0_fix0(env0, d2e0)
        case D2Etry0(_):
            f0_try0(env0, d2e0)
        case D2Eaddr(_):
            f0_addr(env0, d2e0)
        case D2Eview(_):
            f0_view(env0, d2e0)
        case D2Eeval(_):
            f0_eval(env0, d2e0)
        case D2Efold(_):
            f0_fold(env0, d2e0)
        case D2Efree(_):
            f0_free(env0, d2e0)
        case D2Ewhere(_):
            f0_where(env0, d2e0)
        case D2Eassgn(_):
            f0_assgn(env0, d2e0)
        case D2Exazgn(_):
            f0_xazgn(env0, d2e0)
        case D2Exchng(_):
            f0_xchng(env0, d2e0)
        case D2Eraise(_):
            f0_raise(env0, d2e0)
        case D2El0azy(_):
            f0_l0azy(env0, d2e0)
        case D2El1azy(_):
            f0_l1azy(env0, d2e0)
        case D2Eelazy(_):
            f0_elazy(env0, d2e0)
        case D2Eannot(_):
            f0_annot(env0, d2e0)
        case D2Elabck(_):
            f0_labck(env0, d2e0)
        case D2Et2pck(_):
            f0_t2pck(env0, d2e0)
        case D2Et2ped(_):
            f0_t2ped(env0, d2e0)
        case D2Enone0(_):
            f0_none0(env0, d2e0)
        case D2Eextnam(_):
            f0_extnam(env0, d2e0)
        case D2Esynext(_):
            f0_synext(env0, d2e0)
        case _:
            d3exp_none1(d2e0)
where:
    def f0_top(env0: !tr23env, d2e0: d2exp) -> d3exp:
        let loc0 = d2e0.lctn()
        let D2Etop(sym1) = d2e0.node()
        let t2p0 = s2typ_new0_x2tp(loc0)
        d3exp_make_tpnd(loc0, t2p0, D3Etop(sym1))
    def f0_var(env0: !tr23env, d2e0: d2exp) -> d3exp:
        let loc0 = d2e0.lctn()
        let D2Evar(d2v1) = d2e0.node()
        let t2p1 = d2v1.styp()
        let d3e1 = d3exp_make_tpnd(loc0, t2p1, D3Evar(d2v1))
        match t2p1.node():
            case T2Plft(t2p1):
                d3exp_make_tpnd(loc0, t2p1, D3Eflat(d3e1))
            case _:
                d3e1
    def f0_con(env0: !tr23env, d2e0: d2exp) -> d3exp:
        let loc0 = d2e0.lctn()
        let D2Econ(d2c1) = d2e0.node()
        d2con23_tapqize(loc0, d2c1)
    def f0_cst(env0: !tr23env, d2e0: d2exp) -> d3exp:
        let loc0 = d2e0.lctn()
        let D2Ecst(d2c1) = d2e0.node()
        d2cst23_tapqize(loc0, d2c1)
    def f0_cons(env0: !tr23env, d2e0: d2exp) -> d3exp:
        let loc0 = d2e0.lctn()
        let D2Econs(d2cs) = d2e0.node()
        match d2cs:
            case list_nil():
                d3exp_none1(d2e0)
            case list_cons(d2c1, _):
                d2con23_tapqize(loc0, d2c1)
    def f0_csts(env0: !tr23env, d2e0: d2exp) -> d3exp:
        let loc0 = d2e0.lctn()
        let D2Ecsts(d2cs) = d2e0.node()
        match d2cs:
            case list_nil():
                d3exp_none1(d2e0)
            case list_cons(d2c1, _):
                d2cst23_tapqize(loc0, d2c1)
    def f0_sym0(env0: !tr23env, d2e0: d2exp) -> d3exp:
        let loc0 = d2e0.lctn()
        let D2Esym0(drxp, d1e1, dpis) = d2e0.node()
        trans23_d2exp(env0, drxp.dexp())
    def f0_sapp(env0: !tr23env, d2e0: d2exp) -> d3exp:
        let D2Esapp(d2f0, s2es) = d2e0.node()
        let d3f0 = trans23_d2exp(env0, d2f0)
        let tfun = d3f0.styp()
        let d3f1 = match tfun.node():
            case T2Puni0(s2vs, t2p1):
                let t2ps = f1_t2ps(s2vs, s2es)
                let svts = list_ziprev(s2vs, t2ps)
                let t2p1 = s2typ_subst0(t2p1, svts)
                d3exp_make_tpnd(loc0, t2p1, D3Esapq(d3f0, t2ps))
            case _:
                d3f0
        let t2p1 = d3f1.styp()
        d3exp_make_tpnd(loc0, t2p1, D3Esapp(d3f1, s2es))
    where:
        let loc0 = d2e0.lctn()
        def f1_t2ps(s2vs: s2varlst, s2es: s2explst) -> s2typlst:
