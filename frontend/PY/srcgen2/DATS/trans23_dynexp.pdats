            match s2es:
                case list_nil():
                    let t2p1 = s2typ_new0_x2tp(loc0)
                    list_cons(t2p1, f1_t2ps(s2vs, s2es))
                case list_cons(s2e1, s2es):
                    if (sort2_imprq(s2e1.sort())):
                        let t2p1 = s2exp_stpize(s2e1)
                        list_cons(t2p1, f1_t2ps(s2vs, s2es))
