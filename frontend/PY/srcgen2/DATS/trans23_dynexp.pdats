        def f1_unif(env0: !tr23env, t2j1: t2jag, d2f1: d2exp) -> Void:
            let t2ps = t2jag_get_t2ps(t2j1)
            let s2es = match d2f1.node():
                case D2Etapp(_, s2es):
                    s2es
            f2_t2ps_s2es(env0, t2ps, s2es)
        where:
            def f2_t2p1_s2e1(env0: !tr23env, t2p1: s2typ, s2e1: s2exp) -> Void:
                let utbf = unify23_s2typ(env0, t2p1, s2exp_stpize(s2e1))
            def f2_t2ps_s2es(env0: !tr23env, t2ps: s2typlst, s2es: s2explst) -> Void:
                match t2ps:
                    case list_nil():
                        ()
                    case list_cons(t2p1, t2ps):
                        match s2es:
                            case list_nil():
                                ()
                            case list_cons(s2e1, s2es):
                                f2_t2p1_s2e1(env0, t2p1, s2e1)
                                f2_t2ps_s2es(env0, t2ps, s2es)
        def f1_wind(env0: !tr23env, d3f0: d3exp, t2js: t2jaglst, d2fs: d2explst) -> d3exp:
            match t2js:
                case list_nil():
                    match d2fs:
                        case list_nil():
                            d3f0
                        case list_cons(d2f1, d2fs):
                            let d3f0 = f1_tapp(d3f0, d2f1)
                            let d3f0 = d3exp_none2(d3f0)
                            f1_wind(env0, d3f0, t2js, d2fs)
                case list_cons(t2j1, t2js):
                    match d2fs:
                        case list_nil():
                            d3f0
                        case list_cons(d2f1, d2fs):
                            let d3f0 = f1_tapp(d3f0, d2f1)
                            let utbf = f1_unif(env0, t2j1, d2f1)
                            f1_wind(env0, d3f0, t2js, d2fs)

    def f0_tapp(env0: !tr23env, d2e0: d2exp) -> d3exp:
        let loc0 = d2e0.lctn()
