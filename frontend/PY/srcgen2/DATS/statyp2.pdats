private:
    let stamper = stamper_new()

def the_x2t2p_stamp_new() -> stamp:
    stamper.getinc()


private:
    enum X2t2p:
        case X2T2P(loc_t, S2typ, stamp)
    @linear
    enum X2t2p_vt:
        case X2T2P_vt(loc_t, S2typ, stamp)
    @impl
    type X2t2p_tbox = X2t2p

@impl
def x2t2p_get_lctn(xt2p):
    let X2T2P(loc0, t2p0, stmp) = xt2p
    loc0

@impl
def x2t2p_get_stmp(xt2p):
    let X2T2P(loc0, t2p0, stmp) = xt2p
    stmp

@impl
def x2t2p_get_styp(xt2p):
    let X2T2P(loc0, t2p0, stmp) = xt2p
    t2p0

@impl
def x2t2p_make_lctn(loc0):
    X2T2P(loc0, t2p0, stmp)
where:
    let t2p0 = s2typ_none0()
    let stmp = the_x2t2p_stamp_new()

@impl
def x2t2p_set_styp(xt2p, t2p0):
    let xt2p = @sapp[X2t2p_vt] UN.castlin10(xt2p)
    let @(X2T2P_vt)(loc0, !styp, stmp) = xt2p
    styp := t2p0


@impl
def intrep_s2typ_xint(tint):
    match tint.node():
        case T_INT01(_):
            the_s2typ_sint()
        case T_INT02(_):
            the_s2typ_sint()
        case T_INT03(bas, rep, sfx):
            if sfx <= 0:
                the_s2typ_sint()
            else:
                f0_rep(rep)
where:
    def f0_rep(rep: String) -> S2typ:
        if (nu <= 0):
            match nl:
                case 0:
                    the_s2typ_sint()
                case 1:
                    the_s2typ_slint()
                case _:
                    the_s2typ_sllint()
        else:
            match nl:
                case 0:
                    the_s2typ_uint()
                case 1:
                    the_s2typ_ulint()
                case _:
                    the_s2typ_ullint()
    where:
        type X0 = cgtz
        type R0 = SInt
        @impl[X0, R0]
        def foldl/fopr(r0, x0):
            if x0 == 'l':
                r0 + 1
            else:
                if x0 == 'L':
                    r0 + 1
                else:
                    r0
        let nl = @inst[R0] strn_foldl(rep, 0)
        @impl[X0, R0]
        def foldl/fopr(r0, x0):
            if x0 == 'u':
                r0 + 1
            else:
                if x0 == 'U':
                    r0 + 1
                else:
                    r0
        let nu = @inst[R0] strn_foldl(rep, 0)

