private:
    def f0_trcdknd(linq: Bool, prfq: Bool, tknd: trcdknd) -> sort2:
        if prfq:
            if linq:
                the_sort2_view
            else:
                the_sort2_prop
        else:
            if linq:
                match tknd:
                    case TRCDbox0():
                        the_sort2_tbox
                    case TRCDbox1():
                        the_sort2_vtbx
                    case _:
                        the_sort2_vwtp
            else:
                match tknd:
                    case TRCDbox0():
                        the_sort2_tbox
                    case TRCDbox1():
                        the_sort2_vtbx
                    case _:
                        the_sort2_type
    def f0_labelize(t2ps: s2typlst, i0: SInt) -> l2t2plst:
        match t2ps:
            case list_nil():
                list_nil()
            case list_cons(t2p1, t2ps):
                let ltp1 = S2LAB(LABint(i0), t2p1)
                list_cons(ltp1, f0_labelize(t2ps, i0 + 1))
    def f0_orderize(ltps: l2t2plst) -> l2t2plst:
        type X0 = l2t2p
        def f1_test(ltps: list[X0]) -> Bool:
            @inst[X0] list_sortedq(ltps)
        def f1_sort(ltps: l2t2plst) -> l2t2plst:
            @inst[X0] list_mergesort(ltps)
        if f1_test(ltps):
            ltps
        else:
            f1_sort(ltps)

@impl
def s2typ_tup0(npf1, t2ps):
    let linq = s2typlst_linq(t2ps)
    let prfq = s2typlst_prfq(t2ps)
    let s2t0 = if prfq:
        if linq:
            the_sort2_view
        else:
            the_sort2_prop
    else: match ():
        case ():
            if linq:
                the_sort2_vwtp
            else:
                the_sort2_type
    let trcd = TRCDflt0
    let ltps = f0_labelize(t2ps, 0)
    s2typ_make_node(s2t0, T2Ptrcd(trcd, npf1, ltps))

@impl
def s2typ_tup1(tknd, npf1, t2ps):
    let linq = s2typlst_linq(t2ps)
    let prfq = s2typlst_prfq(t2ps)
    let s2t0 = f0_trcdknd(linq, prfq, tknd)
    let ltps = f0_labelize(t2ps, 0)
    s2typ_make_node(s2t0, T2Ptrcd(tknd, npf1, ltps))

@impl
def s2typ_rcd2(tknd, npf1, ltps):
    let linq = l2t2plst_linq(ltps)
    let prfq = l2t2plst_prfq(ltps)
    let s2t0 = f0_trcdknd(linq, prfq, tknd)
    let ltps = f0_orderize(ltps)
    s2typ_make_node(s2t0, T2Ptrcd(tknd, npf1, ltps))


