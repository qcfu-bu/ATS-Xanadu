@impl
def g1arg_fprint(g1a, out):
    match g1a.node():
        case G1ARGnode(tok):
            prints("G1ARGnode(", tok, ")")
where:
    @impl[]
    def g_print/out():
        out

@impl
def s1qid_fprint(qid, out):
    @impl[]
    def g_print/out():
        out
    match qid:
        case S1QIDnone(id1):
            prints("S1QIDnone(", id1, ")")
        case S1QIDsome(tok, id1):
            prints("S1QIDsome(", tok, ";", id1, ")")

