@impl
def g1nam_fprint(g1n, out):
    @impl[]
    def g_print/out():
        out
    match g1n:
        case G1Nnil():
            prints("G1Nnil(", ")")
        case G1Nid0(id0):
            prints("G1Nid0(", id0, ")")
        case G1Nint(int):
            prints("G1Nint(", int, ")")
        case G1Nchr(chr):
            prints("G1Nchr(", chr, ")")
        case G1Nflt(flt):
            prints("G1Nflt(", flt, ")")
        case G1Nstr(str):
            prints("G1Nstr(", str, ")")
        case G1Nlist(g1ns):
            prints("G1Nlist(", g1ns, ")")
        case G1Nnone1(g1n1):
            prints("G1Nnone1(", g1n1, ")")

@impl
def g1exp_fprint(g1e, out):
    @impl[]
    def g_print/out():
        out
    match g1e.node():
        case G1Eint(tok):
            prints("G1Eint(", tok, ")")
        case G1Echr(tok):
            prints("G1Echr(", tok, ")")
        case G1Eflt(tok):
            prints("G1Eflt(", tok, ")")
        case G1Estr(tok):
            prints("G1Estr(", tok, ")")
        case G1Eid0(id0):
            prints("G1Eid0(", id0, ")")
        case G1Eb0sh():
            prints("G1Eb0sh(", ")")
        case G1Eb1sh(g1e):
            prints("G1Eb1sh(", g1e, ")")
        case G1Ea0pp():
            prints("G1Ea0pp(", ")")
        case G1Ea1pp(g1f0, g1e1):
            prints("G1Ea1pp(", g1f0, ";", g1e1, ")")
        case G1Ea2pp(g1f0, g1e1, g1e2):
            prints("G1Ea2pp(", g1f0, ";", g1e1, ";", g1e2, ")")
        case G1Elist(g1es):
            prints("G1Elist(", g1es, ")")
        case G1Eift0(g1e1, g1e2, g1e3):
            prints("G1Eift0(", g1e1, ";", g1e2, ";", g1e3, ")")
        case G1Enone0():
            prints("G1Enone0(", ")")
        case G1Enone1(g0e1):
            prints("G1Enone1(", g0e1, ")")
        case G1Eerrck(lvl, g1e1):
            prints("G1Eerrck(", lvl, ";", g1e1, ")")

