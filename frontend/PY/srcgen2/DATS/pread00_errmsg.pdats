private:
    def auxmain(out: FILR, dcl: d0ecl) -> Void:
        @impl[]
        def g_print/out():
            out
        match dcl.node():
            case D0Cnonfix(knd, ids):
                i0dntlst_fpemsg(out, ids)
            case D0Cfixity(knd, ids, opt):
                i0dntlst_fpemsg(out, ids)
            case D0Cstatic(knd, dc1):
                fpemsg(out, dc1)
            case D0Cextern(knd, dc1):
                fpemsg(out, dc1)
            case D0Clocal0(tkb, ds1, tin, ds2, tke):
                d0eclist_fpemsg(out, ds1)
                d0eclist_fpemsg(out, ds2)
            case D0Cabssort(tknd, tid0):
                fpemsg(out, tid0)
            case D0Cstacst0(tknd, sid0, tmas, tcln, s0t1):
                fpemsg(out, sid0)
                t0maglst_fpemsg(out, tmas)
                fpemsg(out, s0t1)
            case D0Csortdef(tknd, tid0, teq1, tdf2):
                fpemsg(out, tid0)
                token_EQ0_fpemsg(out, teq1)
                s0tdf_fpemsg(out, tdf2)
            case D0Csymload(tknd, symb, twth, dqid, gopt):
                s0ymb_fpemsg(out, symb)
                d0qid_fpemsg(out, dqid)
                g0expopt_fpemsg(out, gopt)
            case D0Cinclude(knd0, tknd, g0e1):
                g0exp_fpemsg(out, g0e1)
            case D0Cstaload(knd0, tknd, g0e1):
                g0exp_fpemsg(out, g0e1)
            case D0Cdyninit(tknd, g0e1):
                g0exp_fpemsg(out, g0e1)
            case D0Cextcode(tknd, g0e1):
                g0exp_fpemsg(out, g0e1)
            case D0Cdatasort(tknd, d0ts):
                d0tstlst_fpemsg(out, d0ts)
            case D0Cvaldclst(tknd, d0cs):
                d0valdclist_fpemsg(out, d0cs)
            case D0Cvardclst(tknd, d0cs):
                d0vardclist_fpemsg(out, d0cs)
            case D0Cfundclst(tknd, tqas, d0cs):
                t0qaglst_fpemsg(out, tqas)
                d0fundclist_fpemsg(out, d0cs)
            case D0Cimplmnt0(tknd, sqas, tqas, dqid, tias, f0as, sres, tkeq, body):
                s0qaglst_fpemsg(out, sqas)
                t0qaglst_fpemsg(out, tqas)
                t0iaglst_fpemsg(out, tias)
                s0res_fpemsg(out, sres)
                f0arglst_fpemsg(out, f0as)
                d0exp_fpemsg(out, body)
            case D0Cdatatype(tknd, d0ts, wdcs):
                d0typlst_fpemsg(out, d0ts)
                wd0eclseq_fpemsg(out, wdcs)
            case D0Cdynconst(tknd, tqas, d0cs):
                t0qaglst_fpemsg(out, tqas)
                d0cstdclist_fpemsg(out, d0cs)
            case D0Ctkerr(_):
                ()
            case D0Cerrck(_, _):
                d0ecl_fpemsg(out, dcl)
            case _:
                ()

@impl
def d0ecl_fpemsg(out, dcl):
    @impl[]
    def g_print/out():
        out
    match dcl.node():
        case D0Cerrck(lvl, d1c):
            auxmain(out, d1c)
            printsln()
            printsln("PREAD00-ERROR:", dcl.lctn(), ":", dcl)
        case _:
            ()


