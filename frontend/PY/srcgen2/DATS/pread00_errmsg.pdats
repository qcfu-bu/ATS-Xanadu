@impl
def g0exp_fpemsg(out, g0e):
    @impl[]
    def g_print/out():
        out
    match g0e.node():
        case G0Eerrck(lvl, ge1):
            let loc = g0e.lctn()
        case _:
            ()

private:
    def auxmain(out: FILR, s0t: sort0) -> Void:
        @impl[]
        def g_print/out():
            out
        match s0t.node():
            case S0Tid0(id0):
                i0dnt_fpemsg(out, id0)
            case S0Tint(int):
                t0int_fpemsg(out, int)
            case S0Tapps(sts):
                sort0lst_fpemsg(out, sts)
            case S0Tlpar(tkb, sts, tke):
                sort0lst_fpemsg(out, sts)
            case S0Ttkerr(_):
                ()
            case S0Terrck(_):
                sort0_fpemsg(out, s0t)

@impl
def sort0_fpemsg(out, s0t):
    @impl[]
    def g_print/out():
        out
    match s0t.node():
        case S0Terrck(lvl, st1):
            auxmain(out, st1)
            if (lvl >= xatsv_FPEMSG_ERRLVL):
                ()
            else:
                printsln("PREAD00-ERROR:", s0t.lctn(), ":", s0t)
        case _:
            ()


private:
    def auxmain(out: FILR, s0e: s0exp) -> Void:
        @impl[]
        def g_print/out():
            out
        match s0e.node():
            case S0Eid0(id0):
                i0dnt_fpemsg(out, id0)
            case S0Eint(int):
                t0int_fpemsg(out, int)
            case S0Echr(chr):
                t0chr_fpemsg(out, chr)
            case S0Eflt(flt):
                t0flt_fpemsg(out, flt)
            case S0Estr(str):
                t0str_fpemsg(out, str)
            case S0Eop1(_):
                ()
            case S0Eop2(_):
                ()
            case S0Eop3(_):
                ()
            case S0Eapps(ses):
                s0explst_fpemsg(out, ses)
            case S0Efimp(tkb, ses, tke):
                s0explst_fpemsg(out, ses)
            case S0Elpar(tkb, ses, srp):
                fpemsg(out, ses)
                fpemsg(out, srp)
            case S0Etkerr(_):
                ()
            case S0Eerrck(_):
                s0exp_fpemsg(out, s0e)

@impl
def s0exp_fpemsg(out, s0e):
    @impl[]
    def g_print/out():
        out
    match s0e.node():
        case S0Eerrck(lvl, se1):
            auxmain(out, se1)
            if (lvl >= xatsv_FPEMSG_ERRLVL):
                ()
            else:
                printsln("PREAD00-ERROR:", s0e.lctn(), ":", s0e)
        case _:
            ()


@impl
def l0s0e_fpemsg(out, lse):
    match lse:
        case S0LAB(lab, teq, s0e):
            s0exp_fpemsg(out, s0e)

@impl
def s0arg_fpemsg(out, s0a):
    @impl[]
    def g_print/out():
        out
    match s0a.node():
        case S0ARGnone(tok):
            printsln("PREAD00-ERROR:", tok.lctn(), ":", s0a)
        case S0ARGsome(sid0, topt):
            fpemsg(out, sid0)
            fpemsg(out, topt)

@impl
def s0mag_fpemsg(out, sma):
    @impl[]
    def g_print/out():
        out
    match sma.node():
        case S0MAGnone(tok):
            let loc = sma.lctn()
            printsln("PREAD00-ERROR:", loc, ":", sma)
        case S0MAGsing(sid0):
            i0dnt_fpemsg(out, sid0)
        case S0MAGlist(tbeg, s0as, tend):
            s0arglst_fpemsg(out, s0as)
            token_RPAREN_fpemsg(out, tend)

@impl
def t0arg_fpemsg(out, t0a):
    @impl[]
    def g_print/out():
        out
    match t0a.node():
        case T0ARGnone(tok):
            let loc = t0a.lctn()
            printsln("PREAD00-ERROR:", loc, ":", t0a)
        case T0ARGsome(s0t1, topt):
            fpemsg(out, s0t1)

@impl
def t0mag_fpemsg(out, tma):
    @impl[]
    def g_print/out():
        out
    match tma.node():
        case T0MAGnone(tok):
            let loc = tok.lctn()
            printsln("PREAD00-ERROR:", loc, ":", tma)
        case T0MAGlist(tbeg, t0as, tend):
            t0arglst_fpemsg(out, t0as)
            token_RPAREN_fpemsg(out, tend)

@impl
def s0qua_fpemsg(out, s0q):
    match s0q.node():
        case S0QUAprop(s0e):
            s0exp_fpemsg(out, s0e)
        case S0QUAvars(sids, tres):
            i0dntlst_fpemsg(out, sids)
            sort0opt_fpemsg(out, tres)

@impl
def s0uni_fpemsg(out, s0u):
    match s0u.node():
        case S0UNInone(tok):
            ()
        case S0UNIsome(tbeg, s0qs, tend):
            s0qualst_fpemsg(out, s0qs)
            token_RBRACE_fpemsg(out, tend)

@impl
def s0tdf_fpemsg(out, tdf):
    match tdf.node():
        case S0TDFsort(s0t):
            sort0_fpemsg(out, s0t)
        case S0TDFtsub(tbeg, s0a1, tbar, s0es, tend):
            s0arg_fpemsg(out, s0a1)
            token_BAR_fpemsg(out, tbar)
            s0explst_fpemsg(out, s0es)
            token_RBRACE_fpemsg(out, tend)

@impl
def g0expopt_fpemsg(out, opt):
    match opt:
        case optn_nil():
            ()
        case optn_cons(g0e):
            g0exp_fpemsg(out, g0e)

@impl
def sort0opt_fpemsg(out, opt):
    match opt:
        case optn_nil():
            ()
        case optn_cons(s0t):
            sort0_fpemsg(out, s0t)

@impl
def s0expopt_fpemsg(out, opt):
    match opt:
        case optn_nil():
            ()
        case optn_cons(s0e):
            s0exp_fpemsg(out, s0e)

@impl
def i0dntlst_fpemsg(out, ids):
    @inst[i0dnt] list_foritm(ids)
where:
    @impl[i0dnt]
    def foritm/work(id1):
        i0dnt_fpemsg(out, id1)

