@impl
def s0ymb_fpemsg(out, sym):
    @impl[]
    def g_print/out():
        out
    printsln("PREAD00-ERROR:", sym)

@impl
def i0dnt_fpemsg(out, id0):
    @impl[]
    def g_print/out():
        out
    match id0.node():
        case I0DNTsome(_):
            ()
        case I0DNTnone(tok):
            let loc = tok.lctn()
            printsln("PREAD00-ERROR:", loc, ":", id0)

