@impl
def s0exp_RPAREN_fpemsg(out, srp):
    match srp:
        case s0exp_RPAREN_cons0(tend):
            token_RPAREN_fpemsg(out, tend)
        case s0exp_RPAREN_cons1(tbar, s0es, tend):
            s0explst_fpemsg(out, s0es)

@impl
def l0s0e_RBRACE_fpemsg(out, lsrb):
    match lsrb:
        case l0s0e_RBRACE_cons0(tend):
            token_RBRACE_fpemsg(out, tend)
        case l0s0e_RBRACE_cons1(tbar, lses, tend):
            l0s0elst_fpemsg(out, lses)

@extern
def s0eff_fpemsg() -> (FILR, s0eff) -> Void

@extern
def s0res_fpemsg() -> (FILR, s0res) -> Void

@extern
def d0res_fpemsg() -> (FILR, d0res) -> Void

@overload fpemsg = s0res_fpemsg

@overload fpemsg = d0res_fpemsg

@extern
def f0arg_fpemsg() -> (FILR, f0arg) -> Void

@extern
def f0arglst_fpemsg() -> (FILR, f0arglst) -> Void

@extern
def d0cls_fpemsg() -> (FILR, d0cls) -> Void

@extern
def d0clslst_fpemsg() -> (FILR, d0clslst) -> Void

@extern
def t0qua_fpemsg() -> (FILR, t0qua) -> Void

@extern
def t0inv_fpemsg() -> (FILR, t0inv) -> Void

@extern
def t0qualst_fpemsg() -> (FILR, t0qualst) -> Void

private:
    def auxmain(out: FILR, d0p: d0pat) -> Void:
        @impl[]
        def g_print/out():
            out
        match d0p.node():
            case D0Pid0(id0):
                i0dnt_fpemsg(out, id0)
            case D0Pint(int):
                t0int_fpemsg(out, int)
            case D0Pchr(chr):
                t0chr_fpemsg(out, chr)
            case D0Pflt(flt):
                t0flt_fpemsg(out, flt)
            case D0Pstr(str):
                t0str_fpemsg(out, str)
            case D0Paspt(tas, dp1):
                d0pat_fpemsg(out, dp1)
            case D0Papps(dps):
                d0patlst_fpemsg(out, dps)
            case D0Psarg(tkb, sas, tke):
                s0arglst_fpemsg(out, sas)
                token_RBRACE_fpemsg(out, tke)
            case D0Plpar(tkb, dps, drp):
                fpemsg(out, dps)
                fpemsg(out, drp)
            case D0Ptup1(tbeg, topt, d0ps, tend):
                fpemsg(out, d0ps)
                fpemsg(out, tend)
            case D0Prcd2(tbeg, topt, ldps, tend):
                fpemsg(out, ldps)
                fpemsg(out, tend)
            case D0Pannot(d0p1, s0e2):
                fpemsg(out, d0p1)
                fpemsg(out, s0e2)
            case D0Ptkerr(_):
                ()
            case D0Perrck(lvl0, d0p1):
                d0pat_fpemsg(out, d0p)

@impl
def d0pat_fpemsg(out, d0p):
    @impl[]
    def g_print/out():
        out
    match d0p.node():
        case D0Perrck(lvl, dp1):
            auxmain(out, dp1)
            if (lvl >= xatsv_FPEMSG_ERRLVL):
                ()
            else:
                printsln("PREAD00-ERROR:", d0p.lctn(), ":", d0p)
        case _:
            ()


@impl
def l0d0p_fpemsg(out, ldp):
    match ldp:
        case D0LAB(lab, teq, d0p):
            d0pat_fpemsg(out, d0p)

private:
    def auxmain(out: FILR, d0e: d0exp) -> Void:
        @impl[]
        def g_print/out():
            out
        match d0e.node():
            case D0Eid0(id0):
                i0dnt_fpemsg(out, id0)
            case D0Eint(int):
                t0int_fpemsg(out, int)
            case D0Echr(chr):
                t0chr_fpemsg(out, chr)
            case D0Eflt(flt):
                t0flt_fpemsg(out, flt)
            case D0Estr(str):
                t0str_fpemsg(out, str)
            case D0Eopid(id0):
                i0dnt_fpemsg(out, id0)
            case D0Eapps(des):
                d0explst_fpemsg(out, des)
            case D0Esarg(tkb, ses, tke):
                s0explst_fpemsg(out, ses)
                token_RBRACE_fpemsg(out, tke)
            case D0Etarg(tkb, ses, tke):
                s0explst_fpemsg(out, ses)
                token_RBRACE_fpemsg(out, tke)
            case D0Elpar(tkb, des, drp):
                fpemsg(out, des)
                fpemsg(out, drp)
            case D0Eift0(tift, d0e1, dthn, dels):
                fpemsg(out, d0e1)
                fpemsg(out, dthn)
                fpemsg(out, dels)
            case D0Eift1(tift, d0e1, dthn, dels, tinv):
                fpemsg(out, d0e1)
                fpemsg(out, dthn)
                fpemsg(out, dels)
                t0inv_fpemsg(out, tinv)
            case D0Ecas0(tcas, d0e1, tkof, tbar, dcls):
                d0exp_fpemsg(out, d0e1)
                token_OF0_fpemsg(out, tkof)
                d0clslst_fpemsg(out, dcls)
            case D0Etup1(tbeg, topt, d0es, tend):
                fpemsg(out, d0es)
                fpemsg(out, tend)
            case D0Ercd2(tbeg, topt, ldes, tend):
                fpemsg(out, ldes)
                fpemsg(out, tend)
            case D0Elet0(tknd, dcls, topt, d0es, tend):
                d0eclist_fpemsg(out, dcls)
                d0explst_fpemsg(out, d0es)
                token_ENDLET_fpemsg(out, tend)
            case D0Ewhere(d0e1, dcls):
                match dcls:
                    case d0eclseq_WHERE(tbeg, topt, d0cs, tend):
                        d0exp_fpemsg(out, d0e1)
                        d0eclist_fpemsg(out, d0cs)
                        tkend_WHERE_fpemsg(out, topt, tend)
            case D0Ebrckt(tbeg, d0es, tend):
                d0explst_fpemsg(out, d0es)
                token_RBRCKT_fpemsg(out, tend)
            case D0Edtsel(tdot, lab1, opt2):
                fpemsg(out, lab1)
                fpemsg(out, opt2)
            case D0Etry0(tknd, d0es, twth, tbar, dcls, tend):
                d0explst_fpemsg(out, d0es)
                token_WITH_fpemsg(out, twth)
                d0clslst_fpemsg(out, dcls)
            case D0Elam0(tknd, fags, sres, arrw, body, tend):
                f0arglst_fpemsg(out, fags)
                fpemsg(out, sres)
                fpemsg(out, arrw)
                fpemsg(out, body)
            case D0Efix0(tknd, dpid, fags, arrw, sres, body, tend):
                i0dnt_fpemsg(out, dpid)
                f0arglst_fpemsg(out, fags)
                fpemsg(out, sres)
                fpemsg(out, arrw)
                fpemsg(out, body)
            case D0Eraise(tknd, d0e1):
                fpemsg(out, d0e1)
            case D0Eannot(d0e1, s0e2):
                fpemsg(out, d0e1)
                fpemsg(out, s0e2)
            case D0Equal0(tok1, d0e2):
                fpemsg(out, d0e2)
            case D0Eextnam(tok1, gnm2):
                ()
            case D0Eexists(tknd, d0es, d0e1):
                fpemsg(out, d0es)
                fpemsg(out, d0e1)
            case D0Esynext(tok1, d0e2):
                fpemsg(out, d0e2)
            case D0Etkerr(tok1):
                ()
            case D0Eerrck(lvl0, d0e1):
                d0exp_fpemsg(out, d0e)

@impl
def d0exp_fpemsg(out, d0e):
    @impl[]
    def g_print/out():
        out
    match d0e.node():
        case D0Eerrck(lvl, de1):
            auxmain(out, de1)
            if (lvl >= xatsv_FPEMSG_ERRLVL):
                ()
            else:
                printsln("PREAD00-ERROR:", d0e.lctn(), ":", d0e)
        case _:
            ()


