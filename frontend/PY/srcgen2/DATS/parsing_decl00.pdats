def p1_precmod() -> p1_fun[precmod]

@extern
def p1_precint() -> p1_fun[precint]

@impl
def p1_i0dntseq(buf, err):
    list_vt2t(@sapp[i0dnt] ps_p1fun(buf, err, p1_i0dnt))

@impl
def p1_g0magseq(buf, err):
    list_vt2t(@sapp[g0mag] ps_p1fun(buf, err, p1_g0mag))

@impl
def p1_precopt(buf, err):
    let tok = buf.getk0()
    let tnd = tok.tnode()
    match tnd:
        case T_INT01(_):
            buf.skip1()
            PRECint1(tok)
        case T_INT02(_):
            buf.skip1()
            PRECint1(tok)
        case _:
            let dnt1 = p1_i0dnt(buf, err)
            let pmod = p1_precmod(buf, err)
            PRECopr2(dnt1, pmod)

@impl
def p1_precint(buf, err):
    let tok = buf.getk0()
    let tnd = tok.tnode()
    match tnd:
        case _:
            let tok0 = tok
            buf.skip1()
            let tint = buf.getk1()
            PINTopr2(tok0, tint)

@impl
def p1_precmod(buf, err):
    let tok0 = buf.getk0()
    let tnd0 = tok0.tnode()
    match tnd0:
        case T_LPAREN():
            let tbeg = tok0
            buf.skip1()
            let pint = p1_precint(buf, err)
            let tend = p1_RPAREN(buf, err)
            PMODsome(tbeg, pint, tend)
        case _:
            PMODnone()

@impl
def p1_g0edf(buf, err):
    let e00 = err
    let tok = buf.getk0()
    let tnd = tok.tnode()
    match tnd:
        case T_EQ0():
            buf.skip1()
            let g0e = p1_g0exp(buf, err)
            G0EDFsome(optn_cons(tok), g0e)
        case _:
            let g0e = p1_g0exp(buf, err)
            match g0e.node():
                case G0Etkerr(_):
                    G0EDFnone
                case _:
                    G0EDFsome(optn_nil, g0e)

@impl
def p1_a0tdf(buf, err):
    let e00 = err
    let tok = buf.getk0()
    let tnd = tok.tnode()
    match tnd:
        case T_IDSYM(sym):
            match 0:
                case _ if (sym == "=="):
                    buf.skip1()
                    let s0e = p1_s0exp(buf, err)
                    err := e00
                    A0TDFeqeq(tok, s0e)
                case _ if (sym == "<="):
                    buf.skip1()
                    let s0e = p1_s0exp(buf, err)
                    err := e00
                    A0TDFlteq(tok, s0e)
        case _:
            A0TDFsome()

type Pk_fun[R0: Type] = (token, !tkbf0, &SInt >> _) -> R0

@extern
def p1_dynconst() -> p1_fun[d0ecl]

@extern
def pk_dynconst() -> Pk_fun[d0ecl]

