private:
    def f0_s0q0(s0q0: s0qua) -> s0qua:
        match s0q0.node():
            case S0QUAprop(s0p):
                match s0p.node():
                    case S0Eid0(sid):
                        let loc = s0p.lctn()
                        let opt = optn_nil()
                        let ids = list_sing(sid)
                        s0qua_make_node(loc, S0QUAvars(ids, opt))
                    case _:
                        s0q0
            case _:
                s0q0
    def auxs0qs(xs: s0qualst) -> s0qualst:
        @inst[s0qua] @inst[s0qua] list_map(xs)
    where:
        @impl[s0qua, s0qua]
        def map/fopr:
            f0_s0q0
    def f0_f0a0(f0a0: f0arg) -> f0arg:
        match f0a0.node():
            case F0ARGsapp(tbeg, s0qs, tend):
                let loc0 = f0a0.lctn()
                let s0qs = auxs0qs(s0qs)
                let node = F0ARGsapp(tbeg, s0qs, tend)
                f0arg_make_node(loc0, node)
            case _:
                f0a0
    def f0_f0as(xs: f0arglst) -> f0arglst:
        @inst[f0arg] @inst[f0arg] list_map(xs)
    where:
        @impl[f0arg, f0arg]
        def map/fopr:
            f0_f0a0
    def t0_s0qs(xs: s0qualst) -> Bool:
        match xs:
            case list_nil():
                false
            case list_cons(x1, xs):
                match x1.node():
                    case S0QUAprop(s0p):
                        match s0p.node():
                            case S0Eid0(sid):
                                true
                            case _:
                                t0_s0qs(xs)
                    case _:
                        t0_s0qs(xs)
    def t0_f0as(xs: f0arglst) -> Bool:
        match xs:
            case list_nil():
                false
            case list_cons(x1, xs):
                match x1.node():
                    case F0ARGsapp(tbeg, s0qs, tend):
                        if t0_s0qs(s0qs):
                            true
                        else:
                            t0_f0as(xs)
                    case _:
                        t0_f0as(xs)

@impl
def p1_f0argsq1(buf, err):
    let f0as = p1_f0argseq(buf, err)
    if t0_f0as(f0as):
        f0_f0as(f0as)
    else:
        f0as


