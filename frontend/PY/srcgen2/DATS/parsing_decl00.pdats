@impl
def fp_d0ecl(f00, buf, err):
    let e00 = err
    let tok = buf.getk0()
    let tnd = tok.tnode()
    def ENDq(tnd: tnode) -> Bool:
        match tnd:
            case T_END():
                true
            case T_ENDLAM():
                true
            case T_ENDFIX():
                true
            case T_ENDLET():
                true
            case T_ENDWHR():
                true
            case T_ENDLOC():
                true
            case _:
                false
    match tnd:
        case T_LOCAL():
            let tbeg = tok
            buf.skip1()
            let head = fp_d0eclseq(f00, buf, err)
            let tmid = pq_IN0(buf, err)
            let body = fp_d0eclseq(f00, buf, err)
            let tend = p1_ENDLOC(buf, err)
            let lres = tbeg.lctn() + tend.lctn()
            err := e00
            d0ecl_make_node(lres, D0Clocal0(tbeg, head, tmid, body, tend))
        case T_VAL(_) if f00 > 0:
            pk_valdclst(tok, buf, err)
        case T_VAR(_) if f00 > 0:
            pk_vardclst(tok, buf, err)
        case T_FUN(_) if f00 > 0:
            pk_fundclst(tok, buf, err)
        case T_IMPLMNT(_) if f00 > 0:
            pk_implmnt0(tok, buf, err)
        case T_ABSSORT():
            let tknd = tok
            buf.skip1()
            let tid0 = p1_s0tid(buf, err)
            let lres = tknd.lctn() + tid0.lctn()
            err := e00
            d0ecl_make_node(lres, D0Cabssort(tknd, tid0))
        case T_STACST0():
            let tknd = tok
            buf.skip1()
            let seid = p1_s0eid(buf, err)
            let tmas = p1_t0magseq(buf, err)
            let tok1 = p1_CLN(buf, err)
            let s0t2 = p1_sort0(buf, err)
            let lres = tknd.lctn() + s0t2.lctn()
            err := e00
            d0ecl_make_node(lres, D0Cstacst0(tknd, seid, tmas, tok1, s0t2))
        case T_SORTDEF():
            let tknd = tok
            buf.skip1()
            let tid0 = p1_s0tid(buf, err)
            let teq1 = p1_EQ0(buf, err)
            let def2 = p1_s0tdf(buf, err)
            let lres = tknd.lctn() + def2.lctn()
            err := e00
            d0ecl_make_node(lres, D0Csortdef(tknd, tid0, teq1, def2))
        case T_SEXPDEF(k0):
            let tknd = tok
            buf.skip1()
            let sid0 = p1_s0eid(buf, err)
            let smas = p1_s0magseq(buf, err)
            let tres = pq_sort0_anno(buf, err)
            let teq1 = p1_EQ0(buf, err)
            let def2 = p1_s0exp(buf, err)
            let lres = tknd.lctn() + def2.lctn()
            err := e00
            d0ecl_make_node(lres, D0Csexpdef(tknd, sid0, smas, tres, teq1, def2))
        case T_ABSTYPE(k0):
            let tknd = tok
            buf.skip1()
            let sid0 = p1_s0eid(buf, err)
            let tmas = p1_t0magseq(buf, err)
            let tres = pq_ids0t_anno(buf, err)
            let tdef = p1_a0tdf(buf, err)
            let lknd = tknd.lctn()
            let lres = match tdef:
                case A0TDFsome():
                    match tmas:
                        case list_nil(_):
                            lknd + sid0.lctn()
                        case list_cons(_):
                            let t0ma = list_last(tmas)
                            lknd + t0ma.lctn()
                case A0TDFlteq(tok, s0e):
                    lknd + s0e.lctn()
                case A0TDFeqeq(tok, s0e):
                    lknd + s0e.lctn()
            err := e00
            d0ecl_make_node(lres, D0Cabstype(tknd, sid0, tmas, tres, tdef))
        case T_ABSOPEN():
            let tknd = tok
            buf.skip1()
            let sqid = p1_s0qid(buf, err)
            let lres = tknd.lctn() + sqid.lctn()
            err := e00
            d0ecl_make_node(lres, D0Cabsopen(tknd, sqid))
        case T_ABSIMPL():
            let tknd = tok
            buf.skip1()
            let sqid = p1_s0qid(buf, err)
            let smas = p1_s0magseq(buf, err)
            let tres = pq_sort0_anno(buf, err)
            let teq1 = p1_EQ0(buf, err)
            let def2 = p1_s0exp(buf, err)
            let lres = tknd.lctn() + def2.lctn()
            err := e00
            d0ecl_make_node(lres, D0Cabsimpl(tknd, sqid, smas, tres, teq1, def2))
        case T_DATASORT():
            let tknd = tok
            buf.skip1()
            let dtcs = p1_d0tstseq_AND(buf, err)
            let lres = match dtcs:
                case list_nil():
                    tknd.lctn()
                case list_cons(_, _):
                    let dtc1 = list_last(dtcs)
                    tknd.lctn() + dtc1.lctn()
            err := e00
            d0ecl_make_node(lres, D0Cdatasort(tknd, dtcs))
        case T_EXCPTCON():
            let tknd = tok
            buf.skip1()
            let lknd = tknd.lctn()
            let topt = pq_BAR(buf, err)
            let dtcs = p1_d0tcnseq_BAR(buf, err)
            let lres = match dtcs:
                case list_nil():
                    match topt:
                        case optn_nil():
                            lknd
                        case optn_cons(tbar):
                            lknd + tbar.lctn()
                case list_cons(_):
                    let dtc1 = list_last(dtcs)
                    lknd + dtc1.lctn()
            err := e00
            d0ecl(lres, D0Cexcptcon(tknd, topt, dtcs))
        case T_DATATYPE(k0):
            let tknd = tok
            buf.skip1()
            let dtps = p1_d0typseq_AND(buf, err)
            let tok1 = buf.getk0()
            let wopt = match tok1.node():
                case T_WHERE():
                    buf.skip1()
                    let topt = pq_LBRACE(buf, err)
                    let wdcs = p1_d0eclseq_sta(buf, err)
                    let tok2 = buf.getk0()
                    match tok2.node():
                        case T_RBRACE():
                            buf.skip1()
                        case T_ENDWHR():
                            buf.skip1()
                        case _:
                            err := err + 1
                    WD0CSsome(tok1, topt, wdcs, tok2)
                case _:
                    WD0CSnone()
            let lknd = tknd.lctn()
            let lres = match wopt:
                case WD0CSnone():
                    match dtps:
                        case list_nil():
                            lknd
                        case list_cons(_):
                            let dtp1 = list_last(dtps)
                            lknd + dtp1.lctn()
                case WD0CSsome(_, _, _, tend):
                    lknd + tend.lctn()
            err := e00
            d0ecl(lres, D0Cdatatype(tknd, dtps, wopt))
        case _ if t0_dctkind(tnd):
            pk_dynconst(tok, buf, err)
        case T_SRP_STATIC():
            let tknd = tok
            buf.skip1()
            let dcl0 = fp_d0ecl(f00, buf, err)
            let lres = tknd.lctn() + dcl0.lctn()
            err := e00
            d0ecl_make_node(lres, D0Cstatic(tknd, dcl0))
        case T_SRP_EXTERN():
            let tknd = tok
            buf.skip1()
            let dcl0 = fp_d0ecl(f00, buf, err)
            let lres = tknd.lctn() + dcl0.lctn()
            err := e00
            d0ecl_make_node(lres, D0Cextern(tknd, dcl0))
        case T_SRP_STAVAL():
            let tknd = tok
            buf.skip1()
            let dcl0 = p1_dynconst(buf, err)
            let lres = tknd.lctn() + dcl0.lctn()
            err := e00
            d0ecl_make_node(lres, D0Cstatic(tknd, dcl0))
        case T_SRP_EXTVAL():
            let tknd = tok
            buf.skip1()
            let dcl0 = p1_dynconst(buf, err)
            let lres = tknd.lctn() + dcl0.lctn()
            err := e00
            d0ecl_make_node(lres, D0Cextern(tknd, dcl0))
        case T_SRP_DEFINE():
            let tknd = tok
            buf.skip1()
            let gid0 = p1_g0eid(buf, err)
            let gmas = p1_g0magseq(buf, err)
            let gedf = p1_g0edf(buf, err)
            let lres = match gedf:
                case G0EDFnone():
                    match gmas:
                        case list_nil(_):
                            gid0.lctn()
                        case list_cons(_):
                            let larg = lctn(list_last(gmas))
                            gid0.lctn() + larg
                case G0EDFsome(topt, g0e1):
                    gid0.lctn() + g0e1.lctn()
            err := e00
            d0ecl(lres, D0Cdefine(tknd, gid0, gmas, gedf))
        case T_SRP_SYMLOAD():
            let tknd = tok
            buf.skip1()
            let symb = p1_s0ymb(buf, err)
            let twth = p1_WITH(buf, err)
            let dqid = p1_d0qid(buf, err)
            let tok1 = buf.getk0()
            let opt1 = match tok1.node():
                case T_OF0():
                    buf.skip1()
                    optn_cons(p1_g0exp(buf, err))
                case _:
                    optn_nil()
            let lres = match opt1:
                case optn_nil():
                    tknd.lctn() + dqid.lctn()
                case optn_cons(g0e1):
                    tknd.lctn() + g0e1.lctn()
            err := e00
            d0ecl_make_node(lres, D0Csymload(tknd, symb, twth, dqid, opt1))
        case T_SRP_INCLUDE():
            let knd0 = f00
            let tknd = tok
            buf.skip1()
            let g0e1 = p1_g0exp(buf, err)
            let lres = tknd.lctn() + g0e1.lctn()
            err := e00
            d0ecl_make_node(lres, D0Cinclude(knd0, tknd, g0e1))
        case T_SRP_STALOAD():
            let knd0 = f00
            let tknd = tok
            buf.skip1()
            let g0e1 = p1_g0exp(buf, err)
            let lres = tknd.lctn() + g0e1.lctn()
            err := e00
            d0ecl_make_node(lres, D0Cstaload(knd0, tknd, g0e1))
        case T_SRP_DYNINIT():
            let tknd = tok
            buf.skip1()
            let g0e1 = p1_g0exp(buf, err)
            let lres = tknd.lctn() + g0e1.lctn()
            err := e00
            d0ecl_make_node(lres, D0Cdyninit(tknd, g0e1))
        case T_SRP_EXTCODE():
            let tknd = tok
            buf.skip1()
            let g0e1 = p1_g0exp(buf, err)
            let lres = tknd.lctn() + g0e1.lctn()
            err := e00
            d0ecl_make_node(lres, D0Cextcode(tknd, g0e1))
        case T_SRP_THEN0():
            let tknd = tok
            buf.skip1()
            let lres = tknd.lctn()
            d0ecl_make_node(lres, D0Cthen0(tknd))
        case T_SRP_ELSE1():
            let tknd = tok
            buf.skip1()
            let lres = tknd.lctn()
            d0ecl_make_node(lres, D0Celse1(tknd))
        case T_SRP_ENDIF():
            let tknd = tok
            buf.skip1()
            let lres = tknd.lctn()
            d0ecl_make_node(lres, D0Cendif(tknd))
        case T_SRP_IFEXP():
            let tknd = tok
            buf.skip1()
            let g0e1 = p1_g0exp(buf, err)
            let lres = tknd.lctn() + g0e1.lctn()
            err := e00
            d0ecl_make_node(lres, D0Cifexp(tknd, g0e1))
        case T_SRP_ELSIF():
            let tknd = tok
            buf.skip1()
            let g0e1 = p1_g0exp(buf, err)
            let lres = tknd.lctn() + g0e1.lctn()
            err := e00
            d0ecl_make_node(lres, D0Celsif(tknd, g0e1))
        case T_SRP_NONFIX():
            let tknd = tok
            buf.skip1()
            let dnts = p1_i0dntseq(buf, err)
            let lres = match dnts:
                case list_nil(_):
                    tknd.lctn()
                case list_cons(_):
                    let dnt1 = list_last(dnts)
                    tknd.lctn() + dnt1.lctn()
            err := e00
            d0ecl_make_node(lres, D0Cnonfix(tknd, dnts))
        case T_SRP_FIXITY(k0):
            let tknd = tok
            let loc0 = tok.lctn()
            buf.skip1()
            let dnts = p1_i0dntseq(buf, err)
            let tok1 = buf.getk0()
            let opt1 = match tok1.node():
                case T_OF0():
                    buf.skip1()
                    p1_precopt(buf, err)
                case _:
                    PRECnil0()
            let lopt = precopt_lctn(opt1)
            let lopt = match lopt:
                case optn_vt_cons(_):
                    lopt
                case ~optn_vt_nil():
                    match dnts:
                        case list_nil():
                            optn_vt_nil()
                        case list_cons(_):
                            let dnt1 = list_last(dnts)
                            optn_vt_cons(dnt1.lctn())
            let lres = match lopt:
                case ~optn_vt_nil():
                    loc0
                case ~optn_vt_cons(loc1):
                    loc0 + loc1
            err := e00
            d0ecl_make_node(lres, D0Cfixity(tknd, dnts, opt1))
        case _:
            err := e00 + 1
            d0ecl(tok.lctn(), D0Ctkerr(tok))

@impl
def fp_d0eclseq(f00, buf, err):
    let e00 = err
    def loop(buf: !tkbf0 >> _, err: &SInt >> _, res: list_vt[d0ecl]) -> list_vt[d0ecl]:
        let dcl = fp_d0ecl(f00, buf, err)
        if (err == e00):
            loop(buf, err, cons_vt(dcl, res))
        else:
            err := e00
            list_vt_reverse0(res)
    list_vt2t(loop(buf, err, list_vt_nil))

private:
    let xatsv_STA = 0
    let xatsv_DYN = 1

@impl
def p1_d0eclseq_sta(buf, err):
    fp_d0eclseq(xatsv_STA, buf, err)

@impl
def p1_d0eclseq_dyn(buf, err):
    fp_d0eclseq(xatsv_DYN, buf, err)


@impl
def fp_d0eclsq1(f00, buf, err):
    def loop(buf: !tkbf0 >> _, e00: SInt, err: &SInt >> _, res: list_vt[d0ecl]) -> list_vt[d0ecl]:
        let dcl = fp_d0ecl(f00, buf, err)
        let res = list_vt_cons(dcl, res)
        if (err == e00):
            loop(buf, e00, err, res)
        else:
            let tok = buf.getk0()
            match tok.node():
                case T_EOF():
                    err := e00
                    list_vt_reverse0(res)
                case _:
                    err := e00
                    buf.skip1()
                    let dcl = d0ecl(tok.lctn(), D0Ctkskp(tok))
                    loop(buf, e00, err, cons_vt(dcl, res))
    let e00 = err
    list_vt2t(loop(buf, e00, err, list_vt_nil))

private:
    let xatsv_STA = 0
    let xatsv_DYN = 1

