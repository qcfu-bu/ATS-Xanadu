@impl
def p1_q0arg(buf, err):
    let sid0 = p1_s0aid(buf, err)
    let tok0 = buf.getk0()
    let topt = match tok0.node():
        case T_CLN():
            buf.skip1()
            optn_cons(p1_sort0_app_NGT0(buf, err))
        case _:
            optn_nil
    let lid0 = sid0.lctn()
