def precopt_lctn(opt: precopt) -> optn_vt[loc_t]:
    match opt:
        case PRECnil0():
            optn_vt_nil()
        case PRECint1(tok):
            optn_vt_cons(tok.lctn())
        case PRECopr2(id0, pmd):
            match pmd:
                case PMODnone():
                    optn_vt_cons(id0.lctn())
                case PMODsome(tbeg, _, tend):
                    optn_vt_cons(id0.lctn() + tend.lctn())

@extern
def p1_i0dntseq() -> p1_fun[i0dntlst]

@extern
def p1_g0magseq() -> p1_fun[g0maglst]

@extern
def p1_precopt() -> p1_fun[precopt]

