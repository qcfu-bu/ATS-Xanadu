def d0pat_errck(lvl: SInt, d0p: d0pat) -> d0pat:
    d0pat(d0p.lctn(), D0Perrck(lvl, d0p))

def d0pat_errvl_a1(d0p: d0pat) -> SInt:
    match d0p.node():
        case D0Perrck(lvl, _):
            lvl
        case _:
            0

@overload d0pat_errvl = d0pat_errvl_a1

@overload errvl = d0pat_errvl_a1

def d0pat_errvl_a2(de1: d0pat, de2: d0pat) -> SInt:
    maxs(errvl(de1), errvl(de2))

@overload d0pat_errvl = d0pat_errvl_a2

@overload errvl = d0pat_errvl_a2

@extern
def d0pat_errvl_d0ps(d0ps: d0patlst) -> SInt

@overload d0pat_errvl = d0pat_errvl_d0ps

@overload errvl = d0pat_errvl_d0ps

@impl
def d0pat_errvl_d0ps(d0ps):
    match d0ps:
        case list_nil():
            0
        case list_cons(d0p1, d0ps):
            maxs(errvl(d0p1), errvl(d0ps))

