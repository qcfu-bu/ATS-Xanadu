@extern
def pread00_t0qua() -> fpread00[t0qua]

@extern
def pread00_t0qualst() -> fpread00[t0qualst]

@extern
def pread00_f0unarrw() -> fpread00[f0unarrw]

@impl
def pread00_d0pat(d0p, err):
    match d0p.node():
        case D0Pid0(_):
            d0p
        case D0Pint(_):
            d0p
        case D0Pchr(_):
            d0p
        case D0Pflt(_):
            d0p
        case D0Pstr(_):
            d0p
        case D0Paspt(_):
            f0_aspt(d0p, err)
        case D0Papps(_):
            f0_apps(d0p, err)
        case D0Psarg(_):
            f0_sarg(d0p, err)
        case D0Plpar(_):
            f0_lpar(d0p, err)
        case D0Ptup1(_):
            f0_tup1(d0p, err)
        case D0Prcd2(_):
            f0_rcd2(d0p, err)
        case D0Pannot(_):
            f0_annot(d0p, err)
        case D0Ptkerr(_):
            err := err + 1
            d0pat_errck(1, d0p)
        case _:
            err := err + 1
            d0pat_errck(1, d0p)
where:
    def f0_aspt(d0p: d0pat, err: &SInt >> _) -> d0pat:
        let e00 = err
        let D0Paspt(tas, dp1) = d0p.node()
        let dp1 = pread00_d0pat(dp1, err)
        if (err == e00):
            d0p
        else:
            let loc = d0p.lctn()
            d0pat_aspt_errck(loc, tas, dp1)
    def f0_apps(d0p: d0pat, err: &SInt >> _) -> d0pat:
        let e00 = err
        let D0Papps(dps) = d0p.node()
        let dps = pread00_d0patlst(dps, err)
        if (err == e00):
            d0p
        else:
            d0pat_apps_errck(d0p.lctn(), dps)
    def f0_sarg(d0p: d0pat, err: &SInt >> _) -> d0pat:
        let e00 = err
        let D0Psarg(tkb, sas, tke) = d0p.node()
        let sas = pread00_s0arglst(sas, err)
        match tke.node():
            case T_RBRACE():
                ()
            case _:
                err := err + 1
        if (err == e00):
            d0p
        else:
            d0pat_sarg_errck(d0p.lctn(), tkb, sas, tke)
    def f0_lpar(d0p: d0pat, err: &SInt >> _) -> d0pat:
        let e00 = err
        let D0Plpar(tkb, dps, drp) = d0p.node()
        let dps = pread00_d0patlst(dps, err)
        let drp = pread00_d0pat_RPAREN(drp, err)
        if (err == e00):
            d0p
        else:
            d0pat_lpar_errck(d0p.lctn(), tkb, dps, drp)
    def f0_tup1(d0p: d0pat, err: &SInt >> _) -> d0pat:
        let e00 = err
        let D0Ptup1(tbeg, topt, d0ps, tend) = d0p.node()
        let d0p2 = pread00_d0patlst(d0ps, err)
        let tend = pread00_d0pat_RPAREN(tend, err)
        if (err == e00):
            d0p
        else:
            d0pat_tup1_errck(d0p.lctn(), tbeg, topt, d0ps, tend)
    def f0_rcd2(d0p: d0pat, err: &SInt >> _) -> d0pat:
        let e00 = err
        let D0Prcd2(tbeg, topt, ldps, tend) = d0p.node()
        let ldps = pread00_l0d0plst(ldps, err)
        let tend = pread00_l0d0p_RBRACE(tend, err)
        if (err == e00):
            d0p
        else:
            d0pat_rcd2_errck(d0p.lctn(), tbeg, topt, ldps, tend)
    def f0_annot(d0p: d0pat, err: &SInt >> _) -> d0pat:
        let e00 = err
        let D0Pannot(d0p1, s0e2) = d0p.node()
        let d0p1 = pread00_d0pat(d0p1, err)
