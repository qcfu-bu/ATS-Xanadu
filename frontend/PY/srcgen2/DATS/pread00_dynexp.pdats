@extern
def d0exp_errvl_drp0(drp: d0exp_RPAREN) -> SInt

@overload errvl = d0exp_errvl_drp0

@impl
def d0exp_errvl_drp0(drp0):
    match drp0:
        case d0exp_RPAREN_cons0(tok):
            0
        case d0exp_RPAREN_cons1(tkb, des, tke):
            cons1_errvl(des)
        case d0exp_RPAREN_cons2(tkb, des, tke):
            cons2_errvl(des)
where:
    def cons1_errvl(d0es: d0explst) -> SInt:
        d0exp_errvl(d0es)
    def cons2_errvl(d0es: d0explst) -> SInt:
        d0exp_errvl(d0es)

