where:
    def auxlst(ds1: d0explst, err: &SInt >> _) -> d0explst:
        match ds1:
            case list_nil():
                list_nil()
            case list_cons(de1, ds2):
                let e00 = err
                let de1 = match ds2:
                    case list_nil():
                        match de1.node():
                            case D0Etkerr(_):
                                de1
                            case _:
                                pread00_d0exp(de1, err)
                    case list_cons(_):
                        pread00_d0exp(de1, err)
                let ds2 = auxlst(ds2, err)
                if (err == e00):
                    ds1
                else:
                    list_cons(de1, ds2)

