                case _:
                    err := err + 1
                    d0exp_RPAREN_cons1(tsep, d0es, tend)
        case d0exp_RPAREN_cons2(tsep, d0es, tend):
            let e00 = err
            def cons2_d0explst(xs: d0explst, err: &SInt >> _) -> d0explst:
                match xs:
                    case list_nil():
                        list_nil()
                    case list_cons(x1, xs):
                        cons2_d0explst_a2(x1, xs, err)

            def cons2_d0explst_a2(x1: d0exp, xs: d0explst, err: &SInt >> _) -> d0explst:
                match xs:
                    case list_nil():
                        match x1.node():
                            case D0Etkerr(_):
                                list_nil()
                            case _:
                                let d0e1 = pread00_d0exp(x1, err)
                                list_cons(d0e1, list_nil())
                    case list_cons(x2, xs):
                        let d0e1 = pread00_d0exp(x1, err)
                        list_cons(d0e1, cons2_d0explst_a2(x2, xs, err))
            let d0es = cons2_d0explst(d0es, err)
            match tend.node():
                case T_RPAREN():
                    if (err == e00):
                        drp0
                    else:
                        d0exp_RPAREN_cons2(tsep, d0es, tend)
                case _:
                    err := err + 1
                    d0exp_RPAREN_cons2(tsep, d0es, tend)

