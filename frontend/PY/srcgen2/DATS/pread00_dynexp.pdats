@impl
def pread00_d0exp_RPAREN(drp0, err):
    match drp0:
        case d0exp_RPAREN_cons0(tend):
            match tend.node():
                case T_RPAREN():
                    drp0
                case _:
                    err := err + 1
                    drp0
        case d0exp_RPAREN_cons1(tsep, d0es, tend):
            let e00 = err
            let d0es = pread00_d0explst(d0es, err)
            match tend.node():
                case T_RPAREN():
