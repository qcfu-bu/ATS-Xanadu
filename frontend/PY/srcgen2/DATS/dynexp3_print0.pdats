@impl
def d3pat_fprint(d3p0, out0):
    @impl[]
    def g_print/out():
        out0
    match d3p0.node():
        case D3Pany():
            prints("D3Pany(", ")")
        case D3Pvar(d2v):
            prints("D3Pvar(", d2v, ")")
        case D3Pint(tok):
            prints("D3Pint(", tok, ")")
        case D3Pbtf(sym):
            prints("D3Pbtf(", sym, ")")
        case D3Pchr(tok):
            prints("D3Pchr(", tok, ")")
        case D3Pflt(tok):
            prints("D3Pflt(", tok, ")")
        case D3Pstr(tok):
            prints("D3Pstr(", tok, ")")
        case D3Pcon(d2c):
            prints("D3Pcon(", d2c, ")")
        case D3Pbang(d3p1):
            prints("D3Pbang(", d3p1, ")")
        case D3Pflat(d3p1):
            prints("D3Pflat(", d3p1, ")")
        case D3Pfree(d3p1):
            prints("D3Pfree(", d3p1, ")")
        case D3Psapp(d3f0, s2vs):
            prints("D3Psapp(", d3f0, ";", s2vs, ")")
        case D3Psapq(d3f0, s2as):
            prints("D3Psapq(", d3f0, ";", s2as, ")")
        case D3Ptapq(d3p1, tjas):
            prints("D3Ptapq(", d3p1, ";", tjas, ")")
        case D3Pdap1(d3f0):
            prints("D3Pdap1(", d3f0, ")")
        case D3Pdapp(d3f0, npf1, d3ps):
            print("D3Pdapp(")
            prints(d3f0, ";", npf1, ";", d3ps, ")")
        case D3Prfpt(d3p1, tkas, d3p2):
            print("D3Prfpt(")
            prints(d3p1, ";", tkas, ";", d3p2, ")")
        case D3Ptup0(npf1, d3ps):
            prints("D3Ptup0(", npf1, ";", d3ps, ")")
        case D3Ptup1(tknd, npf1, d3ps):
            print("D3Ptup1(")
            prints(tknd, ";", npf1, ";", d3ps, ")")
        case D3Prcd2(tknd, npf1, ldps):
            print("D3Prcd2(")
            prints(tknd, ";", npf1, ";", ldps, ")")
        case D3Pargtp(d3p1, t2p2):
            prints("D3Pargtp(", d3p1, ";", t2p2, ")")
        case D3Pannot(d3p1, s1e2, s2e2):
            prints("D3Pannot(", d3p1, ";", s1e2, ";", s2e2, ")")
        case D3Pt2pck(d3p1, t2p2):
            prints("D3Pt2pck(", d3p1, ";", t2p2, ")")
        case D3Pnone0():
            prints("D3Pnone0(", ")")
        case D3Pnone1(d2p1):
            prints("D3Pnone1(", d2p1, ")")
        case D3Pnone2(d3p1):
            prints("D3Pnone2(", d3p1, ")")
        case D3Perrck(lvl1, d3p2):
            if (lvl1 >= 2):
                prints("D3Perrck(", lvl1, ";", d3p2, ")")
            else:
                let loc0 = d3p0.lctn()
                prints("D3Perrck(", loc0, ";", lvl1, ";", d3p2, ")")

@impl
def d3exp_fprint(d3e0, out0):
    @impl[]
    def g_print/out():
        out0
    match d3e0.node():
        case D3Eint(tok):
            prints("D3Eint(", tok, ")")
        case D3Ebtf(sym):
            prints("D3Ebtf(", sym, ")")
        case D3Echr(tok):
            prints("D3Echr(", tok, ")")
        case D3Eflt(tok):
            prints("D3Eflt(", tok, ")")
        case D3Estr(tok):
            prints("D3Estr(", tok, ")")
        case D3Ei00(int):
            prints("D3Ei00(", int, ")")
        case D3Eb00(btf):
            prints("D3Eb00(", btf, ")")
        case D3Ec00(chr):
            prints("D3Ec00(", chr, ")")
        case D3Ef00(flt):
            prints("D3Ef00(", flt, ")")
        case D3Es00(str):
            prints("D3Es00(", str, ")")
        case D3Etop(sym):
            prints("D3Etop(", sym, ")")
        case D3Evar(d2v):
            prints("D3Evar(", d2v, ")")
        case D3Econ(d2c):
            prints("D3Econ(", d2c, ")")
        case D3Ecst(d2c):
            prints("D3Ecst(", d2c, ")")
        case D3Etimp(d2e1, timp):
            prints("D3Etimp(", d2e1, ";", timp, ")")
        case D3Etimq(d2e1, timp, tmps):
            print("D3Etimq(")
            prints(d2e1, ";", timp, ";", tmps, ")")
        case D3Esapp(d3e1, s2es):
            prints("D3Esapp(", d3e1, ";", s2es, ")")
        case D3Esapq(d3e1, t2ps):
            prints("D3Esapq(", d3e1, ";", t2ps, ")")
        case D3Etapp(d3e1, s2es):
            prints("D3Etapp(", d3e1, ";", s2es, ")")
        case D3Etapq(d3e1, tjas):
            prints("D3Etapq(", d3e1, ";", tjas, ")")
        case D3Edap0(d3f0):
            prints("D3Edap0(", d3f0, ")")
        case D3Edapp(d3f0, npf1, d3es):
            print("D3Edapp(")
            prints(d3f0, ";", npf1, ";", d3es, ")")
        case D3Epcon(tknd, dlab, dtup):
            print("D3Epcon(")
            prints(tknd, ";", dlab, ";", dtup, ")")
        case D3Eproj(tknd, dlab, dtup):
            print("D3Eproj(")
            prints(tknd, ";", dlab, ";", dtup, ")")
        case D3Elet0(dcls, d3e1):
            prints("D3Elet0(", dcls, ";", d3e1, ")")
        case D3Eift0(d3e1, dthn, dels):
            print("D3Eift0(")
            prints(d3e1, ";", dthn, ";", dels, ")")
        case D3Ecas0(tknd, d3e1, dcls):
            print("D3Ecas0(")
            prints(tknd, ";", d3e1, ";", dcls, ")")
        case D3Eseqn(d3es, d3e1):
            prints("D3Eseqn(", d3es, ";", d3e1, ")")
        case D3Etup0(npf1, d3es):
            prints("D3Etup0(", npf1, ";", d3es, ")")
        case D3Etup1(tknd, npf1, d3es):
            print("D3Etup1(")
            prints(tknd, ";", npf1, ";", d3es, ")")
        case D3Ercd2(tknd, npf1, ldes):
            print("D3Ercd2(")
            prints(tknd, ";", npf1, ";", ldes, ")")
        case D3Elam0(tknd, f3as, sres, arrw, body):
            prints("D3Elam0(", tknd, ";")
            prints(f3as, ";", sres, ";", arrw, ";", body, ")")
        case D3Efix0(tknd, dpid, f3as, sres, arrw, body):
            prints("D3Efix0(", tknd, ";", dpid, ";")
            prints(f3as, ";", sres, ";", arrw, ";", body, ")")
        case D3Etry0(tknd, d3e1, dcls):
            print("D3Etry0(")
            prints(tknd, ";", d3e1, ";", dcls, ")")
        case D3Eaddr(d3e1):
            prints("D3Eaddr(", d3e1, ")")
        case D3Eview(d3e1):
            prints("D3Eview(", d3e1, ")")
        case D3Elval(d3e1):
            prints("D3Elval(", d3e1, ")")
        case D3Eflat(d3e1):
            prints("D3Eflat(", d3e1, ")")
        case D3Eeval(d3e1):
            prints("D3Eeval(", d3e1, ")")
        case D3Efold(d3e1):
            prints("D3Efold(", d3e1, ")")
        case D3Efree(d3e1):
            prints("D3Efree(", d3e1, ")")
        case D3Edp2tr(d3e1):
            prints("D3Edp2tr(", d3e1, ")")
        case D3Edl0az(d3e1):
            prints("D3Edl0az(", d3e1, ")")
        case D3Edl1az(d3e1):
            prints("D3Edl1az(", d3e1, ")")
        case D3Edelaz(d3e1):
            prints("D3Edelaz(", d3e1, ")")
        case D3Ewhere(d3e1, dcls):
            prints("D3Ewhere(", d3e1, ";", dcls, ")")
        case D3Eassgn(d3el, d3er):
            prints("D3Eassgn(", d3el, ";", d3er, ")")
        case D3Exazgn(d3el, d3er):
            prints("D3Exazgn(", d3el, ";", d3er, ")")
        case D3Exchng(d3el, d3er):
            prints("D3Exchng(", d3el, ";", d3er, ")")
        case D3Eraise(tknd, d3e1):
            prints("D3Eraise(", tknd, ";", d3e1, ")")
        case D3El0azy(dsym, d3e1):
            prints("D3El0azy(", dsym, ";", d3e1, ")")
        case D3El1azy(dsym, d3e1, d3es):
            print("D3El1azy(")
            prints(dsym, ";", d3e1, ";", d3es, ")")
        case D3Eelazy(dsym, d3e1, d3es):
            print("D3Eelazy(")
            prints(dsym, ";", d3e1, ";", d3es, ")")
        case D3Eannot(d3e1, s1e2, s2e2):
            print("D3Eannot(")
            prints(d3e1, ";", s1e2, ";", s2e2, ")")
        case D3Elabck(d3e1, lab2):
            let t2p1 = d3e1.styp()
            print("D3Elabck(")
            prints(d3e1, "(", t2p1, ");", lab2, ")")
        case D3Et2pck(d3e1, t2p2):
            let t2p1 = d3e1.styp()
            print("D3Et2pck(")
            prints(d3e1, "(", t2p1, ");", t2p2, ")")
        case D3Et2ped(d3e1, t2p2):
            let t2p1 = d3e1.styp()
            print("D3Et2ped(")
            prints(d3e1, "(", t2p1, ");", t2p2, ")")
        case D3Eexists(s2es, d3e1):
            prints("D3Eexists(", s2es, ";", d3e1, ")")
        case D3Eextnam(tknd, gnam):
            prints("D3Eextnam(", tknd, ";", gnam, ")")
        case D3Esynext(tknd, gexp):
            prints("D3Esynext(", tknd, ";", gexp, ")")
        case D3Enone0():
            prints("D3Enone0(", ")")
        case D3Enone1(d2e1):
            prints("D3Enone1(", d2e1, ")")
        case D3Enone2(d3e1):
            prints("D3Enone2(", d3e1, ")")
        case D3Eerrck(lvl1, d3e2):
            if (lvl1 >= 2):
                prints("D3Eerrck(", lvl1, ";", d3e2, ")")
            else:
                let loc0 = d3e0.lctn()
                prints("D3Eerrck(", loc0, ";", lvl1, ";", d3e2, ")")

