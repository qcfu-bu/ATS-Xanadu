        case TIMPLallx(d2c1, t2js, dcls):
            prints("TIMPLallx(", d2c1, ";", t2js, ";", "...", ")")

@impl
def d3ecl_fprint(dcl0, out0):
    @impl[]
    def g_print/out():
        out0
    match dcl0.node():
        case D3Cd2ecl(d2cl):
            prints("D3Cd2ecl(", d2cl, ")")
        case D3Cstatic(tknd, dcl1):
            prints("D3Cstatic(", tknd, ";", dcl1, ")")
        case D3Cextern(tknd, dcl1):
            prints("D3Cextern(", tknd, ";", dcl1, ")")
        case D3Ctmpsub(svts, dcl1):
            prints("D3Ctmpsub(", svts, ";", dcl1, ")")
        case D3Cdclst0(dcls):
            prints("D3Cdclst0(", dcls, ")")
        case D3Clocal0(head, body):
            prints("D3Clocal0(", head, ";", body, ")")
        case D3Cabsopen(tknd, simp):
            prints("D3Cabsopen(", tknd, ";", simp, ")")
        case D3Cabsimpl(tknd, simp, sdef):
            print("D3Cabsimpl(")
            prints(tknd, ";", simp, ";", sdef, ")")
        case D3Cinclude(knd0, tknd, gsrc, fopt, dopt):
            print("D3Cinclude(")
            prints(knd0, ";", tknd, ";", gsrc, ";", fopt, ";", "...", ")")
        case D3Cstaload(knd0, tknd, gsrc, fopt, dopt):
            print("D3Cstaload(")
            prints(knd0, ";", tknd, ";", gsrc, ";", fopt, ";", "...", ")")
        case D3Cdyninit(tknd, g1e1):
            prints("D3Cdyninit(", tknd, ";", g1e1, ")")
        case D3Cextcode(tknd, g1e1):
            prints("D3Cextcode(", tknd, ";", g1e1, ")")
        case D3Cvaldclst(tknd, d3vs):
            prints("D3Cvaldclst(", tknd, ";", d3vs, ")")
        case D3Cvardclst(tknd, d3vs):
            prints("D3Cvardclst(", tknd, ";", d3vs, ")")
        case D3Cfundclst(tknd, tqas, d2cs, d3fs):
            print("D3Cfundclst(")
            prints(tknd, ";", tqas, ";", d2cs, ";", d3fs, ")")
        case D3Cimplmnt0(tknd, stmp, sqas, tqas, dqid, tias, farg, sres, body):
            print("D3Cimplmnt0(")
            prints(tknd, ";", stmp, ";")
            prints(sqas, ";", tqas, ";")
            prints(dqid, ";", tias, ";", farg, ";", sres, ";", body, ")")
        case D3Ctmplocal(dtmp, dcls):
            prints("D3Ctmplocal(", dtmp, ";", dcls, ")")
        case D3Cimpltmpr(dcl1, t2js):
            prints("D3Cimpltmpr(", dcl1, ";", t2js, ")")
        case D3Cnone0():
            prints("D3Cnone0(", ")")
        case D3Cnone1(d2cl):
            prints("D3Cnone1(", d2cl, ")")
        case D3Cnone2(d3cl):
            prints("D3Cnone2(", d3cl, ")")
        case D3Cerrck(lvl1, d3cl):
            if (lvl1 >= 2):
                prints("D3Cerrck(", lvl1, ";", d3cl, ")")
            else:
                let loc0 = dcl0.lctn()
                prints("D3Cerrck(", loc0, ";", lvl1, ";", d3cl, ")")

