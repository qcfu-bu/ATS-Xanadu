        let d2e1 = trans2a_d2exp(env0, d2e1)
        let targ = d2e1.styp()
        let tres = s2typ_new0_x2tp(loc0)
        let dcls = trans2a_d2clslst_tpck1(env0, dcls, targ, tres)
        d2exp_make_tpnd(loc0, tres, D2Ecas0(tknd, d2e1, dcls))
    def f0_seqn(env0: !tr2aenv, d2e0: d2exp) -> d2exp:
        d2exp_make_tpnd(loc0, d2e1.styp(), D2Eseqn(d2es, d2e1))
    where:
        let loc0 = d2e0.lctn()
        let D2Eseqn(d2es, d2e1) = d2e0.node()
        let d2es = trans2a_d2explst_tpck1(env0, d2es, the_s2typ_void())
        let d2e1 = trans2a_d2exp(env0, d2e1)
    def f0_tup0(env0: !tr2aenv, d2e0: d2exp) -> d2exp:
        d2exp_make_tpnd(loc0, t2p0, D2Etup0(npf1, d2es))
    where:
        let loc0 = d2e0.lctn()
        let D2Etup0(npf1, d2es) = d2e0.node()
        let d2es = trans2a_d2explst(env0, d2es)
        let t2p0 = match d2es:
            case list_nil():
                the_s2typ_void()
            case list_cons(_):
                s2typ_tup0(npf1, s2typlst(d2es))
    def f0_tup1(env0: !tr2aenv, d2e0: d2exp) -> d2exp:
        d2exp_make_tpnd(loc0, t2p0, D2Etup1(tknd, npf1, d2es))
    where:
        let loc0 = d2e0.lctn()
        let D2Etup1(tknd, npf1, d2es) = d2e0.node()
        let d2es = trans2a_d2explst(env0, d2es)
        let t2ps = s2typlst(d2es)
        let linq = s2typlst_linq(t2ps)
        let trcd = match tknd.node():
            case T_TRCD10(0):
                TRCDflt0
            case T_TRCD10(1):
                TRCDbox1
            case T_TRCD10(2):
                if linq:
                    TRCDbox1
                else:
                    TRCDbox0
            case T_TRCD10(3):
                TRCDbox0
            case T_TRCD10(4):
                TRCDbox1
            case T_TRCD10(5):
                TRCDbox2
        let t2p0 = s2typ_tup1(trcd, npf1, t2ps)
    def f0_rcd2(env0: !tr2aenv, d2e0: d2exp) -> d2exp:
        d2exp_make_tpnd(loc0, t2p0, D2Ercd2(tknd, npf1, ldes))
