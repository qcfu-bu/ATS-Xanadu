    def d2pat_lftize(d2p0: d2pat) -> Void:
        match d2p0.node():
            case D2Pannot(d2p1, s1e1, s2e2):
                match d2p1.node():
                    case D2Pvar(d2v1):
                        if s2exp_cbrfq(s2e2):
                            d2var_lftize(d2v1)
                        else:
                            ()
                    case _:
                        ()
            case _:
                ()
    def d2patlst_lftize(d2ps: d2patlst) -> Void:
        list_foritm(d2ps)
    where:
        @impl[d2pat]
        def foritm/work:
            d2pat_lftize

