        case D2Edap0(_):
            f0_dap0(env0, d2e0)
        case D2Edapp(_):
            f0_dapp(env0, d2e0)
        case D2Eproj(_):
            f0_proj(env0, d2e0)
        case D2Elet0(_):
            f0_let0(env0, d2e0)
        case D2Eift0(_):
            f0_ift0(env0, d2e0)
        case D2Ecas0(_):
            f0_cas0(env0, d2e0)
        case D2Eseqn(_):
            f0_seqn(env0, d2e0)
        case D2Etup0(_):
            f0_tup0(env0, d2e0)
        case D2Etup1(_):
            f0_tup1(env0, d2e0)
        case D2Ercd2(_):
            f0_rcd2(env0, d2e0)
        case D2Elam0(_):
            f0_lam0(env0, d2e0)
        case D2Efix0(_):
            f0_fix0(env0, d2e0)
        case D2Etry0(_):
            f0_try0(env0, d2e0)
        case D2Eaddr(_):
            f0_addr(env0, d2e0)
        case D2Eview(_):
            f0_view(env0, d2e0)
        case D2Eeval(_):
            f0_eval(env0, d2e0)
        case D2Efold(_):
            f0_fold(env0, d2e0)
        case D2Efree(_):
            f0_free(env0, d2e0)
        case D2Ewhere(_):
            f0_where(env0, d2e0)
        case D2Eassgn(_):
            f0_assgn(env0, d2e0)
        case D2Exazgn(_):
            f0_xazgn(env0, d2e0)
        case D2Exchng(_):
            f0_xchng(env0, d2e0)
        case D2Ebrget(_):
            f0_brget(env0, d2e0)
        case D2Ebrset(_):
            f0_brset(env0, d2e0)
        case D2Edtsel(_):
            f0_dtsel(env0, d2e0)
        case D2Eraise(_):
