    def f0_sapp(env0: !tr2aenv, d2e0: d2exp) -> d2exp:
        let D2Esapp(d2f0, s2es) = d2e0.node()
        let d2f0 = trans2a_d2exp(env0, d2f0)
        let tfun = d2f0.styp()
        let tfun = s2typ_hnfiz0(tfun)
        let tres = match tfun.node():
            case T2Puni0(s2vs, t2p1):
                let svts = f1_svts(s2vs, s2es, list_nil)
                s2typ_subst0(t2p1, svts)
            case _:
                tfun
        d2exp_make_tpnd(loc0, tres, D2Esapp(d2f0, s2es))
    where:
        let loc0 = d2e0.lctn()
        def f1_svts(s2vs: s2varlst, s2es: s2explst, svts: s2vts) -> s2vts:
            match s2vs:
                case list_nil():
                    svts
                case list_cons(s2v1, s2vs):
                    f1_svts_cons(s2v1, s2vs, s2es, svts)

        def f1_svts_cons(s2v1: s2var, s2vs: s2varlst, s2es: s2explst, svts: s2vts) -> s2vts:
            match s2es:
                case list_nil():
                    let t2p1 = s2typ_new0_x2tp(loc0)
                    let svts = list_cons((s2v1, t2p1), svts)
                    f1_svts(s2vs, s2es, svts)
                case list_cons(s2e1, s2es):
                    if (sort2_imprq(s2e1.sort())):
                        let t2p1 = s2exp_stpize(s2e1)
                        let svts = list_cons((s2v1, t2p1), svts)
                        f1_svts(s2vs, s2es, svts)
                    else:
                        f1_svts_cons(s2v1, s2vs, s2es, svts)
    private:
        def f1_root(d2f0: d2exp) -> d2exp:
            match d2f0.node():
                case D2Etapp(d2f0, _):
                    f1_root(d2f0)
                case _:
                    d2f0
        def f1_make(d2e0: d2exp, d2f0: d2exp) -> d2exp:
            match d2e0.node():
                case D2Etapp(d2e1, s2es):
                    let d2e1 = f1_make(d2e1, d2f0)
                    d2exp_make_tpnd(d2e1.lctn(), d2e1.styp(), D2Etapp(d2e1, s2es))
                case _:
                    d2f0
        def f1_type(d2e0: d2exp) -> s2typ:
            let d2f0 = f1_root(d2e0)
            match d2f0.node():
                case D2Econ(d2c0):
                    let tqas = d2c0.tqas()
                    let tfun = d2c0.styp()
                    f1_tqas_tfun(d2e0, tqas, tfun)
                case D2Ecst(d2c0):
                    let tqas = d2c0.tqas()
                    let tfun = d2c0.styp()
                    f1_tqas_tfun(d2e0, tqas, tfun)
                case _:
                    s2typ_none0()

        def f1_tqas(d2e0: d2exp, tqas: t2qas) -> s2vts:
            let loc0 = d2e0.lctn()
            let svts = list_nil
            let (tqas, svts) = f2_main(d2e0, tqas, svts)
            f2_tqas(loc0, tqas, svts)
        where:
            def f2_main(d2e0: d2exp, tqas: t2qas, svts: s2vts) -> (t2qas, s2vts):
                match tqas:
                    case list_nil():
                        (tqas, svts)
                    case list_cons(_):
                        match d2e0.node():
                            case D2Etapp(d2e1, s2es):
                                let (tqas, svts) = f2_main(d2e1, tqas, svts)
                                match tqas:
                                    case list_nil():
                                        (tqas, svts)
                                    case list_cons(tqa1, tqas):
                                        let loc0 = d2e0.lctn()
                                        let s2vs = tqa1.s2vs()
                                        let svts = f2_s2vs_s2es(loc0, s2vs, s2es, svts)
                                        (tqas, svts)
                            case _:
                                (tqas, svts)

            def f2_tqas(loc0: loc_t, tqas: t2qas, svts: s2vts) -> s2vts:
                match tqas:
                    case list_nil():
                        svts
                    case list_cons(tqa1, tqas):
                        let s2vs = tqa1.s2vs()
                        let svts = f2_s2vs(loc0, s2vs, svts)
                        f2_tqas(loc0, tqas, svts)

            def f2_s2vs(loc0: loc_t, s2vs: s2varlst, svts: s2vts) -> s2vts:
                match s2vs:
                    case list_nil():
                        svts
                    case list_cons(s2v1, s2vs):
                        let t2p1 = s2typ_new0_x2tp(loc0)
                        let svts = list_cons((s2v1, t2p1), svts)
                        f2_s2vs(loc0, s2vs, svts)

            def f2_s2vs_s2es(loc0: loc_t, s2vs: s2varlst, s2es: s2explst, svts: s2vts) -> s2vts:
                match s2vs:
                    case list_nil():
                        svts
                    case list_cons(s2v1, s2vs):
                        match s2es:
                            case list_nil():
                                let t2p1 = s2typ_new0_x2tp(loc0)
                                let svts = list_cons((s2v1, t2p1), svts)
                                f2_s2vs_s2es(loc0, s2vs, s2es, svts)
                            case list_cons(s2e1, ses2):
                                let t2p1 = match s2e1.node():
                                    case S2Eany(_):
                                        s2typ_new0_x2tp(loc0)
                                    case _:
                                        s2exp_stpize(s2e1)
                                let svts = list_cons((s2v1, t2p1), svts)
                                let s2es = match s2e1.node():
                                    case S2Eany(k0):
                                        if k0 <= 1:
                                            s2es
                                        else:
                                            ses2
                                    case _:
                                        ses2
                                f2_s2vs_s2es(loc0, s2vs, s2es, svts)

        def f1_tqas_tfun(d2e0: d2exp, tqas: t2qas, tfun: s2typ) -> s2typ:
            let svts = f1_tqas(d2e0, tqas)
            s2typ_subst0(tfun, svts)

    def f0_tapp(env0: !tr2aenv, d2e0: d2exp) -> d2exp:
        let loc0 = d2e0.lctn()
        let D2Etapp(d2f0, s2es) = d2e0.node()
        let t2p0 = f1_type(d2e0)
        let d2f0 = f1_root(d2f0)
        let d2f0 = trans2a_d2exp(env0, d2f0)
        let ubtf = match t2p0.node():
            case T2Pnone0():
                false
            case _:
                unify2a_s2typ(env0, t2p0, d2f0.styp())
        f1_make(d2e0, d2f0)
    def f0_dap0(env0: !tr2aenv, d2e0: d2exp) -> d2exp:
        let loc0 = d2e0.lctn()
        let D2Edap0(d2f0) = d2e0.node()
        let npf1 = -(1)
        let tres = s2typ_new0_x2tp(loc0)
        let f2cl = s2typ_new0_x2tp(loc0)
        let t2ps = list_nil()
        let tfun = s2typ_make_node(sort2_none0(), T2Pfun1(f2cl, npf1, t2ps, tres))
        let d2f0 = trans2a_d2exp_tpck(env0, d2f0, tfun)
        d2exp(loc0, tres, D2Edap0(d2f0))
    def f0_dapp(env0: !tr2aenv, d2e0: d2exp) -> d2exp:
        let loc0 = d2e0.lctn()
        let D2Edapp(d2f0, npf1, d2es) = d2e0.node()
        match d2f0.node():
            case D2Edtsel(_):
                f0_dapp_dtsel(env0, d2e0)
            case _:
                f0_dapp_elses(env0, d2e0)

    def f0_dapp_dtsel(env0: !tr2aenv, d2e0: d2exp) -> d2exp:
        let loc0 = d2e0.lctn()
        let D2Edapp(d2f0, npf1, d2es) = d2e0.node()
        let lsym = d2f0.lctn()
        let D2Edtsel(tknd, lab1, dpis, npf1, darg) = d2f0.node()
        let sym1 = match lab1:
            case LABint(int):
                the_symbl_nil
            case LABsym(sym):
                sym
        let d1e1 = d1exp(lsym, D1Eid0(sym1))
        let drxp = d2rxp_new1(lsym)
        let dsym = d2exp_make_node(lsym, D2Esym0(drxp, d1e1, dpis))
        let d2e1 = match d2es:
            case list_cons(d2e1, _):
                d2e1
        let darg = match darg:
            case optn_nil():
                list_sing(d2e1)
            case optn_cons(d2es):
                list_cons(d2e1, d2es)
        f0_dapp_elses(env0, d2exp(loc0, D2Edapp(dsym, npf1, darg)))

    def f0_dapp_elses(env0: !tr2aenv, d2e0: d2exp) -> d2exp:
        let loc0 = d2e0.lctn()
        let D2Edapp(d2f0, npf1, d2es) = d2e0.node()
        let d2f0 = trans2a_d2exp(env0, d2f0)
        let tfun = d2f0.styp()
        let tfun = s2typ_hnfiz0(tfun)
        let tfun = deuni2a_s2typ(env0, tfun)
        match tfun.node():
            case T2Pfun1(_, _, t2ps, tres):
                let d2es = trans2a_d2explst_tpcks(env0, d2es, t2ps)
                d2exp_make_tpnd(loc0, tres, D2Edapp(d2f0, npf1, d2es))
            case _:
                let f2cl = s2typ_new0_x2tp(loc0)
                let tres = s2typ_new0_x2tp(loc0)
                let d2es = trans2a_d2explst(env0, d2es)
                let s2tf = the_sort2_tbox
                let t2ps = s2typlst_of_d2explst(d2es)
                let tfun = s2typ_make_node(s2tf, T2Pfun1(f2cl, npf1, t2ps, tres))
                let d2f0 = d2exp_t2pckify(env0, d2f0, tfun)
                d2exp_make_tpnd(loc0, tres, D2Edapp(d2f0, npf1, d2es))
    def f0_proj(env0: !tr2aenv, d2e0: d2exp) -> d2exp:
        let loc0 = d2e0.lctn()
        let D2Eproj(tknd, drxp, dlab, dtup) = d2e0.node()
        let dtup = trans2a_d2exp(env0, dtup)
        let ttup = s2typ_hnfiz0(dtup.styp())
        let topt = s2typ_prjout/opt(ttup, dlab)
        let dtup = match topt:
            case optn_vt_nil():
                d2exp_make_tpnd(loc0, ttup, D2Elabck(dtup, dlab))
            case optn_vt_cons(tprj):
                dtup
        let tprj = match topt:
            case ~optn_vt_nil():
                s2typ_new0_x2tp(loc0)
            case ~optn_vt_cons(tprj):
                tprj
        d2exp_make_tpnd(loc0, tprj, D2Eproj(tknd, drxp, dlab, dtup))
    def f0_let0(env0: !tr2aenv, d2e0: d2exp) -> d2exp:
        let loc0 = d2e0.lctn()
