    def f0_ift0(env0: !tr2aenv, d2e0: d2exp) -> d2exp:
        let loc0 = d2e0.lctn()
        let D2Eift0(d2e1, dthn, dels) = d2e0.node()
        let t2p1 = the_s2typ_bool()
        let d2e1 = trans2a_d2exp_tpck(env0, d2e1, t2p1)
        let t2p0 = match dels:
            case optn_nil():
                the_s2typ_void()
            case optn_cons(_):
                match dthn:
                    case optn_nil():
                        the_s2typ_void()
                    case optn_cons(_):
                        s2typ_new0_x2tp(loc0)
        let dthn = match dthn:
            case optn_nil():
                optn_nil()
            case optn_cons(d2e2):
                optn_cons(trans2a_d2exp_tpck(env0, d2e2, t2p0))
        let dels = match dels:
            case optn_nil():
                optn_nil()
            case optn_cons(d2e3):
                optn_cons(trans2a_d2exp_tpck(env0, d2e3, t2p0))
        d2exp_make_tpnd(loc0, t2p0, D2Eift0(d2e1, dthn, dels))
    def f0_cas0(env0: !tr2aenv, d2e0: d2exp) -> d2exp:
        let loc0 = d2e0.lctn()
