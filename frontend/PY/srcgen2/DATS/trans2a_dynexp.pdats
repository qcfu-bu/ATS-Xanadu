def s2typ_new0_x2tp(loc0: loc_t) -> s2typ:
    s2typ_xtv(x2t2p_make_lctn(loc0))

def s2typ_subst0(t2p0: s2typ, svts: s2vts) -> s2typ:
    match svts:
        case list_nil():
            t2p0
        case list_cons(_):
            s2typ_subst0(t2p0, svts)

def s2typ_bang(t2p0: s2typ) -> s2typ:
    match t2p0.node():
        case T2Plft(t2p1):
            t2p1
        case _:
            s2typ_lft(t2p0)

def d2pat_exbang(d2p0: d2pat) -> Void:
    match d2p0.node():
        case D2Pvar(d2v1):
            let t2p1 = d2v1.styp()
            d2v1.styp(s2typ_bang(t2p1))
        case _:
            ()

def d2patlst_exbang(d2ps: d2patlst) -> Void:
    match d2ps:
        case list_nil():
            ()
        case list_cons(d2p1, d2ps):
            d2pat_exbang(d2p1)
            d2patlst_exbang(d2ps)

def d2pat_make_tpnd(loc0: loc_t, t2p0: s2typ, node: d2pat_node) -> d2pat:
    let d2p0 = d2pat(loc0, node)
    d2p0.styp(t2p0)
    d2p0

def d2exp_make_tpnd(loc0: loc_t, t2p0: s2typ, node: d2exp_node) -> d2exp:
    let d2e0 = d2exp(loc0, node)
    d2e0.styp(t2p0)
    d2e0

@overload d2pat = d2pat_make_tpnd

@overload d2exp = d2exp_make_tpnd

def d2pat_t2pckify(env0: !tr2aenv, d2p0: d2pat, t2p0: s2typ) -> d2pat:
    let t2p1 = d2p0.styp()
    let ubtf = unify2a_s2typ(env0, t2p1, t2p0)
    if ubtf:
        d2p0
    else:
        let loc0 = d2p0.lctn()
        d2pat(loc0, t2p0, D2Pt2pck(d2p0, t2p0))

def d2pat_t2pkcify(env0: !tr2aenv, d2p0: d2pat, t2p0: s2typ) -> d2pat:
    let t2p1 = d2p0.styp()
    let ubtf = unify2a_s2typ(env0, t2p0, t2p1)
    if ubtf:
        d2p0
    else:
        let loc0 = d2p0.lctn()
        d2pat(loc0, t2p0, D2Pt2pkc(d2p0, t2p0))

def d2exp_t2pckify(env0: !tr2aenv, d2e0: d2exp, t2p0: s2typ) -> d2exp:
    let t2p1 = d2e0.styp()
    let ubtf = unify2a_s2typ(env0, t2p1, t2p0)
    if ubtf:
        d2e0
    else:
        let loc0 = d2e0.lctn()
        d2exp(loc0, t2p0, D2Et2pck(d2e0, t2p0))

@impl
def trans2a_d2pat(env0, d2p0):
    match d2p0.node():
        case D2Pany(_):
            f0_any(env0, d2p0)
        case D2Pvar(_):
            f0_var(env0, d2p0)
        case D2Pint(_):
            f0_int(env0, d2p0)
        case D2Pi00(_):
            f0_i00(env0, d2p0)
        case D2Pbtf(_):
            f0_btf(env0, d2p0)
        case D2Pb00(_):
            f0_b00(env0, d2p0)
        case D2Pchr(_):
            f0_chr(env0, d2p0)
        case D2Pc00(_):
            f0_c00(env0, d2p0)
        case D2Pstr(_):
            f0_str(env0, d2p0)
        case D2Ps00(_):
            f0_s00(env0, d2p0)
        case D2Pcon(_):
            f0_con(env0, d2p0)
        case D2Pbang(_):
            f0_bang(env0, d2p0)
        case D2Pflat(_):
            f0_flat(env0, d2p0)
        case D2Pfree(_):
            f0_free(env0, d2p0)
        case D2Pcons(_):
            f0_cons(env0, d2p0)
        case D2Psapp(_):
            f0_sapp(env0, d2p0)
        case D2Pdap0(_):
            f0_dap0(env0, d2p0)
        case D2Pdap1(_):
            f0_dap1(env0, d2p0)
        case D2Pdapp(_):
            f0_dapp(env0, d2p0)
        case D2Prfpt(_):
            f0_rfpt(env0, d2p0)
        case D2Ptup0(_):
            f0_tup0(env0, d2p0)
        case D2Ptup1(_):
            f0_tup1(env0, d2p0)
        case D2Prcd2(_):
            f0_rcd2(env0, d2p0)
        case D2Pannot(_):
            f0_annot(env0, d2p0)
        case D2Perrck(_):
            f0_errck(env0, d2p0)
        case _:
            d2pat_none2(d2p0)
where:
    def f0_int(env0: !tr2aenv, d2p0: d2pat) -> d2pat:
        d2pat_make_tpnd(loc0, t2p0, D2Pint(tok))
    where:
        let loc0 = d2p0.lctn()
        let D2Pint(tok) = d2p0.node()
        let t2p0 = the_s2typ_sint()
    def f0_i00(env0: !tr2aenv, d2p0: d2pat) -> d2pat:
        d2pat_make_tpnd(loc0, t2p0, D2Pi00(int))
    where:
        let loc0 = d2p0.lctn()
        let D2Pi00(int) = d2p0.node()
        let t2p0 = the_s2typ_sint()
    def f0_btf(env0: !tr2aenv, d2p0: d2pat) -> d2pat:
        d2pat_make_tpnd(loc0, t2p0, D2Pbtf(sym))
    where:
        let loc0 = d2p0.lctn()
        let D2Pbtf(sym) = d2p0.node()
        let t2p0 = the_s2typ_bool()
    def f0_b00(env0: !tr2aenv, d2p0: d2pat) -> d2pat:
        d2pat_make_tpnd(loc0, t2p0, D2Pb00(btf))
    where:
        let loc0 = d2p0.lctn()
        let D2Pb00(btf) = d2p0.node()
        let t2p0 = the_s2typ_bool()
    def f0_chr(env0: !tr2aenv, d2p0: d2pat) -> d2pat:
        d2pat_make_tpnd(loc0, t2p0, D2Pchr(tok))
    where:
        let loc0 = d2p0.lctn()
        let D2Pchr(tok) = d2p0.node()
        let t2p0 = the_s2typ_char()
    def f0_c00(env0: !tr2aenv, d2p0: d2pat) -> d2pat:
        d2pat_make_tpnd(loc0, t2p0, D2Pc00(chr))
    where:
        let loc0 = d2p0.lctn()
        let D2Pc00(chr) = d2p0.node()
        let t2p0 = the_s2typ_char()
    def f0_str(env0: !tr2aenv, d2p0: d2pat) -> d2pat:
        d2pat_make_tpnd(loc0, t2p0, D2Pstr(tok))
    where:
        let loc0 = d2p0.lctn()
        let D2Pstr(tok) = d2p0.node()
        let t2p0 = the_s2typ_strn()
    def f0_s00(env0: !tr2aenv, d2p0: d2pat) -> d2pat:
        d2pat_make_tpnd(loc0, t2p0, D2Ps00(str))
    where:
        let loc0 = d2p0.lctn()
        let D2Ps00(str) = d2p0.node()
        let t2p0 = the_s2typ_strn()
    def f0_any(env0: !tr2aenv, d2p0: d2pat) -> d2pat:
        d2pat_make_tpnd(loc0, t2p0, D2Pany())
    where:
        let loc0 = d2p0.lctn()
        let D2Pany() = d2p0.node()
        let t2p0 = s2typ_new0_x2tp(loc0)
    def f0_var(env0: !tr2aenv, d2p0: d2pat) -> d2pat:
        d2pat_make_tpnd(loc0, t2p0, D2Pvar(d2v1))
    where:
        let loc0 = d2p0.lctn()
        let D2Pvar(d2v1) = d2p0.node()
        let t2p0 = d2v1.styp()
        let t2p0 = match t2p0.node():
            case T2Pnone0():
                let xtp1 = x2t2p(d2v1)
                let t2p0 = s2typ_xtv(xtp1)
                d2v1.styp(t2p0)
                t2p0
            case _:
                t2p0
    def f0_con(env0: !tr2aenv, d2p0: d2pat) -> d2pat:
        d2pat_make_tpnd(loc0, t2p0, D2Pcon(d2c1))
    where:
        let loc0 = d2p0.lctn()
        let D2Pcon(d2c1) = d2p0.node()
        let t2p0 = d2con2a_s2typ(loc0, d2c1)
    def f0_bang(env0: !tr2aenv, d2p0: d2pat) -> d2pat:
        let loc0 = d2p0.lctn()
        let D2Pbang(d2p1) = d2p0.node()
        let d2p1 = trans2a_d2pat(env0, d2p1)
        let loc1 = d2p1.lctn()
        let t2p1 = d2p1.styp()
        d2pat_exbang(d2p1)
        let t2p0 = t2p1
        let t2p1 = s2typ_bang(t2p0)
        let d2p1 = d2pat(loc1, t2p1, d2p1.node())
        d2pat(loc0, t2p0, D2Pbang(d2p1))
    def f0_flat(env0: !tr2aenv, d2p0: d2pat) -> d2pat:
        let loc0 = d2p0.lctn()
        let D2Pflat(d2p1) = d2p0.node()
        let d2p1 = trans2a_d2pat(env0, d2p1)
        let t2p1 = d2p1.styp()
        d2pat(loc0, t2p1, D2Pflat(d2p1))
    def f0_free(env0: !tr2aenv, d2p0: d2pat) -> d2pat:
        let loc0 = d2p0.lctn()
        let D2Pfree(d2p1) = d2p0.node()
        let d2p1 = trans2a_d2pat(env0, d2p1)
        let t2p1 = d2p1.styp()
        d2pat(loc0, t2p1, D2Pfree(d2p1))
    def f0_cons(env0: !tr2aenv, d2p0: d2pat) -> d2pat:
        let loc0 = d2p0.lctn()
        let D2Pcons(drpt, d2cs) = d2p0.node()
        let t2p0 = s2typ_new0_x2tp(loc0)
        d2pat_make_tpnd(loc0, t2p0, D2Pcons(drpt, d2cs))
    def f0_sapp(env0: !tr2aenv, d2p0: d2pat) -> d2pat:
        let D2Psapp(d2f0, s2as) = d2p0.node()
        let d2f0 = trans2a_d2pat(env0, d2f0)
        let tfun = d2f0.styp()
        let tres = match tfun.node():
            case T2Puni0(s2vs, t2p1):
                let svts = f1_svts(s2vs, s2as, list_nil)
                s2typ_subst0(t2p1, svts)
            case _:
                tfun
        d2pat_make_tpnd(loc0, tres, D2Psapp(d2f0, s2as))
    where:
        let loc0 = d2p0.lctn()
        def f1_svts(s2vs: s2varlst, s2as: s2varlst, svts: s2vts) -> s2vts:
            match s2vs:
                case list_nil():
                    svts
                case list_cons(s2v1, s2vs):
                    f1_svts_cons(s2v1, s2vs, s2as, svts)

        def f1_svts_cons(s2v1: s2var, s2vs: s2varlst, s2as: s2varlst, svts: s2vts) -> s2vts:
            match s2as:
                case list_nil():
                    let t2p1 = s2typ_new0_x2tp(loc0)
                    let svts = list_cons((s2v1, t2p1), svts)
                    f1_svts(s2vs, s2as, svts)
                case list_cons(s2a1, s2as):
                    if (sort2_imprq(s2a1.sort())):
                        let t2p1 = s2typ_var(s2a1)
                        let svts = list_cons((s2v1, t2p1), svts)
                        f1_svts(s2vs, s2as, svts)
                    else:
                        f1_svts_cons(s2v1, s2vs, s2as, svts)
    def f0_dap0(env0: !tr2aenv, d2p0: d2pat) -> d2pat:
        let loc0 = d2p0.lctn()
        let D2Pdap0(d2f0) = d2p0.node()
        let npf1 = -(1)
        let d2ps = list_nil()
        let d2p0 = d2pat_dapp(loc0, d2f0, npf1, d2ps)
        f0_dapp(env0, d2p0)

    def f0_dap1(env0: !tr2aenv, d2p0: d2pat) -> d2pat:
        let loc0 = d2p0.lctn()
        let D2Pdap1(d2f0) = d2p0.node()
        let d2f0 = trans2a_d2pat(env0, d2f0)
        let t2f0 = d2f0.styp()
        let tres = match t2f0.node():
            case T2Pfun1(f2cl, npf1, targ, tres):
                tres
            case _:
                s2typ_new0_x2tp(loc0)
        d2pat(loc0, tres, D2Pdap1(d2f0))

    def f0_dapp(env0: !tr2aenv, d2p0: d2pat) -> d2pat:
        let loc0 = d2p0.lctn()
        let D2Pdapp(d2f0, npf1, d2ps) = d2p0.node()
        let tres = s2typ_new0_x2tp(loc0)
        let d2ps = trans2a_d2patlst(env0, d2ps)
        let f2cl = s2typ_f2cl(F2CLfun())
        let t2ps = s2typlst_of_d2patlst(d2ps)
        let tfun = s2typ_make_node(sort2_none0(), T2Pfun1(f2cl, npf1, t2ps, tres))
        let d2f0 = trans2a_d2pat_tpck(env0, d2f0, tfun)
        d2pat_make_tpnd(loc0, tres, D2Pdapp(d2f0, npf1, d2ps))
    def f0_rfpt(env0: !tr2aenv, d2p0: d2pat) -> d2pat:
        let loc0 = d2p0.lctn()
        let D2Prfpt(d2p1, tkas, d2p2) = d2p0.node()
        let d2p2 = trans2a_d2pat(env0, d2p2)
        let t2p2 = d2p2.styp()
        let d2p1 = trans2a_d2pat_tpck(env0, d2p1, t2p2)
        d2pat_make_tpnd(loc0, t2p2, D2Prfpt(d2p1, tkas, d2p2))
    def f0_tup0(env0: !tr2aenv, d2p0: d2pat) -> d2pat:
        d2pat_make_tpnd(loc0, t2p0, D2Ptup0(npf1, d2ps))
    where:
        let loc0 = d2p0.lctn()
        let D2Ptup0(npf1, d2ps) = d2p0.node()
        let d2ps = trans2a_d2patlst(env0, d2ps)
        let t2p0 = match d2ps:
            case list_nil():
                the_s2typ_void()
            case list_cons(_):
                s2typ_tup0(npf1, s2typlst(d2ps))
    def f0_tup1(env0: !tr2aenv, d2p0: d2pat) -> d2pat:
        d2pat_make_tpnd(loc0, t2p0, D2Ptup1(tknd, npf1, d2ps))
    where:
        let loc0 = d2p0.lctn()
        let D2Ptup1(tknd, npf1, d2ps) = d2p0.node()
        let d2ps = trans2a_d2patlst(env0, d2ps)
        let trcd = match tknd.node():
            case T_TRCD10(0):
                TRCDflt0
            case T_TRCD10(_):
                TRCDbox0
        let t2p0 = s2typ_tup1(trcd, npf1, s2typlst(d2ps))
    def f0_rcd2(env0: !tr2aenv, d2p0: d2pat) -> d2pat:
        d2pat_make_tpnd(loc0, t2p0, D2Prcd2(tknd, npf1, ldps))
    where:
        let loc0 = d2p0.lctn()
        let D2Prcd2(tknd, npf1, ldps) = d2p0.node()
        let ldps = trans2a_l2d2plst(env0, ldps)
        let trcd = match tknd.node():
            case T_TRCD20(0):
                TRCDflt0
            case T_TRCD20(_):
                TRCDbox0
        let t2p0 = s2typ_rcd2(trcd, npf1, l2t2plst(ldps))
    def f0_annot(env0: !tr2aenv, d2p0: d2pat) -> d2pat:
        let loc0 = d2p0.lctn()
        let D2Pannot(d2p1, s1e2, s2e2) = d2p0.node()
        let t2p2 = s2exp_stpize(s2e2)
        let t2p2 = s2typ_hnfiz0(t2p2)
        let d2p1 = trans2a_d2pat_tpck(env0, d2p1, t2p2)
        d2pat_make_tpnd(loc0, t2p2, D2Pannot(d2p1, s1e2, s2e2))
    def f0_errck(env0: !tr2aenv, d2p0: d2pat) -> d2pat:
        d2p0

@impl
def trans2a_l2d2p(env0, ld2p):
    let D2LAB(lab0, d2p1) = ld2p
    D2LAB(lab0, trans2a_d2pat(env0, d2p1))

@impl
def trans2a_d2exp(env0, d2e0):
    match d2e0.node():
        case D2Evar(_):
            f0_var(env0, d2e0)
        case D2Eint(_):
            f0_int(env0, d2e0)
        case D2Ebtf(_):
