@impl
def d2pat_fprint(d2p0, out0):
    @impl[]
    def g_print/out():
        out0
    match d2p0.node():
        case D2Pnil():
            prints("D2Pnil(", ")")
        case D2Pany():
            prints("D2Pany(", ")")
        case D2Parg():
            prints("D2Parg(", ")")
        case D2Pvar(d2v):
            prints("D2Pvar(", d2v, ")")
        case D2Pint(tok):
            prints("D2Pint(", tok, ")")
        case D2Pbtf(sym):
            prints("D2Pbtf(", sym, ")")
        case D2Pchr(tok):
            prints("D2Pchr(", tok, ")")
        case D2Pflt(tok):
            prints("D2Pflt(", tok, ")")
        case D2Pstr(tok):
            prints("D2Pstr(", tok, ")")
        case D2Pi00(int):
            prints("D2Pi00(", int, ")")
        case D2Pb00(btf):
            prints("D2Pb00(", btf, ")")
        case D2Pc00(chr):
            prints("D2Pc00(", chr, ")")
        case D2Pf00(flt):
            prints("D2Pf00(", flt, ")")
        case D2Ps00(str):
            prints("D2Ps00(", str, ")")
        case D2Pcon(d2c):
            prints("D2Pcon(", d2c, ")")
        case D2Pbang(d2p1):
            prints("D2Pbang(", d2p1, ")")
        case D2Pflat(d2p1):
            prints("D2Pflat(", d2p1, ")")
        case D2Pfree(d2p1):
            prints("D2Pfree(", d2p1, ")")
        case D2Pcons(drpt, d2cs):
            prints("D2Pcons(", drpt, ";", d2cs, ")")
        case D2Psapp(d2f0, s2vs):
            prints("D2Psapp(", d2f0, ";", s2vs, ")")
        case D2Pdap0(d1p1):
            prints("D2Pdap0(", d1p1, ")")
        case D2Pdap1(d1p1):
            prints("D2Pdap1(", d1p1, ")")
        case D2Pdapp(d2f0, npf1, d2ps):
            print("D2Pdapp(")
            prints(d2f0, ";", npf1, ";", d2ps, ")")
        case D2Prfpt(d2p1, tknd, d2p2):
            print("D2Prfpt(")
            prints(d2p1, ";", tknd, ";", d2p2, ")")
        case D2Ptup0(npf1, d2ps):
            prints("D2Ptup0(", npf1, ";", d2ps, ")")
        case D2Ptup1(tknd, npf1, d2ps):
            print("D2Ptup1(")
            prints(tknd, ";", npf1, ";", d2ps, ")")
        case D2Prcd2(tknd, npf1, ldps):
            print("D2Prcd2(")
            prints(tknd, ";", npf1, ";", ldps, ")")
        case D2Pargtp(d2p1, t2p2):
            prints("D2Pargtp(", d2p1, ";", t2p2, ")")
        case D2Pannot(d2p1, s1e2, s2e2):
            print("D2Pannot(")
            prints(d2p1, ";", s1e2, ";", s2e2, ")")
        case D2Pg1mac(g1m1):
            prints("D2Pg1mac(", g1m1, ")")
        case D2Pt2pck(d2p1, t2p2):
            let t2p1 = d2p1.styp()
            print("D2Pt2pck(")
            prints(d2p1, ";", t2p1, ";", t2p2, ")")
        case D2Pt2pkc(d2p1, t2p2):
            let t2p1 = d2p1.styp()
            print("D2Pt2pkc(")
            prints(d2p1, ";", t2p1, ";", t2p2, ")")
        case D2Pnone0():
            prints("D2Pnone0(", ")")
        case D2Pnone1(d1p1):
            prints("D2Pnone1(", d1p1, ")")
        case D2Pnone2(d2p1):
            prints("D2Pnone2(", d2p1, ")")
        case D2Perrck(lvl1, d2p2):
            if (lvl1 >= 2):
                prints("D2Perrck(", lvl1, ";", d2p2, ")")
            else:
                let loc0 = d2p0.lctn()
                prints("D2Perrck(", loc0, ";", lvl1, ";", d2p2, ")")

