@impl
def d2ecl_fprint(dcl0, out0):
    @impl[]
    def g_print/out():
        out0
    match dcl0.node():
        case D2Cd1ecl(d1cl):
            prints("D2Cd1ecl(", d1cl, ")")
        case D2Cstatic(tknd, dcl1):
            prints("D2Cstatic(", tknd, ";", dcl1, ")")
        case D2Cextern(tknd, dcl1):
            prints("D2Cextern(", tknd, ";", dcl1, ")")
        case D2Clocal0(head, body):
            prints("D2Clocal(", head, ";", body, ")")
        case D2Cabssort(tid0):
            prints("D2Cabssort(", tid0, ")")
        case D2Cstacst0(s2c1, s2t2):
            prints("D2Cstacst0(", s2c1, ";", s2t2, ")")
        case D2Csortdef(tid1, s2tx):
            prints("D2Csortdef(", tid1, ";", s2tx, ")")
        case D2Csexpdef(s2c1, s2e2):
            prints("D2Csexpdef(", s2c1, ";", s2e2, ")")
        case D2Cabstype(s2c1, atdf):
            prints("D2Cabstype(", s2c1, ";", atdf, ")")
        case D2Cabsopen(tknd, simp):
            prints("D2Cabsopen(", tknd, ";", simp, ")")
        case D2Cabsimpl(tknd, simp, sdef):
            print("D2Cabsimpl(")
            prints(tknd, ";", simp, ";", sdef, ")")
        case D2Csymload(tknd, sym0, dptm):
            print("D2Csymload(")
            prints(tknd, ";", sym0, ";", dptm, ")")
        case D2Cinclude(knd0, tknd, gsrc, fopt, dopt):
            print("D2Cinclude(")
            prints(knd0, ";", tknd, ";", gsrc, ";", fopt, ";", dopt, ")")
        case D2Cstaload(knd0, tknd, gsrc, fopt, dopt):
            print("D2Cstaload(")
            prints(knd0, ";", tknd, ";", gsrc, ";", fopt, ";", "...", ")")
        case D2Cdyninit(tknd, g1e1):
            prints("D2Cdyninit(", tknd, ";", g1e1, ")")
        case D2Cextcode(tknd, g1e1):
            prints("D2Cextcode(", tknd, ";", g1e1, ")")
        case D2Cdatasort(d1cl, s2cs):
            prints("D2Cdatasort(", d1cl, ";", s2cs, ")")
        case D2Cvaldclst(tknd, d2vs):
            prints("D2Cvaldclst(", tknd, ";", d2vs, ")")
        case D2Cvardclst(tknd, d2vs):
            prints("D2Cvardclst(", tknd, ";", d2vs, ")")
        case D2Cfundclst(tknd, tqas, d2cs, d2fs):
            print("D2Cfundclst(")
            prints(tknd, ";", tqas, ";", d2cs, ";", d2fs, ")")
        case D2Cimplmnt0(tknd, sqas, tqas, dqid, tias, farg, sres, body):
            print("D2Cimplmnt0(")
            prints(tknd, ";", sqas, ";", tqas, ";")
            prints(dqid, ";", tias, ";", farg, ";", sres, ";", body, ")")
        case D2Cexcptcon(d1cl, d2cs):
            prints("D2Cexcptcon(", d1cl, ";", d2cs, ")")
        case D2Cdatatype(d1cl, s2cs):
            prints("D2Cdatatype(", d1cl, ";", s2cs, ")")
        case D2Cdynconst(tknd, tqas, d2cs):
            prints("D2Cdynconst(", tknd, ";", tqas, ";", d2cs, ")")
        case D2Cnone0():
            prints("D2Cnone0(", ")")
        case D2Cnone1(d1cl):
            prints("D2Cnone1(", d1cl, ")")
        case D2Cnone2(d2cl):
            prints("D2Cnone2(", d2cl, ")")
        case D2Cthen0(dcls):
            prints("D2Cthen0(", dcls, ")")
        case D2Celse1(dcls):
            prints("D2Celse1(", dcls, ")")
        case D2Cerrck(lvl1, d2cl):
            if (lvl1 >= 2):
                prints("D2Cerrck(", lvl1, ";", d2cl, ")")
            else:
                let loc0 = dcl0.lctn()
                prints("D2Cerrck(", loc0, ";", lvl1, ";", d2cl, ")")

