@impl
def d2exp_fprint(d2e0, out0):
    @impl[]
    def g_print/out():
        out0
    match d2e0.node():
        case D2Eint(tok):
            prints("D2Eint(", tok, ")")
        case D2Ebtf(sym):
            prints("D2Ebtf(", sym, ")")
        case D2Echr(tok):
            prints("D2Echr(", tok, ")")
        case D2Eflt(tok):
            prints("D2Eflt(", tok, ")")
        case D2Estr(tok):
            prints("D2Estr(", tok, ")")
        case D2Ei00(int):
            prints("D2Ei00(", int, ")")
        case D2Eb00(btf):
            prints("D2Eb00(", btf, ")")
        case D2Ec00(chr):
            prints("D2Ec00(", chr, ")")
        case D2Ef00(flt):
            prints("D2Ef00(", flt, ")")
        case D2Es00(str):
            prints("D2Es00(", str, ")")
        case D2Etop(sym):
            prints("D2Etop(", sym, ")")
        case D2Evar(d2v):
            prints("D2Evar(", d2v, ")")
        case D2Econ(d2c):
            prints("D2Econ(", d2c, ")")
        case D2Ecst(d2c):
            prints("D2Ecst(", d2c, ")")
        case D2Econs(d2cs):
            @impl[d2con]
            def g_print(x):
                prints(x.name(), "(", x.lctn(), ")")
            prints("D2Econs(", d2cs, ")")
        case D2Ecsts(d2cs):
            @impl[d2cst]
            def g_print(x):
                prints(x.name(), "(", x.lctn(), ")")
            prints("D2Ecsts(", d2cs, ")")
        case D2Esym0(drxp, d1e1, dpis):
            prints("D2Esym0(", drxp, ";", d1e1, ";", dpis, ")")
        case D2Esapp(d2e1, s2es):
            prints("D2Esapp(", d2e1, ";", s2es, ")")
        case D2Etapp(d2e1, s2es):
            prints("D2Etapp(", d2e1, ";", s2es, ")")
        case D2Edap0(d2f0):
            prints("D2Edap0(", d2f0, ")")
        case D2Edapp(d2f0, npf1, d2es):
            print("D2Edapp(")
            prints(d2f0, ";", npf1, ";", d2es, ")")
        case D2Eproj(tknd, drxp, dlab, dtup):
            prints("D2Eproj(", tknd, ";")
            prints(drxp, ";", dlab, ";", dtup, ")")
        case D2Elet0(dcls, d2e1):
            prints("D2Elet0(", dcls, ";", d2e1, ")")
        case D2Eift0(d2e1, dthn, dels):
            print("D2Eift0(")
            prints(d2e1, ";", dthn, ";", dels, ")")
        case D2Ecas0(tknd, d2e1, d2cs):
            print("D2Ecas0(")
            prints(tknd, ";", d2e1, ";", d2cs, ")")
        case D2Eseqn(d2es, d2e1):
            prints("D2Eseqn(", d2es, ";", d2e1, ")")
        case D2Etup0(npf1, d2es):
            prints("D2Etup0(", npf1, ";", d2es, ")")
        case D2Etup1(tknd, npf1, d2es):
            print("D2Etup1(")
            prints(tknd, ";", npf1, ";", d2es, ")")
        case D2Ercd2(tknd, npf1, ldes):
            print("D2Ercd2(")
            prints(tknd, ";", npf1, ";", ldes, ")")
        case D2Elam0(tknd, f2as, sres, arrw, body):
            prints("D2Elam0(", tknd, ";")
            prints(f2as, ";", sres, ";", arrw, ";", body, ")")
        case D2Efix0(tknd, dpid, f2as, sres, arrw, body):
            prints("D2Efix0(", tknd, ";", dpid, ";")
            prints(f2as, ";", sres, ";", arrw, ";", body, ")")
        case D2Etry0(tknd, d2e1, dcls):
            print("D2Etry0(")
            prints(tknd, ";", d2e1, ";", dcls, ")")
        case D2Eaddr(d2e1):
            prints("D2Eaddr(", d2e1, ")")
        case D2Eview(d2e1):
            prints("D2Eview(", d2e1, ")")
        case D2Elval(d2e1):
            prints("D2Elval(", d2e1, ")")
        case D2Eeval(d2e1):
            prints("D2Eeval(", d2e1, ")")
        case D2Efold(d2e1):
            prints("D2Efold(", d2e1, ")")
        case D2Efree(d2e1):
            prints("D2Efree(", d2e1, ")")
        case D2Ewhere(d2e1, dcls):
            prints("D2Ewhere(", d2e1, ";", dcls, ")")
        case D2Eassgn(d2el, d2er):
            prints("D2Eassgn(", d2el, ";", d2er, ")")
        case D2Exazgn(d2el, d2er):
            prints("D2Exazgn(", d2el, ";", d2er, ")")
        case D2Exchng(d2el, d2er):
            prints("D2Exchng(", d2el, ";", d2er, ")")
        case D2Ebrget(dpis, d2es):
            prints("D2Ebrget(", dpis, ";", d2es, ")")
        case D2Ebrset(dpis, d2es):
            prints("D2Ebrset(", dpis, ";", d2es, ")")
        case D2Edtsel(tknd, lab1, dpis, npf1, opt2):
            print("D2Edtsel(")
            prints(tknd, ";", lab1, ";")
            prints(dpis, ";", npf1, ";", opt2, ")")
        case D2Eraise(tknd, d2e1):
            prints("D2Eraise(", tknd, ";", d2e1, ")")
        case D2El0azy(dsym, d2e1):
            prints("D2El0azy(", dsym, ";", d2e1, ")")
        case D2El1azy(dsym, d2e1, d2es):
            print("D2El1azy(")
            prints(dsym, ";", d2e1, ";", d2es, ")")
        case D2Eelazy(dsym, d2e1, d2es):
            print("D2Eelazy(")
            prints(dsym, ";", d2e1, ";", d2es, ")")
        case D2Eannot(d2e1, s1e2, s2e2):
            print("D2Eannot(")
            prints(d2e1, ";", s1e2, ";", s2e2, ")")
        case D2Eg1mac(g1m1):
            prints("D2Eg1mac(", g1m1, ")")
        case D2Elabck(d2e1, lab2):
            let t2p1 = d2e1.styp()
            print("D2Elabck(")
            prints(d2e1, ";", t2p1, ";", lab2, ")")
        case D2Et2pck(d2e1, t2p2):
            let t2p1 = d2e1.styp()
            print("D2Et2pck(")
            prints(d2e1, ";", t2p1, ";", t2p2, ")")
        case D2Et2ped(d2e1, t2p2):
            let t2p1 = d2e1.styp()
            print("D2Et2ped(")
            prints(d2e1, ";", t2p1, ";", t2p2, ")")
        case D2Eexists(s2es, d2e1):
            prints("D2Eexists(", s2es, ";", d2e1, ")")
        case D2Eextnam(tknd, gnam):
            prints("D2Eextnam(", tknd, ";", gnam, ")")
        case D2Esynext(tknd, gexp):
            prints("D2Esynext(", tknd, ";", gexp, ")")
        case D2Enone0():
            prints("D2Enone0(", ")")
        case D2Enone1(d1e1):
            prints("D2Enone1(", d1e1, ")")
        case D2Enone2(d2e1):
            prints("D2Enone2(", d2e1, ")")
        case D2Eerrck(lvl1, d2e2):
            if (lvl1 >= 2):
                prints("D2Eerrck(", lvl1, ";", d2e2, ")")
            else:
                let loc0 = d2e0.lctn()
                prints("D2Eerrck(", loc0, ";", lvl1, ";", d2e2, ")")

