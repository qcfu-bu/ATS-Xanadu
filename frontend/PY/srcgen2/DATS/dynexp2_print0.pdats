@impl
def x2nam_fprint(xnam, out0):
    @impl[]
    def g_print/out():
        out0
    match xnam:
        case X2NAMnone():
            prints("X2NAMnone(", ")")
        case X2NAMsome(dexp):
            prints("X2NAMsome(", dexp, ")")

@impl
def d2con_fprint(d2c0, out0):
