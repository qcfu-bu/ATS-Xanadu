@overload lctn = token_get_lctn

@overload node = token_get_node

@overload lctn = d2cst_get_lctn

@overload lctn = d3pat_get_lctn

@overload node = d3pat_get_node

@overload lctn = d3exp_get_lctn

@overload node = d3exp_get_node

@overload lctn = f3arg_get_lctn

@overload node = f3arg_get_node

