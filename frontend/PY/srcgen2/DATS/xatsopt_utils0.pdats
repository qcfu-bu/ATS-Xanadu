@impl
def xatsopt_args/filxats_d2parsed(args, xats, fpth):
    def f0_args(args: list[String]) -> Void:
        match args:
            case list_nil():
                ()
            case list_cons(arg1, args):
                xatsopt_flag/pvsadd0(arg1)
                f0_args(args)
    let ret1 = the_fxtyenv_pvsl00d()
    if (ret1 > 0):
        prerrsln("// The fixity-defs loaded!")
    let ret2 = the_tr12env_pvsl01d()
    if (ret2 > 0):
        prerrsln("// The trans12-defs loaded!")
    f0_args(args)
    if (xats >= 1):
        d2parsed_of_fildats(fpth)
    else:
        d2parsed_of_filsats(fpth)
where:
    prerrsln("// Welcome from ATS3/Xanadu!")
    prerrsln("// XATSHOME = ", the_XATSHOME())

