@impl
def xatsopt_flag/split(arg0):
    if len0 <= 2:
        optn_vt_nil()
    else:
        if ((arg0[0] != '-') * (arg0[1] != '-')):
            optn_vt_nil()
        else:
            optn_vt_cons(f0_flag/split(arg0))
where:
    let len0 = strn_length(arg0)
    def f0_flag/split(cs: String) -> (String, optn_vt[String]):
        let pos1 = f1_eqpos(cs, 2)
        if (pos1 < 0):
            let key1 = f1_substr(cs, 2, len0)
            (key1, optn_vt_nil())
        else:
            let key1 = f1_substr(cs, 2, pos1)
            let itm2 = f1_substr(cs, pos1 + 1, len0)
            (key1, optn_vt_cons(itm2))
    where:
        def f1_eqpos(cs: String, i0: SInt) -> SInt:
            if (i0 >= len0):
                -(1)
            else:
                if (cs[i0] == '='):
                    i0
                else:
                    f1_eqpos(cs, i0 + 1)
        def f1_substr(cs: String, i0: SInt, j0: SInt) -> String:
            strn_tabulate/f1un(j0 - i0, (i1) => cs[i0 + i1])
    prerrsln("xatsopt_flag$split: arg0 = ", arg0)

@impl
def xatsopt_flag/pvsadd0(arg0):
    let opt1 = xatsopt_flag/split(arg0)
    match opt1:
        case ~optn_vt_nil():
            ()
        case ~optn_vt_cons((key1, opt2)):
            def f0_g1mstr(str0: String) -> g1mac:
                G1Mstr(str0)
            let key1 = symbl_make_name(key1)
            let itm2 = match opt2:
                case ~optn_vt_nil():
                    G1Mint(1)
                case ~optn_vt_cons(str2):
                    f0_g1mstr(str2)
            the_gmacenv_pvsadd0(key1, itm2)

