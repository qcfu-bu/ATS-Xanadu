    def f0_annot(env0: !tr12env, d1e0: d1exp) -> d2exp:
        let loc0 = d1e0.lctn()
        let D1Eannot(d1e1, s1e2) = d1e0.node()
        let d2e1 = trans12_d1exp(env0, d1e1)
        let s2e2 = trans12_s1exp_impr(env0, s1e2)
        d2exp(loc0, D2Eannot(d2e1, s1e2, s2e2))
    def f0_qual0(env0: !tr12env, d1e0: d1exp) -> d2exp:
        let loc0 = d1e0.lctn()
        let D1Equal0(tok1, d1e2) = d1e0.node()
        match tok1.node():
            case T_IDQUA(name):
                let sym1 = symbl_make_name(name)
                let opt1 = tr12env_find_s2qua(env0, sym1)
                match opt1:
                    case ~optn_vt_nil():
                        d2exp_none1(d1e0)
                    case ~optn_vt_cons(s2i1):
                        match s2i1:
                            case S2ITMenv(envs):
                                let dopt = f1_d2exp(envs, d1e2)
                                match dopt:
                                    case optn_nil():
                                        d2exp_none1(d1e0)
                                    case optn_cons(d2e0):
                                        d2e0
                            case _:
                                d2exp_none1(d1e0)
            case _:
                d2exp_none1(d1e0)
    where:
        def f1_d2exp(envs: f2envlst, dexp: d1exp) -> d2expopt:
            match dexp.node():
                case D1Eid0(deid):
                    let dopt = f2envlst_find_d2itm(envs, deid)
                    match dopt:
                        case ~optn_vt_nil():
                            optn_nil
                        case ~optn_vt_cons(ditm):
                            match ditm:
                                case D2ITMcon(d2cs):
                                    optn_cons(d2exp_cons(dexp.lctn(), d2cs))
                                case D2ITMcst(d2cs):
                                    optn_cons(d2exp_csts(dexp.lctn(), d2cs))
                                case _:
                                    optn_nil
                case D1Equal0(tok1, d1e2):
                    let envs = f1_qual0(envs, tok1)
                    f1_d2exp(envs, d1e2)
                case _:
                    optn_nil

        def f1_qual0(envs: f2envlst, tok1: token) -> f2envlst:
            match tok1.node():
                case T_IDQUA(name):
                    let sym1 = symbl_make_name(name)
                    let opt1 = f2envlst_find_s2itm(envs, sym1)
                    match opt1:
                        case ~optn_vt_nil():
                            list_nil()
                        case ~optn_vt_cons(s2i1):
                            match s2i1:
                                case S2ITMenv(envs):
                                    envs
                                case _:
                                    list_nil()
                case _:
                    list_nil()
    def f0_none0(env0: !tr12env, d1e0: d1exp) -> d2exp:
        let loc0 = d1e0.lctn()
        let D1Enone0() = d1e0.node()
        d2exp_none0(loc0)
    def f0_extnam(env0: !tr12env, d1e0: d1exp) -> d2exp:
        let loc0 = d1e0.lctn()
        let D1Eextnam(tknd, gnm1) = d1e0.node()
        d2exp_make_node(loc0, D2Eextnam(tknd, gnm1))
    def f0_synext(env0: !tr12env, d1e0: d1exp) -> d2exp:
        let loc0 = d1e0.lctn()
        let D1Esynext(tknd, gexp) = d1e0.node()
        d2exp_make_node(loc0, D2Esynext(tknd, gexp))

