    def f0_fix0(env0: !tr12env, d1e0: d1exp) -> d2exp:
        let loc0 = d1e0.lctn()
        let D1Efix0(tknd, tok1, f1as, sres, arrw, body) = d1e0.node()
        tr12env_pshlam0(env0)
        let d2v1 = trans12_d1pid(env0, tok1)
        tr12env_add0_d2var(env0, d2v1)
        let f2as = trans12_f1arglst(env0, f1as)
        tr12env_add0_f2arglst(env0, f2as)
        let sres = trans12_s1res(env0, sres)
        let body = trans12_d1exp(env0, body)
        tr12env_poplam0(env0)
        d2exp_make_node(loc0, D2Efix0(tknd, d2v1, f2as, sres, arrw, body))
    def f0_try0(env0: !tr12env, d1e0: d1exp) -> d2exp:
        let loc0 = d1e0.lctn()
        let D1Etry0(tknd, d1e1, dcls) = d1e0.node()
