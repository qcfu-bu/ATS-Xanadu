@impl
def trans12_f1arg(env0, f1a0):
    match f1a0.node():
        case F1ARGdapp(_):
            f0_dyn0(env0, f1a0)
        case F1ARGsapp(_):
            f0_sapp(env0, f1a0)
        case F1ARGmets(_):
            f0_mets(env0, f1a0)
where:
    def f0_dyn0(env0: !tr12env, f1a0: f1arg) -> f2arg:
        var npf1: SInt = -(1)
        let F1ARGdapp(d1p0) = f1a0.node()
        let d2ps = match d1p0.node():
            case D1Pl1st(d1ps):
                trans12_d1patlst(env0, d1ps)
            case D1Pl2st(dps1, dps2):
                let dps1 = trans12_d1patlst(env0, dps1)
                let dps2 = trans12_d1patlst(env0, dps2)
                npf1 := list_length(dps1)
                list_append(dps1, dps2)
            case _:
                list_sing(trans12_d1pat(env0, d1p0))
        f2arg(f1a0.lctn(), F2ARGdapp(npf1, d2ps))
    def f0_sapp(env0: !tr12env, f1a0: f1arg) -> f2arg:
        let F1ARGsapp(s1qs) = f1a0.node()
        let (s2vs, s2ps) = trans12_s1qualst(env0, s1qs)
        f2arg(f1a0.lctn(), F2ARGsapp(s2vs, s2ps))
    def f0_mets(env0: !tr12env, f1a0: f1arg) -> f2arg:
        let F1ARGmets(s1es) = f1a0.node()
        let s2es = trans12_s1explst(env0, s1es)
        f2arg(f1a0.lctn(), F2ARGmets(s2es))

