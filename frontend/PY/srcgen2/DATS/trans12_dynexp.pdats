@impl
def trans12_d1expseq(env0, loc0, d1es):
    def auxlst1(env0: !tr12env, d1es: d1explst) -> (d2explst, d2exp):
        match d1es:
            case list_nil():
                let d2e1 = d2exp_none0(loc0)
                (list_nil(), d2e1)
            case list_cons(d1e1, d1es):
                auxlst2(env0, d1e1, d1es, list_vt_nil())

    def auxlst2(env0: !tr12env, d1e1: d1exp, d1es: d1explst, d2es: d2explst_vt) -> (d2explst, d2exp):
        match d1es:
            case list_nil():
                let d2e1 = trans12_d1exp(env0, d1e1)
                let d2es = list_vt2t(list_vt_reverse0(d2es))
                (d2es, d2e1)
            case list_cons(d1e2, d1es):
                let d2e1 = trans12_d1exp(env0, d1e1)
                let d2es = list_vt_cons(d2e1, d2es)
                auxlst2(env0, d1e2, d1es, d2es)
    let (d2es, d2e1) = auxlst1(env0, d1es)
    match d2es:
        case list_nil(_):
            d2e1
        case list_cons(_):
            d2exp_make_node(loc0, D2Eseqn(d2es, d2e1))

private:
    def f0_id0(loc0: loc_t, g1m0: g1mac) -> d1pat:
        let G1Mid0(sym) = g1m0
        d1pat(loc0, D1Pid0(sym))
    def f0_int(loc0: loc_t, g1m0: g1mac) -> d2pat:
        let G1Mint(int) = g1m0
        d2pat(loc0, D2Pi00(int))
    def f0_btf(loc0: loc_t, g1m0: g1mac) -> d2pat:
        let G1Mbtf(btf) = g1m0
        d2pat(loc0, D2Pb00(btf))
    def f0_chr(loc0: loc_t, g1m0: g1mac) -> d2pat:
        let G1Mchr(chr) = g1m0
        d2pat(loc0, D2Pc00(chr))
    def f0_flt(loc0: loc_t, g1m0: g1mac) -> d2pat:
        let G1Mflt(flt) = g1m0
        d2pat(loc0, D2Pf00(flt))
    def f0_str(loc0: loc_t, g1m0: g1mac) -> d2pat:
        let G1Mstr(str) = g1m0
        d2pat(loc0, D2Ps00(str))
    def f0_apps(env0: !tr12env, loc0: loc_t, g1m0: g1mac) -> d2pat:
        let npf1 = -(1)
        let G1Mapps(g1f0, g1ms) = g1m0
        let d2f0 = trd2pat_g1mac(env0, loc0, g1f0)
        let d2ps = trd2pat_g1maclst(env0, loc0, g1ms)
        d2pat_make_node(loc0, D2Pdapp(d2f0, npf1, d2ps))

@impl
def trd2pat_g1mac(env0, loc0, g1m0):
    match g1m0:
        case G1Mid0(_):
            trans12_d1pat(env0, f0_id0(loc0, g1m0))
        case G1Mint(_):
            f0_int(loc0, g1m0)
        case G1Mbtf(_):
            f0_btf(loc0, g1m0)
        case G1Mchr(_):
            f0_chr(loc0, g1m0)
        case G1Mflt(_):
            f0_flt(loc0, g1m0)
        case G1Mstr(_):
            f0_str(loc0, g1m0)
        case G1Mapps(_):
            f0_apps(env0, loc0, g1m0)
        case _:
            d2pat(loc0, D2Pg1mac(g1m0))


