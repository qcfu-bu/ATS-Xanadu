        else:
            d1ecl_stacst0_errck(dcl.lctn(), tknd, sid0, tmas, s1t1)
    def f0_sortdef(dcl: d1ecl, err: &SInt >> _) -> d1ecl:
        let e00 = err
        let loc = dcl.lctn()
        let D1Csortdef(tknd, tid0, stdf) = dcl.node()
        let stdf = tread01_s1tdf(stdf, err)
        if (err == e00):
