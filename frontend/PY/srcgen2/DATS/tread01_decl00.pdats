    def f0_absimpl(dcl: d1ecl, err: &SInt >> _) -> d1ecl:
        let e00 = err
        let D1Cabsimpl(tknd, sqid, smas, tres, sdef) = dcl.node()
        let smas = tread01_s1maglst(smas, err)
        let tres = tread01_sort1opt(tres, err)
