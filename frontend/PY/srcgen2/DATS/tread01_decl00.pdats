@impl
def tread01_d1ecl(d1cl, err):
    match d1cl.node():
        case D1Cnone0(_):
            d1cl
        case D1Cd0ecl(_):
            d1cl
        case D1Cthen0(_):
            f0_then0(d1cl, err)
        case D1Celse1(_):
            f0_else1(d1cl, err)
        case D1Cifexp(_):
            f0_ifexp(d1cl, err)
        case D1Celsif(_):
            f0_elsif(d1cl, err)
        case D1Cstatic(_):
            f0_static(d1cl, err)
        case D1Cextern(_):
            f0_extern(d1cl, err)
        case D1Cdefine(_):
            f0_define(d1cl, err)
        case D1Clocal0(_):
            f0_local0(d1cl, err)
        case D1Cabssort(_):
            d1cl
        case D1Cstacst0(_):
            f0_stacst0(d1cl, err)
        case D1Csortdef(_):
            f0_sortdef(d1cl, err)
        case D1Csexpdef(_):
            f0_sexpdef(d1cl, err)
        case D1Cabstype(_):
            f0_abstype(d1cl, err)
        case D1Cabsopen(_):
            d1cl
        case D1Cabsimpl(_):
            f0_absimpl(d1cl, err)
        case D1Csymload(_):
            f0_symload(d1cl, err)
        case D1Cinclude(_):
            f0_include(d1cl, err)
        case D1Cstaload(_):
            f0_staload(d1cl, err)
        case D1Cdyninit(_):
            f0_dyninit(d1cl, err)
        case D1Cextcode(_):
            f0_extcode(d1cl, err)
        case D1Cdatasort(_):
            f0_datasort(d1cl, err)
        case D1Cvaldclst(_):
            f0_valdclst(d1cl, err)
        case D1Cvardclst(_):
            f0_vardclst(d1cl, err)
        case D1Cfundclst(_):
            f0_fundclst(d1cl, err)
        case D1Cimplmnt0(_):
            f0_implmnt0(d1cl, err)
        case D1Cexcptcon(_):
            f0_excptcon(d1cl, err)
        case D1Cdatatype(_):
            f0_datatype(d1cl, err)
        case D1Cdynconst(_):
            f0_dynconst(d1cl, err)
        case _:
            let lvl0 = 1
            err := err + 1
            d1ecl_errck(lvl0, d1cl)
where:
    let loc0 = d1cl.lctn()
    def f0_then0(dcl: d1ecl, err: &SInt >> _) -> d1ecl:
        let e00 = err
        let D1Cthen0(dcls) = dcl.node()
        let dcls = tread01_d1eclist(dcls, err)
        if (err == e00):
            dcl
        else:
            d1ecl_then0_errck(dcl.lctn(), dcls)
    def f0_else1(dcl: d1ecl, err: &SInt >> _) -> d1ecl:
        let e00 = err
        let D1Celse1(dcls) = dcl.node()
        let dcls = tread01_d1eclist(dcls, err)
        if (err == e00):
            dcl
        else:
            d1ecl_else1_errck(dcl.lctn(), dcls)
    def f0_ifexp(dcl: d1ecl, err: &SInt >> _) -> d1ecl:
        let e00 = err
        let D1Cifexp(tknd, dthn, dels, dend) = dcl.node()
        let dthn = tread01_d1eclopt(dthn, err)
        let dels = tread01_d1eclopt(dels, err)
        match dend:
            case optn_cons(_):
                ()
            case _:
                err := err + 1
        if (err == e00):
            dcl
        else:
            d1ecl_ifexp_errck(dcl.lctn(), tknd, dthn, dels, dend)
    def f0_elsif(dcl: d1ecl, err: &SInt >> _) -> d1ecl:
        let e00 = err
        let D1Celsif(tknd, dthn, dels, dend) = dcl.node()
        let dthn = tread01_d1eclopt(dthn, err)
        let dels = tread01_d1eclopt(dels, err)
        match dend:
            case optn_nil():
                ()
            case optn_cons(_):
                err := err + 1
        if (err == e00):
            dcl
        else:
            d1ecl_elsif_errck(dcl.lctn(), tknd, dthn, dels, dend)
    def f0_static(dcl: d1ecl, err: &SInt >> _) -> d1ecl:
        let e00 = err
        let D1Cstatic(tknd, dcl1) = dcl.node()
        let dcl1 = tread01_d1ecl(dcl1, err)
        if (err == e00):
            dcl
        else:
            d1ecl_static_errck(dcl.lctn(), tknd, dcl1)
    def f0_extern(dcl: d1ecl, err: &SInt >> _) -> d1ecl:
        let e00 = err
        let D1Cextern(tknd, dcl1) = dcl.node()
        let dcl1 = tread01_d1ecl(dcl1, err)
        if (err == e00):
            dcl
        else:
            d1ecl_extern_errck(dcl.lctn(), tknd, dcl1)
    def f0_define(dcl: d1ecl, err: &SInt >> _) -> d1ecl:
        let e00 = err
        let D1Cdefine(tknd, geid, gmas, gopt) = dcl.node()
        let gopt = tread01_g1expopt(gopt, err)
        if (err == e00):
            dcl
        else:
            d1ecl_define_errck(dcl.lctn(), tknd, geid, gmas, gopt)
    def f0_local0(dcl: d1ecl, err: &SInt >> _) -> d1ecl:
        let e00 = err
        let loc = dcl.lctn()
        let D1Clocal0(dcs1, dcs2) = dcl.node()
        let dcs1 = tread01_d1eclist(dcs1, err)
        let dcs2 = tread01_d1eclist(dcs2, err)
        if (err == e00):
            dcl
        else:
            d1ecl_local0_errck(loc, dcs1, dcs2)
    def f0_stacst0(dcl: d1ecl, err: &SInt >> _) -> d1ecl:
        let e00 = err
        let D1Cstacst0(tknd, sid0, tmas, s1t1) = dcl.node()
        let tmas = tread01_t1maglst(tmas, err)
        let s1t1 = tread01_sort1(s1t1, err)
        if (err == e00):
