    def f0_symload(dcl: d1ecl, err: &SInt >> _) -> d1ecl:
        let e00 = err
        let D1Csymload(tknd, deid, dqid, gopt) = dcl.node()
        let gopt = tread01_g1expopt(gopt, err)
        if (err == e00):
            dcl
        else:
            d1ecl_symload_errck(dcl.lctn(), tknd, deid, dqid, gopt)
    def f0_include(dcl: d1ecl, err: &SInt >> _) -> d1ecl:
        let e00 = err
        let D1Cinclude(knd0, tknd, g1e1, fopt, dopt) = dcl.node()
        let g1e1 = tread01_g1exp(g1e1, err)
        let dopt = match dopt:
            case optn_nil():
                err := err + 1
                optn_nil()
            case optn_cons(dcls):
                optn_cons(tread01_d1eclist(dcls, err))
        if (err == e00):
            dcl
        else:
            d1ecl_include_errck(dcl.lctn(), knd0, tknd, g1e1, fopt, dopt)
    def f0_staload(dcl: d1ecl, err: &SInt >> _) -> d1ecl:
        let e00 = err
