    def f0_abstype(dcl: d1ecl, err: &SInt >> _) -> d1ecl:
        let e00 = err
        let D1Cabstype(tknd, seid, tmas, tres, atdf) = dcl.node()
        let smas = tread01_t1maglst(tmas, err)
        let tres = tread01_sort1opt(tres, err)
        let atdf = tread01_a1tdf(atdf, err)
        if (err == e00):
