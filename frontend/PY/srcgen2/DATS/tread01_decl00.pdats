def d1ecl_errck(lvl: SInt, dcl: d1ecl) -> d1ecl:
    d1ecl(dcl.lctn(), D1Cerrck(lvl, dcl))

def d1ecl_then0_errck(loc0: loc_t, dcls: d1eclist) -> d1ecl:
    let lvl = 0
    d1ecl_errck(lvl + 1, d1ecl(loc0, D1Cthen0(dcls)))

