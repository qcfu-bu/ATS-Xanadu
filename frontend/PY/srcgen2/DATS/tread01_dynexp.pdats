@impl
def tread01_d1exp(d1e0, err):
    match d1e0.node():
        case D1Eid0(_):
            d1e0
        case D1Eint(_):
            d1e0
        case D1Echr(_):
            d1e0
        case D1Eflt(_):
            d1e0
        case D1Estr(_):
            d1e0
        case D1Eb0sh():
            d1e0
        case D1Eb1sh(d1e1):
            d1e0
        case D1Ea0pp():
            err := err + 1
            d1exp_a0pp_errck(loc0)
        case D1Ea1pp(d1e1, d1e2):
            let e00 = err
            let d1e1 = tread01_d1exp(d1e1, err)
            let d1e2 = tread01_d1exp(d1e2, err)
            if (err == e00):
                d1e0
            else:
                d1exp_a1pp_errck(loc0, d1e1, d1e2)
        case D1Ea2pp(d1e1, d1e2, d1e3):
            let e00 = err
            let d1e1 = tread01_d1exp(d1e1, err)
            let d1e2 = tread01_d1exp(d1e2, err)
            let d1e3 = tread01_d1exp(d1e3, err)
            if (err == e00):
                d1e0
            else:
                d1exp_a2pp_errck(loc0, d1e1, d1e2, d1e3)
        case D1Esarg(s1es):
            let e00 = err
            let s1es = tread01_s1explst(s1es, err)
            if (err == e00):
                d1e0
            else:
                d1exp_sarg_errck(loc0, s1es)
        case D1Etarg(s1es):
            let e00 = err
            let s1es = tread01_s1explst(s1es, err)
            if (err == e00):
                d1e0
            else:
                d1exp_targ_errck(loc0, s1es)
        case D1El1st(d1es):
            let e00 = err
            let d1es = tread01_d1explst(d1es, err)
            if (err == e00):
                d1e0
            else:
