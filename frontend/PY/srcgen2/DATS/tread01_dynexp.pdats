@impl
def tread01_d1pat(d1p0, err):
    match d1p0.node():
        case D1Pid0(_):
            d1p0
        case D1Pint(_):
            d1p0
        case D1Pchr(_):
            d1p0
        case D1Pflt(_):
            d1p0
        case D1Pstr(_):
            d1p0
        case D1Paspt(tknd, d1p1):
            let e00 = err
            let d1p1 = tread01_d1pat(d1p1, err)
            if (err == e00):
                d1p0
            else:
                d1pat_aspt_errck(loc0, tknd, d1p1)
        case D1Pa0pp():
            err := err + 1
            d1pat_a0pp_errck(loc0)
        case D1Pa1pp(d1p1, d1p2):
            let e00 = err
            let d1p1 = tread01_d1pat(d1p1, err)
            let d1p2 = tread01_d1pat(d1p2, err)
            if (err == e00):
                d1p0
            else:
                d1pat_a1pp_errck(loc0, d1p1, d1p2)
        case D1Pa2pp(d1p1, d1p2, d1p3):
            let e00 = err
            let d1p1 = tread01_d1pat(d1p1, err)
            let d1p2 = tread01_d1pat(d1p2, err)
            let d1p3 = tread01_d1pat(d1p3, err)
            if (err == e00):
                d1p0
            else:
                d1pat_a2pp_errck(loc0, d1p1, d1p2, d1p3)
        case D1Psarg(s1as):
            let e00 = err
            let s1as = tread01_s1arglst(s1as, err)
            if (err == e00):
                d1p0
            else:
                d1pat_sarg_errck(loc0, s1as)
        case D1Pl1st(d1ps):
            let e00 = err
            let d1ps = tread01_d1patlst(d1ps, err)
            if (err == e00):
                d1p0
            else:
                d1pat_l1st_errck(loc0, d1ps)
        case D1Pl2st(dps1, dps2):
            let e00 = err
            let dps1 = tread01_d1patlst(dps1, err)
            let dps2 = tread01_d1patlst(dps2, err)
            if (err == e00):
                d1p0
            else:
                d1pat_l2st_errck(loc0, dps1, dps2)
        case D1Pt1up(tknd, d1ps):
            let e00 = err
            let d1ps = tread01_d1patlst(d1ps, err)
            if (err == e00):
                d1p0
            else:
                d1pat_t1up_errck(loc0, tknd, d1ps)
        case D1Pt2up(tknd, dps1, dps2):
            let e00 = err
            let dps1 = tread01_d1patlst(dps1, err)
            let dps2 = tread01_d1patlst(dps2, err)
            if (err == e00):
                d1p0
            else:
                d1pat_t2up_errck(loc0, tknd, dps1, dps2)
        case D1Pannot(d1p1, s1e2):
            let e00 = err
            let d1p1 = tread01_d1pat(d1p1, err)
            let s1e2 = tread01_s1exp(s1e2, err)
            if (err == e00):
                d1p0
            else:
                d1pat_annot_errck(loc0, d1p1, s1e2)
        case D1Pqual0(tok1, d1p2):
            let e00 = err
            let d1p2 = tread01_d1pat(d1p2, err)
            if (err == e00):
                d1p0
            else:
                d1pat_qual0_errck(loc0, tok1, d1p2)
        case _:
            let lvl0 = 1
            err := err + 1
            d1pat_errck(lvl0, d1p0)
where:
    let loc0 = d1p0.lctn()

@impl
def tread01_l1d1p(ld1p, err):
    let e00 = err
    let D1LAB(lab0, d1p1) = ld1p
    let d1p1 = tread01_d1pat(d1p1, err)
    if (err == e00):
        ld1p
    else:
        D1LAB(lab0, d1p1)

