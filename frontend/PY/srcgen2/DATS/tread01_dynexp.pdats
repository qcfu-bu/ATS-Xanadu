def d1pat_errck(lvl: SInt, d1p: d1pat) -> d1pat:
    d1pat(d1p.lctn(), D1Perrck(lvl, d1p))

def d1pat_errvl_a1(d1p: d1pat) -> SInt:
    match d1p.node():
        case D1Perrck(lvl, _):
            lvl
        case _:
            0

