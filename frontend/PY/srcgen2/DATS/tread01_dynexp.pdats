@extern
def d1pat_errvl_lst(dps: d1patlst) -> SInt

@impl
def d1pat_errvl_lst(dps):
    match dps:
        case list_nil():
            0
        case list_cons(de1, dps):
            maxs(errvl(de1), d1pat_errvl_lst(dps))

@overload errvl = d1pat_errvl_lst

@extern
def l1d1p_errvl_ldps(ldps: l1d1plst) -> SInt

@impl
def l1d1p_errvl_ldps(ldps):
    match ldps:
        case list_nil():
            0
        case list_cons(ldp1, ldps):
            let D1LAB(lab, dp1) = ldp1
            maxs(errvl(dp1), l1d1p_errvl_ldps(ldps))

@overload errvl = l1d1p_errvl_ldps

