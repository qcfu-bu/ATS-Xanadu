@impl
def t3read0_d3pat(evn0, d3p0, err0):
    d3p0

@impl
def t3read0_d3exp(evn0, d3e0, err0):
    match d3e0.node():
        case D3Evar(_):
            d3e0
        case D3Eint(_):
            d3e0
        case D3Ebtf(_):
            d3e0
        case D3Echr(_):
            d3e0
        case D3Eflt(_):
            d3e0
        case D3Estr(_):
            d3e0
        case D3Ei00(_):
            d3e0
        case D3Eb00(_):
            d3e0
        case D3Ec00(_):
            d3e0
        case D3Ef00(_):
            d3e0
        case D3Es00(_):
            d3e0
        case D3Econ(_):
            d3e0
        case D3Ecst(_):
            d3e0
        case D3Etop(_):
            d3e0
        case D3Etimp(_):
            f0_timp(evn0, d3e0, err0)
        case D3Etapp(_):
            f0_tapp(evn0, d3e0, err0)
        case D3Etapq(_):
            f0_tapq(evn0, d3e0, err0)
        case D3Edap0(_):
            f0_dap0(evn0, d3e0, err0)
        case D3Edapp(_):
            f0_dapp(evn0, d3e0, err0)
        case D3Epcon(_):
            f0_pcon(evn0, d3e0, err0)
        case D3Eproj(_):
            f0_proj(evn0, d3e0, err0)
        case D3Elet0(_):
            f0_let0(evn0, d3e0, err0)
        case D3Eift0(_):
            f0_ift0(evn0, d3e0, err0)
        case D3Ecas0(_):
            f0_cas0(evn0, d3e0, err0)
        case D3Eseqn(_):
            f0_seqn(evn0, d3e0, err0)
        case D3Etup0(_):
            f0_tup0(evn0, d3e0, err0)
        case D3Etup1(_):
            f0_tup1(evn0, d3e0, err0)
        case D3Elam0(_):
            f0_lam0(evn0, d3e0, err0)
        case D3Efix0(_):
            f0_fix0(evn0, d3e0, err0)
        case D3Etry0(_):
            f0_try0(evn0, d3e0, err0)
        case D3Eaddr(_):
            f0_addr(evn0, d3e0, err0)
        case D3Eview(_):
            f0_view(evn0, d3e0, err0)
        case D3Eflat(_):
            f0_flat(evn0, d3e0, err0)
        case D3Eeval(_):
            f0_eval(evn0, d3e0, err0)
        case D3Efold(_):
            f0_fold(evn0, d3e0, err0)
        case D3Efree(_):
            f0_free(evn0, d3e0, err0)
        case D3Edp2tr(_):
            f0_dp2tr(evn0, d3e0, err0)
        case D3Edl0az(_):
            f0_dl0az(evn0, d3e0, err0)
        case D3Edl1az(_):
            f0_dl1az(evn0, d3e0, err0)
        case D3Ewhere(_):
            f0_where(evn0, d3e0, err0)
        case D3Eassgn(_):
            f0_assgn(evn0, d3e0, err0)
        case D3Exazgn(_):
            f0_xazgn(evn0, d3e0, err0)
        case D3Exchng(_):
            f0_xchng(evn0, d3e0, err0)
        case D3Eraise(_):
            f0_raise(evn0, d3e0, err0)
        case D3El0azy(_):
            f0_l0azy(evn0, d3e0, err0)
        case D3El1azy(_):
            f0_l1azy(evn0, d3e0, err0)
        case D3Eelazy(_):
            f0_elazy(evn0, d3e0, err0)
        case D3Eannot(_):
            f0_annot(evn0, d3e0, err0)
        case D3Et2ped(_):
            f0_t2ped(evn0, d3e0, err0)
        case _:
            let dres = d3exp_none2(d3e0)
            dres
where:
    def f0_timp(evn0: !t3r0evn, d3e0: d3exp, nerr: &SInt >> _) -> d3exp:
        let nerr = err0
        let D3Etimp(d3f0, timp) = d3e0.node()
        t3r0evn_timp/psh(evn0, timp)
        let timp = t3read0_timpl(evn0, timp, err0)
        t3r0evn_timp/pop(evn0)
        if (nerr == err0):
            d3e0
        else:
            let lvl0 = 0
            let loc0 = d3e0.lctn()
            let t2p0 = d3e0.styp()
            let tmps = t3r0evn_tmps/get(evn0)
            d3exp_errck(lvl0 + 1, d3exp_make_tpnd(loc0, t2p0, D3Etimq(d3f0, timp, tmps)))
    def f0_tapp(evn0: !t3r0evn, d3e0: d3exp, err0: &SInt >> _) -> d3exp:
        let nerr = err0
        let D3Etapp(d3f0, s2es) = d3e0.node()
        let d3f0 = t3read0_d3exp(evn0, d3f0, err0)
        if (err0 == nerr):
            d3e0
        else:
            let t2p0 = d3f0.styp()
            d3exp_tapp_errck(d3e0.lctn(), t2p0, d3f0, s2es)
    def f0_tapq(evn0: !t3r0evn, d3e0: d3exp, err0: &SInt >> _) -> d3exp:
        let nerr = err0
        let D3Etapq(d3f0, t2js) = d3e0.node()
        let d3f0 = t3read0_d3exp(evn0, d3f0, err0)
        if (err0 == nerr):
            d3e0
        else:
            let loc0 = d3e0.lctn()
            let t2p0 = d3e0.styp()
            d3exp_tapq_errck(d3e0.lctn(), t2p0, d3f0, t2js)
    def f0_dap0(evn0: !t3r0evn, d3e0: d3exp, err0: &SInt >> _) -> d3exp:
        let nerr = err0
        let D3Edap0(d3f0) = d3e0.node()
        let d3f0 = t3read0_d3exp(evn0, d3f0, err0)
        if (err0 == nerr):
            d3e0
        else:
            let loc0 = d3e0.lctn()
            let t2p0 = d3e0.styp()
            d3exp_dap0_errck(loc0, t2p0, d3f0)
    def f0_dapp(evn0: !t3r0evn, d3e0: d3exp, err0: &SInt >> _) -> d3exp:
        let nerr = err0
        let D3Edapp(d3f0, npf1, d3es) = d3e0.node()
        let d3f0 = t3read0_d3exp(evn0, d3f0, err0)
        let d3es = t3read0_d3explst(evn0, d3es, err0)
        if (err0 == nerr):
            d3e0
        else:
            let loc0 = d3e0.lctn()
            let t2p0 = d3e0.styp()
            d3exp_dapp_errck(loc0, t2p0, d3f0, npf1, d3es)
    def f0_pcon(evn0: !t3r0evn, d3e0: d3exp, err0: &SInt >> _) -> d3exp:
        let nerr = err0
        let D3Epcon(tknd, dlab, dcon) = d3e0.node()
        let dcon = t3read0_d3exp(evn0, dcon, err0)
        if (err0 == nerr):
            d3e0
        else:
            let loc0 = d3e0.lctn()
            let t2p0 = d3e0.styp()
            d3exp_pcon_errck(loc0, t2p0, tknd, dlab, dcon)
    def f0_proj(evn0: !t3r0evn, d3e0: d3exp, err0: &SInt >> _) -> d3exp:
        let nerr = err0
        let D3Eproj(tknd, dlab, dtup) = d3e0.node()
        let dtup = t3read0_d3exp(evn0, dtup, err0)
        if (err0 == nerr):
            d3e0
        else:
            let loc0 = d3e0.lctn()
            let t2p0 = d3e0.styp()
            d3exp_proj_errck(loc0, t2p0, tknd, dlab, dtup)
    def f0_let0(evn0: !t3r0evn, d3e0: d3exp, err0: &SInt >> _) -> d3exp:
        let nerr = err0
        let D3Elet0(dcls, d3e1) = d3e0.node()
        let dcls = t3read0_d3eclist(evn0, dcls, err0)
        let d3e1 = t3read0_d3exp(evn0, d3e1, err0)
        if (err0 == nerr):
