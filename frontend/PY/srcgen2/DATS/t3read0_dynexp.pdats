@impl
def t3read0_d3cls(evn0, dcls, err0):
    match dcls.node():
        case D3CLSgpt(dgpt):
            dcls
        case D3CLScls(dgpt, d3e1):
            let nerr = err0
            let d3e1 = t3read0_d3exp(evn0, d3e1, err0)
            if (err0 == nerr):
                dcls
            else:
                d3cls(dcls.lctn(), D3CLScls(dgpt, d3e1))

@impl
def t3read0_timpl(evn0, timp, err0):
    match timp.node():
        case TIMPLall1(dcst, t2js, d3cs):
            err0 := err0 + 1
            timp
        case TIMPLallx(dcst, t2js, d3cs):
            match d3cs:
                case list_nil():
                    err0 := err0 + 1
                    timp
                case list_cons(dcl1, d3cs):
                    let nerr = err0
                    let dcl1 = t3read0_d3ecl(evn0, dcl1, err0)
                    if (err0 == nerr):
                        timp
                    else:
                        let stmp = timp.stmp()
                        let d3cs = list_cons(dcl1, d3cs)
                        timpl_make_node(stmp, TIMPLallx(dcst, t2js, d3cs))

