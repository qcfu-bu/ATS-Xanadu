@overload lctn = token_get_lctn

@overload node = token_get_node

@overload sexp = d2con_get_sexp

@overload sexp = d2cst_get_sexp

def d3exp_errck(lvl0: SInt, d3e0: d3exp) -> d3exp:
    let loc0 = d3e0.lctn()
    let t2p0 = d3e0.styp()
    d3exp_make_tpnd(loc0, t2p0, D3Eerrck(lvl0, d3e0))

def d3exp_errvl_a1(d3e0: d3exp) -> SInt:
    match d3e0.node():
        case D3Eerrck(lvl0, _):
            lvl0
        case _:
            0

@overload d3exp_errvl = d3exp_errvl_a1

@overload errvl = d3exp_errvl_a1

def d3exp_errvl_a2(d3e1: d3exp, d3e2: d3exp) -> SInt:
    maxs(errvl(d3e1), errvl(d3e2))

@overload d3exp_errvl = d3exp_errvl_a2

@overload errvl = d3exp_errvl_a2

@extern
def d3exp_errvl_lst(d3es: d3explst) -> SInt

@impl
def d3exp_errvl_lst(d3es):
    match d3es:
        case list_nil():
            0
        case list_cons(d3e1, d3es):
            maxs(errvl(d3e1), d3exp_errvl_lst(d3es))

@overload d3exp_errvl = d3exp_errvl_lst

@overload errvl = d3exp_errvl_lst

@extern
def d3exp_errvl_opt(dopt: d3expopt) -> SInt

@impl
def d3exp_errvl_opt(dopt):
    match dopt:
        case optn_nil():
            0
        case optn_cons(d3e1):
            errvl(d3e1)

@overload d3exp_errvl = d3exp_errvl_opt

@overload errvl = d3exp_errvl_opt

def d3cls_errvl_a1(dcl: d3cls) -> SInt:
    match dcl.node():
        case D3CLSgpt(dgpt):
            0
        case D3CLScls(dgpt, d3e1):
            errvl(d3e1)

@overload errvl = d3cls_errvl_a1

@extern
def d3cls_errvl_lst(dcls: d3clslst) -> SInt

@impl
def d3cls_errvl_lst(dcls):
    match dcls:
        case list_nil():
            0
        case list_cons(dcl1, dcls):
            maxs(errvl(dcl1), d3cls_errvl_lst(dcls))

@overload errvl = d3cls_errvl_lst

