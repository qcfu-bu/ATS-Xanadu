@impl
def implknd_fprint(knd, out):
    @impl[]
    def g_print/out():
        out
    match knd:
        case IMPLgen():
            print("IMPLgen")
        case IMPLprf():
            print("IMPLprf")
        case IMPLval():
            print("IMPLval")
        case IMPLfun():
            print("IMPLfun")
        case IMPLtmp():
