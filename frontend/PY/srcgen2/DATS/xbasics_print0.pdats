let xatsv_ATS_PACKNAME = "ATS3.XANADU.xatsopt-20220500"

include "srcgen2/HATS/xatsopt_sats.hats"

include "srcgen2/HATS/xatsopt_dpre.hats"

from "srcgen2/SATS/xbasics" import *

@impl
def dctkind_fprint(dck, out):
    match dck:
        case DCKfun():
            print("DCKfun")
        case DCKval():
            print("DCKval")
        case DCKpraxi():
            print("DCKpraxi")
        case DCKprfun():
            print("DCKprfun")
        case DCKprval():
            print("DCKprval")
        case DCKfcast():
            print("DCKfcast")
        case DCKnspec():
            print("DCKnspec")
where:
    @impl[]
    def g_print/out():
        out

@impl
def valkind_fprint(vlk, out):
    @impl[]
    def g_print/out():
        out
    match vlk:
        case VLKval():
            print("VLKval")
        case VLKvlp():
            print("VLKvlp")
        case VLKvln():
            print("VLKvln")
        case VLKvlr():
            print("VLKvlr")
        case VLKprval():
            print("VLKprval")

@impl
def varkind_fprint(vrk, out):
    @impl[]
    def g_print/out():
        out
    match vrk:
        case VRKvar():
            print("VAKvar")

@impl
def funkind_fprint(fnk, out):
    @impl[]
    def g_print/out():
        out
    match fnk:
        case FNKfn0():
            print("FNKfn0")
        case FNKfn1():
            print("FNKfn1")
        case FNKfn2():
            print("FNKfn2")
        case FNKfnx():
            print("FNKfnx")
        case FNKfun():
            print("FNKfun")
        case FNKpraxi():
            print("FNKpraxi")
        case FNKprfn0():
            print("FNKprfn0")
        case FNKprfn1():
            print("FNKprfn1")
        case FNKprfun():
            print("FNKprfun")
        case FNKfcast():
            print("FNKfcast")

