@impl
def f2clknd_fprint(f2cl, out):
    @impl[]
    def g_print/out():
        out
    match f2cl:
        case F2CLfun():
            print("F2CLfun")
        case F2CLclo(knd):
            prints("F2CLclo(", knd, ")")

@impl
