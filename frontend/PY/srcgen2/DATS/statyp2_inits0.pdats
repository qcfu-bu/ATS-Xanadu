@impl
def the_s2typ_elazy1(tlam):
    let s2t0 = the_sort2_tbox
    let tcon = the_s2typ_elazy0()
    let tenv = match tlam.node():
        case T2Pfun1(f2cl, npf1, t2ps, tres):
            if (list_singq(t2ps)):
                list_head(t2ps)
            else:
                s2typ_none0()
        case _:
            s2typ_none0()
    let telt = match tlam.node():
        case T2Pfun1(f2cl, npf1, t2ps, tres):
            tres
        case _:
            s2typ_none0()
    s2typ(s2t0, T2Papps(tcon, list_pair(telt, tenv)))


