    let sllint_t2pr = @inst[s2typ] a0ref_make_1val(t2p0)
    let ullint_t2pr = @inst[s2typ] a0ref_make_1val(t2p0)
    def s2typ_name_t2pr(name: sym_t, t2pr: a0ref[s2typ]) -> s2typ:
        let t2p0 = t2pr[]
        match t2p0.node():
            case T2Pnone0():
                let opt1 = the_sexpenv_pvsfind(name)
                match opt1:
                    case ~optn_vt_nil():
                        t2p0
                    case ~optn_vt_cons(s2i1):
                        match s2i1:
                            case S2ITMcst(s2cs):
                                let list_cons(s2c1, _) = s2cs
                                let t2p1 = s2typ_cst(s2c1)
                                t2pr[] := t2p1
                                t2p1
                            case _:
                                t2p0
            case _:
                t2p0

