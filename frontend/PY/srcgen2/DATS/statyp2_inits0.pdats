    let ullint_name = symbl("the_s2exp_ullint0")
    private:
        let t2p0 = s2typ_none0()

    let void_t2pr = @inst[s2typ] a0ref_make_1val(t2p0)
    let sint_t2pr = @inst[s2typ] a0ref_make_1val(t2p0)
    let uint_t2pr = @inst[s2typ] a0ref_make_1val(t2p0)
    let bool_t2pr = @inst[s2typ] a0ref_make_1val(t2p0)
    let char_t2pr = @inst[s2typ] a0ref_make_1val(t2p0)
