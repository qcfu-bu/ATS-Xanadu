@impl
def trans01_d0arg(tenv, d0a0):
    let loc0 = d0a0.lctn()
    match d0a0.node():
        case D0ARGnone(tok):
            let loc = tok.lctn()
            let tok = token_make_node(loc, T0IDALP_NONE)
            d1arg_make_node(loc0, D1ARGdyn1(tok))
        case D0ARGsta0(_, s0qs, _):
            let s1qs = trans01_s0qualst(tenv, s0qs)
            d1arg_make_node(loc0, D1ARGsta0(s1qs))
        case D0ARGdyn1(dpid):
            let dpid = trans01_i0dnt(tenv, dpid)
            d1arg_make_node(loc0, D1ARGdyn1(dpid))
        case D0ARGdyn2(tbeg, a0ts, aopt, tend):
            let a1ts = trans01_a0typlst(tenv, a0ts)
            let aopt = optn_trans01_fnp(tenv, aopt, trans01_a0typlst)
            d1arg_make_node(loc0, D1ARGdyn2(a1ts, aopt))

def s1taload_from_fpath(fpth: fpath) -> (SInt, d1parsed):
    let fnm2 = fpath_get_fnm2(fpth)
    let opt2 = the_d1parenv_pvsfind(fnm2)
    match opt2:
        case ~optn_vt_nil():
            let fnm1 = fpath_get_fnm1(fpth)
            let knd1 = fname_stadyn(fnm1)
            let knd1 = if knd1 < 0:
                0
            else: knd1
            let dpar = d0parsed_from_fpath(knd1, fnm1)
            let dpar = d0parsed_of_pread00(dpar)
            let dpar = d1parsed_of_trans01(dpar)
            the_d1parenv_pvsadd0(fnm2, dpar)
            (0, dpar)
        case ~optn_vt_cons(dpar):
            (1, dpar)

@impl
def trans01_d0ecl(tenv, d0cl):
    match d0cl.node():
        case D0Cfixity(_):
            f0_fixity(tenv, d0cl)
        case D0Cnonfix(_):
            f0_nonfix(tenv, d0cl)
        case D0Cstatic(_):
            f0_static(tenv, d0cl)
        case D0Cextern(_):
            f0_extern(tenv, d0cl)
        case D0Cdefine(_):
            f0_define(tenv, d0cl)
        case D0Cmacdef(_):
            f0_macdef(tenv, d0cl)
        case D0Clocal0(tbeg, dcs1, topt, dcs2, tend):
            let loc0 = d0cl.lctn()
            tr01env_pshloc1(tenv)
            let dcs1 = trans01_d0eclist(tenv, dcs1)
            tr01env_pshloc2(tenv)
            let dcs2 = trans01_d0eclist(tenv, dcs2)
            tr01env_locjoin(tenv)
            d1ecl(loc0, D1Clocal0(dcs1, dcs2))
        case D0Cabssort(_):
            f0_abssort(tenv, d0cl)
        case D0Cstacst0(_):
            f0_stacst0(tenv, d0cl)
        case D0Csortdef(_):
            f0_sortdef(tenv, d0cl)
        case D0Csexpdef(_):
            f0_sexpdef(tenv, d0cl)
        case D0Cabstype(_):
            f0_abstype(tenv, d0cl)
        case D0Cabsopen(_):
            f0_absopen(tenv, d0cl)
        case D0Cabsimpl(_):
            f0_absimpl(tenv, d0cl)
        case D0Csymload(_):
            f0_symload(tenv, d0cl)
        case D0Cinclude(_):
            f0_include(tenv, d0cl)
        case D0Cstaload(_):
            f0_staload(tenv, d0cl)
        case D0Cdyninit(_):
            f0_dyninit(tenv, d0cl)
        case D0Cextcode(_):
            f0_extcode(tenv, d0cl)
        case D0Cdatasort(_):
            f0_datasort(tenv, d0cl)
        case D0Cvaldclst(_):
            f0_valdclst(tenv, d0cl)
        case D0Cvardclst(_):
            f0_vardclst(tenv, d0cl)
        case D0Cfundclst(_):
            f0_fundclst(tenv, d0cl)
        case D0Cimplmnt0(_):
            f0_implmnt0(tenv, d0cl)
        case D0Cexcptcon(_):
            f0_excptcon(tenv, d0cl)
        case D0Cdatatype(_):
            f0_datatype(tenv, d0cl)
        case D0Cdynconst(_):
            f0_dynconst(tenv, d0cl)
        case D0Ctkerr(tok):
            match tok.node():
                case T_EOF():
                    d1ecl_none0(d0cl.lctn())
                case _:
                    d1ecl_none1(d0cl)
        case _:
            d1ecl_none1(d0cl)
where:
    def f0_fixity(tenv: !tr01env, d0cl: d0ecl) -> d1ecl:
        let loc0 = d0cl.lctn()
        let D0Cfixity(tknd, id0s, popt) = d0cl.node()
        let T_SRP_FIXITY(knd0) = tknd.node()
        let pval = prcdv_encode(h1precopt(tenv, popt))
        let fxty = if (knd0 == KINFIX0):
            FIXTYinf(pval, ASSOCnon)
        else: match ():
            case ():
                if (knd0 == KINFIXL):
                    FIXTYinf(pval, ASSOClft)
                else:
                    if (knd0 == KINFIXR):
                        FIXTYinf(pval, ASSOCrgt)
                    else:
                        if (knd0 == KPREFIX):
                            FIXTYpre(pval)
                        else:
                            if (knd0 == KPSTFIX):
                                FIXTYpst(pval)
                            else:
                                FIXTYnon()
        def loop(tenv: !tr01env, id0s: i0dntlst) -> Void:
            match id0s:
                case list_nil():
                    ()
                case list_cons(id0, id0s):
                    let tok = trans01_i0dnt(tenv, id0)
                    let sym = match tok.node():
                        case T_IDALP(nam):
                            symbl(nam)
                        case T_IDSYM(nam):
                            symbl(nam)
                        case T_IDDLR(nam):
                            symbl(nam)
                    tr01env_insmix/any(tenv, sym, fxty)
                    loop(tenv, id0s)
        loop(tenv, id0s)
        d1ecl_make_node(loc0, D1Cd0ecl(d0cl))
    where:
        def h1signint(pint: precint) -> SInt:
            match pint:
                case PINTint1(tint):
                    token2sint(tint)
                case PINTopr2(topr, tint):
                    match topr.node():
                        case T_IDSYM("+"):
                            0 + token2sint(tint)
                        case T_IDSYM("-"):
                            0 - token2sint(tint)
        def h1precopt(tenv: !tr01env, popt: precopt) -> SInt:
            match popt:
                case PRECnil0():
                    0
                case PRECint1(tint):
                    token2sint(tint)
                case PRECopr2(topr, pmod):
                    let tok = trans01_i0dnt(tenv, topr)
                    let sym = match tok.node():
                        case T_IDALP(nam):
                            symbl(nam)
                        case T_IDSYM(nam):
                            symbl(nam)
                    let fopt = tr01env_search/opt(tenv, sym)
                    let pval = match fopt:
                        case ~optn_vt_nil():
                            let nam = sym.name()
                            prerrs("TRANS01-WARN1:", tok.lctn())
                            prerrsln(":[", nam, "] is a non-operator!")
                            0
                        case ~optn_vt_cons(fxty):
                            prcdv_decode(fixty_prcdv(fxty))
                    match pmod:
                        case PMODnone():
                            pval
                        case PMODsome(tbeg, pint, tend):
                            pval + h1signint(pint)
    def f0_nonfix(tenv: !tr01env, d0cl: d0ecl) -> d1ecl:
        let loc0 = d0cl.lctn()
        let D0Cnonfix(tknd, id0s) = d0cl.node()
        def loop(tenv: !tr01env, id0s: i0dntlst) -> Void:
            match id0s:
                case list_nil():
                    ()
                case list_cons(id0, id0s):
                    let tok = trans01_i0dnt(tenv, id0)
                    let sym = match tok.node():
                        case T_IDALP(nam):
                            symbl(nam)
                        case T_IDSYM(nam):
                            symbl(nam)
                    tr01env_insert/any(tenv, sym, FIXTYnon)
                    loop(tenv, id0s)
        loop(tenv, id0s)
        d1ecl_make_node(loc0, D1Cd0ecl(d0cl))
    def f0_static(tenv: !tr01env, d0cl: d0ecl) -> d1ecl:
        let loc0 = d0cl.lctn()
        let D0Cstatic(tknd, dcl1) = d0cl.node()
        let dcl1 = trans01_d0ecl(tenv, dcl1)
        d1ecl(loc0, D1Cstatic(tknd, dcl1))
    def f0_extern(tenv: !tr01env, d0cl: d0ecl) -> d1ecl:
        let loc0 = d0cl.lctn()
        let D0Cextern(tknd, dcl1) = d0cl.node()
        let dcl1 = trans01_d0ecl(tenv, dcl1)
        d1ecl(loc0, D1Cextern(tknd, dcl1))
    def f0_define(tenv: !tr01env, d0cl: d0ecl) -> d1ecl:
        let loc0 = d0cl.lctn()
        let D0Cdefine(tknd, geid, gmas, gedf) = d0cl.node()
        let geid = trans01_i0dnt(tenv, geid)
        let gmas = trans01_g0maglst(tenv, gmas)
        let gedf = match gedf:
            case G0EDFnone():
                optn_nil()
            case G0EDFsome(topt, g0e1):
                optn_cons(trans01_g0exp(tenv, g0e1))
        d1ecl_make_node(loc0, D1Cdefine(tknd, geid, gmas, gedf))
    def f0_macdef(tenv: !tr01env, d0cl: d0ecl) -> d1ecl:
        let loc0 = d0cl.lctn()
        let D0Cmacdef(tknd, geid, gmas, dedf) = d0cl.node()
        let geid = trans01_i0dnt(tenv, geid)
        let gmas = trans01_g0maglst(tenv, gmas)
        let dedf = match dedf:
            case D0EDFnone():
                optn_nil()
            case D0EDFsome(topt, d0e1):
                optn_cons(trans01_d0exp(tenv, d0e1))
        d1ecl_make_node(loc0, D1Cmacdef(tknd, geid, gmas, dedf))
    def f0_abssort(tenv: !tr01env, d0cl: d0ecl) -> d1ecl:
        let loc0 = d0cl.lctn()
        let D0Cabssort(tknd, tid0) = d0cl.node()
        let tid0 = trans01_i0dnt(tenv, tid0)
        d1ecl(loc0, D1Cabssort(tknd, tid0))
    def f0_stacst0(tenv: !tr01env, d0cl: d0ecl) -> d1ecl:
        let loc0 = d0cl.lctn()
        let D0Cstacst0(tknd, sid0, tmas, tcln, s0t1) = d0cl.node()
        let sid0 = trans01_i0dnt(tenv, sid0)
        let tmas = trans01_t0maglst(tenv, tmas)
        let s1t1 = trans01_sort0(tenv, s0t1)
        d1ecl_make_node(loc0, D1Cstacst0(tknd, sid0, tmas, s1t1))
    def f0_sortdef(tenv: !tr01env, d0cl: d0ecl) -> d1ecl:
        let D0Csortdef(tknd, tid0, teq1, stdf) = d0cl.node()
        let tid0 = trans01_i0dnt(tenv, tid0)
        let stdf = match stdf.node():
            case S0TDFsort(s0t1):
                let s1t1 = trans01_sort0(tenv, s0t1)
                s1tdf(stdf.lctn(), S1TDFsort(s1t1))
            case S0TDFtsub(tbeg, s0a1, tbar, s0es, tend):
                let s1a1 = trans01_s0arg(tenv, s0a1)
                let s1es = trans01_s0explst(tenv, s0es)
                s1tdf(stdf.lctn(), S1TDFtsub(s1a1, s1es))
        d1ecl_make_node(d0cl.lctn(), D1Csortdef(tknd, tid0, stdf))
    def f0_sexpdef(tenv: !tr01env, d0cl: d0ecl) -> d1ecl:
        let loc0 = d0cl.lctn()
        let D0Csexpdef(tknd, seid, smas, tres, teq1, s0e2) = d0cl.node()
        let seid = trans01_i0dnt(tenv, seid)
        let smas = trans01_s0maglst(tenv, smas)
        let tres = trans01_sort0opt(tenv, tres)
        let s1e2 = trans01_s0exp(tenv, s0e2)
        d1ecl_make_node(loc0, D1Csexpdef(tknd, seid, smas, tres, s1e2))
    def f0_abstype(tenv: !tr01env, d0cl: d0ecl) -> d1ecl:
        let loc0 = d0cl.lctn()
        let D0Cabstype(tknd, seid, tmas, tres, atdf) = d0cl.node()
        let seid = trans01_i0dnt(tenv, seid)
        let tmas = trans01_t0maglst(tenv, tmas)
        let tres = trans01_sort0opt(tenv, tres)
        let atdf = match atdf:
            case A0TDFsome():
                A1TDFsome()
            case A0TDFlteq(tknd, s0e1):
                A1TDFlteq(trans01_s0exp(tenv, s0e1))
            case A0TDFeqeq(tknd, s0e1):
                A1TDFeqeq(trans01_s0exp(tenv, s0e1))
        d1ecl_make_node(loc0, D1Cabstype(tknd, seid, tmas, tres, atdf))
    def f0_absopen(tenv: !tr01env, d0cl: d0ecl) -> d1ecl:
        let loc0 = d0cl.lctn()
        let D0Cabsopen(tknd, sqid) = d0cl.node()
        let sqid = trans01_s0qid(tenv, sqid)
        d1ecl_make_node(loc0, D1Cabsopen(tknd, sqid))
    def f0_absimpl(tenv: !tr01env, d0cl: d0ecl) -> d1ecl:
        let loc0 = d0cl.lctn()
        let D0Cabsimpl(tknd, sqid, smas, tres, teq1, s0e2) = d0cl.node()
        let sqid = trans01_s0qid(tenv, sqid)
        let smas = trans01_s0maglst(tenv, smas)
        let tres = trans01_sort0opt(tenv, tres)
        let s1e2 = trans01_s0exp(tenv, s0e2)
        d1ecl_make_node(loc0, D1Cabsimpl(tknd, sqid, smas, tres, s1e2))
    def f0_symload(tenv: !tr01env, d0cl: d0ecl) -> d1ecl:
        let loc0 = d0cl.lctn()
        let D0Csymload(tknd, symb, twth, dqid, gopt) = d0cl.node()
        let deid = match symb.node():
            case S0YMBi0dnt(deid):
                let tok = trans01_i0dnt(tenv, deid)
                match tok.node():
                    case T_IDALP(nam):
                        symbl(nam)
                    case T_IDSYM(nam):
                        symbl(nam)
                    case T_IDDLR(nam):
                        symbl(nam)
            case S0YMBbrckt(tlb, trb):
                symbl("[]")
        let dqid = trans01_d0qid(tenv, dqid)
        let gopt = trans01_g0expopt(tenv, gopt)
        d1ecl_make_node(loc0, D1Csymload(tknd, deid, dqid, gopt))
    private:
        def xstrnormize(base: String) -> String:
            base
        def xstrevalize(base: String) -> String:
            base
        def f0_g1e1(g1e1: g1exp) -> fnameopt:
            match g1e1.node():
                case G1Estr(_):
                    f1_gstr(g1e1)
                case _:
                    optn_nil()

        def f1_gstr(g1e1: g1exp) -> fnameopt:
            f1_tokn(tok1)
        where:
            let G1Estr(tok1) = g1e1.node()

        def f1_tokn(tok1: token) -> fnameopt:
            match tok1.node():
                case T_STRN1_clsd(base, ln):
                    let base = xstrunqtize(base, ln)
                    let base = xstrnormize(base)
                    let base = xstrevalize(base)
                    optn_cons(FNMbase(base))
                case _:
                    optn_nil()

    def f0_include(tenv: !tr01env, d0cl: d0ecl) -> d1ecl:
        let D0Cinclude(knd0, tknd, g0e1) = d0cl.node()
        let g1e1 = trans01_g0exp(tenv, g0e1)
        let opt0 = f0_g1e1(g1e1)
        let opt1 = match opt0:
            case optn_nil():
                optn_nil()
            case optn_cons(fnm0):
                fsrch_combined(fnm0)
        let dopt = match opt1:
            case optn_nil():
                optn_nil()
            case optn_cons(fpth):
                let fnm1 = fpath_get_fnm1(fpth)
                let knd1 = if knd0 <= 0:
                    knd0
                else: match ():
                    case ():
                        let knd1 = fname_stadyn(fnm1)
                        if knd1 < 0:
                            knd0
                        else:
                            knd1
                let dpar = d0parsed_from_fpath(knd1, fnm1)
                let src0 = d0parsed_get_source(dpar)
                let dopt = d0parsed_get_parsed(dpar)
                the_drpth_push_lcsrc(src0)
                let dopt = trans01_d0eclistopt(tenv, dopt)
                the_drpth_pop0_lcsrc(src0)
                dopt
        d1ecl_make_node(loc0, D1Cinclude(knd0, tknd, g1e1, opt1, dopt))
    where:
        let loc0 = d0cl.lctn()
    private:
        def xstrnormize(base: String) -> String:
            base
        def xstrevalize(base: String) -> String:
            base
        def f0_g1e1(g1e1: g1exp) -> fnameopt:
            match g1e1.node():
                case G1Estr(_):
                    f1_gstr(g1e1)
                case G1Ea2pp(_):
                    f1_a2pp(g1e1)
                case _:
                    optn_nil()

        def f1_gstr(g1e1: g1exp) -> fnameopt:
            f1_tokn(tok1)
        where:
            let G1Estr(tok1) = g1e1.node()

        def f1_tokn(tok1: token) -> fnameopt:
            match tok1.node():
                case T_STRN1_clsd(base, ln):
                    let base = xstrunqtize(base, ln)
                    let base = xstrnormize(base)
                    let base = xstrevalize(base)
                    optn_cons(FNMbase(base))
                case _:
                    optn_nil()

        def f1_a2pp(gapp: g1exp) -> fnameopt:
            match gapp.node():
                case G1Ea2pp(g1f0, g1e1, g1e2):
                    match g1f0.node():
                        case G1Eid0(id0):
                            if (id0 != EQ0_symbl):
                                optn_nil
                            else:
                                match g1e2.node():
                                    case G1Estr(_):
                                        f1_gstr(g1e2)
                                    case _:
                                        optn_nil()
                        case _:
                            optn_nil()

    def f0_staload(tenv: !tr01env, d0cl: d0ecl) -> d1ecl:
        let D0Cstaload(knd0, tknd, g0e1) = d0cl.node()
        let g1e1 = trans01_g0exp(tenv, g0e1)
        let opt0 = f0_g1e1(g1e1)
        let opt1 = match opt0:
            case optn_nil():
                optn_nil()
            case optn_cons(fnm0):
                fsrch_combined(fnm0)
        let dopt = match opt1:
            case optn_nil():
                optn_nil()
            case optn_cons(fpth):
                optn_cons(s1taload_from_fpath(fpth))
        let knd0 = match dopt:
            case optn_nil():
                knd0
            case optn_cons((shrd, dpar)):
                dpar.stadyn()
        d1ecl(loc0, D1Cstaload(knd0, tknd, g1e1, opt1, dopt))
    where:
        let loc0 = d0cl.lctn()
    def f0_dyninit(tenv: !tr01env, d0cl: d0ecl) -> d1ecl:
        let D0Cdyninit(tknd, g0e1) = d0cl.node()
        let g1e1 = trans01_g0exp(tenv, g0e1)
        d1ecl(loc0, D1Cdyninit(tknd, g1e1))
    where:
        let loc0 = d0cl.lctn()
    def f0_extcode(tenv: !tr01env, d0cl: d0ecl) -> d1ecl:
        let D0Cextcode(tknd, g0e1) = d0cl.node()
        let g1e1 = trans01_g0exp(tenv, g0e1)
        d1ecl(loc0, D1Cextcode(tknd, g1e1))
    where:
        let loc0 = d0cl.lctn()
    def f0_datasort(tenv: !tr01env, d0cl: d0ecl) -> d1ecl:
        let loc0 = d0cl.lctn()
        let D0Cdatasort(tknd, d0ts) = d0cl.node()
        let d1ts = trans01_d0tstlst(tenv, d0ts)
        d1ecl(loc0, D1Cdatasort(tknd, d1ts))
    def f0_valdclst(tenv: !tr01env, d0cl: d0ecl) -> d1ecl:
        let loc0 = d0cl.lctn()
        let D0Cvaldclst(tknd, d0vs) = d0cl.node()
        let d1vs = trans01_d0valdclist(tenv, d0vs)
        d1ecl(loc0, D1Cvaldclst(tknd, d1vs))
    def f0_vardclst(tenv: !tr01env, d0cl: d0ecl) -> d1ecl:
        let loc0 = d0cl.lctn()
        let D0Cvardclst(tknd, d0vs) = d0cl.node()
        let d1vs = trans01_d0vardclist(tenv, d0vs)
        d1ecl(loc0, D1Cvardclst(tknd, d1vs))
    def f0_fundclst(tenv: !tr01env, d0cl: d0ecl) -> d1ecl:
        let loc0 = d0cl.lctn()
        let D0Cfundclst(tknd, tqas, d0fs) = d0cl.node()
        let tqas = trans01_t0qaglst(tenv, tqas)
        let d1fs = trans01_d0fundclist(tenv, d0fs)
        d1ecl(loc0, D1Cfundclst(tknd, tqas, d1fs))
    def f0_implmnt0(tenv: !tr01env, d0cl: d0ecl) -> d1ecl:
        let loc0 = d0cl.lctn()
        let D0Cimplmnt0(tknd, sqas, tqas, dqid, tias, f0as, sres, teq1, body) = d0cl.node()
        let sqas = trans01_s0qaglst(tenv, sqas)
        let tqas = trans01_t0qaglst(tenv, tqas)
        let dqid = trans01_d0qid(tenv, dqid)
        let tias = trans01_t0iaglst(tenv, tias)
        let f1as = trans01_f0arglst(tenv, f0as)
        let sres = trans01_s0res(tenv, sres)
        let body = trans01_d0exp(tenv, body)
        d1ecl_make_node(loc0, D1Cimplmnt0(tknd, sqas, tqas, dqid, tias, f1as, sres, body))
    def f0_excptcon(tenv: !tr01env, d0cl: d0ecl) -> d1ecl:
        let loc0 = d0cl.lctn()
        let D0Cexcptcon(tknd, topt, tcns) = d0cl.node()
        let tcns = trans01_d0tcnlst(tenv, tcns)
        d1ecl_make_node(loc0, D1Cexcptcon(tknd, tcns))
    def f0_datatype(tenv: !tr01env, d0cl: d0ecl) -> d1ecl:
        let loc0 = d0cl.lctn()
        let D0Cdatatype(tknd, d0ts, wdcs) = d0cl.node()
        let d1ts = trans01_d0typlst(tenv, d0ts)
        let wdcs = trans01_wd0eclseq(tenv, wdcs)
        d1ecl(loc0, D1Cdatatype(tknd, d1ts, wdcs))
    def f0_dynconst(tenv: !tr01env, d0cl: d0ecl) -> d1ecl:
        let loc0 = d0cl.lctn()
        let D0Cdynconst(tknd, tqas, d0cs) = d0cl.node()
        let tqas = trans01_t0qaglst(tenv, tqas)
        let d1cs = trans01_d0cstdclist(tenv, d0cs)
        d1ecl(loc0, D1Cdynconst(tknd, tqas, d1cs))

