@impl
def trans01_d0eclist(tenv, dcls):
    let dres = list_vt_nil()
    list_vt2t(list_vt_reverse0(f0_d0eclist(tenv, dcls, dres)))
where:
    type D1eclist_vt = list_vt[d1ecl]
    def d1cls_vt2t_reverse0(dcls: list_vt[d1ecl]) -> d1eclist:
        list_vt2t(@inst[d1ecl] list_vt_reverse0(dcls))
    def f1_then0(tenv: !tr01env, dcl0: d0ecl, dcls: d0eclist) -> (d1eclopt, d0eclist):
        match dcls:
            case list_nil():
                let dthn = optn_nil()
                (dthn, dcls)
            case list_cons(dcl1, d2ls):
                match dcl1.node():
                    case D0Cthen0(_):
                        let dres = list_vt_nil()
                        let (dres, dcls) = f1_d0eclist(tenv, d2ls, dres)
                        let loc1 = dcl1.lctn()
                        let opt1 = optn_cons(d1ecl(loc1, D1Cthen0(dres)))
                        (opt1, dcls)
                    case _:
                        let dres = list_vt_nil()
                        let (dres, dcls) = f1_d0eclist(tenv, dcls, dres)
                        let loc1 = dcl0.lctn()
                        let opt1 = optn_cons(d1ecl(loc1, D1Cthen0(dres)))
                        (opt1, dcls)

    def f1_else1(tenv: !tr01env, dcl0: d0ecl, dcls: d0eclist) -> (d1eclopt, d0eclist):
        match dcls:
            case list_nil():
                let dels = optn_nil()
                (dels, dcls)
            case list_cons(dcl1, d2ls):
                match dcl1.node():
                    case D0Celse1(_):
                        let dres = list_vt_nil()
                        let (dres, dcls) = f1_d0eclist(tenv, d2ls, dres)
                        let loc1 = dcl1.lctn()
                        let opt1 = optn_cons(d1ecl(loc1, D1Celse1(dres)))
                        (opt1, dcls)
                    case D0Celsif(tknd, gexp):
                        let (dthn, dcls) = f1_then0(tenv, dcl1, d2ls)
                        let (dels, dcls) = f1_else1(tenv, dcl1, dcls)
                        let dend = optn_nil
                        let loc1 = dcl1.lctn()
                        let gexp = trans01_g0exp(tenv, gexp)
                        let opt1 = optn_cons(d1ecl(loc1, D1Celsif(gexp, dthn, dels, dend)))
                        (opt1, dcls)
                    case _:
                        let dels = optn_nil()
                        (dels, dcls)

    def f1_endif(tenv: !tr01env, dcl0: d0ecl, dcls: d0eclist) -> (d1eclopt, d0eclist):
        match dcls:
            case list_nil():
                let dels = optn_nil()
                (dels, dcls)
            case list_cons(dcl1, d2ls):
                match dcl1.node():
                    case D0Cendif(tend):
                        let loc1 = dcl1.lctn()
                        let opt1 = optn_cons(d1ecl(loc1, D1Cendif(tend)))
                        (opt1, d2ls)
                    case _:
                        let dels = optn_nil()
                        (dels, dcls)

    def f1_d0ecl(tenv: !tr01env, dcl0: d0ecl, dcls: d0eclist) -> (d1ecl, d0eclist):
        match dcl0.node():
            case D0Cifexp(tknd, gexp):
                let (dthn, dcls) = f1_then0(tenv, dcl0, dcls)
                let (dels, dcls) = f1_else1(tenv, dcl0, dcls)
                let (dend, dcls) = f1_endif(tenv, dcl0, dcls)
                let loc0 = dcl0.lctn()
                let gexp = trans01_g0exp(tenv, gexp)
                let dcl0 = d1ecl(loc0, D1Cifexp(gexp, dthn, dels, dend))
                (dcl0, dcls)
            case _:
                let dcl0 = trans01_d0ecl(tenv, dcl0)
                (dcl0, dcls)

    def f1_d0eclist(tenv: !tr01env, dcls: d0eclist, dres: D1eclist_vt) -> (d1eclist, d0eclist):
        match dcls:
            case list_nil():
                let dres = d1cls_vt2t_reverse0(dres)
                (dres, dcls)
            case list_cons(dcl1, d2ls):
                match dcl1.node():
                    case D0Celse1(_):
                        let dres = d1cls_vt2t_reverse0(dres)
                        (dres, dcls)
                    case D0Celsif(_):
                        let dres = d1cls_vt2t_reverse0(dres)
                        (dres, dcls)
                    case D0Cendif(_):
                        let dres = d1cls_vt2t_reverse0(dres)
                        (dres, dcls)
                    case _:
                        let (dcl1, dcls) = f1_d0ecl(tenv, dcl1, d2ls)
                        let dres = list_vt_cons(dcl1, dres)
                        f1_d0eclist(tenv, dcls, dres)
    def f0_d0eclist(tenv: !tr01env, dcls: d0eclist, dres: D1eclist_vt) -> D1eclist_vt:
        match dcls:
            case list_nil():
                dres
            case list_cons(dcl1, d2ls):
                match dcl1.node():
                    case D0Cifexp(_):
                        let (dcl1, dcls) = f1_d0ecl(tenv, dcl1, d2ls)
                        let dres = list_vt_cons(dcl1, dres)
                        f0_d0eclist(tenv, dcls, dres)
                    case _:
                        let dcl1 = trans01_d0ecl(tenv, dcl1)
                        let dres = list_vt_cons(dcl1, dres)
                        f0_d0eclist(tenv, d2ls, dres)

