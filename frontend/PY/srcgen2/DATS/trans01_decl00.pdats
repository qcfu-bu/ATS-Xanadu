def xstrunqtize(src0: String, ln: SInt) -> String:
    let n0 = ln - 1
    type Chrs = list_vt[Char]
    def loop(i0: SInt, cs: Chrs) -> String:
        if (i0 < n0):
            let c0 = src0[i0]
            match 0:
                case _ if (c0 == '\\'):
                    let i1 = i0 + 1
                    let c1 = src0[i1]
                    let ch = match 0:
                        case _ if c1 == 'n':
                            '\n'
                        case _ if c1 == 't':
                            '\t'
                        case _ if c1 == 'r':
                            '\r'
                        case _ if c1 == 'b':
                            '\b'
                        case _ if c1 == 'f':
                            '\f'
                        case _ if c1 == 'v':
                            '\v'
                        case _:
                            c1
                    if (ch == '\n'):
                        loop(i1 + 1, cs)
                    else:
                        loop(i1 + 1, list_vt_cons(ch, cs))
                case _:
                    loop(i0 + 1, list_vt_cons(c0, cs))
        else:
            strn_make_llist(list_vt_reverse0(cs))
    loop(1, list_vt_nil())

@impl
def trans01_q0arg(tenv, q0a0):
    match q0a0.node():
        case Q0ARGsome(sid0, tres):
            let sid0 = trans01_i0dnt(tenv, sid0)
            let tres = trans01_sort0opt(tenv, tres)
            q1arg_make_node(q0a0.lctn(), Q1ARGsome(sid0, tres))

@impl
def trans01_s0qag(tenv, sqa0):
    match sqa0.node():
        case S0QAGnone(tok):
            let q1as = list_nil
            s1qag_make_node(sqa0.lctn(), S1QAGsome(q1as))
        case S0QAGsome(tbeg, q0as, tend):
            let q1as = trans01_q0arglst(tenv, q0as)
            s1qag_make_node(sqa0.lctn(), S1QAGsome(q1as))

