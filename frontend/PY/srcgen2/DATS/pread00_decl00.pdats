@extern
def pread00_s0tcn() -> fpread00[s0tcn]

@extern
def pread00_d0tst() -> fpread00[d0tst]

@extern
def pread00_s0tcnlst() -> fpread00[s0tcnlst]

@extern
def pread00_d0tstlst() -> fpread00[d0tstlst]

@impl
def pread00_s0tcn(syn, err):
    match syn.node():
        case S0TCNnode(sid0, topt):
            let e00 = err
            let sid0 = pread00_i0dnt(sid0, err)
            let topt = pread00_sort0opt(topt, err)
            if (err == e00):
                syn
            else:
                s0tcn(syn.lctn(), S0TCNnode(sid0, topt))

@impl
def pread00_d0tst(syn, err):
    match syn.node():
        case D0TSTnode(tid0, teq1, tbar, tcns):
            let e00 = err
            let tid0 = pread00_i0dnt(tid0, err)
            match teq1.node():
                case T_EQ0():
                    ()
                case _:
                    err := err + 1
            let tcns = pread00_s0tcnlst(tcns, err)
            if (err == e00):
                syn
            else:
                d0tst(syn.lctn(), D0TSTnode(tid0, teq1, tbar, tcns))

@impl
def pread00_s0tcnlst(lst, err):
    list_pread00_fnp(lst, err, pread00_s0tcn)

@impl
def pread00_d0tstlst(lst, err):
    list_pread00_fnp(lst, err, pread00_d0tst)

@extern
def pread00_s0uni() -> fpread00[s0uni]

@extern
def pread00_d0tcn() -> fpread00[d0tcn]

@extern
def pread00_d0typ() -> fpread00[d0typ]

@extern
def pread00_s0unilst() -> fpread00[s0unilst]

@extern
def pread00_d0tcnlst() -> fpread00[d0tcnlst]

@extern
def pread00_d0typlst() -> fpread00[d0typlst]

@extern
def pread00_wd0eclseq() -> fpread00[wd0eclseq]

@impl
def pread00_s0uni(s0u, err):
    let e00 = err
    match s0u.node():
        case S0UNInone(tok):
            err := err + 1
            s0u
        case S0UNIsome(tbeg, s0qs, tend):
            let s0qs = pread00_s0qualst(s0qs, err)
            match tend.node():
                case T_RBRACE():
                    ()
                case _:
                    err := err + 1
            if (err == e00):
                s0u
            else:
                s0uni(s0u.lctn(), S0UNIsome(tbeg, s0qs, tend))

@impl
def pread00_d0tcn(tcn, err):
    let e00 = err
    let loc = tcn.lctn()
    let D0TCNnode(s0us, deid, s0es, sres) = tcn.node()
    let deid = pread00_i0dnt(deid, err)
    let s0us = pread00_s0unilst(s0us, err)
    let s0es = pread00_s0explst(s0es, err)
    let sres = pread00_s0expopt(sres, err)
    if (err == e00):
        tcn
    else:
        d0tcn_make_node(loc, D0TCNnode(s0us, deid, s0es, sres))

@impl
def pread00_d0typ(d0t, err):
    let e00 = err
    let loc = d0t.lctn()
    let D0TYPnode(deid, tmas, tres, teq1, tcns) = d0t.node()
    let deid = pread00_i0dnt(deid, err)
    let tmas = pread00_t0maglst(tmas, err)
    let tres = pread00_sort0opt(tres, err)
    match teq1.node():
        case T_EQ0():
            ()
        case _:
            err := err + 1
    let tcns = pread00_d0tcnlst(tcns, err)
    if (err == e00):
        d0t
    else:
        d0typ_make_node(loc, D0TYPnode(deid, tmas, tres, teq1, tcns))

@impl
def pread00_s0unilst(lst, err):
    list_pread00_fnp(lst, err, pread00_s0uni)

@impl
def pread00_d0tcnlst(lst, err):
    list_pread00_fnp(lst, err, pread00_d0tcn)

@impl
def pread00_d0typlst(lst, err):
    list_pread00_fnp(lst, err, pread00_d0typ)

@impl
def pread00_wd0eclseq(wdcs, err):
    match wdcs:
        case WD0CSnone():
            wdcs
        case WD0CSsome(tbeg, topt, d0cs, tend):
            let e00 = err
            let d0cs = pread00_d0eclist(d0cs, err)
            match topt:
                case optn_nil():
                    match tend.node():
                        case T_ENDWHR():
                            ()
                        case _:
                            err := err + 1
                case optn_cons(_):
                    match tend.node():
                        case T_RBRACE():
                            ()
                        case _:
                            err := err + 1
            if (err == e00):
                wdcs
            else:
                WD0CSsome(tbeg, topt, d0cs, tend)

