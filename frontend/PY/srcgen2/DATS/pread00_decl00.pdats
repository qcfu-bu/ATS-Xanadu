@impl
def pread00_a0typ(atp, err):
    match atp.node():
        case A0TYPsome(s0e1, topt):
            let e00 = err
            let loc = atp.lctn()
            let s0e1 = pread00_s0exp(s0e1, err)
            if (err == e00):
                atp
            else:
                a0typ(loc, A0TYPsome(s0e1, topt))

@impl
def pread00_d0arg(dag, err):
    match dag.node():
        case D0ARGnone(tok):
            err := err + 1
            dag
        case D0ARGsta0(tbeg, s0qs, tend):
            let e00 = err
            let s0qs = pread00_s0qualst(s0qs, err)
            match tend.node():
                case T_RBRACE():
                    ()
                case _:
                    err := err + 1
            if (err == e00):
                dag
            else:
                d0arg(dag.lctn(), D0ARGsta0(tbeg, s0qs, tend))
        case D0ARGdyn1(dpid):
            let e00 = err
            let loc = dag.lctn()
            let dpid = pread00_i0dnt(dpid, err)
            if (err == e00):
                dag
            else:
                d0arg_make_node(loc, D0ARGdyn1(dpid))
        case D0ARGdyn2(tbeg, atps, opt2, tend):
            let e00 = err
            let loc = dag.lctn()
            let atps = pread00_a0typlst(atps, err)
            let opt2 = match opt2:
                case optn_nil():
                    opt2
                case optn_cons(atps):
                    let e00 = err
                    let atps = pread00_a0typlst(atps, err)
                    if (err == e00):
                        opt2
                    else:
                        optn_cons(atps)
            if (err == e00):
                dag
            else:
                d0arg_make_node(loc, D0ARGdyn2(tbeg, atps, opt2, tend))

@impl
def pread00_d0ecl(dcl, err):
    match dcl.node():
        case D0Cnonfix(_):
            f0_nonfix(dcl, err)
        case D0Cfixity(_):
            f0_fixity(dcl, err)
        case D0Cstatic(_):
            f0_static(dcl, err)
        case D0Cextern(_):
            f0_extern(dcl, err)
        case D0Cdefine(_):
            f0_define(dcl, err)
        case D0Cmacdef(_):
            f0_macdef(dcl, err)
        case D0Clocal0(_):
            f0_local0(dcl, err)
        case D0Cabssort(_):
            f0_abssort(dcl, err)
        case D0Cstacst0(_):
            f0_stacst0(dcl, err)
        case D0Csortdef(_):
            f0_sortdef(dcl, err)
        case D0Csexpdef(_):
            f0_sexpdef(dcl, err)
        case D0Cabstype(_):
            f0_abstype(dcl, err)
        case D0Cabsopen(_):
            f0_absopen(dcl, err)
        case D0Cabsimpl(_):
            f0_absimpl(dcl, err)
        case D0Csymload(_):
            f0_symload(dcl, err)
        case D0Cinclude(_):
            f0_include(dcl, err)
        case D0Cstaload(_):
            f0_staload(dcl, err)
        case D0Cdyninit(_):
            f0_dyninit(dcl, err)
        case D0Cextcode(_):
            f0_extcode(dcl, err)
        case D0Cdatasort(_):
            f0_datasort(dcl, err)
        case D0Cvaldclst(_):
            f0_valdclst(dcl, err)
        case D0Cvardclst(_):
            f0_vardclst(dcl, err)
        case D0Cfundclst(_):
            f0_fundclst(dcl, err)
        case D0Cimplmnt0(_):
            f0_implmnt0(dcl, err)
        case D0Cexcptcon(_):
            f0_excptcon(dcl, err)
        case D0Cdatatype(_):
            f0_datatype(dcl, err)
        case D0Cdynconst(_):
            f0_dynconst(dcl, err)
        case D0Ctkerr(tok):
            dcl
        case D0Ctkskp(tok):
            let lvl = 1
            err := err + 1
            d0ecl_errck(lvl, dcl)
        case D0Cendif(_):
            dcl
        case D0Cthen0(_):
            dcl
        case D0Celse1(_):
            dcl
