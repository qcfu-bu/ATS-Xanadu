def d0ecl_errck(lvl: SInt, dcl: d0ecl) -> d0ecl:
    d0ecl(dcl.lctn(), D0Cerrck(lvl, dcl))

def d0ecl_errvl_a1(dcl: d0ecl) -> SInt:
    match dcl.node():
        case D0Cerrck(lvl, _):
            lvl
        case _:
            0

@overload d0ecl_errvl = d0ecl_errvl_a1

@overload errvl = d0ecl_errvl_a1

@extern
def d0ecl_errvl_dcls(dcls: d0eclist) -> SInt

@overload d0ecl_errvl = d0ecl_errvl_dcls

@overload errvl = d0ecl_errvl_dcls

@impl
def d0ecl_errvl_dcls(dcls):
    match dcls:
        case list_nil():
            0
        case list_cons(dcl1, dcls):
            max(errvl(dcl1), errvl(dcls))

