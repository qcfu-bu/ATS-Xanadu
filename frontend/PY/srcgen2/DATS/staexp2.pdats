            TRCDbox2
    let s2t1 = if linq:
        the_sort2_view
    else: the_sort2_prop
    let s2t2 = match tnd0:
        case T_TRCD20(0):
            if linq:
                the_sort2_vwtp
            else:
                the_sort2_type
        case T_TRCD20(1):
            the_sort2_vtbx
        case T_TRCD20(2):
            if linq:
                the_sort2_vtbx
            else:
                the_sort2_tbox
        case T_TRCD20(3):
            the_sort2_tbox
        case T_TRCD20(4):
            the_sort2_vtbx
        case T_TRCD20(5):
            the_sort2_tbox
    let lss1 = match tnd0:
        case T_TRCD20(3):
            let tres = the_sort2_prop
            l2s2elst_stck(loc0, lss1, tres)
        case _:
            lss1
    let lss2 = match tnd0:
        case T_TRCD20(3):
            let tres = the_sort2_type
            l2s2elst_stck(loc0, lss2, tres)
        case _:
            lss2
    let npf1 = list_length(lss1)
    let lses = list_append(lss1, lss2)
    s2exp(s2t2, S2Etrcd(knd0, npf1, lses))

@impl
def s2exp_any1():
    s2exp_anys(1)

@impl
def s2exp_anys(knd0):
    s2exp(s2t0, S2Eany(knd0))
where:
    let s2t0 = sort2_none0()

@impl
def s2exp_none0():
    s2exp(s2t0, S2Enone0())
where:
    let s2t0 = sort2_none0()

@impl
def s2exp_none1(s1e0):
    let loc0 = s1e0.lctn()
    let s2t0 = sort2_none0()
    s2exp_make_node(s2t0, S2Enone1(s1e0))

private:
    enum S2exp:
        case S2EXP(sort2, s2exp_node)
    @impl
    type S2exp_tbox = S2exp

@impl
def s2exp_get_sort(s2e0):
    let S2EXP(s2t0, node) = s2e0
    s2t0

@impl
def s2exp_get_node(s2e0):
    let S2EXP(s2t0, node) = s2e0
    node

@impl
def s2exp_make_node(s2t0, node):
    S2EXP(s2t0, node)


@impl
def l2s2e_get_sort(lx):
    let s2t = s2exp_get_sort(lx.itm())
    s2t

@impl
def l2s2e_get_node(lx):
    let s2t = s2exp_get_node(lx.itm())
    s2t

