private:
    def f1_stcks(loc0: loc_t, s2es: s2explst, s2ts: sort2lst, nerr: &SInt >> _) -> s2explst:
        match s2es:
            case list_nil():
                list_nil()
            case list_cons(s2e1, ses2):
                let ne00 = nerr
                let s2t1 = match s2ts:
                    case list_nil():
                        S2Tnone0()
                    case list_cons(s2t1, _):
                        s2t1
                let s2ts = match s2ts:
                    case list_nil():
                        list_nil()
                    case list_cons(_, s2ts):
                        s2ts
                let st10 = s2e1.sort()
                let s2e1 = if st10.lte(s2t1):
                    s2e1
                else: match ():
                    case ():
                        nerr := (nerr + 1)
                        s2exp_cast(loc0, s2e1, s2t1)
                let ses2 = f1_stcks(loc0, ses2, s2ts, nerr)
                if (ne00 == nerr):
                    s2es
                else:
                    list_cons(s2e1, ses2)
    def f0_stcks(loc0: loc_t, s2es: s2explst, s2ts: sort2lst) -> s2explst:
        var nerr: SInt = 0
        f1_stcks(loc0, s2es, s2ts, nerr)

