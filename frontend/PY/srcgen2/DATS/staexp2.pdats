@impl
def s2exp_apps(loc0, s2f0, s2es):
    let s2f0 = match s2f0.sort():
        case S2Tfun0(_):
            s2f0
        case S2Tfun1(_):
            s2f0
        case _:
            s2exp_cast(loc0, s2f0, S2Tfun0())
    let s2ts = match s2f0.sort():
        case S2Tfun1(s2ts, _):
            s2ts
        case _:
            list_nil()
    let tres = match s2f0.sort():
        case S2Tfun1(_, s2t1):
            s2t1
        case _:
            S2Tnone0()
    let s2es = f0_stcks(loc0, s2es, s2ts)
    s2exp_make_node(tres, S2Eapps(s2f0, s2es))


@impl
def s2exp_apps_pq(loc0, s2f0, s2es):
    match 0:
        case _ if isTOP0(s2f0):
            f0_top0(loc0, s2es)
        case _ if isTOP1(s2f0):
            f0_top1(loc0, s2es)
        case _ if isCBV0(s2f0):
            f0_cbv0(loc0, s2es)
        case _ if isCBV1(s2f0):
            f0_cbv1(loc0, s2es)
        case _ if isCBRF(s2f0):
            f0_cbrf(loc0, s2es)
        case _:
            s2exp_apps(loc0, s2f0, s2es)
where:
    def S2Ecbv0(s2e1: S2exp) -> s2exp_node:
        S2Earg1(0, s2e1)
    def S2Ecbv1(s2e1: S2exp) -> s2exp_node:
        S2Earg1(1, s2e1)
    def S2Ecbrf(s2e1: S2exp) -> s2exp_node:
        S2Earg1(-(1), s2e1)
    def f1_test(s2f0: S2exp, name: sym_t) -> Bool:
        match s2f0.node():
            case S2Ecst(s2c1):
                let opt1 = s2c1.sexp()
                match opt1:
                    case ~optn_vt_nil():
                        name == s2cst_get_name(s2c1)
                    case ~optn_vt_cons(s2f1):
                        f1_test(s2f1, name)
            case _:
                false
    def isTOP0(s2f0: S2exp) -> Bool:
        f1_test(s2f0, TOP0_VT_T0_symbl)
    def isTOP1(s2f0: S2exp) -> Bool:
        f1_test(s2f0, TOP1_VT_T0_symbl)
    def isCBV0(s2f0: S2exp) -> Bool:
        f1_test(s2f0, CBV0_V0_VT_symbl)
    def isCBV1(s2f0: S2exp) -> Bool:
        f1_test(s2f0, CBV1_V0_VT_symbl)
    def isCBRF(s2f0: S2exp) -> Bool:
        f1_test(s2f0, CBRF_VT_VT_symbl)
    def f0_top0(loc0: loc_t, s2es: s2explst) -> S2exp:
        let s2e1 = match s2es:
            case list_cons(s2e1, _):
                s2e1
        let s2t0 = if sort2_boxq(s2e1.sort()):
            the_sort2_tbox
        else: the_sort2_type
        s2exp_make_node(s2t0, S2Etop0(s2e1))
    def f0_top1(loc0: loc_t, s2es: s2explst) -> S2exp:
        let s2e1 = match s2es:
            case list_cons(s2e1, _):
                s2e1
        let s2t0 = if sort2_boxq(s2e1.sort()):
            the_sort2_tbox
        else: the_sort2_type
        s2exp_make_node(s2t0, S2Etop1(s2e1))
    def f0_cbv0(loc0: loc_t, s2es: s2explst) -> S2exp:
        let s2e1 = match s2es:
            case list_cons(s2e1, _):
                s2e1
        s2exp_make_node(s2e1.sort(), S2Ecbv0(s2e1))
    def f0_cbv1(loc0: loc_t, s2es: s2explst) -> S2exp:
        let s2e1 = match s2es:
            case list_cons(s2e1, _):
                s2e1
        s2exp_make_node(s2e1.sort(), S2Ecbv1(s2e1))
    def f0_cbrf(loc0: loc_t, s2es: s2explst) -> S2exp:
        let s2e1 = match s2es:
            case list_cons(s2e1, _):
                s2e1
        s2exp_make_node(s2e1.sort(), S2Ecbrf(s2e1))

