private:
    def f0_d2valdcl(env0: !tr2aenv, dval: d2valdcl) -> d2valdcl:
        let loc0 = d2valdcl_get_lctn(dval)
        let dpat = d2valdcl_get_dpat(dval)
        let tdxp = d2valdcl_get_tdxp(dval)
        let wsxp = d2valdcl_get_wsxp(dval)
        let tdxp = match tdxp:
            case TEQD2EXPnone():
                TEQD2EXPnone()
            case TEQD2EXPsome(teq1, d2e2):
                let tres = dpat.styp()
                let d2e2 = trans2a_d2exp_tpck(env0, d2e2, tres)
                let d2e2 = d2exp(loc0, tres, D2Et2pck(d2e2, tres))
                TEQD2EXPsome(teq1, d2e2)
        d2valdcl_make_args(loc0, dpat, tdxp, wsxp)

@impl
def trans2a_d2valdclist(env0, dcls):
    list_trans2a_fnp(env0, dcls, f0_d2valdcl)
where:
    let dcls = list_trans2a_fnp(env0, dcls, trans2a_d2valdcl)


@impl
def trans2a_d2vardclist(env0, dcls):
    list_trans2a_fnp(env0, dcls, trans2a_d2vardcl)

private:
    def f0_tres(f2as: f2arglst, tres: s2typ) -> s2typ:
        match f2as:
            case list_nil():
                tres
            case list_cons(f2a1, f2as):
                match f2a1.node():
                    case F2ARGdapp(_):
                        let T2Pfun1(f2cl, npf1, t2ps, tres) = tres.node()
                        f0_tres(f2as, tres)
                    case F2ARGsapp(_):
                        let tres = match tres.node():
                            case T2Puni0(s2vs, tres):
                                tres
                            case _:
                                tres
                        f0_tres(f2as, tres)
                    case F2ARGmets(_):
                        f0_tres(f2as, tres)
    def f0_d2fundcl(env0: !tr2aenv, dfun: d2fundcl) -> d2fundcl:
        let loc0 = d2fundcl_get_lctn(dfun)
        let dvar = d2fundcl_get_dpid(dfun)
        let f2as = d2fundcl_get_farg(dfun)
        let tdxp = d2fundcl_get_tdxp(dfun)
        let sres = d2fundcl_get_sres(dfun)
        let wsxp = d2fundcl_get_wsxp(dfun)
        let tdxp = match tdxp:
            case TEQD2EXPnone():
                TEQD2EXPnone()
            case TEQD2EXPsome(teq1, d2e2):
                let tres = f0_tres(f2as, dvar.styp())
                let d2e2 = trans2a_d2exp_tpck(env0, d2e2, tres)
                let d2e2 = d2exp(loc0, tres, D2Et2ped(d2e2, tres))
                TEQD2EXPsome(teq1, d2e2)
        d2fundcl(loc0, dvar, f2as, sres, tdxp, wsxp)

@impl
def trans2a_d2fundclist(env0, dcls):
    list_trans2a_fnp(env0, dcls, f0_d2fundcl)
where:
    let dcls = list_trans2a_fnp(env0, dcls, trans2a_d2fundcl)


