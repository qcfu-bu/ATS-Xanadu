@overload name = s2var_get_name

@overload sort = s2var_get_sort

@overload node = s2typ_get_node

@overload styp = d2con_get_styp

@overload lctn = d2cst_get_lctn

@overload styp = d2cst_get_styp

@overload tqas = d2cst_get_tqas

@overload styp = d2var_get_styp

