def s2typ_subst0(t2p0: s2typ, svts: s2vts) -> s2typ:
    match svts:
        case list_nil():
            t2p0
        case list_cons(_):
            s2typ_subst0(t2p0, svts)

def s2var_copy(s2v0: s2var) -> s2var:
    s2var(s2v0.name(), s2v0.sort())

def s2typ_new0_x2tp(loc0: loc_t) -> s2typ:
    s2typ_xtv(x2t2p_make_lctn(loc0))

def s2typ_fun1(f2cl: f2clknd, npf1: SInt, t2ps: s2typlst, tres: s2typ) -> s2typ:
    let s2t0 = match f2cl:
        case F2CLfun():
            the_sort2_tbox
        case F2CLclo(knd):
            match knd:
                case 0:
                    the_sort2_type
                case 1:
                    the_sort2_vtbx
                case _:
                    the_sort2_tbox
    let f2cl = s2typ_f2cl(f2cl)
    s2typ_make_node(s2t0, T2Pfun1(f2cl, npf1, t2ps, tres))

def s2typ_elim_unis(t2p0: s2typ) -> s2typ:
    match t2p0.node():
        case T2Puni0(svs1, t2p1):
            let svts = f0_svs1(svs1)
            s2typ_elim_unis(s2typ_subst0(t2p1, svts))
        case _:
            t2p0
where:
    def f0_svs1(svs1: s2varlst) -> s2vts:
        @inst[x0] @inst[y0] list_maprev(svs1)
    where:
        type X0 = s2var
        type Y0 = (s2var, s2typ)
        @impl[X0, Y0]
        def map/fopr(s2v1):
            (s2v1, t2p2)
        where:
            let t2p2 = s2typ_var(s2var_copy(s2v1))

def s2typ_elim_s2vs(t2p0: s2typ, s2vs: s2varlst) -> s2typ:
    type X0 = s2var
    @impl[X0]
    def filter/test(s2v):
        sort2_imprq(s2v.sort())
    let svs2 = @inst[X0] list_filter(s2vs)
    def f0_svs1_svs2(svs1: s2varlst, svs2: s2varlst, svts: s2vts) -> s2vts:
        match svs1:
            case list_nil():
                svts
            case list_cons(s2v1, svs1):
                match svs2:
                    case list_nil():
                        let s2v2 = s2var_copy(s2v1)
                        let t2p2 = s2typ_var(s2v2)
                        let svts = list_cons((s2v1, t2p2), svts)
                        f0_svs1_svs2(svs1, svs2, svts)
                    case list_cons(s2v2, svs2):
                        let t2p2 = s2typ_var(s2v2)
                        let svts = list_cons((s2v1, t2p2), svts)
                        f0_svs1_svs2(svs1, svs2, svts)
    match s2vs:
        case list_nil():
            t2p0
        case list_cons(_):
            match t2p0.node():
                case T2Puni0(svs1, t2p1):
                    let svts = list_nil()
                    let svts = f0_svs1_svs2(svs1, svs2, svts)
                    s2typ_subst0(t2p1, svts)
                case _:
                    t2p0

@impl
def x2t2p_make_dvar(d2v0):
    x2t2p_make_lctn(d2v0.lctn())

@impl
def d2cfn_fix_xtyp(d2c1):
    d2c1.xtyp(xt2p)
where:
    let loc1 = d2c1.lctn()
    let tqas = d2c1.tqas()
    let t2p1 = d2c1.styp()
    let svts = s2vts_make_lctn_tqas(loc1, tqas)
    let xt2p = s2typ_subst0(t2p1, svts)

@impl
def d2exp_sym0_styp(loc0, name, dpis, t2p0):
    let drxp = d2rxp_new1(loc0)
    let d1e1 = d1exp_make_node(loc0, D1Eid0(name))
    let d2e0 = d2exp_make_node(loc0, D2Esym0(drxp, d1e1, dpis))
    d2e0.styp(t2p0)
    d2e0

@impl
def s2typ_fun1_f2arglst(f2as, f2cl, tres):
    let ndyn = f1_ndyn(f2as)
    f0_f2as(f2as, ndyn, tres)
where:
    def f0_f2as(f2as: f2arglst, ndyn: SInt, tres: s2typ) -> s2typ:
        match f2as:
            case list_nil():
                tres
            case list_cons(f2a1, f2as):
                match f2a1.node():
                    case F2ARGmets(_):
                        f0_f2as(f2as, ndyn, tres)
                    case F2ARGsapp(s2vs, s2ps):
                        let s2vs = s2varlst_imprq(s2vs)
                        let tres = f0_f2as(f2as, ndyn, tres)
                        let s2t0 = tres.sort()
                        match s2vs:
                            case list_nil():
                                tres
                            case list_cons(_):
                                s2typ(s2t0, T2Puni0(s2vs, tres))
                    case F2ARGdapp(npf1, d2ps):
                        let ndyn = ndyn - 1
                        let tres = f0_f2as(f2as, ndyn, tres)
                        let t2ps = s2typlst_of_d2patlst(d2ps)
                        let f2cl = if (ndyn <= 0):
                            f2cl
                        else: F2CLclo(C0FPTR)
                        s2typ_fun1(f2cl, npf1, t2ps, tres)

    def f1_ndyn(xs: f2arglst) -> SInt:
        match xs:
            case list_nil():
                0
            case list_cons(x1, xs):
                match x1.node():
                    case F2ARGdapp(_):
                        f1_ndyn(xs) + 1
                    case _:
                        f1_ndyn(xs)

