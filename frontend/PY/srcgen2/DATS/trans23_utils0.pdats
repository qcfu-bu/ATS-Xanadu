def s2typ_subst0(t2p0: s2typ, svts: s2vts) -> s2typ:
    match svts:
        case list_nil():
            t2p0
        case list_cons(_):
            s2typ_subst0(t2p0, svts)

@impl
def s2typ_fun1_f3arglst(f3as, tfun, tres):
    auxmain(f3as, tfun)
where:
    def f1_imprq(s2vs: s2varlst) -> Bool:
        match s2vs:
            case list_nil():
                false
            case list_cons(s2v1, s2vs):
                if sort2_imprq(s2v1.sort()):
                    true
                else:
                    f1_imprq(s2vs)
    def auxmain(f3as: f3arglst, tfun: s2typ) -> s2typ:
        match f3as:
            case list_nil():
                tres
            case list_cons(f3a1, f3as):
                match f3a1.node():
                    case F3ARGmets(_):
                        auxmain(f3as, tfun)
                    case F3ARGsapp(s2vs, s2ps):
                        if not(f1_imprq(s2vs)):
                            auxmain(f3as, tfun)
                        else:
                            let T2Puni0(s2vs, tfun) = tfun.node()
                            let s2t0 = tfun.sort()
                            let tres = auxmain(f3as, tfun)
                            s2typ_make_node(s2t0, T2Puni0(s2vs, tres))
                    case F3ARGdapp(npf1, d3ps):
                        let s2t0 = tfun.sort()
                        let T2Pfun1(f2cl, npf1, targ, tfun) = tfun.node()
                        let tres = auxmain(f3as, tfun)
                        let t2ps = s2typlst_of_d3patlst(d3ps)
                        s2typ_make_node(s2t0, T2Pfun1(f2cl, npf1, t2ps, tres))

@impl
