    let lvl = maxs(errvl(lses), errvl(lsrb))
    s0exp_errck(lvl + 1, s0exp(loc, S0Ercd2(tkb, opt, lses, lsrb)))

def s0exp_lams_errck(loc: loc_t, tknd: token, smas: s0maglst, tres: sort0opt, arrw: token, body: s0exp, tend: tokenopt) -> s0exp:
    let lvl = s0exp_errvl(body)
    s0exp_errck(lvl + 1, s0exp_make_node(loc, S0Elams(tknd, smas, tres, arrw, body, tend)))

