@impl
def pread00_i0dnt(id0, err):
    match id0.node():
        case I0DNTsome(_):
            id0
        case I0DNTnone(_):
            err := err + 1
            id0

@impl
def pread00_l0abl(l0ab, err):
    match l0ab.node():
        case L0ABLsome(lab):
            l0ab
        case L0ABLnone(tok):
            err := err + 1
            l0ab

@impl
def pread00_s0ymb(symb, err):
    match symb.node():
        case S0YMBi0dnt(deid):
            let deid = pread00_i0dnt(deid, err)
            symb
        case S0YMBbrckt(tkb, tke):
            symb

@impl
def pread00_s0qid(sqid, err):
    match sqid:
        case S0QIDnone(id0):
            let id0 = pread00_i0dnt(id0, err)
            sqid
        case S0QIDsome(tok, id0):
            let id0 = pread00_i0dnt(id0, err)
            sqid

@impl
def pread00_d0qid(dqid, err):
    match dqid:
        case D0QIDnone(id0):
            let id0 = pread00_i0dnt(id0, err)
            dqid
        case D0QIDsome(tok, id0):
            let id0 = pread00_i0dnt(id0, err)
            dqid

def g0exp_errck(lvl: SInt, g0e: g0exp) -> g0exp:
    g0exp(g0e.lctn(), G0Eerrck(lvl, g0e))

def g0exp_apps_errck(loc: loc_t, ges: g0explst) -> g0exp:
    let lvl = 0
    g0exp_errck(lvl + 1, g0exp(loc, G0Eapps(ges)))

def g0exp_lpar_errck(loc: loc_t, tkb: token, ges: g0explst, tke: token) -> g0exp:
    let lvl = 0
    g0exp_errck(lvl + 1, g0exp(loc, G0Elpar(tkb, ges, tke)))

def g0exp_ift0_errck(loc: loc_t, tift: token, g0e1: g0exp, gthn: g0exp_THEN, gels: g0exp_ELSE, tend: tokenopt) -> g0exp:
    let lvl = 0
    g0exp_errck(lvl + 1, g0exp(loc, G0Eift0(tift, g0e1, gthn, gels, tend)))

@impl
def pread00_g0exp(g0e, err):
    match g0e.node():
        case G0Eid0(_):
            g0e
        case G0Eint(_):
            g0e
        case G0Echr(_):
            g0e
        case G0Eflt(_):
            g0e
        case G0Estr(_):
            g0e
        case G0Eapps(_):
            f0_apps(g0e, err)
        case G0Elpar(_):
            f0_lpar(g0e, err)
        case G0Eift0(_):
            f0_ift0(g0e, err)
        case G0Etkerr(_):
            err := err + 1
            g0exp_errck(1, g0e)
        case _:
            err := err + 1
            g0exp_errck(1, g0e)
where:
    def f0_apps(g0e: g0exp, err: &SInt >> _) -> g0exp:
        let e00 = err
        let G0Eapps(ges) = g0e.node()
        let ges = pread00_g0explst(ges, err)
        if (err == e00):
            g0e
        else:
            g0exp_apps_errck(g0e.lctn(), ges)
    def f0_lpar(g0e: g0exp, err: &SInt >> _) -> g0exp:
        let e00 = err
        let G0Elpar(tkb, ges, tke) = g0e.node()
        let ges = pread00_g0explst(ges, err)
        match tke.node():
            case T_RPAREN():
                ()
            case _:
                err := err + 1
        if (err == e00):
            g0e
        else:
            g0exp_lpar_errck(g0e.lctn(), tkb, ges, tke)
    def f0_ift0(g0e: g0exp, err: &SInt >> _) -> g0exp:
        let e00 = err
        let G0Eift0(tift, g0e1, gthn, gels, tend) = g0e.node()
        let g0e1 = pread00_g0exp(g0e1, err)
        let gthn = match gthn:
            case g0exp_THEN(tok1, g0e2):
                let e00 = err
                match tok1.node():
                    case T_THEN():
                        ()
                    case _:
                        err := err + 1
                let g0e2 = pread00_g0exp(g0e2, err)
                if (err == e00):
                    gthn
                else:
                    g0exp_THEN(tok1, g0e2)
        let gels = match gels:
            case g0exp_ELSE(tok1, g0e3):
                let e00 = err
                match tok1.node():
                    case T_ELSE():
                        ()
                    case _:
                        err := err + 1
                let g0e3 = pread00_g0exp(g0e3, err)
                if (err == e00):
                    gels
                else:
                    g0exp_ELSE(tok1, g0e3)
        if (err == e00):
            g0e
        else:
            g0exp_ift0_errck(g0e.lctn(), tift, g0e1, gthn, gels, tend)

@impl
def pread00_g0mag(gma, err):
    match gma.node():
        case G0MAGnone(tok):
            err := err + 1
            gma
        case G0MAGsarg(tbeg, g0as, tend):
            let e00 = err
            let g0as = pread00_i0dntlst(g0as, err)
            match tend.node():
                case T_RBRACE():
                    ()
                case _:
                    err := err + 1
            if (err == e00):
                gma
            else:
                g0mag_make_node(gma.lctn(), G0MAGsarg(tbeg, g0as, tend))
        case G0MAGdarg(tbeg, g0as, tend):
            let e00 = err
            let g0as = pread00_i0dntlst(g0as, err)
            match tend.node():
                case T_RPAREN():
                    ()
                case _:
                    err := err + 1
            if (err == e00):
                gma
            else:
                g0mag_make_node(gma.lctn(), G0MAGsarg(tbeg, g0as, tend))

def sort0_errck(lvl: SInt, s0t: sort0) -> sort0:
    sort0(s0t.lctn(), S0Terrck(lvl, s0t))

def sort0_errvl_a1(s0t: sort0) -> SInt:
    match s0t.node():
        case S0Terrck(lvl, _):
            lvl
        case _:
            0

@overload sort0_errvl = sort0_errvl_a1

@overload errvl = sort0_errvl_a1

def sort0_errvl_a2(st1: sort0, st2: sort0) -> SInt:
    maxs(errvl(st1), errvl(st2))

@overload sort0_errvl = sort0_errvl_a2

@overload errvl = sort0_errvl_a2

def sort0_errvl_a3(st1: sort0, st2: sort0, st3: sort0) -> SInt:
    maxs(errvl(st1), errvl(st2), errvl(st3))

@overload sort0_errvl = sort0_errvl_a3

@overload errvl = sort0_errvl_a3

@extern
def sort0_errvl_sts(sts: sort0lst) -> SInt

@overload errvl = sort0_errvl_sts

@impl
def sort0_errvl_sts(sts):
    match sts:
        case list_nil():
            0
        case list_cons(st1, sts):
            maxs(errvl(st1), errvl(sts))

def sort0_apps_errck(loc: loc_t, sts: sort0lst) -> sort0:
    let lvl = errvl(sts)
    sort0_errck(lvl + 1, sort0(loc, S0Tapps(sts)))

def sort0_lpar_errck(loc: loc_t, tkb: token, sts: sort0lst, tke: token) -> sort0:
    let lvl = errvl(sts)
    sort0_errck(lvl + 1, sort0(loc, S0Tlpar(tkb, sts, tke)))

@impl
def pread00_sort0(s0t, err):
    match s0t.node():
        case S0Tid0(_):
            s0t
        case S0Tint(_):
            s0t
        case S0Tqid(_):
            f0_qid(s0t, err)
        case S0Tapps(_):
            f0_apps(s0t, err)
        case S0Tlpar(_):
            f0_lpar(s0t, err)
        case S0Ttkerr(_):
            err := err + 1
            sort0_errck(1, s0t)
        case _:
            err := err + 1
            sort0_errck(1, s0t)
where:
    def f0_qid(s0t: sort0, err: &SInt >> _) -> sort0:
        err := err + 1
        sort0_errck(1, s0t)
    def f0_apps(s0t: sort0, err: &SInt >> _) -> sort0:
        let e00 = err
        let S0Tapps(sts) = s0t.node()
        let sts = pread00_sort0lst(sts, err)
        if (err == e00):
            s0t
        else:
            sort0_apps_errck(s0t.lctn(), sts)
    def f0_lpar(s0t: sort0, err: &SInt >> _) -> sort0:
        let e00 = err
        let S0Tlpar(tkb, sts, tke) = s0t.node()
        let sts = pread00_sort0lst(sts, err)
        match tke.node():
            case T_RPAREN():
                ()
            case _:
                err := err + 1
        if (err == e00):
            s0t
        else:
            sort0_lpar_errck(s0t.lctn(), tkb, sts, tke)

def s0exp_errck(lvl: SInt, s0e: s0exp) -> s0exp:
    s0exp(s0e.lctn(), S0Eerrck(lvl, s0e))

def s0exp_errvl_a1(s0e: s0exp) -> SInt:
    match s0e.node():
        case S0Eerrck(lvl, _):
            lvl
        case _:
            0

@overload s0exp_errvl = s0exp_errvl_a1

@overload errvl = s0exp_errvl_a1

def s0exp_errvl_a2(se1: s0exp, se2: s0exp) -> SInt:
