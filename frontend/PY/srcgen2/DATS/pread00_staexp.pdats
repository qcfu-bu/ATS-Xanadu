        case s0exp_RPAREN_cons1(tkb, ses, tke):
            errvl(ses)

def l0s0e_errvl(lse: l0s0e) -> SInt:
    s0exp_errvl(s0e)
where:
    let S0LAB(lab, tok, s0e) = lse

