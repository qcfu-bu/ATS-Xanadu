    let lvl = 0
    s0exp_errck(lvl + 1, s0exp(loc, S0Eop2(tok)))

def s0exp_op3_errck(loc: loc_t, tkb: token, id0: i0dnt, tke: token) -> s0exp:
    let lvl = 0
    s0exp_errck(lvl + 1, s0exp(loc, S0Eop3(tkb, id0, tke)))

def s0exp_apps_errck(loc: loc_t, ses: s0explst) -> s0exp:
    let lvl = s0exp_errvl_ses(ses)
    s0exp_errck(lvl + 1, s0exp(loc, S0Eapps(ses)))

def s0exp_fimp_errck(loc: loc_t, tkb: token, ses: s0explst, tke: token) -> s0exp:
    let lvl = s0exp_errvl_ses(ses)
    s0exp_errck(lvl + 1, s0exp(loc, S0Efimp(tkb, ses, tke)))

