    let lvl = s0exp_errvl(s0e)
    s0exp_errck(lvl + 1, s0exp(loc, S0Eannot(s0e, s0t)))

def s0exp_qual0_errck(loc: loc_t, tok: token, se1: s0exp) -> s0exp:
    let lvl = s0exp_errvl(se1)
    s0exp_errck(lvl + 1, s0exp(loc, S0Equal0(tok, se1)))

@impl
def pread00_s0arg(s0a, err):
    match s0a.node():
        case S0ARGnone(tok):
            err := err + 1
            s0a
        case S0ARGsome(id0, opt):
            match id0.node():
                case I0DNTsome(_):
                    ()
                case I0DNTnone(_):
                    err := err + 1
            match opt:
                case optn_nil():
                    s0a
                case optn_cons(s0t):
                    let s0t = pread00_sort0(s0t, err)
                    s0a

@impl
def pread00_s0arglst(s0as, err):
    match s0as:
        case list_nil():
            list_nil()
        case list_cons(s0a1, sas1):
            let s0a1 = pread00_s0arg(s0a1, err)
            let sas1 = pread00_s0arglst(sas1, err)
            s0as

@impl
def pread00_s0mag(sma, err):
    match sma.node():
        case S0MAGnone(tok):
            err := err + 1
            sma
        case S0MAGsing(s0a):
            match s0a.node():
                case I0DNTsome(_):
                    sma
                case I0DNTnone(_):
                    err := err + 1
                    sma
        case S0MAGlist(tklp, s0as, tkrp):
            let s0as = pread00_s0arglst(s0as, err)
            match tkrp.node():
                case T_RPAREN():
                    sma
                case _:
                    err := err + 1
                    sma

@impl
def pread00_s0maglst(lst, err):
    list_pread00_fnp(lst, err, pread00_s0mag)

@impl
def pread00_t0arg(t0a, err):
    match t0a.node():
        case T0ARGnone(tok):
            err := err + 1
            t0a
        case T0ARGsome(s0t, opt):
            match opt:
                case optn_nil():
                    let s0t = pread00_sort0(s0t, err)
                    t0a
                case optn_cons(tok):
                    let s0t = pread00_sort0(s0t, err)
                    t0a

@impl
def pread00_t0arglst(lst, err):
    list_pread00_fnp(lst, err, pread00_t0arg)

@impl
def pread00_t0mag(tma, err):
    match tma.node():
        case T0MAGnone(tok):
            err := err + 1
            tma
        case T0MAGlist(tklp, t0as, tkrp):
            let t0as = pread00_t0arglst(t0as, err)
            match tkrp.node():
                case T_RPAREN():
                    tma
                case _:
                    err := err + 1
                    tma

@impl
def pread00_t0maglst(lst, err):
    list_pread00_fnp(lst, err, pread00_t0mag)

@impl
def pread00_s0qua(s0q, err):
    match s0q.node():
        case S0QUAprop(s0e):
            let s0e = pread00_s0exp(s0e, err)
            s0q
        case S0QUAvars(ids, opt):
            let ids = pread00_i0dntlst(ids, err)
            let opt = pread00_sort0opt(opt, err)
            s0q

@impl
def pread00_s0qualst(lst, err):
    list_pread00_fnp(lst, err, pread00_s0qua)

@impl
def pread00_s0exp(s0e, err):
    match s0e.node():
        case S0Eid0(_):
            s0e
        case S0Eint(_):
            s0e
        case S0Echr(_):
            s0e
        case S0Eflt(_):
            s0e
        case S0Estr(_):
            s0e
        case S0Eop1(_):
            f0_op1(s0e, err)
        case S0Eop2(_):
            f0_op2(s0e, err)
        case S0Eop3(_):
            f0_op3(s0e, err)
        case S0Eapps(_):
            f0_apps(s0e, err)
        case S0Efimp(_):
            f0_fimp(s0e, err)
        case S0Elpar(_):
            f0_lpar(s0e, err)
        case S0Etup1(_):
            f0_tup1(s0e, err)
        case S0Ercd2(_):
            f0_rcd2(s0e, err)
        case S0Elams(_):
            f0_lams(s0e, err)
        case S0Euni0(_):
            f0_uni0(s0e, err)
        case S0Eexi0(_):
            f0_exi0(s0e, err)
        case S0Eannot(_):
            f0_annot(s0e, err)
        case S0Equal0(_):
            f0_qual0(s0e, err)
        case S0Etkerr(_):
            err := err + 1
            s0exp_errck(1, s0e)
        case _:
            err := err + 1
            s0exp_errck(1, s0e)
where:
    def f0_op1(s0e: s0exp, err: &SInt >> _) -> s0exp:
        let S0Eop1(tok) = s0e.node()
        s0exp_op1_errck(s0e.lctn(), tok)
    def f0_op2(s0e: s0exp, err: &SInt >> _) -> s0exp:
        let e00 = err
        let S0Eop2(tok) = s0e.node()
        match tok.node():
            case T_IDSYM(_):
                s0e
            case _:
                s0exp_op2_errck(s0e.lctn(), tok)
    def f0_op3(s0e: s0exp, err: &SInt >> _) -> s0exp:
        let e00 = err
        let S0Eop3(tkb, id0, tke) = s0e.node()
        match id0.node():
            case I0DNTsome(_):
                ()
            case _:
                err := err + 1
        match tke.node():
            case T_RPAREN():
                ()
            case _:
                err := err + 1
        if (err == e00):
            s0e
        else:
            s0exp_op3_errck(s0e.lctn(), tkb, id0, tke)
    def f0_apps(s0e: s0exp, err: &SInt >> _) -> s0exp:
        let e00 = err
        let S0Eapps(sts) = s0e.node()
        let ses = pread00_s0explst(sts, err)
        if (err == e00):
            s0e
        else:
            s0exp_apps_errck(s0e.lctn(), ses)
    def f0_fimp(s0e: s0exp, err: &SInt >> _) -> s0exp:
        let e00 = err
        let S0Efimp(tkb, ses, tke) = s0e.node()
        let ses = pread00_s0explst(ses, err)
        match tke.node():
            case T_GT0():
                ()
            case _:
                err := err + 1
        if (err == e00):
            s0e
        else:
            s0exp_fimp_errck(s0e.lctn(), tkb, ses, tke)
    def f0_lpar(s0e: s0exp, err: &SInt >> _) -> s0exp:
        let e00 = err
        let S0Elpar(tkb, ses, srp) = s0e.node()
        let ses = pread00_s0explst(ses, err)
        let srp = pread00_s0exp_RPAREN(srp, err)
        if (err == e00):
            s0e
        else:
