@impl
def tread3a_f3arg(farg, err):
    match farg.node():
        case F3ARGdapp(npf1, d3ps):
            let e00 = err
            let d3ps = tread3a_d3patlst(d3ps, err)
            if (err == e00):
                farg
            else:
                f3arg(farg.lctn(), F3ARGdapp(npf1, d3ps))
        case _:
            farg

