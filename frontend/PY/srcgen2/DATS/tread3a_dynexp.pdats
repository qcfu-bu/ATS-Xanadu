def d3pat_errck(lvl0: SInt, d3p0: d3pat) -> d3pat:
    let loc0 = d3p0.lctn()
    d3pat_make_node(loc0, D3Perrck(lvl0, d3p0))

def d3exp_errck(lvl0: SInt, d3e0: d3exp) -> d3exp:
    let loc0 = d3e0.lctn()
    d3exp_make_node(loc0, D3Eerrck(lvl0, d3e0))

def d3pat_errvl_a1(d3p0: d3pat) -> SInt:
    match d3p0.node():
        case D3Perrck(lvl0, _):
            lvl0
        case _:
            0

@overload d3pat_errvl = d3pat_errvl_a1

@overload errvl = d3pat_errvl_a1

def d3pat_errvl_a2(d3p1: d3pat, d3p2: d3pat) -> SInt:
    maxs(errvl(d3p1), errvl(d3p2))

@overload d3pat_errvl = d3pat_errvl_a2

@overload errvl = d3pat_errvl_a2

@extern
def d3pat_errvl_lst(d3ps: d3patlst) -> SInt

@impl
def d3pat_errvl_lst(d3ps):
    match d3ps:
        case list_nil():
            0
        case list_cons(d3p1, d3ps):
            maxs(errvl(d3p1), d3pat_errvl_lst(d3ps))

@overload d3pat_errvl = d3pat_errvl_lst

@overload errvl = d3pat_errvl_lst

@extern
def l3d3p_errvl_ldps(ldps: l3d3plst) -> SInt

@impl
def l3d3p_errvl_ldps(ldps):
    match ldps:
        case list_nil():
            0
        case list_cons(ldp1, ldps):
            let D3LAB(lab, dp1) = ldp1
            maxs(errvl(dp1), l3d3p_errvl_ldps(ldps))

@overload l3d3p_errvl = l3d3p_errvl_ldps

@overload errvl = l3d3p_errvl_ldps

