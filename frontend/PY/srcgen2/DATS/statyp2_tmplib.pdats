@impl
def s2typ_hnfiz0_e1nv[E1nv](e1nv, t2p0):
    var flag: SInt = 0
    @inst[E1nv] s2typ_hnfizx_e1nv(e1nv, t2p0, flag)

@impl
def s2typ_subst0_e1nv[E1nv](e1nv, t2p0, svts):
    var flag: SInt = 0
    @inst[E1nv] s2typ_substx_e1nv(e1nv, t2p0, svts, flag)

@impl[]
def s2typ_hnfizx_e1nv[E1nv](e1nv, t2p0, flag):
    s2typ_hnfizx(e1nv, t2p0, flag)
where:
    def s2typ_substx(e1nv: !E1nv, t2p0: s2typ, svts: s2vts, flag: &SInt >> _) -> s2typ:
        @inst[E1nv] s2typ_substx_e1nv(e1nv, t2p0, svts, flag)
    def s2typ_hnfizx(e1nv: !E1nv, t2p0: s2typ, flag: &SInt >> _) -> s2typ:
        match t2p0.node():
            case T2Pf2cl(_):
                t2p0
            case T2Plam1(_):
                t2p0
            case T2Pnone0(_):
                t2p0
            case T2Pnone1(_):
                t2p0
            case T2Ps2exp(_):
                t2p0
            case T2Pcst(_):
                f0_cst(e1nv, t2p0, flag)
            case T2Pvar(_):
                f0_var(e1nv, t2p0, flag)
            case T2Plft(_):
                f0_lft(e1nv, t2p0, flag)
            case T2Pxtv(_):
                f0_xtv(e1nv, t2p0, flag)
            case T2Ptop0(_):
                f0_top0(e1nv, t2p0, flag)
            case T2Ptop1(_):
                f0_top1(e1nv, t2p0, flag)
            case T2Parg1(_):
                f0_arg1(e1nv, t2p0, flag)
            case T2Patx2(_):
                f0_atx2(e1nv, t2p0, flag)
            case T2Papps(_):
                f0_apps(e1nv, t2p0, flag)
            case T2Plam1(_):
                f0_lam1(e1nv, t2p0, flag)
            case T2Pfun1(_):
                f0_fun1(e1nv, t2p0, flag)
            case T2Ptrcd(_):
                f0_trcd(e1nv, t2p0, flag)
            case T2Ptext(_):
                f0_text(e1nv, t2p0, flag)
            case T2Pexi0(_):
                f0_exi0(e1nv, t2p0, flag)
            case T2Puni0(_):
                f0_uni0(e1nv, t2p0, flag)
            case _:
                s2typ_none1(t2p0)
    where:
        def f0_cst(e1nv: !E1nv, t2p0: s2typ, flag: &SInt >> _) -> s2typ:
            match opt1:
                case ~optn_vt_nil():
                    t2p0
                case ~optn_vt_cons(t2p1):
                    flag := flag + 1
                    s2typ_hnfizx(e1nv, t2p1, flag)
        where:
            let T2Pcst(s2c1) = t2p0.node()
            let opt1 = @inst[E1nv] s2typ_eval/s2cst(e1nv, s2c1)
        def f0_var(e1nv: !E1nv, t2p0: s2typ, flag: &SInt >> _) -> s2typ:
            match opt1:
                case ~optn_vt_nil():
                    t2p0
                case ~optn_vt_cons(t2p1):
                    flag := flag + 1
                    s2typ_hnfizx(e1nv, t2p1, flag)
        where:
            let T2Pvar(s2v1) = t2p0.node()
            let opt1 = @inst[E1nv] s2typ_eval/s2var(e1nv, s2v1)
        def f0_lft(e1nv: !E1nv, t2p0: s2typ, flag: &SInt >> _) -> s2typ:
            let fval = flag
            let t2p1 = s2typ_hnfizx(e1nv, t2p1, flag)
            if (flag <= fval):
                t2p0
            else:
                s2typ(t2p0.sort(), T2Plft(t2p1))
        where:
            let T2Plft(t2p1) = t2p0.node()
        def f0_xtv(e1nv: !E1nv, t2p0: s2typ, flag: &SInt >> _) -> s2typ:
            let t2p1 = xtp1.styp()
            match t2p1.node():
                case T2Pnone0():
                    t2p0
                case _:
                    flag := flag + 1
                    let t2p1 = s2typ_hnfizx(e1nv, t2p1, flag)
                    xtp1.styp(t2p1)
                    t2p1
        where:
            let T2Pxtv(xtp1) = t2p0.node()
        def f0_top0(e1nv: !E1nv, t2p0: s2typ, flag: &SInt >> _) -> s2typ:
            let fval = flag
            let T2Ptop0(t2p1) = t2p0.node()
            let t2p1 = s2typ_hnfizx(e1nv, t2p1, flag)
            if (flag <= fval):
                t2p0
            else:
                s2typ(t2p0.sort(), T2Ptop0(t2p1))
        def f0_top1(e1nv: !E1nv, t2p0: s2typ, flag: &SInt >> _) -> s2typ:
            let fval = flag
            let T2Ptop1(t2p1) = t2p0.node()
            let t2p1 = s2typ_hnfizx(e1nv, t2p1, flag)
            if (flag <= fval):
                t2p0
            else:
                s2typ(t2p0.sort(), T2Ptop1(t2p1))
        def f0_arg1(e1nv: !E1nv, t2p0: s2typ, flag: &SInt >> _) -> s2typ:
            let fval = flag
            let t2p1 = s2typ_hnfizx(e1nv, t2p1, flag)
            if (flag <= fval):
                t2p0
            else:
                s2typ_make_node(t2p0.sort(), T2Parg1(knd0, t2p1))
        where:
            let T2Parg1(knd0, t2p1) = t2p0.node()
        def f0_atx2(e1nv: !E1nv, t2p0: s2typ, flag: &SInt >> _) -> s2typ:
            let fval = flag
            let t2p1 = s2typ_hnfizx(e1nv, t2p1, flag)
            let t2p2 = s2typ_hnfizx(e1nv, t2p2, flag)
            if (flag <= fval):
                t2p0
            else:
                s2typ_make_node(t2p0.sort(), T2Patx2(t2p1, t2p2))
        where:
            let T2Patx2(t2p1, t2p2) = t2p0.node()
        def f0_apps(e1nv: !E1nv, t2p0: s2typ, flag: &SInt >> _) -> s2typ:
            let fval = flag
            let t2f0 = s2typ_hnfizx(e1nv, t2f0, flag)
            let t2ps = s2typlst_hnfizx(e1nv, t2ps, flag)
            match t2f0.node():
                case T2Plam1(s2vs, t2p1):
                    flag := flag + 1
                    let svts = s2vts(s2vs, t2ps)
                    let tres = s2typ_substx(e1nv, t2p1, svts, flag)
                    s2typ_hnfizx(e1nv, tres, flag)
                case _:
                    if (flag <= fval):
                        t2p0
                    else:
                        s2typ_make_node(t2p0.sort(), T2Papps(t2f0, t2ps))
        where:
            let T2Papps(t2f0, t2ps) = t2p0.node()
        def f0_lam1(e1nv: !E1nv, t2p0: s2typ, flag: &SInt >> _) -> s2typ:
            let fval = flag
            let t2p1 = s2typ_hnfizx(e1nv, t2p1, flag)
            if (flag <= fval):
                t2p0
            else:
                s2typ_make_node(t2p0.sort(), T2Plam1(s2vs, t2p1))
        where:
            let T2Plam1(s2vs, t2p1) = t2p0.node()
        def f0_fun1(e1nv: !E1nv, t2p0: s2typ, flag: &SInt >> _) -> s2typ:
            let fval = flag
            let f2cl = s2typ_hnfizx(e1nv, f2cl, flag)
            let tres = s2typ_hnfizx(e1nv, tres, flag)
            let targ = s2typlst_hnfizx(e1nv, targ, flag)
            if (flag <= fval):
                t2p0
            else:
                s2typ_make_node(t2p0.sort(), T2Pfun1(f2cl, npf1, targ, tres))
        where:
            let T2Pfun1(f2cl, npf1, targ, tres) = t2p0.node()
        def f0_trcd(e1nv: !E1nv, t2p0: s2typ, flag: &SInt >> _) -> s2typ:
            let fval = flag
            let ltps = l2t2plst_hnfizx(e1nv, ltps, flag)
            if (flag <= fval):
                t2p0
            else:
                s2typ_make_node(t2p0.sort(), T2Ptrcd(tknd, npf1, ltps))
        where:
            let T2Ptrcd(tknd, npf1, ltps) = t2p0.node()
        def f0_text(e1nv: !E1nv, t2p0: s2typ, flag: &SInt >> _) -> s2typ:
            let fval = flag
            let t2ps = s2typlst_hnfizx(e1nv, t2ps, flag)
            if (flag <= fval):
                t2p0
            else:
                s2typ_make_node(t2p0.sort(), T2Ptext(tnm1, t2ps))
        where:
            let T2Ptext(tnm1, t2ps) = t2p0.node()
        def f0_exi0(e1nv: !E1nv, t2p0: s2typ, flag: &SInt >> _) -> s2typ:
            let fval = flag
            let t2p1 = s2typ_hnfizx(e1nv, t2p1, flag)
            if (flag <= fval):
                t2p0
            else:
                s2typ_make_node(t2p0.sort(), T2Pexi0(s2vs, t2p1))
        where:
            let T2Pexi0(s2vs, t2p1) = t2p0.node()
        def f0_uni0(e1nv: !E1nv, t2p0: s2typ, flag: &SInt >> _) -> s2typ:
            let fval = flag
            let t2p1 = s2typ_hnfizx(e1nv, t2p1, flag)
            if (flag <= fval):
                t2p0
            else:
                s2typ_make_node(t2p0.sort(), T2Puni0(s2vs, t2p1))
        where:
            let T2Puni0(s2vs, t2p1) = t2p0.node()

    def l2t2p_hnfizx(e1nv: !E1nv, ltp0: l2t2p, flag: &SInt >> _) -> l2t2p:
        let fval = flag
        let S2LAB(l0, t2p0) = ltp0
        let t2p0 = s2typ_hnfizx(e1nv, t2p0, flag)
        if flag <= fval:
            ltp0
        else:
            S2LAB(l0, t2p0)

    def s2typlst_hnfizx(e1nv: !E1nv, t2ps: s2typlst, flag: &SInt >> _) -> s2typlst:
        match t2ps:
            case list_nil():
                list_nil()
            case list_cons(t2p1, tps2):
                let fval = flag
                let t2p1 = s2typ_hnfizx(e1nv, t2p1, flag)
                let tps2 = s2typlst_hnfizx(e1nv, tps2, flag)
                if (flag <= fval):
                    t2ps
                else:
                    list_cons(t2p1, tps2)

    def l2t2plst_hnfizx(e1nv: !E1nv, ltps: l2t2plst, flag: &SInt >> _) -> l2t2plst:
        match ltps:
            case list_nil():
                list_nil()
            case list_cons(ltp1, lts2):
                let fval = flag
                let ltp1 = l2t2p_hnfizx(e1nv, ltp1, flag)
                let lts2 = l2t2plst_hnfizx(e1nv, lts2, flag)
                if (flag <= fval):
                    ltps
                else:
                    list_cons(ltp1, lts2)

@impl[]
def s2typ_substx_e1nv[E1nv](e1nv, t2p0, s2vtx, flag):
    s2typ_substx(e1nv, t2p0, s2vtx, flag)
where:
    def s2typ_substx(e1nv: !E1nv, t2p0: s2typ, svts: s2vts, flag: &SInt >> _) -> s2typ:
        match t2p0.node():
            case T2Pcst(_):
                f0_cst(e1nv, t2p0, svts, flag)
            case T2Pvar(_):
                f0_var(e1nv, t2p0, svts, flag)
            case T2Pxtv(_):
                f0_xtv(e1nv, t2p0, svts, flag)
            case T2Ptop0(_):
                f0_top0(e1nv, t2p0, svts, flag)
            case T2Ptop1(_):
                f0_top1(e1nv, t2p0, svts, flag)
            case T2Parg1(_):
                f0_arg1(e1nv, t2p0, svts, flag)
            case T2Patx2(_):
                f0_atx2(e1nv, t2p0, svts, flag)
            case T2Papps(_):
                f0_apps(e1nv, t2p0, svts, flag)
            case T2Pfun1(_):
                f0_fun1(e1nv, t2p0, svts, flag)
            case T2Plam1(_):
                f0_lam1(e1nv, t2p0, svts, flag)
            case T2Ptext(_):
                f0_text(e1nv, t2p0, svts, flag)
            case T2Pexi0(_):
                f0_exi0(e1nv, t2p0, svts, flag)
            case T2Puni0(_):
                f0_uni0(e1nv, t2p0, svts, flag)
            case T2Ptrcd(_):
                f0_trcd(e1nv, t2p0, svts, flag)
            case T2Pnone0(_):
                t2p0
            case T2Pnone1(_):
                t2p0
            case T2Ps2exp(_):
                t2p0
            case _:
                s2typ_none1(t2p0)
    where:
        def f0_cst(e1nv: !E1nv, t2p0: s2typ, svts: s2vts, flag: &SInt >> _) -> s2typ:
            let T2Pcst(s2c1) = t2p0.node()
            let opt1 = s2typ_eval/s2cst(e1nv, s2c1)
            match opt1:
                case ~optn_vt_nil():
                    t2p0
                case ~optn_vt_cons(t2p1):
                    let fval = flag
                    let t2p1 = s2typ_substx(e1nv, t2p1, svts, flag)
                    if flag <= fval:
                        t2p0
                    else:
                        t2p1
        def f0_var(e1nv: !E1nv, t2p0: s2typ, svts: s2vts, flag: &SInt >> _) -> s2typ:
            let T2Pvar(s2v1) = t2p0.node()
            let opt1 = s2vts_search/opt(svts, s2v1)
            match opt1:
                case ~optn_vt_nil():
                    t2p0
                case ~optn_vt_cons(t2p1):
                    flag := flag + 1
                    t2p1
        def f0_xtv(e1nv: !E1nv, t2p0: s2typ, svts: s2vts, flag: &SInt >> _) -> s2typ:
            let T2Pxtv(xt2p) = t2p0.node()
            let t2p1 = xt2p.styp()
            match t2p1.node():
                case T2Pnone0():
                    t2p0
                case _:
                    flag := flag + 1
                    s2typ_substx(e1nv, t2p1, svts, flag)
        def f0_top0(e1nv: !E1nv, t2p0: s2typ, svts: s2vts, flag: &SInt >> _) -> s2typ:
            let fval = flag
            let T2Ptop0(t2p1) = t2p0.node()
            let t2p1 = s2typ_substx(e1nv, t2p1, svts, flag)
            if flag <= fval:
                t2p0
            else:
                s2typ(t2p0.sort(), T2Ptop0(t2p1))
        def f0_top1(e1nv: !E1nv, t2p0: s2typ, svts: s2vts, flag: &SInt >> _) -> s2typ:
            let fval = flag
            let T2Ptop1(t2p1) = t2p0.node()
            let t2p1 = s2typ_substx(e1nv, t2p1, svts, flag)
            if flag <= fval:
                t2p0
            else:
                s2typ(t2p0.sort(), T2Ptop1(t2p1))
        def f0_arg1(e1nv: !E1nv, t2p0: s2typ, svts: s2vts, flag: &SInt >> _) -> s2typ:
            let fval = flag
            let T2Parg1(knd0, t2p1) = t2p0.node()
            let t2p1 = s2typ_substx(e1nv, t2p1, svts, flag)
            if flag <= fval:
                t2p0
            else:
                s2typ(t2p0.sort(), T2Parg1(knd0, t2p1))
        def f0_atx2(e1nv: !E1nv, t2p0: s2typ, svts: s2vts, flag: &SInt >> _) -> s2typ:
            let fval = flag
            let T2Patx2(t2p1, t2p2) = t2p0.node()
            let t2p1 = s2typ_substx(e1nv, t2p1, svts, flag)
            let t2p2 = s2typ_substx(e1nv, t2p2, svts, flag)
            if flag <= fval:
                t2p0
            else:
                s2typ(t2p0.sort(), T2Patx2(t2p1, t2p2))
        def f0_apps(e1nv: !E1nv, t2p0: s2typ, svts: s2vts, flag: &SInt >> _) -> s2typ:
            let fval = flag
            let T2Papps(t2f0, t2ps) = t2p0.node()
            let t2f0 = s2typ_substx(e1nv, t2f0, svts, flag)
            let t2ps = s2typlst_substx(e1nv, t2ps, svts, flag)
            if flag <= fval:
                t2p0
            else:
                s2typ(t2p0.sort(), T2Papps(t2f0, t2ps))
        def f0_lam1(e1nv: !E1nv, t2p0: s2typ, svts: s2vts, flag: &SInt >> _) -> s2typ:
            let fval = flag
            let T2Plam1(s2vs, t2p1) = t2p0.node()
            let t2p1 = s2typ_substx(e1nv, t2p1, svts, flag)
            if flag <= fval:
                t2p0
            else:
                s2typ(t2p0.sort(), T2Plam1(s2vs, t2p1))
        def f0_fun1(e1nv: !E1nv, t2p0: s2typ, svts: s2vts, flag: &SInt >> _) -> s2typ:
            let fval = flag
            let T2Pfun1(f2cl, npf1, t2ps, tres) = t2p0.node()
            let t2ps = s2typlst_substx(e1nv, t2ps, svts, flag)
            let tres = s2typ_substx(e1nv, tres, svts, flag)
            if flag <= fval:
                t2p0
            else:
                let s2t0 = t2p0.sort()
                s2typ(s2t0, T2Pfun1(f2cl, npf1, t2ps, tres))
        def f0_text(e1nv: !E1nv, t2p0: s2typ, svts: s2vts, flag: &SInt >> _) -> s2typ:
            let fval = flag
            let T2Ptext(name, t2ps) = t2p0.node()
            let t2ps = s2typlst_substx(e1nv, t2ps, svts, flag)
            if flag <= fval:
                t2p0
            else:
                s2typ(t2p0.sort(), T2Ptext(name, t2ps))
        def f0_exi0(e1nv: !E1nv, t2p0: s2typ, svts: s2vts, flag: &SInt >> _) -> s2typ:
            let fval = flag
            let T2Pexi0(s2vs, t2p1) = t2p0.node()
            let t2p1 = s2typ_substx(e1nv, t2p1, svts, flag)
            if flag <= fval:
                t2p0
            else:
                s2typ(t2p0.sort(), T2Pexi0(s2vs, t2p1))
        def f0_uni0(e1nv: !E1nv, t2p0: s2typ, svts: s2vts, flag: &SInt >> _) -> s2typ:
            let fval = flag
            let T2Puni0(s2vs, t2p1) = t2p0.node()
            let t2p1 = s2typ_substx(e1nv, t2p1, svts, flag)
            if flag <= fval:
                t2p0
            else:
                s2typ(t2p0.sort(), T2Puni0(s2vs, t2p1))
        def f0_trcd(e1nv: !E1nv, t2p0: s2typ, svts: s2vts, flag: &SInt >> _) -> s2typ:
            let fval = flag
            let T2Ptrcd(knd0, npf1, ltps) = t2p0.node()
            let ltps = l2t2plst_substx(e1nv, ltps, svts, flag)
            if flag <= fval:
                t2p0
            else:
                s2typ_make_node(t2p0.sort(), T2Ptrcd(knd0, npf1, ltps))

    def s2typlst_substx(e1nv: !E1nv, t2ps: s2typlst, svts: s2vts, flag: &SInt >> _) -> s2typlst:
        match t2ps:
            case list_nil():
                list_nil()
            case list_cons(t2p1, tps2):
                let fval = flag
                let t2p1 = s2typ_substx(e1nv, t2p1, svts, flag)
                let tps2 = s2typlst_substx(e1nv, tps2, svts, flag)
                if flag <= fval:
                    t2ps
                else:
                    list_cons(t2p1, tps2)

    def l2t2plst_substx(e1nv: !E1nv, ltps: l2t2plst, svts: s2vts, flag: &SInt >> _) -> l2t2plst:
        match ltps:
            case list_nil():
                list_nil()
            case list_cons(ltp1, lts2):
                let fval = flag
                let S2LAB(lab1, t2p1) = ltp1
                let t2p1 = s2typ_substx(e1nv, t2p1, svts, flag)
                let ltp1 = if (flag <= fval):
                    ltp1
                else: S2LAB(lab1, t2p1)
                let lts2 = l2t2plst_substx(e1nv, lts2, svts, flag)
                if flag <= fval:
                    ltps
                else:
                    list_cons(ltp1, lts2)

