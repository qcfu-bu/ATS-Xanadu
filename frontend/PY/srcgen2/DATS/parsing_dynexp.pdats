@extern
def p1_d0eclseq_WHERE() -> p1_fun[list[d0eclseq_WHERE]]

private:
    @extern
    def p1_napp() -> p1_fun[d0exp]
    def f0_whrs(d0e0: d0exp, wdcs: list[d0eclseq_WHERE]) -> d0exp:
        match wdcs:
            case list_nil():
                d0e0
            case list_cons(wdc1, wdcs):
                let loc1 = match wdc1:
                    case d0eclseq_WHERE(_, _, _, tend):
                        d0e0.lctn() + tend.lctn()
                let d0e1 = d0exp(loc1, D0Ewhere(d0e0, wdc1))
                f0_whrs(d0e1, wdcs)
    @impl
    def p1_napp(buf, err):
        let e00 = err
        let tok = buf.getk0()
        let tnd = tok.tnode()
        match tnd:
            case T_IF0():
                let tknd = tok
                buf.skip1()
                let d0e1 = p1_d0exp_app(buf, err)
                let d0e2 = p1_d0exp_THEN(buf, err)
                let d0e3 = p1_d0exp_ELSE(buf, err)
                let tend = pq_ENDIF0(buf, err)
                let tinv = p1_t0endinv(buf, err)
                let lres = match tinv:
                    case T0ENDINVnone():
                        match d0e3:
                            case d0exp_ELSE_none(tok):
                                match d0e2:
                                    case d0exp_THEN_some(_, d0e2):
                                        tknd.lctn() + d0e2.lctn()
                            case d0exp_ELSE_some(_, d0e3):
                                tknd.lctn() + d0e3.lctn()
                    case T0ENDINVsome(_, tinv):
                        tknd.lctn() + tinv.lctn()
                err := e00
                match tinv:
                    case T0ENDINVnone(_):
                        d0exp_make_node(lres, D0Eift0(tknd, d0e1, d0e2, d0e3))
                    case T0ENDINVsome(_, tinv):
                        d0exp_make_node(lres, D0Eift1(tknd, d0e1, d0e2, d0e3, tinv))
            case T_CASE(k0):
                let tknd = tok
                buf.skip1()
                let d0e1 = p1_d0exp_app(buf, err)
                let tof0 = p1_OF0(buf, err)
                let tbar = pq_BAR(buf, err)
                let dcls = p1_d0clsseq_BAR(buf, err)
                let tend = pq_ENDCAS(buf, err)
                let tinv = p1_t0endinv(buf, err)
                let lknd = tknd.lctn()
                let lres = match tinv:
                    case T0ENDINVnone():
                        match dcls:
                            case list_nil():
                                match tbar:
                                    case optn_nil():
                                        lknd + tof0.lctn()
                                    case optn_cons(tbar):
                                        lknd + tbar.lctn()
                            case list_cons(_, _):
                                let dcl1 = list_last(dcls)
                                lknd + dcl1.lctn()
                    case T0ENDINVsome(_, tinv):
                        lknd + tinv.lctn()
                err := e00
                match tinv:
                    case T0ENDINVnone(_):
                        d0exp_make_node(lres, D0Ecas0(tknd, d0e1, tof0, tbar, dcls))
                    case T0ENDINVsome(_, tinv):
                        d0exp_make_node(lres, D0Ecas1(tknd, d0e1, tof0, tbar, dcls, tinv))
            case T_LAM(k0):
                let tknd = tok
                buf.skip1()
                let farg = p1_f0argseq(buf, err)
                let sres = p1_s0res(buf, err)
                let arrw = p1_f0unarrw(buf, err)
                let body = p1_d0exp(buf, err)
                let tend = pq_ENDLAM(buf, err)
                let lres = match tend:
                    case optn_nil():
                        tknd.lctn() + body.lctn()
                    case optn_cons(tok2):
                        tknd.lctn() + tok2.lctn()
                err := e00
                d0exp_make_node(lres, D0Elam0(tknd, farg, sres, arrw, body, tend))
            case T_FIX(k0):
                let tknd = tok
                buf.skip1()
                let dpid = p1_d0pid(buf, err)
                let farg = p1_f0argseq(buf, err)
                let sres = p1_s0res(buf, err)
                let arrw = p1_f0unarrw(buf, err)
                let body = p1_d0exp(buf, err)
                let tend = pq_ENDFIX(buf, err)
                let lres = match tend:
                    case optn_nil():
                        tknd.lctn() + body.lctn()
                    case optn_cons(tok2):
                        tknd.lctn() + tok2.lctn()
                err := e00
                d0exp_make_node(lres, D0Efix0(tknd, dpid, farg, sres, arrw, body, tend))
            case _:
                err := e00 + 1
                d0exp_make_node(tok.lctn(), D0Etkerr(tok))

@impl
def p1_d0exp(buf, err):
    let e00 = err
    let d0es = p1_d0expseq_atm(buf, err)
    match d0es:
        case list_nil():
            p1_napp(buf, err)
        case list_cons(d0e1, des2):
            let d0e0 = match des2:
                case list_nil():
                    d0e1
                case list_cons(_):
                    let d0e2 = list_last(des2)
                    let loc0 = d0e1.lctn() + d0e2.lctn()
                    d0exp_make_node(loc0, D0Eapps(d0es))
            let wdcs = p1_d0eclseq_WHERE(buf, err)
            let d0e0 = f0_whrs(d0e0, wdcs)
            let sopt = pq_s0exp_anno(buf, err)
            d0exp_annotopt(d0e0, sopt)


@impl
def p1_l0d0e(buf, err):
    let e00 = err
    let lab0 = p1_l0abl(buf, err)
    let teq1 = p1_EQ0(buf, err)
    let d0e2 = p1_d0exp(buf, err)
    err := e00
    D0LAB(lab0, teq1, d0e2)

@impl
def p1_s0res(buf, err):
    let e00 = err
    let tok = buf.getk0()
    match tok.node():
        case T_CLN():
            let tcln = tok
            buf.skip1()
            let seff = S0EFFnone(tcln)
            let s0e1 = p1_s0exp_app_NEQ0(buf, err)
            err := e00
            S0RESsome(seff, s0e1)
        case T_CLNLT(_):
            let tbeg = tok
            buf.skip1()
            let s0fs = list_vt2t(@sapp[s0exp] ps_COMMA_p1fun(buf, err, p1_s0exp_app_NGT0))
            let tend = p1_GT0(buf, err)
            let s0e1 = p1_s0exp_app_NEQ0(buf, err)
            let lres = tbeg.lctn() + tend.lctn()
            err := e00
            S0RESsome(S0EFFsome(tbeg, s0fs, tend), s0e1)
        case _:
            S0RESnone()

@impl
def p1_t0qua(buf, err):
    let e00 = err
    let tok = buf.getk0()
    match tok.node():
        case T_LBRACE():
            let tbeg = tok
            buf.skip1()
            let s0qs = p1_s0quaseq_BSCLN(buf, err)
            let tend = p1_RBRACE(buf, err)
            err := e00
            T0QUAsome(tbeg, s0qs, tend)
        case _:
            err := e00 + 1
            T0QUAnone(tok)

@impl
def p1_t0inv(buf, err):
    let t0qs = p1_t0quaseq(buf, err)
    let tok0 = buf.getk0()
    match tok0.node():
        case T_LPAREN():
            let tbeg = tok0
            buf.skip1()
            let d0ts = p1_d0patseq_COMMA(buf, err)
            let tend = p1_RPAREN(buf, err)
            let tann = pq_s0exp_anno(buf, err)
            T0INVsome(t0qs, tbeg, d0ts, tend)
        case _:
            T0INVnone(t0qs, tok0)

@impl
def p1_t0quaseq(buf, err):
    list_vt2t(@sapp[t0qua] ps_p1fun(buf, err, p1_t0qua))

@impl
def p1_t0endinv(buf, err):
    let tok0 = buf.getk0()
    match tok0.node():
        case T_ENDST():
            buf.skip1()
            let tinv = p1_t0inv(buf, err)
            T0ENDINVsome(_, tinv)
        case _:
            T0ENDINVnone

@impl
def p1_d0exp_atm(buf, err):
    let e00 = err
    let tok = buf.getk0()
    let tnd = tok.tnode()
    match tnd:
        case _ if t0_d0eid(tnd):
            let id0 = p1_d0eid(buf, err)
            err := e00
            d0exp(id0.lctn(), D0Eid0(id0))
        case _ if t0_t0int(tnd):
            let i00 = p1_t0int(buf, err)
            err := e00
            d0exp(i00.lctn(), D0Eint(i00))
        case _ if t0_t0chr(tnd):
            let c00 = p1_t0chr(buf, err)
            err := e00
            d0exp(c00.lctn(), D0Echr(c00))
        case _ if t0_t0flt(tnd):
            let f00 = p1_t0flt(buf, err)
            err := e00
            d0exp(f00.lctn(), D0Eflt(f00))
        case _ if t0_t0str(tnd):
            let s00 = p1_t0str(buf, err)
            err := e00
            d0exp(s00.lctn(), D0Estr(s00))
        case T_OP1():
            let tok0 = tok
            buf.skip1()
            let deid = p1_d0eid(buf, err)
            let loc0 = tok0.lctn() + deid.lctn()
            err := e00
            d0exp_make_node(loc0, D0Eopid(deid))
        case T_OP2(_):
            let tok0 = tok
            buf.skip1()
            let loc0 = tok0.lctn()
            let opid = i0dnt_some(tok)
            err := e00
            d0exp_make_node(loc0, D0Eopid(opid))
        case T_OP3(_):
            let tbeg = tok
            buf.skip1()
            let deid = p1_d0eid(buf, err)
            let tend = p1_RPAREN(buf, err)
            let loc0 = tbeg.lctn() + tend.lctn()
            err := e00
            d0exp_make_node(loc0, D0Eopid(deid))
        case T_LT0():
            let tok1 = tok
            buf.skip1()
            let mark = tokbuf_mark_get(buf)
            let s0es = list_vt2t(@sapp[s0exp] ps_COMMA_p1fun(buf, err, p1_s0exp_app_NGT0))
            let tok2 = buf.getk0()
            match tok2.node():
                case T_GT0():
                    let tbeg = tok1
                    let tend = tok2
                    buf.skip1()
                    tokbuf_mark_clr(buf, mark)
                    let lres = tbeg.lctn() + tend.lctn()
                    err := e00
                    d0exp(lres, D0Etarg(tbeg, s0es, tend))
                case _:
                    tokbuf_mark_set(buf, mark)
                    let loc1 = tok1.lctn()
                    let tnd2 = T0IDSYM_LT0
                    let tok2 = token_make_node(loc1, tnd2)
                    d0exp(loc1, D0Eid0(i0dnt_some(tok2)))
        case T_GT0():
            let tok1 = tok
            buf.skip1()
            let loc1 = tok1.lctn()
            let tnd2 = T0IDSYM_GT0
            let tok2 = token_make_node(loc1, tnd2)
            d0exp(loc1, D0Eid0(i0dnt_some(tok2)))
        case T_LTGT():
            let tbeg = tok
            let tend = tok
            buf.skip1()
            let s0es = list_nil()
            let lres = tbeg.lctn()
            err := e00
            d0exp(lres, D0Etarg(tbeg, s0es, tend))
        case T_LBRACE():
            let tbeg = tok
            buf.skip1()
            let s0es = p1_s0expseq_COMMA(buf, err)
            let tend = p1_RBRACE(buf, err)
            let lres = tbeg.lctn() + tend.lctn()
            err := e00
            d0exp(lres, D0Esarg(tbeg, s0es, tend))
        case T_LPAREN():
            let tbeg = tok
            buf.skip1()
            let d0es = p1_d0expseq_COMMA(buf, err)
            let dend = p1_d0exp_RPAREN(buf, err)
            let lres = tbeg.lctn() + d0exp_RPAREN_lctn(dend)
            err := e00
            d0exp(lres, D0Elpar(tbeg, d0es, dend))
        case T_TRCD10(k0):
            let tbeg = tok
            buf.skip1()
            let topt = if (k0 <= 1):
                optn_nil()
            else: optn_cons(p1_LPAREN(buf, err))
            let d0es = p1_d0expseq_COMMA(buf, err)
            let dend = p1_d0exp_RPAREN(buf, err)
            let lres = tbeg.lctn() + d0exp_RPAREN_lctn(dend)
            err := e00
            d0exp_make_node(lres, D0Etup1(tbeg, topt, d0es, dend))
        case T_TRCD20(k0):
            let tbeg = tok
            buf.skip1()
            let topt = if (k0 <= 1):
                optn_nil()
            else: optn_cons(p1_LBRACE(buf, err))
            let ldes = p1_l0d0eseq_COMMA(buf, err)
            let dend = p1_l0d0e_RBRACE(buf, err)
            let lres = tbeg.lctn() + l0d0e_RBRACE_lctn(dend)
            err := e00
            d0exp_make_node(lres, D0Ercd2(tbeg, topt, ldes, dend))
        case T_LET():
            let tok1 = tok
            buf.skip1()
            let d0cs = p1_d0eclseq_dyn(buf, err)
            let topt = pq_IN0(buf, err)
            let d0es = p1_d0expseq_SMCLN(buf, err)
            let tok2 = p1_ENDLET(buf, err)
            let lres = tok1.lctn() + tok2.lctn()
            err := e00
            d0exp_make_node(lres, D0Elet0(tok1, d0cs, topt, d0es, tok2))
        case T_TRY():
            let tok1 = tok
            buf.skip1()
            let d0es = p1_d0expseq_SMCLN(buf, err)
            let tok2 = p1_WITH(buf, err)
            let tbar = pq_BAR(buf, err)
            let dcls = p1_d0clsseq_BAR(buf, err)
            let tend = pq_ENDTRY(buf, err)
            let lknd = tok1.lctn()
            let lres = match tend:
                case optn_nil():
                    match dcls:
                        case list_nil():
                            match tbar:
                                case optn_nil():
                                    lknd + tok2.lctn()
                                case optn_cons(tbar):
                                    lknd + tbar.lctn()
                        case list_cons(_, _):
                            let dcl1 = list_last(dcls)
                            lknd + dcl1.lctn()
                case optn_cons(tok3):
                    lknd + tok3.lctn()
            err := e00
            d0exp_make_node(lres, D0Etry0(tok1, d0es, tok2, tbar, dcls, tend))
        case _ if t0_dtsel(tnd):
            let tok1 = tok
            buf.skip1()
            let lab1 = p1_l0abl(buf, err)
            let tok2 = buf.getk0()
            let arg2 = match tok2.node():
                case T_LPAREN():
                    let d0e2 = p1_d0exp_atm(buf, err)
                    optn_cons(d0e2)
                case _:
                    optn_nil()
            let loc1 = tok1.lctn()
            let lres = match arg2:
                case optn_nil():
                    loc1 + lab1.lctn()
                case optn_cons(d0e2):
                    loc1 + d0e2.lctn()
            err := e00
            d0exp(lres, D0Edtsel(tok1, lab1, arg2))
        case T_LBRCKT():
            let tbeg = tok
            buf.skip1()
            let d0es = p1_d0expseq_COMMA(buf, err)
            let tend = p1_RBRCKT(buf, err)
            let lres = tbeg.lctn() + tend.lctn()
            err := e00
            d0exp_make_node(lres, D0Ebrckt(tbeg, d0es, tend))
        case T_IDQUA(_):
            let tok0 = tok
            buf.skip1()
            let d0e1 = p1_d0exp_atm(buf, err)
            err := e00
            let lres = tok0.lctn() + d0e1.lctn()
            d0exp_make_node(lres, D0Equal0(tok0, d0e1))
        case T_DLR_RAISE(_):
            let tok0 = tok
            buf.skip1()
            let d0e1 = p1_d0exp_app(buf, err)
            err := e00
            let lres = tok0.lctn() + d0e1.lctn()
            d0exp_make_node(lres, D0Eraise(tok0, d0e1))
        case T_DLR_EXISTS(_):
            let tok0 = tok
            buf.skip1()
            let sqas = p1_d0expseq_sarg(buf, err)
            let d0e1 = p1_d0exp_atm(buf, err)
            err := e00
            let lres = tok0.lctn() + d0e1.lctn()
            d0exp_make_node(lres, D0Eexists(tok0, sqas, d0e1))
        case T_DLR_EXTNAM(_):
            let tok0 = tok
            buf.skip1()
            let gnm1 = p1_g0nam(buf, err)
            err := e00
            let lres = tok0.lctn() + gnm1.lctn()
            d0exp_make_node(lres, D0Eextnam(tok0, gnm1))
        case T_DLR_SYNEXT(_):
            let tok0 = tok
            buf.skip1()
            let gexp = p1_g0exp_atm(buf, err)
            err := e00
            let lres = tok0.lctn() + gexp.lctn()
            d0exp_make_node(lres, D0Esynext(tok0, gexp))
        case _:
            err := e00 + 1
            d0exp_make_node(tok.lctn(), D0Etkerr(tok))

