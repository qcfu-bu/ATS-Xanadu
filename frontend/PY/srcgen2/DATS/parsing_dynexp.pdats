@impl
def p1_d0clsseq_BAR(buf, err):
    list_vt2t(@sapp[d0cls] ps_BAR_p1fun(buf, err, p1_d0cls))

private:
    def p1_d0exp_app_ntk(buf: !tkbf0, err: &SInt >> _, ntk: tnode -> Bool) -> d0exp:
        def p1_ntk(buf: !tkbf0, err: &SInt >> _) -> d0exp:
            let e00 = err
            let tok = buf.getk0()
            let tnd = tok.tnode()
            if ntk(tnd):
                p1_d0exp_atm(buf, err)
            else:
                err := e00 + 1
                d0exp(tok.lctn(), D0Etkerr(tok))
        def p1_apps(buf: !tkbf0, err: &SInt >> _) -> d0exp:
            let d0e1 = p1_ntk(buf, err)
            let d0es = list_vt2t(@sapp[d0exp] ps_p1fun(buf, err, p1_ntk))
            let d0e0 = match d0es:
                case list_nil(_):
                    d0e1
                case list_cons(_):
                    let d0e2 = list_last(d0es)
                    let loc0 = d0e1.lctn() + d0e2.lctn()
                    d0exp_make_node(loc0, D0Eapps(list_cons(d0e1, d0es)))
            let wdcs = p1_d0eclseq_WHERE(buf, err)
            let d0e0 = f0_whrs(d0e0, wdcs)
            let sopt = pq_s0exp_anno(buf, err)
            d0exp_annotopt(d0e0, sopt)

        def f0_whrs(d0e0: d0exp, wdcs: list[d0eclseq_WHERE]) -> d0exp:
            match wdcs:
                case list_nil():
                    d0e0
                case list_cons(wdc1, wdcs):
                    let loc1 = match wdc1:
                        case d0eclseq_WHERE(_, _, _, tend):
                            d0e0.lctn() + tend.lctn()
                    let d0e1 = d0exp(loc1, D0Ewhere(d0e0, wdc1))
                    f0_whrs(d0e1, wdcs)
        def pk_if0(tok: token, buf: !tkbf0, err: &SInt >> _) -> d0exp:
            let e00 = err
            let tknd = tok
            buf.skip1()
            let d0e1 = p1_d0exp_app(buf, err)
            let d0e2 = p1_then(buf, err)
            let d0e3 = p1_else(buf, err)
            let tend = pq_ENDIF0(buf, err)
            let tinv = p1_t0endinv(buf, err)
            let lres = match tinv:
                case T0ENDINVnone():
                    match d0e3:
                        case d0exp_ELSE_none(tok):
                            match d0e2:
                                case d0exp_THEN_some(_, d0e2):
                                    tknd.lctn() + d0e2.lctn()
                        case d0exp_ELSE_some(_, d0e3):
                            tknd.lctn() + d0e3.lctn()
                case T0ENDINVsome(_, tinv):
                    tknd.lctn() + tinv.lctn()
            err := e00
            match tinv:
                case T0ENDINVnone(_):
                    d0exp_make_node(lres, D0Eift0(tknd, d0e1, d0e2, d0e3))
                case T0ENDINVsome(_, tinv):
                    d0exp_make_node(lres, D0Eift1(tknd, d0e1, d0e2, d0e3, tinv))

        def p1_then(buf: !tkbf0, err: &SInt >> _) -> d0exp_THEN:
            let e00 = err
            let tok = buf.getk0()
            match tok.node():
                case T_THEN():
                    buf.skip1()
                    let d0e = p1_apps(buf, err)
                    err := e00
                    d0exp_THEN_some(tok, d0e)
                case _:
                    err := e00 + 1
                    d0exp_THEN_some(tok, p1_ntk(buf, err))

        def p1_else(buf: !tkbf0, err: &SInt >> _) -> d0exp_ELSE:
            let e00 = err
            let tok = buf.getk0()
            match tok.node():
                case T_ELSE():
                    buf.skip1()
                    let d0e = p1_apps(buf, err)
                    err := e00
                    d0exp_ELSE_some(tok, d0e)
                case _:
                    d0exp_ELSE_none(tok)
        def pk_lam0(tok: token, buf: !tkbf0, err: &SInt >> _) -> d0exp:
            let e00 = err
            let tknd = tok
            buf.skip1()
            let farg = p1_f0argseq(buf, err)
            let sres = p1_s0res(buf, err)
            let arrw = p1_f0unarrw(buf, err)
            let body = p1_apps(buf, err)
            let tend = pq_ENDLAM(buf, err)
            let lres = match tend:
                case optn_nil():
                    tknd.lctn() + body.lctn()
                case optn_cons(tok2):
                    tknd.lctn() + tok2.lctn()
            err := e00
            d0exp_make_node(lres, D0Elam0(tknd, farg, sres, arrw, body, tend))
        def pk_fix0(tok: token, buf: !tkbf0, err: &SInt >> _) -> d0exp:
            let e00 = err
            let tknd = tok
            buf.skip1()
            let dpid = p1_d0pid(buf, err)
            let farg = p1_f0argseq(buf, err)
            let sres = p1_s0res(buf, err)
            let arrw = p1_f0unarrw(buf, err)
            let body = p1_apps(buf, err)
            let tend = pq_ENDFIX(buf, err)
            let lres = match tend:
                case optn_nil():
                    tknd.lctn() + body.lctn()
                case optn_cons(tok2):
                    tknd.lctn() + tok2.lctn()
            err := e00
            d0exp_make_node(lres, D0Efix0(tknd, dpid, farg, sres, arrw, body, tend))
        let tok = buf.getk0()
        match tok.node():
            case T_IF0():
                pk_if0(tok, buf, err)
            case T_LAM(k0):
                pk_lam0(tok, buf, err)
            case T_FIX(k0):
                pk_fix0(tok, buf, err)
            case _:
                p1_apps(buf, err)

@impl
def p1_d0exp_app_NBAR(buf, err):
    p1_d0exp_app_ntk(buf, err, ntk)
where:
    def ntk(tnd: tnode) -> Bool:
        match tnd:
            case T_BAR():
                false
            case _:
                true


@impl
def p1_tkend_WHERE(buf, err):
    let e00 = err
    let tok = buf.getk0()
    match tok.node():
        case T_RBRACE():
            buf.skip1()
            tkend_WHERE_cons1(tok)
        case T_ENDWHR():
            buf.skip1()
            tkend_WHERE_cons1(tok)
        case _:
            err := e00 + 1
            tkend_WHERE_cons1(tok)

@impl
def p1_d0eclseq_WHERE(buf, err):
    let tok = buf.getk0()
    match tok.node():
        case T_WHERE():
            let twhr = tok
            buf.skip1()
            let topt = pq_LBRACE(buf, err)
            let d0cs = p1_d0eclseq_dyn(buf, err)
            let tend = p1_tkend_WHERE(buf, err)
            let d0c0 = d0eclseq_WHERE(twhr, topt, d0cs, tend)
            list_cons(d0c0, p1_d0eclseq_WHERE(buf, err))
        case _:
            list_nil()

