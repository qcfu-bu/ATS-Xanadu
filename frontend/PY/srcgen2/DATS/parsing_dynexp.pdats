@extern
def l0d0p_RBRACE_lctn() -> l0d0p_RBRACE -> loc_t

private:
    @extern
    def p1_napp(buf: !tkbf0, err: &SInt >> _) -> d0pat
    @impl
    def p1_napp(buf, err):
        let e00 = err
        let tok = buf.getk0()
        let tnd = tok.tnode()
        match tnd:
            case _:
                err := e00 + 1
                d0pat(tok.lctn(), D0Ptkerr(tok))

@impl
def p1_d0pat(buf, err):
    let d0ps = p1_d0patseq_atm(buf, err)
    match d0ps:
        case list_nil():
            p1_napp(buf, err)
        case list_cons(d0p1, dps1):
            let opt1 = pq_s0exp_annp(buf, err)
            match dps1:
                case list_nil():
                    d0pat_annotopt(d0p1, opt1)
                case list_cons(_):
                    let d0p2 = list_last(dps1)
                    let lres = d0p1.lctn() + d0p2.lctn()
                    d0pat_annotopt(d0pat(lres, D0Papps(d0ps)), opt1)


@impl
def p1_l0d0p(buf, err):
    let e00 = err
    let lab0 = p1_l0abl(buf, err)
    let teq1 = p1_EQ0(buf, err)
    let d0p2 = p1_d0pat(buf, err)
    err := e00
    D0LAB(lab0, teq1, d0p2)

@impl
def p1_d0pat_atm(buf, err):
    let e00 = err
    let tok = buf.getk0()
    let tnd = tok.tnode()
    match tnd:
        case _ if t0_d0pid(tnd):
            let id0 = p1_d0pid(buf, err)
            err := e00
            d0pat(id0.lctn(), D0Pid0(id0))
        case _ if t0_t0int(tnd):
            let i00 = p1_t0int(buf, err)
            err := e00
            d0pat(i00.lctn(), D0Pint(i00))
        case _ if t0_t0chr(tnd):
            let c00 = p1_t0chr(buf, err)
            err := e00
            d0pat(c00.lctn(), D0Pchr(c00))
        case _ if t0_t0flt(tnd):
            let f00 = p1_t0flt(buf, err)
            err := e00
            d0pat(f00.lctn(), D0Pflt(f00))
        case _ if t0_t0str(tnd):
            let s00 = p1_t0str(buf, err)
            err := e00
            d0pat(s00.lctn(), D0Pstr(s00))
        case T_LPAREN():
            let tbeg = tok
            buf.skip1()
            let d0ps = p1_d0patseq_COMMA(buf, err)
            let dend = p1_d0pat_RPAREN(buf, err)
            let lres = tbeg.lctn() + d0pat_RPAREN_lctn(dend)
            err := e00
            d0pat(lres, D0Plpar(tbeg, d0ps, dend))
        case T_LBRACE():
            let tbeg = tok
            buf.skip1()
            let s0as = p1_s0argseq_COMMA(buf, err)
            let tend = p1_RBRACE(buf, err)
            let lres = tbeg.lctn() + tend.lctn()
            err := e00
            d0pat(lres, D0Psarg(tbeg, s0as, tend))
        case T_TRCD10(k0):
            let tbeg = tok
            buf.skip1()
            let topt = if (k0 <= 1):
                optn_nil()
            else: optn_cons(p1_LPAREN(buf, err))
            let d0ps = p1_d0patseq_COMMA(buf, err)
            let dend = p1_d0pat_RPAREN(buf, err)
            let lres = tbeg.lctn() + d0pat_RPAREN_lctn(dend)
            err := e00
            d0pat_make_node(lres, D0Ptup1(tbeg, topt, d0ps, dend))
        case T_AS0():
            let ta0s = tok
            buf.skip1()
            let d0p1 = p1_d0pat(buf, err)
            let lres = ta0s.lctn() + d0p1.lctn()
            err := e00
            d0pat(lres, D0Paspt(ta0s, d0p1))
        case T_IDQUA(nam):
            let tqua = tok
            buf.skip1()
            let d0p1 = p1_d0pat_atm(buf, err)
            let lres = tqua.lctn() + d0p1.lctn()
            err := e00
            d0pat(lres, D0Pqual0(tqua, d0p1))
        case _:
            err := e00 + 1
            d0pat(tok.lctn(), D0Ptkerr(tok))

@impl
def p1_d0pat_app(buf, err):
    let d0p0 = p1_d0pat_atm(buf, err)
    let d0ps = p1_d0patseq_atm(buf, err)
    match d0ps:
        case list_nil():
            d0p0
        case list_cons(_):
            let d0p1 = list_last(d0ps)
            let loc0 = d0p0.lctn() + d0p1.lctn()
            d0pat_make_node(loc0, D0Papps(list_cons(d0p0, d0ps)))

@impl
def p1_d0patseq_atm(buf, err):
    list_vt2t(@sapp[d0pat] ps_p1fun(buf, err, p1_d0pat_atm))

@impl
def p1_d0patseq_COMMA(buf, err):
    list_vt2t(@sapp[d0pat] ps_COMMA_p1fun(buf, err, p1_d0pat))

@impl
def p1_l0d0pseq_COMMA(buf, err):
    list_vt2t(@sapp[l0d0p] ps_COMMA_p1fun(buf, err, p1_l0d0p))

@extern
def p1_f0unarrw() -> p1_fun[f0unarrw]

@impl
def p1_f0arg(buf, err):
    let e00 = err
    let tok = buf.getk0()
    let tnd = tok.tnode()
    match tnd:
        case T_DOTLT(_):
            let tbeg = tok
            buf.skip1()
            let s0es = p1_s0expseq_COMMA(buf, err)
            let tend = p1_GTDOT(buf, err)
            let lres = tbeg.lctn() + tend.lctn()
            err := e00
            f0arg_make_node(lres, F0ARGmets(tbeg, s0es, tend))
        case T_LBRACE():
            let tbeg = tok
            buf.skip1()
            let s0qs = p1_s0quaseq_BSCLN(buf, err)
            let tend = p1_RBRACE(buf, err)
            let lres = tbeg.lctn() + tend.lctn()
            err := e00
            f0arg_make_node(lres, F0ARGsapp(tbeg, s0qs, tend))
        case _:
            let d0p = p1_d0pat_atm(buf, err)
            f0arg_make_node(d0p.lctn(), F0ARGdapp(d0p))

@impl
def p1_f0argseq(buf, err):
    list_vt2t(@sapp[f0arg] ps_p1fun(buf, err, p1_f0arg))

@impl
def p1_f0unarrw(buf, err):
    let e00 = err
    let tok = buf.getk0()
    let tnd = tok.tnode()
    match tnd:
        case T_EQGT():
            buf.skip1()
            F0UNARRWdflt(tok)
        case T_EQLT():
            let tbeg = tok
            buf.skip1()
            let s0es = list_vt2t(@sapp[s0exp] ps_COMMA_p1fun(buf, err, p1_s0exp_app_NGT0))
            let tend = p1_GT0(buf, err)
            err := e00
            F0UNARRWlist(tbeg, s0es, tend)
        case _:
            F0UNARRWnone(tok)

