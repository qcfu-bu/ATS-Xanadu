@extern
def p1_d0guaseq_AND() -> p1_fun[d0gualst]

private:
    def p2_d0exp_app(buf: !tkbf0, err: &SInt >> _) -> d0exp:
        def p2_d0exp_atm(buf: !tkbf0 >> _, err: &SInt >> _) -> d0exp:
            let e00 = err
            let tok = buf.getk0()
            match tok.node():
                case T_EQGT():
                    err := e00 + 1
                    d0exp(tok.lctn(), D0Etkerr(tok))
                case _:
                    p1_d0exp_atm(buf, err)
        let d0e0 = p2_d0exp_atm(buf, err)
        let d0es = list_vt2t(@sapp[d0exp] ps_p1fun(buf, err, p2_d0exp_atm))
        match d0es:
            case list_nil():
                d0e0
            case list_cons(_):
                let d0e1 = list_last(d0es)
                let loc0 = d0e0.lctn() + d0e1.lctn()
                d0exp_make_node(loc0, D0Eapps(list_cons(d0e0, d0es)))

