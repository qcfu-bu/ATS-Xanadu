def d0exp_RPAREN_lctn() -> d0exp_RPAREN -> loc_t

@extern
def l0d0e_RBRACE_lctn() -> l0d0e_RBRACE -> loc_t

enum T0endinv:
    case T0ENDINVnone()
    case T0ENDINVsome(token, t0inv)

