@impl
def t2read0_d2exp(d2e0, err):
    match d2e0.node():
        case D2Evar(_):
            d2e0
        case D2Eint(_):
            d2e0
        case D2Ebtf(_):
            d2e0
        case D2Echr(_):
            d2e0
        case D2Eflt(_):
            d2e0
        case D2Estr(_):
            d2e0
        case D2Ei00(_):
            d2e0
        case D2Eb00(_):
            d2e0
        case D2Ec00(_):
            d2e0
        case D2Ef00(_):
            d2e0
        case D2Es00(_):
            d2e0
        case D2Econ(_):
            d2e0
        case D2Ecst(_):
            d2e0
        case D2Etop(_):
            d2e0
        case D2Econs(_):
            d2e0
        case D2Ecsts(_):
            d2e0
        case D2Esym0(_):
            f0_sym0(d2e0, err)
        case D2Esapp(_):
            f0_sapp(d2e0, err)
        case D2Etapp(_):
            f0_tapp(d2e0, err)
        case D2Edap0(_):
