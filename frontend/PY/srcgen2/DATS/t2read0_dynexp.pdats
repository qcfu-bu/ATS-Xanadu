            let d2e1 = t2read0_d2exp(d2e1, err)
            let d2p2 = t2read0_d2pat(d2p2, err)
            if (err == e00):
                dgua
            else:
                d2gua(dgua.lctn(), D2GUAmat(d2e1, d2p2))

@impl
