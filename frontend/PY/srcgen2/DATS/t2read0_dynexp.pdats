@impl
def t2read0_d2pat(d2p0, err):
    match d2p0.node():
        case D2Pvar(_):
            d2p0
        case D2Pany(_):
            d2p0
        case D2Pint(_):
            d2p0
        case D2Pbtf(_):
            d2p0
        case D2Pchr(_):
            d2p0
        case D2Pflt(_):
            d2p0
        case D2Pstr(_):
            d2p0
        case D2Pi00(_):
            d2p0
        case D2Pb00(_):
            d2p0
        case D2Pc00(_):
            d2p0
        case D2Ps00(_):
            d2p0
        case D2Pcon(_):
            d2p0
        case D2Pcons(_):
            d2p0
        case D2Pbang(_):
            f0_bang(d2p0, err)
        case D2Pflat(_):
            f0_flat(d2p0, err)
        case D2Pfree(_):
            f0_free(d2p0, err)
        case D2Psapp(_):
            f0_sapp(d2p0, err)
        case D2Pdap1(_):
            f0_dap1(d2p0, err)
        case D2Pdapp(_):
            f0_dapp(d2p0, err)
        case D2Prfpt(_):
            f0_rfpt(d2p0, err)
        case D2Ptup0(_):
            f0_tup0(d2p0, err)
        case D2Ptup1(_):
            f0_tup1(d2p0, err)
        case D2Prcd2(_):
            f0_rcd2(d2p0, err)
        case D2Pargtp(_):
            f0_argtp(d2p0, err)
        case D2Pannot(_):
            f0_annot(d2p0, err)
        case _:
            let lvl0 = 1
            err := err + 1
            d2pat_errck(lvl0, d2p0)
where:
    def f0_bang(d2p: d2pat, err: &SInt >> _) -> d2pat:
        let e00 = err
        let D2Pbang(d2p1) = d2p.node()
        let d2p1 = t2read0_d2pat(d2p1, err)
        if (err == e00):
            d2p
        else:
            d2pat_bang_errck(d2p.lctn(), d2p1)
    def f0_flat(d2p: d2pat, err: &SInt >> _) -> d2pat:
        let e00 = err
        let D2Pflat(d2p1) = d2p.node()
        let d2p1 = t2read0_d2pat(d2p1, err)
        if (err == e00):
            d2p
        else:
            d2pat_flat_errck(d2p.lctn(), d2p1)
    def f0_free(d2p: d2pat, err: &SInt >> _) -> d2pat:
        let e00 = err
        let D2Pfree(d2p1) = d2p.node()
        let d2p1 = t2read0_d2pat(d2p1, err)
        if (err == e00):
            d2p
        else:
            d2pat_free_errck(d2p.lctn(), d2p1)
    def f0_sapp(d2p: d2pat, err: &SInt >> _) -> d2pat:
        let e00 = err
        let D2Psapp(d2f0, s2vs) = d2p.node()
        let d2f0 = t2read0_d2pat(d2f0, err)
        if (err == e00):
            d2p
        else:
            let loc = d2p.lctn()
            d2pat_sapp_errck(loc, d2f0, s2vs)
    def f0_dap1(d2p: d2pat, err: &SInt >> _) -> d2pat:
        let e00 = err
        let D2Pdap1(d2f0) = d2p.node()
        let d2f0 = t2read0_d2pat(d2f0, err)
        if (err == e00):
            d2p
        else:
            d2pat_dap1_errck(d2p.lctn(), d2f0)
    def f0_dapp(d2p: d2pat, err: &SInt >> _) -> d2pat:
        let e00 = err
        let D2Pdapp(d2f0, npf1, d2ps) = d2p.node()
        let d2f0 = t2read0_d2pat(d2f0, err)
        let d2ps = t2read0_d2patlst(d2ps, err)
        if (err == e00):
            d2p
        else:
            let loc = d2p.lctn()
            d2pat_dapp_errck(loc, d2f0, npf1, d2ps)
    def f0_rfpt(d2p: d2pat, err: &SInt >> _) -> d2pat:
        let e00 = err
        let D2Prfpt(d2p1, tkas, d2p2) = d2p.node()
        let d2p1 = t2read0_d2pat(d2p1, err)
        let d2p2 = t2read0_d2pat(d2p2, err)
        if (err == e00):
            d2p
        else:
            let loc = d2p.lctn()
