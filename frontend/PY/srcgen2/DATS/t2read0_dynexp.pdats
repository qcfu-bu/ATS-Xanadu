    def f0_sym0(d2e: d2exp, err: &SInt >> _) -> d2exp:
        let e00 = err
        let D2Esym0(drxp, d1e1, dpis) = d2e.node()
        let d2e1 = drxp.dexp()
        match d2e1.node():
            case D2Enone0():
                let lvl0 = 1
                err := err + 1
                d2exp_errck(lvl0, d2e)
            case _:
                let d2e1 = t2read0_d2exp(d2e1, err)
                if (err == e00):
                    d2e
                else:
                    let lvl0 = errvl(d2e1)
                    drxp.dexp(d2e1)
                    d2exp_errck(lvl0 + 1, d2e)
