def d2pat_errck(lvl0: SInt, d2p0: d2pat) -> d2pat:
    let loc0 = d2p0.lctn()
    d2pat_make_node(loc0, D2Perrck(lvl0, d2p0))

def d2exp_errck(lvl0: SInt, d2e0: d2exp) -> d2exp:
    let loc0 = d2e0.lctn()
    d2exp_make_node(loc0, D2Eerrck(lvl0, d2e0))

def d2pat_errvl_a1(d2p0: d2pat) -> SInt:
    match d2p0.node():
        case D2Perrck(lvl0, _):
            lvl0
        case _:
            0

@overload d2pat_errvl = d2pat_errvl_a1

@overload errvl = d2pat_errvl_a1

def d2pat_errvl_a2(d2p1: d2pat, d2p2: d2pat) -> SInt:
    maxs(errvl(d2p1), errvl(d2p2))

@overload d2pat_errvl = d2pat_errvl_a2

@overload errvl = d2pat_errvl_a2

@extern
def d2pat_errvl_lst(d2ps: d2patlst) -> SInt

@impl
def d2pat_errvl_lst(d2ps):
    match d2ps:
        case list_nil():
            0
        case list_cons(d2p1, d2ps):
            maxs(errvl(d2p1), d2pat_errvl_lst(d2ps))

@overload d2pat_errvl = d2pat_errvl_lst

@overload errvl = d2pat_errvl_lst

@extern
def l2d2p_errvl_ldps(ldps: l2d2plst) -> SInt

@impl
def l2d2p_errvl_ldps(ldps):
    match ldps:
        case list_nil():
            0
        case list_cons(ldp1, ldps):
            let D2LAB(lab, dp1) = ldp1
            maxs(errvl(dp1), l2d2p_errvl_ldps(ldps))

@overload l2d2p_errvl = l2d2p_errvl_ldps

