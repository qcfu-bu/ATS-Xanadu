@impl
def t2read0_f2arg(farg, err):
    match farg.node():
        case F2ARGdapp(npf1, d2ps):
            let e00 = err
            let d2ps = t2read0_d2patlst(d2ps, err)
            if (err == e00):
                farg
            else:
                f2arg(farg.lctn(), F2ARGdapp(npf1, d2ps))
        case F2ARGsapp(s2vs, s2es):
            let e00 = err
            if (err == e00):
                farg
            else:
                f2arg(farg.lctn(), F2ARGsapp(s2vs, s2es))
        case F2ARGmets(s2es):
            let e00 = err
            if (err == e00):
                farg
            else:
                f2arg(farg.lctn(), F2ARGmets(s2es))

