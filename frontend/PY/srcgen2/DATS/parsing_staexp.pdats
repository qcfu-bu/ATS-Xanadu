@impl
def p1_t0arg(buf, err):
    let e00 = err
    let mark = tokbuf_mark_get(buf)
    let tok0 = buf.getk1()
    let tok1 = buf.getk0()
    let tnd0 = tok0.tnode()
    match tok1.node():
        case T_CLN() if t0_s0aid(tnd0):
            buf.skip1()
            tokbuf_mark_clr(buf, mark)
            let s0t0 = p1_sort0(buf, err)
            let lres = tok0.lctn() + s0t0.lctn()
            err := e00
            t0arg_make_node(lres, T0ARGsome(s0t0, optn_cons(tok0)))
        case _:
            tokbuf_mark_set(buf, mark)
            let s0t0 = p1_sort0(buf, err)
            if (err > e00):
                t0arg_make_node(tok0.lctn(), T0ARGnone(tok0))
            else:
                t0arg_make_node(s0t0.lctn(), T0ARGsome(s0t0, optn_nil))

