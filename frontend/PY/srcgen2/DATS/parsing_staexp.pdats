@impl
def p1_d0tcn(buf, err):
    let e00 = err
    let s0us = p1_s0uniseq(buf, err)
    let dcon = p1_d0eid(buf, err)
    let s0is = p1_s0expseq_atm(buf, err)
    let tok0 = buf.getk0()
    let tnd0 = tok0.tnode()
    match tnd0:
        case T_OF0():
            buf.skip1()
            let sarg = p1_s0exp(buf, err)
            let lres = match s0us:
                case list_nil():
                    dcon.lctn() + sarg.lctn()
                case list_cons(s0u0, _):
                    s0u0.lctn() + sarg.lctn()
            err := e00
            d0tcn_make_node(lres, D0TCNnode(s0us, dcon, s0is, optn_cons(sarg)))
        case _:
            let lres = match s0us:
                case list_nil():
                    match s0is:
                        case list_nil(_):
                            dcon.lctn()
                        case list_cons(_):
                            let s0i1 = list_last(s0is)
                            dcon.lctn() + s0i1.lctn()
                case list_cons(s0u0, _):
                    match s0is:
                        case list_nil():
                            s0u0.lctn()
                        case list_cons(_):
                            let s0i1 = list_last(s0is)
                            s0u0.lctn() + s0i1.lctn()
            err := e00
            d0tcn_make_node(lres, D0TCNnode(s0us, dcon, s0is, optn_nil()))

@impl
def p1_d0typ(buf, err):
    let e00 = err
    let sid0 = p1_s0eid(buf, err)
    let args = p1_t0magseq(buf, err)
    let tres = pq_ids0t_anno(buf, err)
    let tok1 = p1_EQ0(buf, err)
    let opt2 = pq_BAR(buf, err)
    let dtcs = p1_d0tcnseq_BAR(buf, err)
    let lres = match dtcs:
        case list_nil():
            match opt2:
                case optn_nil():
                    sid0.lctn() + tok1.lctn()
                case optn_cons(tok2):
                    sid0.lctn() + tok2.lctn()
        case list_cons(_):
            let dtc1 = list_last(dtcs)
            sid0.lctn() + dtc1.lctn()
    err := e00
    d0typ_make_node(lres, D0TYPnode(sid0, args, tres, tok1, dtcs))

@impl
def p1_d0tcnseq_BAR(buf, err):
    list_vt2t(@sapp[d0tcn] ps_BAR_p1fun(buf, err, p1_d0tcn))

@impl
def p1_d0typseq_AND(buf, err):
    list_vt2t(@sapp[d0typ] ps_AND_p1fun(buf, err, p1_d0typ))

