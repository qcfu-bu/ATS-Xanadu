            let lres = tbeg.lctn() + tend.lctn()
            err := e00
            t0mag_make_node(lres, T0MAGlist(tbeg, t0as, tend))
        case _:
            let loc = tok.lctn()
            err := e00 + 1
            t0mag_make_node(loc, T0MAGnone(tok))

private:
    def f0_ids(buf: !tkbf0 >> _, err: &SInt >> _) -> i0dntlst:
        let ids = list_vt2t(@sapp[s0aid] ps_COMMA_p1fun(buf, err, p1_s0aid))
        match ids:
            case list_nil():
                list_sing(p1_s0aid(buf, err))
            case _:
                ids

@impl
def p1_s0qua(buf, err):
    let e00 = err
    let tok = buf.getk0()
    let tnd = tok.tnode()
    match tnd:
        case _ if t0_s0aid(tnd):
            let id0 = p1_s0aid(buf, err)
            let tok = buf.getk0()
            let tnd = tok.tnode()
            match tnd:
                case T_CLN():
                    buf.skip1()
                    let ids = list_sing(id0)
                    let s0t = p1_sort0(buf, err)
                    let lres = id0.lctn() + s0t.lctn()
                    err := e00
                    s0qua(lres, S0QUAvars(ids, some(s0t)))
                case T_COMMA():
                    buf.skip1()
                    let ids = f0_ids(buf, err)
                    let ids = list_cons(id0, ids)
                    let tres = pq_sort0_anno(buf, err)
                    let lres = match tres:
                        case optn_nil():
                            id0.lctn()
                        case optn_cons(s0t):
                            id0.lctn() + s0t.lctn()
                    err := e00
                    s0qua(lres, S0QUAvars(ids, tres))
                case _:
                    let s0es = p1_s0expseq_atm(buf, err)
                    let s0e0 = s0exp(id0.lctn(), S0Eid0(id0))
                    let s0e1 = match s0es:
                        case list_nil():
                            s0e0
                        case list_cons(_):
                            let s0ez = list_last(s0es)
                            let lres = id0.lctn() + s0ez.lctn()
                            s0exp(lres, S0Eapps(list_cons(s0e0, s0es)))
                    err := e00
                    s0qua(s0e1.lctn(), S0QUAprop(s0e1))
        case _:
            let s0e0 = p1_s0exp(buf, err)
            err := e00
            s0qua(s0e0.lctn(), S0QUAprop(s0e0))


