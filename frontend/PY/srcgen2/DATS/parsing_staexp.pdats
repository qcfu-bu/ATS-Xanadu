@impl
def p1_s0arg(buf, err):
    let e00 = err
    let tok = buf.getk0()
    let tnd = tok.tnode()
    match tok.node():
        case _ if t0_s0aid(tnd):
            let id0 = p1_s0aid(buf, err)
            let tok = buf.getk0()
            match tok.node():
                case T_CLN():
                    buf.skip1()
                    let s0t = p1_sort0(buf, err)
                    let loc = id0.lctn() + s0t.lctn()
                    err := e00
                    s0arg(loc, S0ARGsome(id0, some(s0t)))
                case _:
                    let loc = id0.lctn()
                    s0arg(loc, S0ARGsome(id0, none()))
        case _:
            err := e00 + 1
            s0arg(tok.lctn(), S0ARGnone(tok))

@impl
def p1_s0mag(buf, err):
    let e00 = err
    let tok = buf.getk0()
    let tnd = tok.tnode()
    match tnd:
        case T_LPAREN():
            let tbeg = tok
            buf.skip1()
            let s0as = p1_s0argseq_COMMA(buf, err)
            let tend = p1_RPAREN(buf, err)
            let lres = tbeg.lctn() + tend.lctn()
            err := e00
            s0mag(lres, S0MAGlist(tbeg, s0as, tend))
        case _ if t0_s0aid(tnd):
