@impl
def p1_sort0_atm(buf, err):
    let e00 = err
    let tok = buf.getk0()
    let tnd = tok.tnode()
    match tnd:
        case _ if t0_s0tid(tnd):
            let id0 = p1_s0tid(buf, err)
            err := e00
            sort0(id0.lctn(), S0Tid0(id0))
        case _ if t0_t0int(tnd):
            let i00 = p1_t0int(buf, err)
            err := e00
            sort0(i00.lctn(), S0Tint(i00))
        case T_LPAREN():
            let tbeg = tok
            buf.skip1()
            let s0ts = p1_sort0seq_COMMA(buf, err)
            let tend = p1_RPAREN(buf, err)
            let loc0 = tbeg.lctn() + tend.lctn()
            err := e00
            sort0(loc0, S0Tlpar(tbeg, s0ts, tend))
        case T_IDQUA(qid):
            let tqua = tok
            buf.skip1()
            let s0t0 = p1_sort0_atm(buf, err)
            let loc0 = tqua.lctn() + s0t0.lctn()
            err := e00
            sort0(loc0, S0Tqid(tqua, s0t0))
        case _:
            err := e00 + 1
            sort0(tok.lctn(), S0Ttkerr(tok))

@impl
def p1_sort0seq_atm(buf, err):
    list_vt2t(@sapp[sort0] ps_p1fun(buf, err, p1_sort0_atm))

@impl
def p1_sort0seq_COMMA(buf, err):
    list_vt2t(@sapp[sort0] ps_COMMA_p1fun(buf, err, p1_sort0))

private:
    def p1_sort0_app_ntk(buf: !tkbf0, err: &SInt >> _, ntk: tnode -> Bool) -> sort0:
        def f1_ntk(buf: !tkbf0, err: &SInt >> _) -> sort0:
            let e00 = err
            let tok = buf.getk0()
            let tnd = tok.tnode()
            if ntk(tnd):
                p1_sort0_atm(buf, err)
            else:
                err := e00 + 1
                sort0(tok.lctn(), S0Ttkerr(tok))
        let s0t1 = f1_ntk(buf, err)
        let s0ts = list_vt2t(@sapp[sort0] ps_p1fun(buf, err, f1_ntk))
        match s0ts:
            case list_nil():
                s0t1
            case list_cons(_):
                let s0t2 = list_last(s0ts)
                let lres = s0t1.lctn() + s0t2.lctn()
                sort0(lres, S0Tapps(list_cons(s0t1, s0ts)))

@impl
def p1_sort0_app_NGT0(buf, err):
    p1_sort0_app_ntk(buf, err, ntk)
where:
    def ntk(tnd: tnode) -> Bool:
        match tnd:
            case T_GT0():
                false
            case _:
                true


@impl
def p1_s0tcn(buf, err):
    let e00 = err
    let sid0 = p1_s0eid(buf, err)
    let tok1 = buf.getk0()
    let tnd1 = tok1.tnode()
    match tnd1:
        case T_OF0():
            buf.skip1()
            let s0t0 = p1_sort0(buf, err)
            let lres = sid0.lctn() + s0t0.lctn()
            err := e00
            s0tcn_make_node(lres, S0TCNnode(sid0, optn_cons(s0t0)))
        case _:
            let lres = sid0.lctn()
            s0tcn_make_node(lres, S0TCNnode(sid0, optn_nil))

@impl
def p1_d0tst(buf, err):
    let e00 = err
    let tid0 = p1_s0tid(buf, err)
    let loc0 = tid0.lctn()
    let teq1 = p1_EQ0(buf, err)
    let topt = pq_BAR(buf, err)
    let stcs = p1_s0tcnseq_BAR(buf, err)
    let lres = match stcs:
        case list_nil():
            match topt:
                case optn_nil():
                    loc0 + teq1.lctn()
                case optn_cons(tbar):
                    loc0 + tbar.lctn()
        case list_cons(_):
            let stc1 = list_last(stcs)
            loc0 + stc1.lctn()
    err := e00
    d0tst_make_node(lres, D0TSTnode(tid0, teq1, topt, stcs))

