    S0LAB(lab, tok, s0e)


@impl
def p1_s0exp_atm(buf, err):
    let e00 = err
    let tok = buf.getk0()
    let tnd = tok.tnode()
    match tnd:
        case _ if t0_s0eid(tnd):
            let id0 = p1_s0eid(buf, err)
            err := e00
            s0exp(id0.lctn(), S0Eid0(id0))
        case _ if t0_t0int(tnd):
            let i00 = p1_t0int(buf, err)
            err := e00
            s0exp(i00.lctn(), S0Eint(i00))
        case _ if t0_t0chr(tnd):
            let c00 = p1_t0chr(buf, err)
            err := e00
            s0exp(c00.lctn(), S0Echr(c00))
        case _ if t0_t0flt(tnd):
            let f00 = p1_t0flt(buf, err)
            err := e00
            s0exp(f00.lctn(), S0Eflt(f00))
        case _ if t0_t0str(tnd):
            let s00 = p1_t0str(buf, err)
            err := e00
            s0exp(s00.lctn(), S0Estr(s00))
        case T_OP1(_):
            let tok0 = tok
            buf.skip1()
            s0exp(tok0.lctn(), S0Eop1(tok0))
        case T_OP2(_):
            let tok0 = tok
            buf.skip1()
            s0exp(tok0.lctn(), S0Eop2(tok0))
        case T_OP3(_):
            let tbeg = tok
            buf.skip1()
            let opid = p1_s0eid(buf, err)
            let tend = p1_RPAREN(buf, err)
            let lres = tbeg.lctn() + tend.lctn()
            err := e00
            s0exp(lres, S0Eop3(tbeg, opid, tend))
        case T_MSLT():
            let tbeg = tok
            buf.skip1()
            let s0es = list_vt2t(@sapp[s0exp] ps_COMMA_p1fun(buf, err, p1_s0exp_app_NGT0))
            let tend = p1_GT0(buf, err)
            let lres = tbeg.lctn() + tend.lctn()
            err := e00
            s0exp(lres, S0Efimp(tbeg, s0es, tend))
        case T_LBRACE():
            let tbeg = tok
            buf.skip1()
            let s0qs = p1_s0quaseq_BSCLN(buf, err)
            let tend = p1_RBRACE(buf, err)
            let lres = tbeg.lctn() + tend.lctn()
            err := e00
            s0exp(lres, S0Euni0(tbeg, s0qs, tend))
        case T_LBRCKT():
            let tok0 = tok
            buf.skip1()
            let s0qs = p1_s0quaseq_BSCLN(buf, err)
            let tbeg = token(tok0.lctn(), T_EXISTS(0))
            let tend = p1_RBRCKT(buf, err)
            let lres = tbeg.lctn() + tend.lctn()
            err := e00
            s0exp(lres, S0Eexi0(tbeg, s0qs, tend))
        case T_EXISTS(k0):
            let tbeg = tok
            buf.skip1()
            let s0qs = p1_s0quaseq_BSCLN(buf, err)
            let tend = p1_RBRCKT(buf, err)
            let lres = tbeg.lctn() + tend.lctn()
            err := e00
            s0exp(lres, S0Eexi0(tbeg, s0qs, tend))
        case T_IDQUA(qid):
            let tqua = tok
            buf.skip1()
            let s0e0 = p1_s0exp_atm(buf, err)
            let loc0 = tqua.lctn() + s0e0.lctn()
            err := e00
            s0exp(loc0, S0Equal0(tqua, s0e0))
        case T_LPAREN():
            let tbeg = tok
            buf.skip1()
            let s0es = p1_s0expseq_COMMA(buf, err)
            let tend = p1_s0exp_RPAREN(buf, err)
            let lres = tbeg.lctn() + s0exp_RPAREN_lctn(tend)
            err := e00
            s0exp(lres, S0Elpar(tbeg, s0es, tend))
        case T_TRCD10(k0):
            let tbeg = tok
            buf.skip1()
            let topt = if (k0 <= 1):
                optn_nil()
            else: optn_cons(p1_LPAREN(buf, err))
            let s0es = p1_s0expseq_COMMA(buf, err)
            let tend = p1_s0exp_RPAREN(buf, err)
            let lres = tbeg.lctn() + s0exp_RPAREN_lctn(tend)
            err := e00
            s0exp(lres, S0Etup1(tbeg, topt, s0es, tend))
        case T_TRCD20(k0):
            let tbeg = tok
            buf.skip1()
            let topt = if (k0 <= 1):
                optn_nil()
            else: optn_cons(p1_LBRACE(buf, err))
            let lses = p1_l0s0eseq_COMMA(buf, err)
            let tend = p1_l0s0e_RBRACE(buf, err)
            let lres = tbeg.lctn() + l0s0e_RBRACE_lctn(tend)
            err := e00
            s0exp(lres, S0Ercd2(tbeg, topt, lses, tend))
        case _:
            let loc = tok.lctn()
            err := e00 + 1
            s0exp(loc, S0Etkerr(tok))

@impl
def p1_s0expseq_atm(buf, err):
    list_vt2t(@sapp[s0exp] ps_p1fun(buf, err, p1_s0exp_atm))

