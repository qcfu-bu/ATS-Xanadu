@impl
def p1_s0exp_RPAREN(buf, err):
    let e00 = err
    let tok = buf.getk0()
    let tnd = tok.tnode()
    match tnd:
        case T_BAR():
            let tok1 = tok
            buf.skip1()
            let s0es = p1_s0expseq_COMMA(buf, err)
            let tok2 = p1_RPAREN(buf, err)
            err := e00
            s0exp_RPAREN_cons1(tok1, s0es, tok2)
        case _:
            match tnd:
                case T_RPAREN():
                    buf.skip1()
                    err := e00
                    s0exp_RPAREN_cons0(tok)
                case _:
                    err := e00 + 1
                    s0exp_RPAREN_cons0(tok)

@impl
def p1_l0s0e_RBRACE(buf, err):
    let e00 = err
    let tok = buf.getk0()
    let tnd = tok.tnode()
    match tnd:
        case T_BAR():
            let tok1 = tok
            buf.skip1()
            let lses = p1_l0s0eseq_COMMA(buf, err)
            let tok2 = p1_RBRACE(buf, err)
            err := e00
            l0s0e_RBRACE_cons1(tok1, lses, tok2)
        case _:
            match tnd:
                case T_RBRACE():
                    buf.skip1()
                    err := e00
                    l0s0e_RBRACE_cons0(tok)
                case _:
                    err := e00 + 1
                    l0s0e_RBRACE_cons0(tok)

@impl
def s0exp_RPAREN_lctn(node):
    match node:
        case s0exp_RPAREN_cons0(tbar):
            tbar.lctn()
        case s0exp_RPAREN_cons1(tok1, s0es, tok2):
            tok1.lctn() + tok2.lctn()

@impl
def l0s0e_RBRACE_lctn(node):
    match node:
        case l0s0e_RBRACE_cons0(tbar):
            tbar.lctn()
        case l0s0e_RBRACE_cons1(tok1, lses, tok2):
            tok1.lctn() + tok2.lctn()

private:
    def p1_s0exp_app_ntk(buf: !tkbf0, err: &SInt >> _, ntk: tnode -> Bool) -> s0exp:
        def f1_ntk(buf: !tkbf0, err: &SInt >> _) -> s0exp:
            let e00 = err
            let tok = buf.getk0()
            let tnd = tok.tnode()
            if ntk(tnd):
                p1_s0exp_atm(buf, err)
            else:
                err := e00 + 1
                s0exp(tok.lctn(), S0Etkerr(tok))
        let s0e1 = f1_ntk(buf, err)
        let s0es = list_vt2t(@sapp[s0exp] ps_p1fun(buf, err, f1_ntk))
        match s0es:
            case list_nil():
                s0e1
            case list_cons(_):
                let s0e2 = list_last(s0es)
                let lres = s0e1.lctn() + s0e2.lctn()
                s0exp(lres, S0Eapps(list_cons(s0e1, s0es)))

@impl
