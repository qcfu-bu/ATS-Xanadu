            let s0a0 = p1_s0arg(buf, err)
            let tbar = p1_BAR(buf, err)
            let s0es = p1_s0expseq_SMCLN(buf, err)
            let tend = p1_RBRACE(buf, err)
            let lres = tbeg.lctn() + tend.lctn()
            err := e00
            s0tdf(lres, S0TDFtsub(tbeg, s0a0, tbar, s0es, tend))
        case _:
            let s0t = p1_sort0(buf, err)
            err := e00
            s0tdf(s0t.lctn(), S0TDFsort(s0t))

@impl
def p1_l0s0e(buf, err):
