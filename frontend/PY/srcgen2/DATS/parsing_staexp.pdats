@impl
def p1_g0nam_atm(buf, err):
    let e00 = err
    let tok = buf.getk0()
    let tnd = tok.tnode()
    match tnd:
        case _ if t0_g0nid(tnd):
            let id0 = p1_g0nid(buf, err)
            let loc = id0.lctn()
            err := e00
            g0nam_make_node(loc, G0Nid0(id0))
        case _ if t0_t0int(tnd):
            let i00 = p1_t0int(buf, err)
            let loc = i00.lctn()
            err := e00
            g0nam_make_node(loc, G0Nint(i00))
        case _ if t0_t0chr(tnd):
            let c00 = p1_t0chr(buf, err)
            let loc = c00.lctn()
            err := e00
            g0nam_make_node(loc, G0Nchr(c00))
        case _ if t0_t0flt(tnd):
            let f00 = p1_t0flt(buf, err)
            let loc = f00.lctn()
            err := e00
            g0nam_make_node(loc, G0Nflt(f00))
        case _ if t0_t0str(tnd):
            let s00 = p1_t0str(buf, err)
            let loc = s00.lctn()
            err := e00
            g0nam_make_node(loc, G0Nstr(s00))
        case _:
            err := e00 + 1
            g0nam_make_node(tok.lctn(), G0Ntkerr(tok))

@impl
def p1_g0namseq_COMMA(buf, err):
    list_vt2t(@sapp[g0nam] ps_COMMA_p1fun(buf, err, p1_g0nam_atm))

private:
    def p1_napps(buf: !tkbf0, err: &SInt >> _) -> g0exp:
        let e00 = err
        let tok = buf.getk0()
        let tnd = tok.tnode()
        match tnd:
            case T_IF0():
                let tknd = tok
                buf.skip1()
                let g0e1 = p1_g0exp_app(buf, err)
                let g0e2 = p1_g0exp_THEN(buf, err)
                let g0e3 = p1_g0exp_ELSE(buf, err)
                let topt = optn_nil()
                let lres = match topt:
                    case optn_nil():
                        match g0e3:
                            case g0exp_ELSE(tels, g0e3):
                                tknd.lctn() + g0e3.lctn()
                    case optn_cons(tok1):
                        tknd.lctn() + tok1.lctn()
                err := e00
                g0exp_make_node(lres, G0Eift0(tok, g0e1, g0e2, g0e3, topt))
            case _:
                err := e00 + 1
                g0exp_make_node(tok.lctn(), G0Etkerr(tok))

@impl
def p1_g0exp(buf, err):
    let g0es = p1_g0expseq_atm(buf, err)
    match g0es:
        case list_nil():
            p1_napps(buf, err)
        case list_cons(g0e1, ges1):
            match ges1:
                case list_nil():
                    g0e1
                case list_cons(_):
                    let g0e2 = list_last(ges1)
                    g0exp_make_node(g0e1.lctn() + g0e2.lctn(), G0Eapps(g0es))


@impl
def p1_g0exp_atm(buf, err):
    let e00 = err
    let tok = buf.getk0()
    let tnd = tok.tnode()
    match tnd:
        case _ if t0_g0eid(tnd):
            let id0 = p1_g0eid(buf, err)
            let loc = id0.lctn()
            err := e00
            g0exp_make_node(loc, G0Eid0(id0))
        case _ if t0_t0int(tnd):
            let i00 = p1_t0int(buf, err)
            let loc = i00.lctn()
            err := e00
            g0exp_make_node(loc, G0Eint(i00))
        case _ if t0_t0chr(tnd):
            let c00 = p1_t0chr(buf, err)
            let loc = c00.lctn()
            err := e00
            g0exp_make_node(loc, G0Echr(c00))
        case _ if t0_t0flt(tnd):
            let f00 = p1_t0flt(buf, err)
            let loc = f00.lctn()
            err := e00
            g0exp_make_node(loc, G0Eflt(f00))
        case _ if t0_t0str(tnd):
            let s00 = p1_t0str(buf, err)
            let loc = s00.lctn()
            err := e00
            g0exp_make_node(loc, G0Estr(s00))
        case T_LPAREN():
            let tbeg = tok
            buf.skip1()
            let g0es = p1_g0expseq_COMMA(buf, err)
            let tend = p1_RPAREN(buf, err)
            err := e00
            let lres = tbeg.lctn() + tend.lctn()
            g0exp_make_node(lres, G0Elpar(tbeg, g0es, tend))
        case _:
            err := e00 + 1
            g0exp_make_node(tok.lctn(), G0Etkerr(tok))

@impl
def p1_g0exp_app(buf, err):
    let g0e0 = p1_g0exp_atm(buf, err)
    let g0es = p1_g0expseq_atm(buf, err)
    match g0es:
        case list_nil():
            g0e0
        case list_cons(_):
            let g0e1 = list_last(g0es)
            let loc0 = g0e0.lctn() + g0e1.lctn()
            g0exp_make_node(loc0, G0Eapps(list_cons(g0e0, g0es)))

@impl
def p1_g0exp_THEN(buf, err):
    let e00 = err
    let tok = buf.getk0()
    let tnd = tok.tnode()
    match tnd:
        case T_THEN():
            let tknd = tok
            buf.skip1()
            let g0e1 = p1_g0exp(buf, err)
            err := e00
            g0exp_THEN(tknd, g0e1)
        case _:
            g0exp_THEN(tok, p1_g0exp(buf, err))

