private:
    def p1_napps(buf: !tkbf0, err: &SInt >> _) -> s0exp:
        let e00 = err
        let tok = buf.getk0()
        let tnd = tok.tnode()
        match tnd:
            case T_LAM(k0):
                let tok0 = tok
                buf.skip1()
                let s0ms = p1_s0magseq(buf, err)
                let anno = pq_sort0_anno(buf, err)
                let tok1 = p1_EQGT(buf, err)
                let s0e0 = p1_s0exp(buf, err)
                let opt2 = pq_ENDLAM(buf, err)
                let lres = match opt2:
                    case optn_nil():
                        tok0.lctn() + s0e0.lctn()
                    case optn_cons(tok2):
                        tok0.lctn() + tok2.lctn()
                err := e00
                s0exp(lres, S0Elams(tok0, s0ms, anno, tok1, s0e0, opt2))
            case _:
                err := e00 + 1
                s0exp(tok.lctn(), S0Etkerr(tok))

@impl
def p1_s0exp(buf, err):
    let e00 = err
    let s0es = p1_s0expseq_atm(buf, err)
    match s0es:
        case list_nil():
            p1_napps(buf, err)
        case list_cons(s0e1, ses1):
            let opt = pq_sort0_anno(buf, err)
            match ses1:
                case list_nil(_):
                    s0exp_annotopt(s0e1, opt)
                case list_cons(_):
                    let s0e2 = list_last(ses1)
                    let loc0 = s0e1.lctn() + s0e2.lctn()
                    let s0e0 = s0exp(loc0, S0Eapps(s0es))
                    s0exp_annotopt(s0e0, opt)

@impl
def p1_s0tdf(buf, err):
