            g0mag(tok.lctn(), G0MAGnone(tok))

private:
    def p1_napps(buf: !tkbf0, err: &SInt >> _) -> sort0:
        let e00 = err
        let tok = buf.getk0()
        err := e00 + 1
        sort0(tok.lctn(), S0Ttkerr(tok))

@impl
def p1_sort0(buf, err):
    let s0ts = p1_sort0seq_atm(buf, err)
    match s0ts:
        case list_nil():
            p1_napps(buf, err)
        case list_cons(s0t0, sts1):
            match sts1:
                case list_nil():
                    s0t0
                case list_cons(_):
                    let s0t1 = @inst[sort0lst] @inst[sort0] gseq_last_ini(sts1, s0t0)
                    let loc0 = s0t0.lctn() + s0t1.lctn()
                    sort0(loc0, S0Tapps(s0ts))


