@impl
def p1_g0mag(buf, err):
    let e00 = err
    let tok = buf.getk0()
    let tnd = tok.tnode()
    match tnd:
        case T_LBRACE():
            let tbeg = tok
            buf.skip1()
            let g0as = p1_g0argseq_COMMA(buf, err)
            let tend = p1_RBRACE(buf, err)
            let lres = tbeg.lctn() + tend.lctn()
            err := e00
            g0mag_make_node(lres, G0MAGsarg(tbeg, g0as, tend))
        case T_LPAREN():
            let tbeg = tok
            buf.skip1()
            let g0as = p1_g0argseq_COMMA(buf, err)
            let tend = p1_RPAREN(buf, err)
            let lres = tbeg.lctn() + tend.lctn()
            err := e00
            g0mag_make_node(lres, G0MAGdarg(tbeg, g0as, tend))
        case _:
