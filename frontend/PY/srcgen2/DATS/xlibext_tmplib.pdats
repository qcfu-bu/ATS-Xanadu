@impl[]
def a0ref_get[A: Type](xatsv_A0):
    @inst[A] a0ref_dtget(xatsv_A0)

@impl[]
def a0ref_exch[A: Vt](xatsv_A0, x0):
    @sapp[A] UN.castlin10(x1)
where:
    let x1 = @inst[A] a0ref_dtget(xatsv_A0)
    let x0 = @sapp[?[A]] UN.castlin10(x0)
    let xatsv_A1 = @sapp[a0ref[?[A]]] UN.cast10(xatsv_A0)
    @extern
    def XATSOPT_a0ref_set[A: Type](xatsv_A0: a0ref[A], x0: A) -> Void = extnam()
    @sapp[?[A]] XATSOPT_a0ref_set(xatsv_A1, x0)

@impl[]
def a0ref_make_1val[A: Vt](x0):
    a0ptr2ref(@inst[A] a0ptr_make_1val(x0))

@impl[]
def strn_tabulate/f1un(n0, fopr):
    strn_vt2t(@inst[] strn_vt_tabulate/f1un(n0, fopr))

@impl[]
def strn_vt_tabulate/f1un[N0: SInt](n0, fopr):
    UN_strn_vt_cast(p0)
where:
    type Stmp = strtmp1_vt
    def loop[I0: SInt](p0: Stmp[N0], i0: SInt[I0]) -> Void:
        if (i0 < n0):
            let c0 = fopr(i0)
            @inst[] strtmp_vt_set/at(p0, i0, c0)
            loop(p0, suc(i0))
    let p0 = @inst[] strtmp_vt_alloc(n0)
    let i0 = 0
    loop(p0, i0)

