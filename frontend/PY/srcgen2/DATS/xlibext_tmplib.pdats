@impl[mydict[K0, X0], K0, X0]
def gmap_strmize[K0: Type, X0: Type](kxs):
    strm_vt_map0(@inst[mydict[K0, X0]] @inst[K0] @inst[X0] gmap_key/strmize(kxs))
where:
