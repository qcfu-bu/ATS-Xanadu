@impl
def tr12env_add1_f2env(env0, k0, x0):
    let gsym = k0
    let fenv = x0
    let sopt = tr12env_find_s2itm(env0, gsym)
    match sopt:
        case ~optn_vt_nil():
            let sitm = S2ITMenv(list_sing(fenv))
            tr12env_add0_s2itm(env0, gsym, sitm)
        case ~optn_vt_cons(sitm):
            match sitm:
                case S2ITMenv(envs):
                    let sitm = S2ITMenv(list_cons(fenv, envs))
                    tr12env_add0_s2itm(env0, gsym, sitm)
                case _:
                    let sitm = S2ITMenv(list_sing(fenv))
                    tr12env_add0_s2itm(env0, gsym, sitm)

