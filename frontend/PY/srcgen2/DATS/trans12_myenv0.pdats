            ()
        case list_cons(tqa1, tqas):
            tr12env_add0_t2qag(env0, tqa1)
            tr12env_add0_t2qaglst(env0, tqas)

@impl
def tr12env_add1_d2con(env0, d2c0):
    let sym0 = d2c0.name()
    let dopt = tr12env_find_d2itm(env0, sym0)
    match dopt:
        case ~optn_vt_nil():
            let ditm = D2ITMcon(list_sing(d2c0))
            tr12env_add0_d2itm(env0, sym0, ditm)
        case ~optn_vt_cons(ditm):
            match ditm:
                case D2ITMcon(d2cs):
                    let ditm = D2ITMcon(list_cons(d2c0, d2cs))
                    tr12env_add0_d2itm(env0, sym0, ditm)
                case _:
                    let ditm = D2ITMcon(list_sing(d2c0))
                    tr12env_add0_d2itm(env0, sym0, ditm)

@impl
def tr12env_add1_d2cst(env0, d2c0):
    let sym0 = d2c0.name()
    let dopt = tr12env_find_d2itm(env0, sym0)
    match dopt:
