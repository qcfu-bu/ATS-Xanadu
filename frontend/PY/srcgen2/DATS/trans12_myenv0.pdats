@impl
def tr12env_add1_s2cst(env0, s2c0):
    let sym0 = s2c0.name()
    let sopt = tr12env_find_s2itm(env0, sym0)
    match sopt:
        case ~optn_vt_nil():
            let sitm = S2ITMcst(list_sing(s2c0))
            tr12env_add0_s2itm(env0, sym0, sitm)
        case ~optn_vt_cons(sitm):
            match sitm:
                case S2ITMcst(s2cs):
                    let sitm = S2ITMcst(list_cons(s2c0, s2cs))
                    tr12env_add0_s2itm(env0, sym0, sitm)
                case _:
                    let sitm = S2ITMcst(list_sing(s2c0))
                    tr12env_add0_s2itm(env0, sym0, sitm)

