@impl
def tr12env_qfind_s2itm(env0, qua1, key2):
    let sopt = match qua1.node():
        case T_IDQUA(name):
            let sym1 = symbl_make_name(name)
            tr12env_find_s2env(env0, sym1)
        case _:
            optn_vt_nil()
    match sopt:
        case ~optn_vt_nil():
            optn_vt_nil()
        case ~optn_vt_cons(sitm):
            match sitm:
                case S2ITMenv(envs):
                    f2envlst_find_s2itm(envs, key2)
                case _:
                    optn_vt_nil()

@impl
def tr12env_qfind_d2itm(env0, qua1, key2):
    let sopt = match qua1.node():
        case T_IDQUA(name):
