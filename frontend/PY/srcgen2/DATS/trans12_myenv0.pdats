@impl
def tr12env_find_s2qua(env0, k0):
    let opt0 = tr12env_find_s2itm(env0, k0)
    match opt0:
        case ~optn_vt_nil():
            f0_main(env0, k0.name())
        case _:
            opt0
where:
    def f0_main(env0: !Tr12env, name: String) -> s2itmopt_vt:
        let n0 = strn_length(name)
        def f1_next(i1: SInt) -> SInt:
            if i1 >= n0:
                i1
            else:
                if name[i1] == '$':
                    i1
                else:
                    f1_next(i1 + 1)
        def f1_sub0(i0: SInt, i1: SInt) -> String:
            let df = i1 - i0
            strn_tabulate/f1un(df, (j) => name[i0 + j])
        def f1_sub1(i0: SInt, i1: SInt) -> String:
            let df = i1 - i0
            strn_tabulate/f1un(df + 1, (j) => if j < df: name[i0 + j] else: '.')
        def f1_envs(envs: f2envlst, i0: SInt) -> s2itmopt_vt:
            let i1 = f1_next(i0 + 1)
            let k1 = if i1 >= n0:
                symbl(f1_sub0(i0, i1))
            else: symbl(f1_sub1(i0, i1))
            let opt1 = f2envlst_find_s2itm(envs, k1)
            match opt1:
                case ~optn_vt_nil():
                    optn_vt_nil()
                case ~optn_vt_cons(s2i1):
                    match s2i1:
                        case S2ITMenv(envs):
                            if i1 < n0:
                                f1_envs(envs, i1)
                            else:
                                optn_vt_cons(s2i1)
                        case _:
                            optn_vt_nil
        let i0 = 0
        let i1 = f1_next(i0 + 1)
        if i1 >= n0:
            optn_vt_nil()
        else:
            let k1 = symbl(f1_sub1(i0, i1))
            let opt1 = tr12env_find_s2itm(env0, k1)
            match opt1:
                case ~optn_vt_nil():
                    optn_vt_nil()
                case ~optn_vt_cons(s2i1):
                    match s2i1:
                        case S2ITMenv(envs):
                            f1_envs(envs, i1)
                        case _:
                            optn_vt_nil()

