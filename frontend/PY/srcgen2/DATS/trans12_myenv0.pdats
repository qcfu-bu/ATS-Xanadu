    type Xatslocal1_itm = s2tex

@linear
enum Sortenv:
    case SORTENV(topmap[Xatslocal1_itm], stkmap[Xatslocal1_itm])

def sortenv_make_nil() -> Sortenv:
    SORTENV(topmap, stkmap)
where:
    let topmap = @sapp[Xatslocal1_itm] topmap_make_nil()
    let stkmap = @sapp[Xatslocal1_itm] stkmap_make_nil()

def sortenv_free_top(tenv: Sortenv) -> Sortmap:
    stkmap_free_nil(stkmap)
    topmap
where:
    let ~SORTENV(topmap, stkmap) = tenv

def sortenv_pshlam0(tenv: !Sortenv):
    let @(SORTENV)(topmap, !stkmap) = tenv
    let nerr = stkmap_pshlam0(stkmap)
    fold(tenv)

def sortenv_poplam0(tenv: !Sortenv):
    let @(SORTENV)(topmap, !stkmap) = tenv
    let nerr = stkmap_poplam0(stkmap)
    fold(tenv)

def sortenv_pshlet0(tenv: !Sortenv):
    let @(SORTENV)(topmap, !stkmap) = tenv
    let nerr = stkmap_pshlet0(stkmap)
    fold(tenv)

def sortenv_poplet0(tenv: !Sortenv):
    let @(SORTENV)(topmap, !stkmap) = tenv
    let nerr = stkmap_poplet0(stkmap)
    fold(tenv)

def sortenv_pshloc1(tenv: !Sortenv):
    let @(SORTENV)(topmap, !stkmap) = tenv
    let nerr = stkmap_pshloc1(stkmap)
    fold(tenv)

def sortenv_pshloc2(tenv: !Sortenv):
    let @(SORTENV)(topmap, !stkmap) = tenv
    let nerr = stkmap_pshloc2(stkmap)
    fold(tenv)

def sortenv_locjoin(tenv: !Sortenv):
    let @(SORTENV)(topmap, !stkmap) = tenv
    let (nerr, kxs) = stkmap_poploc0(stkmap)
    if stkmap_nilq(stkmap):
        topmap_insert/kxs(topmap, kxs)
    else:
        stkmap_insert/kxs(stkmap, kxs)
    fold(tenv)

def sortenv_search/opt(tenv: Sortenv, k0: Xatslocal0_key):
    let SORTENV(topmap, stkmap) = tenv
    let opt = stkmap_search/opt(stkmap, k0)
    match opt:
        case optn_vt_cons(_):
            opt
        case ~optn_vt_nil():
            let opt = topmap_search/opt(topmap, k0)
            match opt:
                case optn_vt_cons(_):
                    opt
                case ~optn_vt_nil():
                    the_sortenv_pvsfind(k0)

def sortenv_insert/any(tenv: Sortenv, k0: Xatslocal0_key, x0: Xatslocal1_itm):
    let @(SORTENV)(topmap, !stkmap) = tenv
    if stkmap_nilq(stkmap):
        topmap_insert/any(topmap, k0, x0)
    else:
        stkmap_insert/any(stkmap, k0, x0)


