@impl
def tr12env_ofind_g1mac(env0, key0):
    let sopt = tr12env_find_s2env(env0, SYM.DLRDT_symbl)
    match sopt:
        case ~optn_vt_nil():
            optn_vt_nil()
        case ~optn_vt_cons(sitm):
            match sitm:
                case S2ITMenv(envs):
                    f2envlst_find_g1mac(envs, key0)
                case _:
                    optn_vt_nil()

