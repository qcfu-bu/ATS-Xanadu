@impl
def tr12env_add0_d2var(env0, d2v0):
    let sym0 = d2var_get_name(d2v0)
    let ditm = D2ITMvar(d2v0)
    tr12env_add0_d2itm(env0, sym0, ditm)

@impl
def tr12env_add0_d2pat(env0, d2p0):
    match d2p0.node():
        case D2Pnil():
            ()
        case D2Pany():
            ()
        case D2Parg():
            ()
        case D2Pvar(d2v1):
            tr12env_add0_d2var(env0, d2v1)
        case D2Pint(_):
            ()
        case D2Pbtf(_):
            ()
        case D2Pchr(_):
            ()
        case D2Pflt(_):
            ()
        case D2Pstr(_):
            ()
        case D2Pbang(d2p1):
            tr12env_add0_d2pat(env0, d2p1)
        case D2Pflat(d2p1):
            tr12env_add0_d2pat(env0, d2p1)
        case D2Pfree(d2p1):
            tr12env_add0_d2pat(env0, d2p1)
        case D2Psapp(d2p1, s2vs):
            tr12env_add0_d2pat(env0, d2p1)
        case D2Pdap0(d2p1):
            tr12env_add0_d2pat(env0, d2p1)
        case D2Pdap1(d2p1):
            tr12env_add0_d2pat(env0, d2p1)
        case D2Pdapp(d2f0, npf1, d2ps):
            tr12env_add0_d2pat(env0, d2f0)
            tr12env_add0_d2patlst(env0, d2ps)
        case D2Prfpt(d2p1, tkas, d2p2):
            tr12env_add0_d2pat(env0, d2p2)
            tr12env_add0_d2pat(env0, d2p1)
        case D2Ptup0(npf1, d2ps):
            tr12env_add0_d2patlst(env0, d2ps)
        case D2Ptup1(tknd, npf1, d2ps):
            tr12env_add0_d2patlst(env0, d2ps)
        case D2Prcd2(tknd, npf1, ldps):
            tr12env_add0_l2d2plst(env0, ldps)
        case D2Pannot(d2p1, s1e2, s2e2):
            tr12env_add0_d2pat(env0, d2p1)
        case _:
            ()

@impl
def tr12env_add0_f2arg(env0, f2a0):
    match f2a0.node():
        case F2ARGdapp(npf1, d2ps):
            tr12env_add0_d2patlst(env0, d2ps)
        case F2ARGsapp(_):
            ()
        case F2ARGmets(_):
            ()

@impl
def tr12env_add0_d2gpt(env0, dgpt):
    match dgpt.node():
        case D2GPTpat(d2p1):
            tr12env_add0_d2pat(env0, d2p1)
        case D2GPTgua(d2p1, d2gs):
            tr12env_add0_d2pat(env0, d2p1)

@impl
def tr12env_add1_d2conlst(env0, d2cs):
    @inst[x0] @inst[e1] list_foritm/e1nv(d2cs, env0)
where:
