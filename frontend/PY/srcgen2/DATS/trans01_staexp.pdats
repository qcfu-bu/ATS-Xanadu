    @impl[s1exp]
    def fxitm_pstfix(x0, f1):
        let loc0 = x0.lctn() + f1.lctn()
        FXITMatm(s1exp(loc0, S1Ea1pp(f1, x0)))
    @impl[s1exp]
    def fxatm_none(loc):
