def fxitmlst_resolve_g1exp(loc0: loc_t, itms: G1efxlst) -> g1exp:
    @impl[g1exp]
    def fxitm_infix0(x0, f1, x2):
        let loc0 = x0.lctn() + x2.lctn()
        let g1en = match f1.node():
            case G1Ea0pp():
                G1Ea1pp(x0, x2)
            case _:
                G1Ea2pp(f1, x0, x2)
        FXITMatm(g1exp(loc0, g1en))
    @impl[g1exp]
    def fxitm_prefix(f0, x1):
        let loc0 = f0.lctn() + x1.lctn()
        match f0.node():
            case G1Eb0sh():
                let g1e = g1exp_make_node(loc0, G1Eb1sh(x1))
                FXITMopr(g1e, inftmp_fixty)
            case _:
                FXITMatm(g1exp(loc0, G1Ea1pp(f0, x1)))
    @impl[g1exp]
    def fxitm_pstfix(x0, f1):
        let loc0 = x0.lctn() + f1.lctn()
        FXITMatm(g1exp(loc0, G1Ea1pp(f1, x0)))
    @impl[g1exp]
    def fxatm_none(loc):
        g1exp_none0(loc)
    @impl[g1exp]
    def fxopr_get_lctn(opr):
        opr.lctn()
    @impl[g1exp]
    def fxitm_get_lctn(itm):
        match itm:
            case FXITMatm(x0):
                x0.lctn()
            case FXITMopr(x0, _):
                x0.lctn()
    @impl[g1exp]
    def fxitmlst_resolve/appopr(itm):
        let loc0 = @inst[g1exp] fxitm_get_lctn(itm)
        let g1e1 = g1exp(loc0, G1Ea0pp)
        FXITMopr(g1e1, app_fixty)
    @inst[g1exp] fxitmlst_resolve(loc0, itms)

def fxitmlst_resolve_sort1(loc0: loc_t, itms: S1tfxlst) -> sort1:
    @impl[sort1]
    def fxitm_infix0(x0, f1, x2):
        let loc0 = x0.lctn() + x2.lctn()
        let s1tn = match f1.node():
            case S1Ta0pp():
                S1Ta1pp(x0, x2)
            case _:
                S1Ta2pp(f1, x0, x2)
        FXITMatm(sort1(loc0, s1tn))
    @impl[sort1]
    def fxitm_prefix(f0, x1):
        let loc0 = f0.lctn() + x1.lctn()
        FXITMatm(sort1(loc0, S1Ta1pp(f0, x1)))
    @impl[sort1]
    def fxitm_pstfix(x0, f1):
        let loc0 = x0.lctn() + f1.lctn()
        FXITMatm(sort1(loc0, S1Ta1pp(f1, x0)))
    @impl[sort1]
    def fxatm_none(loc):
        sort1_none0(loc)
    @impl[sort1]
    def fxopr_get_lctn(opr):
        opr.lctn()
    @impl[sort1]
    def fxitm_get_lctn(itm):
        match itm:
            case FXITMatm(x0):
                x0.lctn()
            case FXITMopr(x0, _):
                x0.lctn()
    @impl[sort1]
    def fxitmlst_resolve/appopr(itm):
        let loc0 = @inst[sort1] FIX.fxitm_get_lctn(itm)
        let s1t1 = sort1(loc0, S1Ta0pp)
        FIX.FXITMopr(s1t1, app_fixty)
    @inst[sort1] fxitmlst_resolve(loc0, itms)

def fxitmlst_resolve_s1exp(loc0: loc_t, itms: S1efxlst) -> s1exp:
    @impl[s1exp]
    def fxitm_infix0(x0, f1, x2):
