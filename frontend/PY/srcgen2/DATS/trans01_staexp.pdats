    @impl[s1exp]
    def fxopr_get_lctn(opr):
        opr.lctn()
    @impl[s1exp]
    def fxitm_get_lctn(itm):
        match itm:
            case FXITMatm(x0):
                x0.lctn()
            case FXITMopr(x0, _):
                x0.lctn()
    @impl[s1exp]
    def fxitmlst_resolve/appopr(itm):
        let loc0 = @inst[s1exp] FIX.fxitm_get_lctn(itm)
        let s1e1 = s1exp(loc0, S1Ea0pp)
        FIX.FXITMopr(s1e1, app_fixty)
    @inst[s1exp] fxitmlst_resolve(loc0, itms)

@overload fxis_resolve = fxitmlst_resolve_g1exp

@overload fxis_resolve = fxitmlst_resolve_sort1

@overload fxis_resolve = fxitmlst_resolve_s1exp

@impl
def trans01_i0dnt(tenv, id0):
    match id0.node():
        case I0DNTsome(tok):
            tok
        case I0DNTnone(tok):
            token_none(tok.lctn())
where:
    def token_none(loc: loc_t) -> token:
        token_make_node(loc, T0IDALP_NONE)

@impl
def trans01_t0int(tenv, int):
    match int:
        case T0INTsome(tok):
            tok
        case T0INTnone(tok):
            token_none(tok.lctn())
where:
    def token_none(loc: loc_t) -> token:
        token_make_node(loc, T_ERR())

@impl
def trans01_t0chr(tenv, chr):
    match chr:
        case T0CHRsome(tok):
            tok
        case T0CHRnone(tok):
