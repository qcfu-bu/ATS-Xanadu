@impl
def trans01_t0inv(tenv, tinv):
    match tinv:
        case T0INVnone(t0qs, tok1):
            let t1qs = trans01_t0qualst(tenv, t0qs)
            let d1ps = list_nil()
            let loc0 = match t1qs:
                case list_nil():
                    tok1.lctn()
                case list_cons(t1q1, t1qs):
                    t1q1.lctn() + tok1.lctn()
            T1INVsome(loc0, t1qs, d1ps)
        case T0INVsome(t0qs, tbeg, d0ps, tend):
            let t1qs = trans01_t0qualst(tenv, t0qs)
            let d1ps = trans01_d0patlst(tenv, d0ps)
            let loc0 = match t1qs:
                case list_nil():
                    tbeg.lctn() + tend.lctn()
                case list_cons(t1q1, t1qs):
                    t1q1.lctn() + tend.lctn()
            T1INVsome(loc0, t1qs, d1ps)

