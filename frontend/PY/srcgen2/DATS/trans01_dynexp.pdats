    def f0_tup1(tenv: !tr01env, d0e0: d0exp) -> D1efx:
        let loc0 = d0e0.lctn()
        let D0Etup1(tknd, topt, dps1, tend) = d0e0.node()
        match tend:
            case d0exp_RPAREN_cons0(tok):
                let dps1 = trans01_d0explst(tenv, dps1)
                FXITMatm(d1exp(loc0, D1Et1up(tknd, dps1)))
            case d0exp_RPAREN_cons1(tbeg, dps2, tend):
                let dps1 = trans01_d0explst(tenv, dps1)
                let dps2 = trans01_d0explst(tenv, dps2)
                FXITMatm(d1exp(loc0, D1Et2up(tknd, dps1, dps2)))

    def f0_rcd2(tenv: !tr01env, d0e0: d0exp) -> D1efx:
        let loc0 = d0e0.lctn()
        let D0Ercd2(tknd, topt, lss1, tend) = d0e0.node()
        match tend:
            case l0d0e_RBRACE_cons0(tok):
                let lss1 = trans01_l0d0elst(tenv, lss1)
                FXITMatm(d1exp(loc0, D1Er1cd(tknd, lss1)))
            case l0d0e_RBRACE_cons1(tbeg, lss2, tend):
                let lss1 = trans01_l0d0elst(tenv, lss1)
                let lss2 = trans01_l0d0elst(tenv, lss2)
                FXITMatm(d1exp(loc0, D1Er2cd(tknd, lss1, lss2)))

    def f0_lam0(tenv: !tr01env, d0e0: d0exp) -> D1efx:
        let loc0 = d0e0.lctn()
        let D0Elam0(tknd, f0as, sres, arrw, body, topt) = d0e0.node()
        let f1as = trans01_f0arglst(tenv, f0as)
        let sres = trans01_s0res(tenv, sres)
        let arrw = trans01_f0unarrw(tenv, arrw)
        let body = trans01_d0exp(tenv, body)
        let d1e0 = d1exp(loc0, D1Elam0(tknd, f1as, sres, arrw, body))
        FXITMatm(d1e0)

    def f0_fix0(tenv: !tr01env, d0e0: d0exp) -> D1efx:
        let loc0 = d0e0.lctn()
        let D0Efix0(tknd, deid, f0as, sres, arrw, body, topt) = d0e0.node()
        let deid = trans01_i0dnt(tenv, deid)
        let f1as = trans01_f0arglst(tenv, f0as)
        let sres = trans01_s0res(tenv, sres)
        let arrw = trans01_f0unarrw(tenv, arrw)
        let body = trans01_d0exp(tenv, body)
        let d1e0 = d1exp(loc0, D1Efix0(tknd, deid, f1as, sres, arrw, body))
        FXITMatm(d1e0)

    def f0_try0(tenv: !tr01env, d0e0: d0exp) -> D1efx:
        let loc0 = d0e0.lctn()
        let D0Etry0(tknd, d0es, twth, tbar, d0cs, tend) = d0e0.node()
        let loc1 = tknd.lctn() + twth.lctn()
        let d1es = trans01_d0explst(tenv, d0es)
        let d1e1 = d1exp(loc1, D1Es1eq(d1es))
        let d1cs = trans01_d0clslst(tenv, d0cs)
        let d1e0 = d1exp(loc0, D1Etry0(tknd, d1e1, d1cs))
        FXITMatm(d1e0)

    def f0_d0es(tenv: !tr01env, d0es: d0explst) -> D1efxlst:
        list_trans01_fnp(tenv, d0es, f0_dexp)

@impl
def trans01_l0d0e(tenv, ld0e):
    let D0LAB(l0ab, teq1, d0e1) = ld0e
    let lab0 = match l0ab.node():
        case L0ABLsome(lab1):
            lab1
        case L0ABLnone(tok1):
            label_none()
    D1LAB(lab0, trans01_d0exp(tenv, d0e1))

@impl
def trans01_f0arg(tenv, f0a0):
    let loc0 = f0a0.lctn()
    match f0a0.node():
        case F0ARGnone(tok):
            let loc = tok.lctn()
            let sym = match T0IDALP_NONE:
                case T_IDALP(nam):
                    symbl(nam)
            f1arg(loc0, F1ARGdapp(d1pat(loc, D1Pid0(sym))))
        case F0ARGdapp(d0p1):
            let d1p1 = trans01_d0pat(tenv, d0p1)
            f1arg_make_node(loc0, F1ARGdapp(d1p1))
        case F0ARGsapp(tbeg, s0qs, tend):
            let s1qs = trans01_s0qualst(tenv, s0qs)
            f1arg_make_node(loc0, F1ARGsapp(s1qs))
        case F0ARGmets(tbeg, s0es, tend):
            let s1es = trans01_s0explst(tenv, s0es)
            f1arg_make_node(loc0, F1ARGmets(s1es))

@impl
def trans01_f0unarrw(tenv, arrw):
    match arrw:
        case F0UNARRWnone(tok):
            F1UNARRWdflt(tok.lctn())
        case F0UNARRWdflt(tok):
            F1UNARRWdflt(tok.lctn())
        case F0UNARRWlist(tbeg, s0es, tend):
            let loc0 = tbeg.lctn() + tend.lctn()
            let s1es = trans01_s0explst(tenv, s0es)
            F1UNARRWlist(loc0, s1es)

