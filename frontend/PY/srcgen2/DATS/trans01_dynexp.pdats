type D1pfx = fxitm[d1pat]

type D1efx = fxitm[d1exp]

type D1pfxlst = list[D1pfx]

type D1efxlst = list[D1efx]

@overload lctn = token_get_lctn

@overload node = token_get_node

@overload lctn = l0abl_get_lctn

@overload node = l0abl_get_node

