@impl
def trans01_d0expseq(tenv, d0es):
    def auxloop(tenv: !tr01env, d0e1: d0exp, d0es: d0explst, d1es: list_vt[d1exp]) -> d1explst:
        match d0es:
            case list_nil():
                let d1e1 = match d0e1.node():
                    case D0Etkerr(tok1):
                        d1exp_none0(d0e1.lctn())
                    case _:
                        trans01_d0exp(tenv, d0e1)
                let d1es = list_vt_cons(d1e1, d1es)
                list_vt2t(list_vt_reverse0(d1es))
            case list_cons(d0e2, d0es):
                let d1e1 = trans01_d0exp(tenv, d0e1)
                auxloop(tenv, d0e2, d0es, list_vt_cons(d1e1, d1es))
    match d0es:
        case list_nil():
            list_nil()
        case list_cons(d0e1, d0es):
            auxloop(tenv, d0e1, d0es, list_vt_nil)

