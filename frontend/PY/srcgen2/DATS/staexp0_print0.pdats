@impl
def g0nam_fprint(g0n, out):
    @impl[]
    def g_print/out():
        out
    match g0n.node():
        case G0Nid0(id0):
            prints("G0Nid0(", id0, ")")
        case G0Nint(tok):
            prints("G0Nint(", tok, ")")
        case G0Nchr(tok):
            prints("G0Nchr(", tok, ")")
        case G0Nflt(tok):
            prints("G0Nflt(", tok, ")")
        case G0Nstr(tok):
            prints("G0Nstr(", tok, ")")
        case G0Nlist(tk1, gns, tk2):
            print("G0Nlist(")
            prints(tk1, ";", gns, ";", tk2, ")")
        case G0Ntkerr(tok):
            prints("G0Ntkerr(", tok, ")")

@impl
def g0exp_fprint(g0e, out):
    @impl[]
    def g_print/out():
        out
    match g0e.node():
        case G0Eid0(id0):
            prints("G0Eid0(", id0, ")")
        case G0Eint(tok):
            prints("G0Eint(", tok, ")")
        case G0Echr(tok):
            prints("G0Echr(", tok, ")")
        case G0Eflt(tok):
            prints("G0Eflt(", tok, ")")
        case G0Estr(tok):
            prints("G0Estr(", tok, ")")
        case G0Eapps(ges):
            prints("G0Eapps(", ges, ")")
        case G0Elpar(tkb, ges, tke):
            print("G0Elpar(")
            prints(tkb, ";", ges, ",", tke, ")")
        case G0Eift0(tknd, g0e1, g0e2, g0e3, topt):
            prints("G0Eift0(", tknd, ";")
            prints(g0e1, ";", g0e2, ";", g0e3, ";", topt, ")")
        case G0Etkerr(tok):
            prints("G0Etkerr(", tok, ")")
        case G0Eerrck(lvl, ge1):
            prints("G0Eerrck(", lvl, ";", ge1, ")")

