@impl
def t0int_fprint(int, out):
    @impl[]
    def g_print/out():
        out
    match int:
        case T0INTnone(tok):
            prints("T0INTnone(", tok, ")")
        case T0INTsome(tok):
            prints("T0INTsome(", tok, ")")

