@impl
def s0exp_fprint(s0e, out):
    @impl[]
    def g_print/out():
        out
    match s0e.node():
        case S0Eid0(id0):
            prints("S0Eid0(", id0, ")")
        case S0Eop1(tok):
            prints("S0Eop1(", tok, ")")
        case S0Eop2(tok):
            prints("S0Eop2(", tok, ")")
        case S0Eop3(tkb, id0, tke):
            prints("S0Eop3(", tkb, ";", id0, ";", tke, ")")
        case S0Eint(int):
            prints("S0Eint(", int, ")")
        case S0Echr(chr):
            prints("S0Echr(", chr, ")")
        case S0Eflt(flt):
            prints("S0Eflt(", flt, ")")
        case S0Estr(str):
            prints("S0Estr(", str, ")")
        case S0Eapps(ses):
            prints("S0Eapps(", ses, ")")
        case S0Efimp(tkb, ses, tke):
            prints("S0Efimp(", tkb, ";", ses, ";", tke, ")")
        case S0Elpar(tkb, ses, srp):
            prints("S0Elist(", tkb, ";", ses, ";", srp, ")")
        case S0Etup1(tkb, opt, ses, srp):
            print("S0Etup1(")
            prints(tkb, ";", opt, ";", ses, ";", srp, ")")
        case S0Ercd2(tkb, opt, lses, lsrb):
            print("S0Ercd2(")
            prints(tkb, ";", opt, ";", lses, ";", lsrb, ")")
        case S0Elams(tlam, s0ms, tres, arrw, body, tend):
            print("S0Elams(")
            prints(tlam, ";", s0ms, ";")
            prints(tres, ";", arrw, ";", body, ";", tend, ")")
        case S0Euni0(tkb, sqs, tbe):
            prints("S0Euni0(", tkb, ";", sqs, ";", tbe, ")")
        case S0Eexi0(tkb, sqs, tbe):
            prints("S0Eexi0(", tkb, ";", sqs, ";", tbe, ")")
        case S0Eannot(se1, st2):
            prints("S0Eannot(", se1, ";", st2, ")")
        case S0Equal0(tok, se1):
            prints("S0Equal0(", tok, ";", se1, ")")
        case S0Etkerr(tok):
            prints("S0Etkerr(", tok, ")")
        case S0Eerrck(lvl, se1):
            prints("S0Eerrck(", lvl, ";", se1, ")")

