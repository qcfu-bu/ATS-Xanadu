def trans12_d1typlst(env0, d1ts, s2t0):
    @inst[x0] @inst[y0] @inst[e1] list_map/e1nv(d1ts, env0)
where:
    type X0 = d1typ
    type Y0 = s2cst
    type E1 = tr12env
