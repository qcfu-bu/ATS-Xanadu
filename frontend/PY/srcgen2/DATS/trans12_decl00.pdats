def trans12_t1qaglst_wth(env0, t1qs, t2qs):
    match t1qs:
        case list_nil():
            list_nil()
        case list_cons(t1qa, tqs1):
            match t2qs:
                case list_nil():
                    trans12_t1qaglst(env0, t1qs)
                case list_cons(t2qa, tqs2):
                    let tqag = trans12_t1qag_wth(env0, t1qa, t2qa)
                    list_cons(tqag, trans12_t1qaglst_wth(env0, tqs1, tqs2))

