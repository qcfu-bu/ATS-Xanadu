@impl
def trans12_d1cstdclist(env0, tknd, d1cs, tqas):
    @inst[x0] @inst[y0] @inst[e1] list_map/e1nv(d1cs, env0)
where:
    type E1 = tr12env
    type X0 = d1cstdcl
    type Y0 = d2cstdcl
    @impl[X0, Y0, E1]
