def fint_rep_bas(rep: String, bas: SInt) -> SInt:
    @inst[String] @inst[cgtz] @inst[SInt] gseq_foldl(rep, 0)
where:
    @overload[1001] - = sub_char_char
    @impl[cgtz, SInt]
    def foldl/fopr(r0, c0):
        r0 * bas + (c0 - '0')

def sort2_ofknd(knd0: SInt) -> sort2:
    if (knd0 == TYPESORT):
        the_sort2_type
    else:
        if (knd0 == VWTPSORT):
            the_sort2_vwtp
        else:
            if (knd0 == TBOXSORT):
                the_sort2_tbox
            else:
                if (knd0 == VTBXSORT):
                    the_sort2_vtbx
                else:
                    if (knd0 == PROPSORT):
                        the_sort2_prop
                    else:
                        if (knd0 == VIEWSORT):
                            the_sort2_view
                        else:
                            if (knd0 == TFLTSORT):
                                the_sort2_tflt
                            else:
                                if (knd0 == VTFTSORT):
                                    the_sort2_vtft
                                else:
                                    S2Tnone0()

def abstype_sort2(tknd: token) -> sort2:
    sort2_ofknd(knd0)
where:
    let T_ABSTYPE(knd0) = tknd.node()

def sexpdef_sort2(tknd: token) -> sort2:
    sort2_ofknd(knd0)
where:
    let T_SEXPDEF(knd0) = tknd.node()

private:
    def DLRDT(nm0: String) -> String:
        strn_tabulate/f1un(n0 + 2, (i0) => fopr(i0))
    where:
        let n0 = strn_length(nm0)
        def fopr(i0: SInt) -> Char:
            if i0 == 0:
                '$'
            else:
                if i0 <= n0:
                    nm0[i0 - 1]
                else:
                    '.'
    def iseq0(x0: g1exp) -> Bool:
        match x0.node():
            case G1Eid0(sym):
                sym == SYM.EQ0_symbl
            case _:
                false

@impl
def g1exp_nmspace(g1e0):
    match g1e0.node():
        case G1Ea2pp(x0, x1, x2):
            if iseq0(x0):
                match x1.node():
                    case G1Eid0(sym):
                        let nm0 = SYM.symbl_get_name(sym)
                        optn_cons(SYM.symbl_make_name(DLRDT(nm0)))
                    case _:
                        optn_nil
            else:
                optn_nil()
        case _:
            optn_nil()


@impl
def trans12_q1arg(env0, q1a0):
    match q1a0.node():
        case Q1ARGsome(tok1, opt2):
            let opt2 = trans12_sort1opt(env0, opt2)
            let s2t2 = match opt2:
                case optn_nil():
                    the_sort2_type
                case optn_cons(s2t2):
                    s2t2
            let sid1 = sexpid_sym(tok1)
            s2var_make_idst(sid1, s2t2)

@impl
def trans12_q1arg_wth(env0, q1a1, s2v2):
