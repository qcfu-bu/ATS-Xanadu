def trans12_q1arglst_wth(env0, q1as, s2vs):
    match q1as:
        case list_nil():
            list_nil()
        case list_cons(q1a1, qas1):
            match s2vs:
                case list_nil():
                    trans12_q1arglst(env0, q1as)
                case list_cons(s2v1, svs2):
                    let svar = trans12_q1arg_wth(env0, q1a1, s2v1)
                    list_cons(svar, trans12_q1arglst_wth(env0, qas1, svs2))

