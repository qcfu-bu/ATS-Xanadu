    def map/e1nv/fopr(x0, e1):
        trans12_d1typ(e1, x0, s2t0)

@impl
def trans12_d1tsclst(env0, d1ts, s2cs):
    match d1ts:
        case list_nil():
            ()
        case list_cons(d1t1, d1ts):
            match s2cs:
                case list_cons(s2c1, s2cs):
                    trans12_d1tsc(env0, d1t1, s2c1)
                    trans12_d1tsclst(env0, d1ts, s2cs)

private:
    def f1_s2vs(s2vs: s2varlst) -> s2varlst:
        match s2vs:
            case list_nil():
                list_nil()
            case list_cons(s2v1, s2vs):
                if (s2v1.name() == the_symbl_nil):
                    f1_s2vs(s2vs)
                else:
                    list_cons(s2v1, f1_s2vs(s2vs))
    def f1_tqas(s2c0: s2cst, svss: s2varlstlst) -> t2qaglst:
        match svss:
            case list_nil():
                list_nil()
            case list_cons(s2vs, svss):
                match s2vs:
                    case list_nil(_):
                        f1_tqas(s2c0, svss)
                    case list_cons(_):
                        let s2vs = f1_s2vs(s2vs)
                        let tqa1 = t2qag(s2c0.lctn(), s2vs)
                        list_cons(tqa1, f1_tqas(s2c0, svss))

@impl
def trans12_d1tcnlst(env0, tcns, s2c0, svss):
    @inst[x0] @inst[y0] @inst[e1] list_map/e1nv(tcns, env0)
where:
    type X0 = d1tcn
    type Y0 = d2con
    type E1 = tr12env
    let tqas = f1_tqas(s2c0, svss)
    @impl[X0, Y0, E1]
    def map/e1nv/fopr(x0, e1):
        trans12_d1tcn(e1, x0, s2c0, tqas, svss)


