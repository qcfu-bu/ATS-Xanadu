@impl
def d0ecl_fprint(dcl, out):
    @impl[]
    def g_print/out():
        out
    match dcl.node():
        case D0Ctkerr(tok):
            prints("D0Ctkerr(", tok, ")")
        case D0Ctkskp(tok):
            prints("D0Ctkskp(", tok, ")")
        case D0Cnonfix(tknd, dnts):
            prints("D0Cnonfix(", tknd, ";", dnts, ")")
        case D0Cfixity(tknd, dnts, prec):
            prints("D0Cfixity(", tknd, ";", dnts, ";", prec, ")")
        case D0Cstatic(tknd, dcl1):
            prints("D0Cstatic(", tknd, ";", dcl1, ")")
        case D0Cextern(tknd, dcl1):
            prints("D0Cextern(", tknd, ";", dcl1, ")")
        case D0Cdefine(tknd, geid, gmas, gedf):
            prints("D0Cdefine(")
            prints(tknd, ";", geid, ";", gmas, ";", gedf, ")")
        case D0Cmacdef(tknd, geid, gmas, dedf):
            prints("D0Cmacdef(")
            prints(tknd, ";", geid, ";", gmas, ";", dedf, ")")
        case D0Clocal0(tknd, head, tin1, body, tend):
            prints("D0Clocal0(", tknd, ";")
            prints(head, ";", tin1, ";", body, ";", tend, ")")
        case D0Cabssort(tknd, tid0):
            prints("D0Cabssort(", tknd, ";", tid0, ")")
        case D0Cstacst0(tknd, seid, tmas, tcln, s0t0):
            prints("D0Cstacst0(", tknd, ";")
            prints(seid, ";", tmas, ";", tcln, ";", s0t0, ")")
        case D0Csortdef(tknd, tid0, teq1, def2):
            prints("D0Csortdef(", tknd, ";", tid0, ";", teq1, ";", def2, ")")
        case D0Csexpdef(tknd, sid0, smas, tres, teq1, def2):
            prints("D0Csexpdef(", tknd, ";")
            prints(sid0, ";", smas, ";", tres, ";")
            prints(teq1, ";", def2, ")")
        case D0Cabstype(tknd, seid, tmas, tres, atdf):
            prints("D0Cabstype(", tknd, ";")
            prints(seid, ";", tmas, ";", tres, ";", atdf, ")")
        case D0Cabsopen(tknd, sqid):
            prints("D0Cabsopen(", tknd, ";", sqid, ")")
        case D0Cabsimpl(tknd, sid0, smas, tres, teq1, def2):
            prints("D0Cabsimpl(", tknd, ";")
            prints(sid0, ";", smas, ";", tres, ";")
            prints(teq1, ";", def2, ")")
        case D0Csymload(tknd, symb, twth, dqid, pval):
            prints("D0Csymload(", tknd, ";")
            prints(symb, ";", twth, ";", dqid, ";", pval, ")")
        case D0Cinclude(knd0, tknd, g0e1):
            prints("D0Cinclude(", knd0, ";", tknd, ";", g0e1, ")")
        case D0Cstaload(knd0, tknd, g0e1):
            prints("D0Cstaload(", knd0, ";", tknd, ";", g0e1, ")")
        case D0Cdyninit(tknd, g0e1):
            prints("D0Cdyninit(", tknd, ";", g0e1, ")")
        case D0Cextcode(tknd, g0e1):
            prints("D0Cextcode(", tknd, ";", g0e1, ")")
        case D0Cdatasort(tknd, dtcs):
            prints("D0Cdatasort(", tknd, ";", dtcs, ")")
        case D0Cvaldclst(tknd, dcls):
            prints("D0Cvaldclst(", tknd, ";", dcls, ")")
        case D0Cvardclst(tknd, dcls):
            prints("D0Cvardclst(", tknd, ";", dcls, ")")
        case D0Cfundclst(tknd, t0qs, dcls):
            prints("D0Cfundclst(", tknd, ";", t0qs, ";", dcls, ")")
        case D0Cexcptcon(tknd, tbar, tcns):
            prints("D0Cexcptcon(", tknd, ";", tbar, ";", tcns, ")")
        case D0Cdatatype(tknd, dtps, wdcs):
            prints("D0Cdatatype(", tknd, ";", dtps, ";", wdcs, ")")
        case D0Cdynconst(tknd, tqas, dcls):
            prints("D0Cdynconst(", tknd, ";", tqas, ";", dcls, ")")
        case D0Cimplmnt0(tknd, s0qs, t0qs, dqid, t0is, farg, sres, teq1, d0e2):
            prints("D0Cimplmnt0(", tknd, ";")
