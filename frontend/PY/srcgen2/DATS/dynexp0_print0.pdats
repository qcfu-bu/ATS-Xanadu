@impl
def d0pat_fprint(d0p, out):
    @impl[]
    def g_print/out():
        out
    match d0p.node():
        case D0Pid0(id0):
            prints("D0Pid0(", id0, ")")
        case D0Pint(int):
            prints("D0Pint(", int, ")")
        case D0Pchr(chr):
            prints("D0Pchr(", chr, ")")
        case D0Pflt(flt):
            prints("D0Pflt(", flt, ")")
        case D0Pstr(str):
            prints("D0Pstr(", str, ")")
        case D0Paspt(tknd, d0p1):
            prints("D0Paspt(", tknd, ";", d0p1, ")")
        case D0Papps(d0ps):
            prints("D0Papps(", d0ps, ")")
        case D0Psarg(tbeg, s0as, tend):
            prints("D0Psarg(", tbeg, ";", s0as, ";", tend, ")")
        case D0Plpar(tbeg, t0ps, tend):
            prints("D0Plpar(", tbeg, ";", t0ps, ";", tend, ")")
        case D0Ptup1(tbeg, topt, d0ps, tend):
            print("D0Ptup1(")
            prints(tbeg, ";", topt, ";", d0ps, ";", tend, ")")
        case D0Prcd2(tbeg, topt, ldps, tend):
            print("D0Prcd2(")
            prints(tbeg, ";", topt, ";", ldps, ";", tend, ")")
        case D0Pannot(d0p1, s0e2):
            prints("D0Pannot(", d0p1, ";", s0e2, ")")
        case D0Ptkerr(tok):
            prints("D0Ptkerr(", tok, ")")
        case D0Perrck(lvl1, d0p2):
            prints("D0Perrck(", lvl1, ";", d0p2, ")")

