@impl
def trtmp3c_l3d3e(env0, ld3e):
    let D3LAB(lab0, d3e1) = ld3e
    D3LAB(lab0, trtmp3c_d3exp(env0, d3e1))

@impl
def trtmp3c_d3gua(env0, dgua):
    let loc0 = dgua.lctn()
    match dgua.node():
        case D3GUAexp(dexp):
            let dexp = trtmp3c_d3exp(env0, dexp)
            d3gua(loc0, D3GUAexp(dexp))
        case D3GUAmat(dexp, dpat):
            let dexp = trtmp3c_d3exp(env0, dexp)
            d3gua(loc0, D3GUAmat(dexp, dpat))

@impl
def trtmp3c_d3gpt(env0, dgpt):
    match dgpt.node():
        case D3GPTpat(d3p1):
            dgpt
        case D3GPTgua(d3p1, d3gs):
            let loc0 = dgpt.lctn()
            let d3gs = trtmp3c_d3gualst(env0, d3gs)
            d3gpt(loc0, D3GPTgua(d3p1, d3gs))

@impl
def trtmp3c_d3cls(env0, dcls):
    let loc0 = dcls.lctn()
    match dcls.node():
        case D3CLSgpt(dgpt):
            let dgpt = trtmp3c_d3gpt(env0, dgpt)
            d3cls_make_node(loc0, D3CLSgpt(dgpt))
        case D3CLScls(dgpt, d3e1):
            let dgpt = trtmp3c_d3gpt(env0, dgpt)
            let d3e1 = trtmp3c_d3exp(env0, d3e1)
            d3cls_make_node(loc0, D3CLScls(dgpt, d3e1))

@impl
def trtmp3c_teqd3exp(env0, tdxp):
    match tdxp:
        case TEQD3EXPnone():
            TEQD3EXPnone()
        case TEQD3EXPsome(teq1, d3e2):
            let d3e2 = trtmp3c_d3exp(env0, d3e2)
            TEQD3EXPsome(teq1, d3e2)

@impl
def trtmp3c_d3explst(env0, d3es):
    list_trtmp3c_fnp(env0, d3es, trtmp3c_d3exp)

@impl
def trtmp3c_d3expopt(env0, dopt):
    optn_trtmp3c_fnp(env0, dopt, trtmp3c_d3exp)

