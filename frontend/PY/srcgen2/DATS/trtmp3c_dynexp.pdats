@impl
def trtmp3c_d3exp(env0, d3e0):
    match d3e0.node():
        case D3Evar(_):
            d3e0
        case D3Eint(_):
            d3e0
        case D3Ebtf(_):
            d3e0
        case D3Echr(_):
            d3e0
        case D3Eflt(_):
            d3e0
