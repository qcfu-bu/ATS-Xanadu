        case _:
            let dres = d3exp_none2(d3e0)
            dres
where:
    def f0_timp(env0: !tr3cenv, d3e0: d3exp) -> d3exp:
        let loc0 = d3e0.lctn()
        let t2p0 = d3e0.styp()
        let D3Etimp(d3f0, timp) = d3e0.node()
