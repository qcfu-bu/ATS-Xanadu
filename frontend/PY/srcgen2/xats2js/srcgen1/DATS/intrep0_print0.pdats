@impl
def i0dcl_fprint(dcl0, out0):
    @impl[]
    def g_print/out():
        out0
    match dcl0.node():
        case I0Dd3ecl(d3cl):
            prints("I0Dd3ecl(", d3cl, ")")
        case I0Dstatic(tknd, dcl1):
            prints("I0Dstatic(", tknd, ";", dcl1, ")")
        case I0Dextern(tknd, dcl1):
            prints("I0Dextern(", tknd, ";", dcl1, ")")
        case I0Dtmpsub(svts, idcl):
            prints("I0Dtmpsub(", svts, ";", idcl, ")")
        case I0Ddclst0(dcls):
            prints("I0Ddclst0(", dcls, ")")
        case I0Dlocal0(head, body):
            prints("I0Dlocal0(", head, ";", body, ")")
        case I0Dinclude(knd0, tknd, gsrc, fopt, dopt):
            print("I0Dinclude(")
            prints(knd0, ";", tknd, ";", gsrc, ";", fopt, ";", "...", ")")
        case I0Ddyninit(tknd, gexp):
            prints("I0Ddyninit(", tknd, ";", gexp, ")")
        case I0Dextcode(tknd, gexp):
            prints("I0Dextcode(", tknd, ";", gexp, ")")
        case I0Dvaldclst(tknd, i0vs):
            prints("I0Dvaldclst(", tknd, ";", i0vs, ")")
        case I0Dvardclst(tknd, i0vs):
            prints("I0Dvardclst(", tknd, ";", i0vs, ")")
        case I0Dfundclst(tknd, tqas, d2cs, i0fs):
            prints("I0Dfundclst(", tknd, ";")
            prints(tqas, ";", d2cs, ";", i0fs, ")")
        case I0Dimplmnt0(tknd, stmp, dimp, farg, body):
            print("I0Dimplmnt0(")
            prints(tknd, ";", stmp, ";")
            prints(dimp, ";", farg, ";", body, ")")
        case I0Dnone0():
            let loc0 = dcl0.lctn()
            prints("I0Dnone0(", loc0, ")")
        case I0Dnone1(d3cl):
            let loc0 = dcl0.lctn()
            prints("I0Dnone1(", loc0, ";", d3cl, ")")

