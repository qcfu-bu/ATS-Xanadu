@overload lctn = d2con_get_lctn

@overload lctn = d2cst_get_lctn

@overload lctn = d3pat_get_lctn

@overload lctn = d3exp_get_lctn

@overload lctn = d3ecl_get_lctn

@overload lctn = i0pat_lctn/get

@overload node = i0pat_node/get

@overload lctn = i0exp_lctn/get

@overload node = i0exp_node/get

