@impl
def i0parsed_fprint(ipar, out0):
    let stadyn = i0parsed_stadyn/get(ipar)
    let nerror = i0parsed_nerror/get(ipar)
    let source = i0parsed_source/get(ipar)
    let parsed = i0parsed_parsed/get(ipar)
    @impl[]
    def g_print/out():
        out0
    print("I0PARSED(")
    prints(stadyn, ";", nerror, ";", source, ";", parsed, ")")

