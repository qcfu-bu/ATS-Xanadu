@extern
def tnode_fprint(a: Tnode, b: FILR) -> Void

@extern
def token_fprint(a: Token, b: FILR) -> Void

@extern
def token_get_lctn(a: Token) -> Loc_t

@extern
def token_get_node(a: Token) -> Tnode

@extern
def token_make_node(a: Loc_t, b: Tnode) -> Token

@overload lctn = token_get_lctn

@overload node = token_get_node

@overload token = token_make_node

@extern
def tnode_ANDq(a: Tnode) -> Bool

@extern
def tnode_BARq(a: Tnode) -> Bool

@extern
def tnode_CLNq(a: Tnode) -> Bool

@overload ANDq = tnode_ANDq

@overload BARq = tnode_BARq

@overload CLNq = tnode_CLNq

@extern
def tnode_COMMAq(a: Tnode) -> Bool

@extern
def tnode_SMCLNq(a: Tnode) -> Bool

@extern
def tnode_BSCLNq(a: Tnode) -> Bool

@overload COMMAq = tnode_COMMAq

@overload SMCLNq = tnode_SMCLNq

@overload BSCLNq = tnode_BSCLNq

@extern
def tnode_blankq(a: Tnode) -> Bool

@extern
def tnode_iscmnt(a: Tnode) -> Bool

@extern
def tnode_isskip(a: Tnode) -> Bool

@overload blankq = tnode_blankq

@overload iscmnt = tnode_iscmnt

@overload isskip = tnode_isskip

