enum D2exp_node:
    case D2Eint(Token)
    case D2Ebtf(Sym_t)
    case D2Echr(Token)
    case D2Eflt(Token)
    case D2Estr(Token)
    case D2Ei00(SInt)
    case D2Eb00(Bool)
    case D2Ec00(Char)
    case D2Ef00(Float)
    case D2Es00(String)
    case D2Etop(Sym_t)
    case D2Evar(D2var)
    case D2Econ(D2con)
    case D2Ecst(D2cst)
    case D2Econs(D2conlst)
    case D2Ecsts(D2cstlst)
    case D2Esym0(D2rxp, D1exp, D2ptmlst)
    case D2Esapp(D2exp, S2explst)
    case D2Etapp(D2exp, S2explst)
    case D2Edap0(D2exp)
    case D2Edapp(D2exp, SInt, D2explst)
    case D2Eproj(Token, D2rxp, Label, D2exp)
    case D2Elet0(D2eclist, D2exp)
    case D2Eift0(D2exp, D2expopt, D2expopt)
    case D2Ecas0(Token, D2exp, D2clslst)
    case D2Eseqn(D2explst, D2exp)
    case D2Etup0(SInt, D2explst)
    case D2Etup1(Token, SInt, D2explst)
    case D2Ercd2(Token, SInt, L2d2elst)
    case D2Elam0(Token, F2arglst, S2res, F1unarrw, D2exp)
    case D2Efix0(Token, D2var, F2arglst, S2res, F1unarrw, D2exp)
    case D2Etry0(Token, D2exp, D2clslst)
    case D2Eaddr(D2exp)
    case D2Eview(D2exp)
    case D2Elval(D2exp)
    case D2Eeval(D2exp)
    case D2Efold(D2exp)
    case D2Efree(D2exp)
    case D2Ewhere(D2exp, D2eclist)
    case D2Eassgn(D2exp, D2exp)
    case D2Exazgn(D2exp, D2exp)
    case D2Exchng(D2exp, D2exp)
    case D2Ebrget(D2ptmlst, D2explst)
    case D2Ebrset(D2ptmlst, D2explst)
    case D2Edtsel(Token, Label, D2ptmlst, SInt, D2explstopt)
    case D2Eraise(Token, D2exp)
    case D2El0azy(D1exp, D2exp)
    case D2El1azy(D1exp, D2exp, D2explst)
    case D2Eelazy(D1exp, D2exp, D2explst)
    case D2Eannot(D2exp, S1exp, S2exp)
    case D2Eg1mac(G1mac)
    case D2Elabck(D2exp, Label)
    case D2Et2pck(D2exp, S2typ)
    case D2Et2ped(D2exp, S2typ)
    case D2Eexists(S2explst, D2exp)
    case D2Eextnam(Token, G1nam)
    case D2Esynext(Token, G1exp)
    case D2Enone0()
    case D2Enone1(D1exp)
    case D2Enone2(D2exp)
    case D2Eerrck(SInt, D2exp)
enum S2eff:
    case S2EFFnone()
    case S2EFFsome(S2explst)
enum S2res:
    case S2RESnone()
    case S2RESsome(S2eff, S2exp)

