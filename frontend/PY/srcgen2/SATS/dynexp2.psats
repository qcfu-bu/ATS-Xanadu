    case D2Prfpt(D2pat, Token, D2pat)
    case D2Ptup0(SInt, D2patlst)
    case D2Ptup1(Token, SInt, D2patlst)
    case D2Prcd2(Token, SInt, L2d2plst)
    case D2Pargtp(D2pat, S2typ)
    case D2Pannot(D2pat, S1exp, S2exp)
    case D2Pg1mac(G1mac)
    case D2Pt2pck(D2pat, S2typ)
    case D2Pt2pkc(D2pat, S2typ)
    case D2Pnone0()
    case D2Pnone1(D1pat)
    case D2Pnone2(D2pat)
    case D2Perrck(SInt, D2pat)

