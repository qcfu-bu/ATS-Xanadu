import "srcgen2/SATS/locinfo" as LOC

type Loc_t = LOC.loc_t

include "srcgen2/HATS/xatsopt_sats.hats"

let xatsv_ATS_PACKNAME = "ATS3.XANADU.xatsopt-20220500"

enum Assoc:
    case ASSOCnon
    case ASSOClft
    case ASSOCrgt

@extern
let app_assoc: Assoc

@extern
let imp_assoc: Assoc

@extern
def assoc_fprint(a: Assoc, b: FILR) -> Void

@abstract
type Prcdv_tflt

type Prcdv = Prcdv_tflt

@extern
let a0s_prcdv: Prcdv

@extern
let app_prcdv: Prcdv

@extern
let imp_prcdv: Prcdv

@extern
let brckt_prcdv: Prcdv

@extern
let dtsel_prcdv: Prcdv

@extern
let forall_prcdv: Prcdv

@extern
