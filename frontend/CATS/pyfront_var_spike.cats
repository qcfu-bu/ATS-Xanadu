////////////////////////////////////////////////////////////////////////.
//   VAR (mutable cell) GATING SPIKE — JS glue (.cats)
//   companion for frontend/DATS/pyfront_var_spike.dats
//
//   PYB_log*  -> process.stderr  (progress + nerror line; stdout stays clean)
////////////////////////////////////////////////////////////////////////.
//
function PYB_log(s)        { process.stderr.write(String(s) + "\n"); }
function PYB_log_int(s, n) { process.stderr.write(String(s) + " " + String(n) + "\n"); }
//
////////////////////////////////////////////////////////////////////////.
// end of [frontend/CATS/pyfront_var_spike.cats]
////////////////////////////////////////////////////////////////////////.
