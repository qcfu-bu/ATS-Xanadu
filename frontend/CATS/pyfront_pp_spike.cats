////////////////////////////////////////////////////////////////////////.
//   P2 PRETTY-PRINTER L0-ACCESS SPIKE — JS glue (.cats)
//   companion for frontend/DATS/pyfront_pp_spike.dats
//
//   PYP_log*  -> process.stderr  (progress + GO line; stdout = the dumped tags)
////////////////////////////////////////////////////////////////////////.
//
function PYP_log(s)        { process.stderr.write(String(s) + "\n"); }
function PYP_log_int(s, n) { process.stderr.write(String(s) + " " + String(n) + "\n"); }
//
////////////////////////////////////////////////////////////////////////.
// end of [frontend/CATS/pyfront_pp_spike.cats]
