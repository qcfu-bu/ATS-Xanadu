# ARROW-EFFECTS — `(Int) ->[Fun1] Int`: an explicit code-pointer / nonlinear arrow. At the
# s2exp level the flat `fun` distinction is erased, so Fun1 lowers to F2CLfun (cloref,
# nonlinear) — preserving nonlinearity. `double` (a top-level def, cloref) passes cleanly.
def apply(f: (Int) ->[Fun1] Int, x: Int) -> Int:
    f(x)

def double(x: Int) -> Int:
    x + x

def go() -> Int:
    apply(double, 5)
